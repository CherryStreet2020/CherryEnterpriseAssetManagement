{
  "version": "1.0.0",
  "description": "Detail endpoint contract for GET /api/v1/details/{type}/{id}",
  "response_format": {
    "type": "string",
    "id": "int|guid",
    "header": "object with >=12 meaningful fields",
    "sections": "array of >=3 sections",
    "related": "object with related entity lists (where applicable)"
  },
  "types": [
    { "type": "asset", "entity": "Asset", "pk": "int", "sections_min": 4 },
    { "type": "purchase_order", "entity": "PurchaseOrder", "pk": "int", "sections_min": 3 },
    { "type": "customer_invoice", "entity": "CustomerInvoice", "pk": "int", "sections_min": 3 },
    { "type": "vendor_invoice", "entity": "VendorInvoice", "pk": "int", "sections_min": 3 },
    { "type": "maintenance_event", "entity": "MaintenanceEvent", "pk": "int", "sections_min": 3 },
    { "type": "vendor", "entity": "Vendor", "pk": "int", "sections_min": 3 },
    { "type": "customer", "entity": "Customer", "pk": "int", "sections_min": 3 },
    { "type": "site", "entity": "Site", "pk": "int", "sections_min": 3 },
    { "type": "location", "entity": "Location", "pk": "int", "sections_min": 3 },
    { "type": "company", "entity": "Company", "pk": "int", "sections_min": 3 },
    { "type": "book", "entity": "Book", "pk": "int", "sections_min": 3 },
    { "type": "item", "entity": "Item", "pk": "int", "sections_min": 3 },
    { "type": "work_order", "entity": "MaintenanceEvent (alias)", "pk": "int", "sections_min": 3 },
    { "type": "cip_project", "entity": "CipProject", "pk": "int", "sections_min": 3 },
    { "type": "fiscal_year", "entity": "FiscalYear", "pk": "int", "sections_min": 3 },
    { "type": "fiscal_period", "entity": "FiscalPeriod", "pk": "int", "sections_min": 3 },
    { "type": "lookup_type", "entity": "LookupType", "pk": "int", "sections_min": 3 },
    { "type": "pm_schedule", "entity": "PmSchedule", "pk": "int", "sections_min": 3 },
    { "type": "pm_template", "entity": "PmTemplate", "pk": "int", "sections_min": 3 },
    { "type": "org_node", "entity": "OrgNode", "pk": "guid", "sections_min": 3 },
    { "type": "user", "entity": "ApplicationUser", "pk": "string", "sections_min": 3 }
  ]
}
