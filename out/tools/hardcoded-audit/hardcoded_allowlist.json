{
  "ignore_dirs": [
    "bin", "obj", "node_modules", "wwwroot", ".git", ".vs",
    "Migrations", "tools", "artifacts", "audit-bundle", ".local",
    "proof-bundle", "proof-bundle-2", "proof-bundle-3", "seed", "generated"
  ],
  "ignore_files": [
    "AppDbContextModelSnapshot\\.cs$",
    "\\.Designer\\.cs$"
  ],
  "ignore_patterns": [
    {
      "rule": "RUNTIME_FALLBACK_DEFAULT",
      "snippet_pattern": "User\\.Identity.*Name.*(?:System|Unknown|Admin|Anonymous)",
      "reason": "Standard ASP.NET identity fallback for audit trail — not business reference data"
    },
    {
      "rule": "RUNTIME_FALLBACK_DEFAULT",
      "snippet_pattern": "\\?\\.Name \\?\\? ",
      "reason": "Null-safe navigation for entity display names — display safety"
    },
    {
      "rule": "RUNTIME_FALLBACK_DEFAULT",
      "snippet_pattern": "Username = userId.*System",
      "reason": "Audit trail identity fallback"
    },
    {
      "rule": "RUNTIME_FALLBACK_DEFAULT",
      "snippet_pattern": "ResolutionError \\?\\?",
      "reason": "Error message fallback — not business data"
    },
    {
      "rule": "RUNTIME_FALLBACK_DEFAULT",
      "snippet_pattern": "\\?\\.Error \\?\\?|Error \\?\\? \"",
      "reason": "Error message fallback — not business data"
    },
    {
      "rule": "RUNTIME_FALLBACK_DEFAULT",
      "snippet_pattern": "DetermineCode.*\\?\\? \"Mechanic\"",
      "reason": "Smart Assist default craft heuristic — engine logic, not UI picklist"
    },
    {
      "rule": "RUNTIME_FALLBACK_DEFAULT",
      "snippet_pattern": "PartNumber.*Unknown|Location.*Unknown|Category.*Uncategorized",
      "reason": "Display label fallback for null navigation properties"
    },
    {
      "rule": "RUNTIME_FALLBACK_DEFAULT",
      "snippet_pattern": "ModuleName.*Module \\?\\? \"This\"",
      "reason": "Module disabled page display fallback"
    },
    {
      "rule": "RUNTIME_FALLBACK_DEFAULT",
      "file_pattern": "Pages/Admin/DemoData\\.cshtml\\.cs$",
      "reason": "Demo data page identity fallback — admin tool"
    },
    {
      "rule": "RUNTIME_FALLBACK_DEFAULT",
      "file_pattern": "Pages/Admin/SeedData\\.cshtml\\.cs$",
      "reason": "Seed data page identity fallback — admin tool"
    },
    {
      "rule": "RUNTIME_FALLBACK_DEFAULT",
      "file_pattern": "Services/Seeding/",
      "reason": "Seed pipeline fallback values — infrastructure"
    },
    {
      "rule": "RUNTIME_FALLBACK_DEFAULT",
      "file_pattern": "Services/Maintenance/PMSchedulerService",
      "reason": "PM template name fallback for display"
    },
    {
      "rule": "RUNTIME_FALLBACK_DEFAULT",
      "file_pattern": "Services/Items/",
      "reason": "Service audit trail identity fallbacks"
    },
    {
      "rule": "RUNTIME_FALLBACK_DEFAULT",
      "file_pattern": "Pages/Admin/Sites\\.cshtml\\.cs$",
      "snippet_pattern": "Country.*United States|TimeZone.*America/New_York",
      "reason": "Site creation defaults — Phase 4 FK conversion planned"
    },
    {
      "rule": "CS_INLINE_STRING_LIST",
      "file_pattern": "Reports/DepreciationPreview\\.cshtml\\.cs$",
      "reason": "Property name mapping arrays for CSV import — structural, not picklist"
    },
    {
      "rule": "CS_INLINE_STRING_LIST",
      "file_pattern": "Reports/Builder\\.cshtml\\.cs$",
      "reason": "Default report field selection — structural, not picklist"
    },
    {
      "rule": "CS_INLINE_STRING_LIST",
