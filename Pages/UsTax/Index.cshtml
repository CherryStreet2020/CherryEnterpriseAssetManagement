@page
@model Abs.FixedAssets.Pages.UsTax.IndexModel
@{
    ViewData["Title"] = "US Tax (MACRS/179)";
    Layout = "_ModernLayout";
    ViewData["HasScreenHeader"] = true;
    
    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = "US Tax (MACRS/179)",
        ["Subtitle"] = "Manage Section 179, Bonus Depreciation, and MACRS settings for US tax compliance",
        ["TypeLabel"] = "Tax Compliance",
        ["StatusText"] = "IRS",
        ["StatusTone"] = "info",
        ["ContextPartial"] = "/Pages/UsTax/_UsTaxIndexContext.cshtml",
        ["KpisPartial"] = "/Pages/UsTax/_UsTaxIndexKpis.cshtml",
        ["ActionsPartial"] = "/Pages/UsTax/_UsTaxIndexActions.cshtml"
    };
}

@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

<div class="section-card">
    <div class="section-card-header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Section 179 Limits by Year
        </h3>
        <span class="status-badge info">IRS LIMITS</span>
    </div>
    <div class="section-card-body" data-csp-style="padding: 0;">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Tax Year</th>
                    <th>Maximum Deduction</th>
                    <th>Phaseout Threshold</th>
                    <th>SUV Limit</th>
                    <th>Auto Limit</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var limit in Model.Section179Limits)
                {
                    <tr>
                        <td><strong>@limit.TaxYear</strong></td>
                        <td>@limit.MaxDeduction.ToString("C2")</td>
                        <td>@limit.PhaseoutThreshold.ToString("C2")</td>
                        <td>@limit.SuvLimit.ToString("C2")</td>
                        <td>@limit.AutoDepreciationCap.ToString("C2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="section-card">
    <div class="section-card-header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
            Bonus Depreciation Rates by Year
        </h3>
        <span class="status-badge success">TCJA RATES</span>
    </div>
    <div class="section-card-body" data-csp-style="padding: 0;">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Tax Year</th>
                    <th>Rate</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var rate in Model.BonusRates)
                {
                    <tr>
                        <td><strong>@rate.TaxYear</strong></td>
                        <td>
                            <span class="badge @(rate.Rate > 0 ? "badge-success" : "badge-neutral")">
                                @rate.Rate%
                            </span>
                        </td>
                        <td>@(rate.Notes ?? "-")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="section-card">
    <div class="section-card-header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
            MACRS Property Classes
        </h3>
        <span class="status-badge info">8 CLASSES</span>
    </div>
    <div class="section-card-body" data-csp-style="padding: 0;">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Class</th>
                    <th>Recovery Period</th>
                    <th>Description</th>
                    <th>Examples</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><span class="badge badge-primary">3-Year</span></td>
                    <td>3 years</td>
                    <td>Tractors, horses</td>
                    <td>Qualified rent-to-own property</td>
                </tr>
                <tr>
                    <td><span class="badge badge-primary">5-Year</span></td>
                    <td>5 years</td>
                    <td>Vehicles, computers, office equipment</td>
                    <td>Automobiles, light trucks, computers</td>
                </tr>
                <tr>
                    <td><span class="badge badge-primary">7-Year</span></td>
                    <td>7 years</td>
                    <td>Office furniture, fixtures</td>
                    <td>Desks, files, most manufacturing equipment</td>
                </tr>
                <tr>
                    <td><span class="badge badge-info">10-Year</span></td>
                    <td>10 years</td>
                    <td>Water transportation equipment</td>
                    <td>Vessels, barges, tugs</td>
                </tr>
                <tr>
                    <td><span class="badge badge-info">15-Year</span></td>
                    <td>15 years</td>
                    <td>Land improvements</td>
                    <td>Fences, roads, shrubbery, bridges</td>
                </tr>
                <tr>
                    <td><span class="badge badge-info">20-Year</span></td>
                    <td>20 years</td>
                    <td>Farm buildings, municipal sewers</td>
                    <td>Certain initial clearing and grading</td>
                </tr>
                <tr>
                    <td><span class="badge badge-warning">27.5-Year</span></td>
                    <td>27.5 years</td>
                    <td>Residential rental property</td>
                    <td>Rental houses, apartments</td>
                </tr>
                <tr>
                    <td><span class="badge badge-warning">39-Year</span></td>
                    <td>39 years</td>
                    <td>Nonresidential real property</td>
                    <td>Office buildings, stores, warehouses</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="section-card">
    <div class="section-card-header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            MACRS Conventions
        </h3>
    </div>
    <div class="section-card-body">
        <div class="grid-3">
            <div class="convention-card">
                <h4>Half-Year Convention</h4>
                <p>Treats all property as placed in service at mid-year, regardless of actual date. Used when the mid-quarter convention doesn't apply.</p>
                <p class="convention-note"><strong>Default for:</strong> Personal property (5-year, 7-year)</p>
            </div>
            <div class="convention-card">
                <h4>Mid-Month Convention</h4>
                <p>Treats property as placed in service at mid-month. Required for residential and nonresidential real property.</p>
                <p class="convention-note"><strong>Required for:</strong> 27.5-year and 39-year property</p>
            </div>
            <div class="convention-card">
                <h4>Mid-Quarter Convention</h4>
                <p>Required when more than 40% of all personal property is placed in service in the last quarter of the tax year.</p>
                <p class="convention-note"><strong>Trigger:</strong> &gt;40% in Q4</p>
            </div>
        </div>
    </div>
</div>
