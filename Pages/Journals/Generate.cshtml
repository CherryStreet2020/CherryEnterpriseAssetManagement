@page
@model Abs.FixedAssets.Pages.Journals.GenerateModel
@{
    ViewData["Title"] = "Generate Depreciation Journal";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
    
    var headerVd = new ViewDataDictionary(ViewData)
    {
        ["HeaderTitle"] = "Generate Depreciation",
        ["Subtitle"] = "Create monthly depreciation journal entries for asset books",
        ["TypeLabel"] = "Journals",
        ["StatusText"] = "New Entry",
        ["StatusTone"] = "info",
        ["ContextPartial"] = "Journals/_JournalsGenerateContext",
        ["KpisPartial"] = "Journals/_JournalsGenerateKpis",
        ["KpisViewData"] = new ViewDataDictionary(ViewData) { ["BookCount"] = Model.BookOptions.Count() },
        ["ActionsPartial"] = "Journals/_JournalsGenerateActions"
    };
}
@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@if (!string.IsNullOrWhiteSpace(Model.Error))
{
    <div class="alert alert-danger">@Model.Error</div>
}

<div class="section-card">
    <div class="section-card-header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
            </svg>
            Generate Parameters
        </h3>
        <span class="status-badge info">CONFIGURE</span>
    </div>
    <div class="section-card-body">
        <form method="post">
            <div class="form-grid-2">
                <div class="field-group">
                    <label class="field-label">Book *</label>
                    <select class="form-control" asp-for="BookId" required>
                        <option value="">— Select Book —</option>
                        @foreach (var opt in Model.BookOptions)
                        {
                            <option value="@opt.Value" selected="@(Model.BookId?.ToString()==opt.Value)">
                                @opt.Text
                            </option>
                        }
                    </select>
                </div>

                <div class="field-group">
                    <label class="field-label">Month *</label>
                    <input class="form-control" asp-for="Month" type="month"
                           value="@(Model.Month?.ToString("yyyy-MM"))" required />
                    <span class="field-hint">Select the period for depreciation calculation</span>
                </div>
            </div>

            <div style="margin-top: 24px; display: flex; gap: 12px;">
                <button class="btn-p btn-p--primary" type="submit">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="margin-right: 6px;">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                    </svg>
                    Generate Journal
                </button>
                <a class="btn-p btn-p--secondary" asp-page="./Index">Cancel</a>
            </div>
        </form>
    </div>
</div>

<div class="section-card">
    <div class="section-card-header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            How It Works
        </h3>
    </div>
    <div class="section-card-body">
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;">
            <div style="text-align: center; padding: 20px;">
                <div class="icon-circle icon-bg-blue" style="margin: 0 auto 12px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="#3b82f6">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                </div>
                <h4 style="font-weight: 600; margin-bottom: 8px;">1. Select Period</h4>
                <p class="text-theme-muted" style="font-size: 13px;">Choose the book and month for depreciation calculation</p>
            </div>
            <div style="text-align: center; padding: 20px;">
                <div class="icon-circle icon-bg-green" style="margin: 0 auto 12px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="#22c55e">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                    </svg>
                </div>
                <h4 style="font-weight: 600; margin-bottom: 8px;">2. Calculate</h4>
                <p class="text-theme-muted" style="font-size: 13px;">System calculates depreciation for all active assets</p>
            </div>
            <div style="text-align: center; padding: 20px;">
                <div class="icon-circle icon-bg-amber" style="margin: 0 auto 12px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="#f59e0b">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                </div>
                <h4 style="font-weight: 600; margin-bottom: 8px;">3. Post Journal</h4>
                <p class="text-theme-muted" style="font-size: 13px;">Journal entry is created with debit/credit lines</p>
            </div>
        </div>
    </div>
</div>
