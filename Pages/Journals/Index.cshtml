@page
@model Abs.FixedAssets.Pages.Journals.IndexModel
@using Abs.FixedAssets.Pages.Shared.Primitives
@{
    ViewData["Title"] = "Journal Entries";
    ViewData["Breadcrumb"] = "Depreciation";
    Layout = "_ModernLayout";
    ViewData["HasScreenHeader"] = true;

    Func<DateTime?, string> nd = d => d.HasValue ? d.Value.ToString("MM/dd/yyyy") : "";
    Func<DateTime, string> ndn = d => d.ToString("MM/dd/yyyy");
    Func<decimal, string> money = v => v.ToString("C2");

    var totalEntries = Model.Items?.Count ?? 0;
    var totalDebits = Model.Items?.Sum(j => j.Lines.Sum(l => l.Debit)) ?? 0;
    var totalCredits = Model.Items?.Sum(j => j.Lines.Sum(l => l.Credit)) ?? 0;
    var totalLines = Model.Items?.Sum(j => j.Lines.Count) ?? 0;

    // PR #116d.12.1 — Set ViewData keys consumed by _JournalsKpis BEFORE constructing
    // headerVd so the KPI partial sees them when _ScreenHeader invokes it. Also stash
    // them on headerVd directly so the partial works regardless of which ViewData
    // _ScreenHeader propagates.
    ViewData["TotalEntries"] = totalEntries;
    ViewData["TotalLines"] = totalLines;
    ViewData["TotalDebits"] = totalDebits;
    ViewData["TotalCredits"] = totalCredits;

    var headerVd = new ViewDataDictionary(ViewData)
    {
        ["HeaderTitle"] = "Journal Entries",
        ["Subtitle"] = "Depreciation and adjustment journal entries",
        ["TypeLabel"] = "Depreciation",
        ["StatusText"] = $"{totalEntries} Entries",
        ["StatusTone"] = "success",
        ["ContextText"] = $"{totalLines} Lines / {totalDebits:C0} Total",
        ["KpisPartial"] = "Journals/_JournalsKpis",
        ["ActionsPartial"] = "Journals/_JournalsActions",
        ["TotalEntries"] = totalEntries,
        ["TotalLines"] = totalLines,
        ["TotalDebits"] = totalDebits,
        ["TotalCredits"] = totalCredits
    };
}
@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@if (TempData["Flash"] is string ok && !string.IsNullOrWhiteSpace(ok))
{
    <div class="ds-card" data-tone="success" style="margin-top: 16px; padding: 14px 18px; display: flex; align-items: center; gap: 12px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: var(--ds-success, #34d399); flex-shrink: 0;">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span style="color: var(--text-primary);">@ok</span>
    </div>
}
@if (TempData["FlashError"] is string err && !string.IsNullOrWhiteSpace(err))
{
    <div class="ds-card" data-tone="danger" style="margin-top: 16px; padding: 14px 18px; display: flex; align-items: center; gap: 12px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: var(--ds-danger, #f87171); flex-shrink: 0;">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <span style="color: var(--text-primary);">@err</span>
    </div>
}

@* PR #116d.12 — Filter row wrapped in a DataCard with neutral tone. *@
<div class="ds-card" data-tone="neutral" style="margin-top: 20px; padding: 18px 22px;">
    <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500; margin-bottom: 14px;">Filters</div>
    <form method="get" style="display: flex; gap: 16px; align-items: end; flex-wrap: wrap;">
        <div style="flex: 0 0 160px;">
            <label style="display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500; margin-bottom: 6px;">From</label>
            <input type="date" name="From" value="@(Model.From?.ToString("yyyy-MM-dd"))" style="width: 100%; padding: 8px 10px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface-2, rgba(0,0,0,0.18)); color: var(--text-primary); font-size: 13px;" />
        </div>
        <div style="flex: 0 0 160px;">
            <label style="display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500; margin-bottom: 6px;">To</label>
            <input type="date" name="To" value="@(Model.To?.ToString("yyyy-MM-dd"))" style="width: 100%; padding: 8px 10px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface-2, rgba(0,0,0,0.18)); color: var(--text-primary); font-size: 13px;" />
        </div>
        <div style="flex: 0 0 140px;">
            <label style="display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500; margin-bottom: 6px;">Source</label>
            <input type="text" name="Source" value="@Model.Source" placeholder="e.g., FA" style="width: 100%; padding: 8px 10px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface-2, rgba(0,0,0,0.18)); color: var(--text-primary); font-size: 13px;" />
        </div>
        <div style="flex: 1; min-width: 200px;">
            <label style="display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500; margin-bottom: 6px;">Search</label>
            <input type="text" name="Search" value="@Model.Search" placeholder="Batch / Reference / Description" style="width: 100%; padding: 8px 10px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface-2, rgba(0,0,0,0.18)); color: var(--text-primary); font-size: 13px;" />
        </div>
        <div style="display: flex; gap: 8px;">
            <button class="ds-btn ds-btn--primary ds-btn--md" type="submit">Apply</button>
            <a class="ds-btn ds-btn--secondary ds-btn--md" asp-page="./Index">Reset</a>
        </div>
    </form>
</div>

@* PR #116d.12 — Journal entries table wrapped in a DataCard with brand tone.
   Enhanced-grid preserved for column filters / search / export — DataTable
   primitive doesn't yet support those features. *@
<div class="ds-card" data-tone="brand" style="margin-top: 24px; padding: 0;">
    <div style="padding: 18px 22px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px;">
        <div>
            <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500;">General Ledger</div>
            <div style="font-size: 17px; font-weight: 700; color: var(--text-primary); margin-top: 4px;">All Journal Entries</div>
        </div>
        @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel
        {
            Label = "Entries",
            MonoNum = totalEntries.ToString(),
            Tone = "info",
            ShowDot = true
        })
    </div>
    <div style="padding: 0;">
        @{ var returnUrl = $"{HttpContext.Request.Path}{HttpContext.Request.QueryString}"; }
        @if (Model.Items != null && Model.Items.Any())
        {
            <table class="data-table premium-table" id="journalGrid" data-enhanced-grid="true" data-row-click="true">
                <thead>
                    <tr>
                        <th data-col="Batch" data-filter="text">Batch</th>
                        <th data-col="Posting Date" data-filter="text">Posting Date</th>
                        <th data-col="Reference" data-filter="text">Reference</th>
                        <th data-col="Source" data-filter="text">Source</th>
                        <th data-col="Description" data-filter="text">Description</th>
                        <th style="text-align: right;" data-col="Lines" data-filter="number">Lines</th>
                        <th style="text-align: right;" data-col="Debit" data-filter="number">Debit</th>
                        <th style="text-align: right;" data-col="Credit" data-filter="number">Credit</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var j in Model.Items)
                    {
                        <tr data-row-id="@j.Id" data-row-href="@Url.Page("/Journals/Details", new { id = j.Id, returnUrl = returnUrl })">
                            <td><strong style="color: var(--text-primary);">@j.Batch</strong></td>
                            <td style="color: var(--text-primary);">@ndn(j.PostingDate)</td>
                            <td style="color: var(--text-secondary);">@j.Reference</td>
                            <td>
                                @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel
                                {
                                    Label = j.Source,
                                    Tone = "brand",
                                    ShowDot = false
                                })
                            </td>
                            <td style="max-width: 240px;">
                                <div style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--text-primary);" title="@j.Description">
                                    @j.Description
                                </div>
                            </td>
                            <td style="text-align: right; font-family: var(--font-mono, ui-monospace, monospace); color: var(--text-primary);">@j.Lines.Count</td>
                            <td style="text-align: right; font-family: var(--font-mono, ui-monospace, monospace); font-weight: 600; color: var(--ds-success, #34d399);">@money(j.Lines.Sum(l => l.Debit))</td>
                            <td style="text-align: right; font-family: var(--font-mono, ui-monospace, monospace); font-weight: 600; color: var(--ds-danger, #f87171);">@money(j.Lines.Sum(l => l.Credit))</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            @* PR #116d.12 — EmptyState v2 with document icon for "no journal entries". *@
            <div style="padding: 24px;">
                @await Html.PartialAsync("Primitives/_EmptyStateV2", new EmptyStateModel
                {
                    Icon = "document",
                    Tone = "info",
                    Title = "No journal entries",
                    Body = "Generate depreciation to create journal entries — or widen your filter range. JE rows post automatically from WO labor, parts issue, and depreciation runs.",
                    CtaLabel = "Generate Depreciation",
                    CtaHref = "/Journals/Generate",
                    SecondaryLabel = "Reset Filters",
                    SecondaryHref = "/Journals"
                })
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function() {
    if (typeof initEnhancedGrid === 'function') {
        initEnhancedGrid('journalGrid', {
            searchable: true,
            sortable: true,
            exportable: true,
            columnVisibility: true,
            clickableRows: true
        });
    }
});
</script>
}
