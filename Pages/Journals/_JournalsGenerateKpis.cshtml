@{
    var bookCount = ViewData["BookCount"] as int? ?? 0;
}
<div class="screen-header__kpis">
    <div class="kpi-card">
        <div class="kpi-label">Books</div>
        <div class="kpi-value">@bookCount</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Status</div>
        <div class="kpi-value info">Ready</div>
    </div>
</div>
