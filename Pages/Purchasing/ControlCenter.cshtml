@page "/Purchasing/ControlCenter"
@model Abs.FixedAssets.Pages.Purchasing.ControlCenterModel
@using Abs.FixedAssets.Services.Purchasing
@using Abs.FixedAssets.Models.Production
@{
    ViewData["Title"] = "Purchasing Control Center";
    ViewData["TabTitle"] = "Purchasing";
    ViewData["BodyClass"] = "is-control-center";
    Layout = "_ModernLayout";

    string BadgeStyle(string tone) => tone switch
    {
        "danger" => "background:var(--danger-soft);color:var(--danger);",
        "warning" => "background:var(--warning-soft);color:var(--warning);",
        "success" => "background:var(--success-soft);color:var(--success);",
        "info" => "background:var(--info-soft,#dbeafe);color:var(--info,#0c4a6e);",
        "muted" => "background:rgba(0,0,0,0.04);color:var(--text-muted);",
        _ => "background:rgba(0,0,0,0.04);color:var(--text-muted);",
    };
}

@* Sprint 15.3 PR-11 — anchored page header (Cockpit primitive). *@
@if (Model.PageHeader is not null)
{
    @await Html.PartialAsync("Primitives/Cockpit/_CockpitPageHeader", Model.PageHeader)
}

@* Sprint 15.3 PR-11 — 5-tile hero KPI band (Cockpit primitive). *@
@if (Model.KpiBand is not null)
{
    @await Html.PartialAsync("Primitives/Cockpit/_CockpitKpiBand", Model.KpiBand)
}

@* Sprint 15.3 PR-11 — 10-tab shell. Tabs 1-2 live; tabs 3-10 register the §21
   IA and render a "coming soon" panel until PR-12 / PR-13. *@
@await Html.PartialAsync("Primitives/Cockpit/_CockpitTabShell", Model.TabShell)

<div style="padding:16px 24px 48px 24px;">

    @if (TempData["pcc-flash"] is string flash)
    {
        <div class="ds-card" style="margin-bottom:16px;">
            <div class="ds-card__body">
                <p data-testid="pcc-flash">@flash</p>
            </div>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="ds-card" style="margin-bottom:16px;border-left:3px solid var(--danger);">
            <div class="ds-card__body">
                <p style="color:var(--danger);" data-testid="pcc-error">@Model.ErrorMessage</p>
            </div>
        </div>
    }

    @* ─── PR-12 Subcontract tab body ─────────────────────────────────── *@
    @if (Model.ActiveTab == Abs.FixedAssets.Pages.Purchasing.ControlCenterModel.TabSubcontract
         && Model.SubcontractTab is { } sct)
    {
        <section class="ds-card cockpit__group" data-group="@Model.ActiveTab">
            <div class="ds-card__body">
                <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:12px;">
                    <h2 style="font-size:1.2rem;font-weight:600;margin:0;" data-testid="pcc-tab-title-subcontract">Subcontract operations
                        <span style="color:var(--text-muted);font-weight:400;">· @sct.TotalCount active op(s)</span>
                    </h2>
                    <span style="color:var(--text-muted);font-size:0.875rem;">
                        @if (sct.Rows.Count == 0) { <text>No active subcontract ops in scope</text> }
                        else { <text>Showing @(Model.Skip + 1)–@(Model.Skip + sct.Rows.Count) of @sct.TotalCount</text> }
                    </span>
                </div>
                @if (sct.Rows.Count == 0)
                {
                    <div style="text-align:center;padding:48px 24px;">
                        <i class="fas fa-handshake" style="font-size:48px;color:var(--info,#0c4a6e);"></i>
                        <p style="margin-top:12px;font-weight:600;">No active subcontract operations.</p>
                        <p style="color:var(--text-muted);">Subcontract ops appear here as PROs are released with outside-processing routing steps.</p>
                    </div>
                }
                else
                {
                    <div class="ds-table">
                        <div class="ds-table__scroll">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Op #</th>
                                        <th>PRO</th>
                                        <th>Seq · Code</th>
                                        <th>Supplier</th>
                                        <th>Op status</th>
                                        <th>Ship</th>
                                        <th>Receive</th>
                                        <th>To ship / Recv</th>
                                        <th>Required back</th>
                                        <th>Days late</th>
                                        <th>Flags</th>
                                        <th>Next action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var r in sct.Rows)
                                {
                                    <tr data-testid="pcc-subcontract-row-@r.SubcontractOperationId">
                                        <td><strong>#@r.SubcontractOperationId</strong></td>
                                        <td><a href="/Production/Details/@r.ProductionOrderId">@(r.ProductionOrderNumber ?? $"#{r.ProductionOrderId}")</a></td>
                                        <td>@r.OperationSequence · <span style="font-family:var(--font-mono,monospace);">@r.OperationCode</span></td>
                                        <td>@(r.SupplierName ?? "—")</td>
                                        <td><span style="display:inline-block;padding:2px 8px;border-radius:10px;font-size:0.75rem;font-weight:600;@(BadgeStyle(Abs.FixedAssets.Pages.Purchasing.ControlCenterModel.SubcontractOpStatusTone(r.OpStatus)))">@r.OpStatus</span></td>
                                        <td>@r.ShipmentStatus</td>
                                        <td>@r.ReceiptStatusForOp</td>
                                        <td>@r.QuantityToShip.ToString("N2") / @r.QuantityReceivedBack.ToString("N2")</td>
                                        <td>@(r.RequiredBackDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                                        <td>
                                            @if (r.DaysLateBack.HasValue)
                                            { <span style="color:var(--danger);">@r.DaysLateBack d</span> }
                                            else { <text>—</text> }
                                        </td>
                                        <td>
                                            @if (r.CertRequired) { <span title="Cert required" style="color:var(--warning);">C</span> }
                                            @if (r.InspectionOnReturn) { <span title="Inspection on return" style="color:var(--info,#0c4a6e);">I</span> }
                                        </td>
                                        <td><em style="color:var(--text-muted);">@r.NextActionHint</em></td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    @* ─── PR-12 Vendor WIP tab body ──────────────────────────────────── *@
    else if (Model.ActiveTab == Abs.FixedAssets.Pages.Purchasing.ControlCenterModel.TabVendorWip
             && Model.VendorWipTab is { } vwt)
    {
        <section class="ds-card cockpit__group" data-group="@Model.ActiveTab">
            <div class="ds-card__body">
                <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:12px;">
                    <h2 style="font-size:1.2rem;font-weight:600;margin:0;" data-testid="pcc-tab-title-vendor-wip">Vendor WIP
                        <span style="color:var(--text-muted);font-weight:400;">
                            · @vwt.TotalCount balance(s) · <strong style="color:var(--text-primary);">$@vwt.TotalValueAtVendorUsd.ToString("N0")</strong>
                            @if (vwt.OverdueReturnCount > 0)
                            { <text> · <span style="color:var(--danger);">@vwt.OverdueReturnCount overdue</span></text> }
                        </span>
                    </h2>
                    <span style="color:var(--text-muted);font-size:0.875rem;">
                        @if (vwt.Rows.Count == 0) { <text>No material at suppliers right now</text> }
                        else { <text>Showing @(Model.Skip + 1)–@(Model.Skip + vwt.Rows.Count) of @vwt.TotalCount</text> }
                    </span>
                </div>
                @if (vwt.Rows.Count == 0)
                {
                    <div style="text-align:center;padding:48px 24px;">
                        <i class="fas fa-warehouse" style="font-size:48px;color:var(--success);"></i>
                        <p style="margin-top:12px;font-weight:600;">No material currently at supplier locations.</p>
                        <p style="color:var(--text-muted);">VendorWIP balances appear when WIP is shipped out for outside processing.</p>
                    </div>
                }
                else
                {
                    <div class="ds-table">
                        <div class="ds-table__scroll">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Bal #</th>
                                        <th>PRO</th>
                                        <th>Seq</th>
                                        <th>Supplier</th>
                                        <th>Location</th>
                                        <th>Part · Rev</th>
                                        <th>Lot</th>
                                        <th>At vendor</th>
                                        <th>Value</th>
                                        <th>Status</th>
                                        <th>Quality</th>
                                        <th>Aging</th>
                                        <th>Required back</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var r in vwt.Rows)
                                {
                                    <tr data-testid="pcc-vendor-wip-row-@r.VendorWipBalanceId">
                                        <td><strong>#@r.VendorWipBalanceId</strong></td>
                                        <td><a href="/Production/Details/@r.ProductionOrderId">@(r.ProductionOrderNumber ?? $"#{r.ProductionOrderId}")</a></td>
                                        <td>@r.OperationSequence</td>
                                        <td>@(r.SupplierName ?? "—")</td>
                                        <td>@(r.VendorLocationDescription ?? "—")</td>
                                        <td><span style="font-family:var(--font-mono,monospace);">@(r.PartNumber ?? "—")</span> @r.Revision</td>
                                        <td>@(r.LotNumber ?? "—")</td>
                                        <td>@r.QuantityAtVendor.ToString("N2")</td>
                                        <td>$@r.TotalValueAtVendor.ToString("N2")</td>
                                        <td><span style="display:inline-block;padding:2px 8px;border-radius:10px;font-size:0.75rem;font-weight:600;@(BadgeStyle(Abs.FixedAssets.Pages.Purchasing.ControlCenterModel.VendorWipInventoryTone(r.InventoryStatus)))">@r.InventoryStatus</span></td>
                                        <td>@r.QualityStatus</td>
                                        <td>@r.AgingDaysAtVendor d</td>
                                        <td>
                                            @if (r.RequiredReturnDate.HasValue)
                                            {
                                                var d = r.RequiredReturnDate.Value.ToString("yyyy-MM-dd");
                                                if (r.DaysLateReturn.HasValue)
                                                { <span style="color:var(--danger);">@d (@r.DaysLateReturn d late)</span> }
                                                else
                                                { <text>@d</text> }
                                            }
                                            else { <text>—</text> }
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    @* ─── PR-12 Receipts tab body ────────────────────────────────────── *@
    else if (Model.ActiveTab == Abs.FixedAssets.Pages.Purchasing.ControlCenterModel.TabReceipts
             && Model.ReceiptsTab is { } rct)
    {
        <section class="ds-card cockpit__group" data-group="@Model.ActiveTab">
            <div class="ds-card__body">
                <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:12px;">
                    <h2 style="font-size:1.2rem;font-weight:600;margin:0;" data-testid="pcc-tab-title-receipts">Subcontract receipts
                        <span style="color:var(--text-muted);font-weight:400;">
                            · @rct.TotalCount active
                            @if (rct.OpenDraftCount > 0) { <text> · @rct.OpenDraftCount draft</text> }
                            @if (rct.PendingApprovalCount > 0)
                            { <text> · <span style="color:var(--warning);">@rct.PendingApprovalCount pending approval</span></text> }
                        </span>
                    </h2>
                    <span style="color:var(--text-muted);font-size:0.875rem;">
                        @if (rct.Rows.Count == 0) { <text>No active receipts</text> }
                        else { <text>Showing @(Model.Skip + 1)–@(Model.Skip + rct.Rows.Count) of @rct.TotalCount</text> }
                    </span>
                </div>
                @if (rct.Rows.Count == 0)
                {
                    <div style="text-align:center;padding:48px 24px;">
                        <i class="fas fa-box-open" style="font-size:48px;color:var(--success);"></i>
                        <p style="margin-top:12px;font-weight:600;">No active subcontract receipts.</p>
                        <p style="color:var(--text-muted);">Receipts appear here as vendors return processed WIP — drafted, posting, posted, or pending approval.</p>
                    </div>
                }
                else
                {
                    <div class="ds-table">
                        <div class="ds-table__scroll">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Receipt #</th>
                                        <th>PRO</th>
                                        <th>Seq</th>
                                        <th>Supplier</th>
                                        <th>Packing slip</th>
                                        <th>Date</th>
                                        <th>Status</th>
                                        <th>Lines</th>
                                        <th>Received</th>
                                        <th>Accepted</th>
                                        <th>Rejected</th>
                                        <th>Cert / Insp</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var r in rct.Rows)
                                {
                                    <tr data-testid="pcc-receipt-row-@r.SubcontractReceiptId">
                                        <td><strong>@r.ReceiptNumber</strong></td>
                                        <td><a href="/Production/Details/@r.ProductionOrderId">@(r.ProductionOrderNumber ?? $"#{r.ProductionOrderId}")</a></td>
                                        <td>@r.OperationSequence</td>
                                        <td>@(r.SupplierName ?? "—")</td>
                                        <td>@(r.VendorPackingSlip ?? "—")</td>
                                        <td>@r.ReceiptDate.ToString("yyyy-MM-dd")</td>
                                        <td><span style="display:inline-block;padding:2px 8px;border-radius:10px;font-size:0.75rem;font-weight:600;@(BadgeStyle(Abs.FixedAssets.Pages.Purchasing.ControlCenterModel.ReceiptLifecycleTone(r.Status)))">@r.Status</span></td>
                                        <td>@r.LineCount</td>
                                        <td>@r.TotalReceived.ToString("N2")</td>
                                        <td>@r.TotalAccepted.ToString("N2")</td>
                                        <td>@r.TotalRejected.ToString("N2")</td>
                                        <td>
                                            @if (r.CertReceived) { <span title="Cert received" style="color:var(--success);">C✓</span> }
                                            else if (r.InspectionRequired) { <span title="Inspection required" style="color:var(--warning);">I</span> }
                                            else { <text>—</text> }
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    @* ─── PR-12 Inspection Holds tab body ────────────────────────────── *@
    else if (Model.ActiveTab == Abs.FixedAssets.Pages.Purchasing.ControlCenterModel.TabInspectionHolds
             && Model.InspectionHoldsTab is { } iht)
    {
        <section class="ds-card cockpit__group" data-group="@Model.ActiveTab">
            <div class="ds-card__body">
                <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:12px;">
                    <h2 style="font-size:1.2rem;font-weight:600;margin:0;" data-testid="pcc-tab-title-inspection-holds">Inspection holds
                        <span style="color:var(--text-muted);font-weight:400;">
                            · @iht.TotalCount hold(s)
                            @if (iht.OldHoldsCount > 0)
                            { <text> · <span style="color:var(--danger);">@iht.OldHoldsCount aged 7+ days</span></text> }
                        </span>
                    </h2>
                    <span style="color:var(--text-muted);font-size:0.875rem;">
                        @if (iht.Rows.Count == 0) { <text>No inspection holds in scope</text> }
                        else { <text>Showing 1–@iht.Rows.Count of @iht.TotalCount</text> }
                    </span>
                </div>
                @if (iht.Rows.Count == 0)
                {
                    <div style="text-align:center;padding:48px 24px;">
                        <i class="fas fa-flask" style="font-size:48px;color:var(--success);"></i>
                        <p style="margin-top:12px;font-weight:600;">No material on inspection hold.</p>
                        <p style="color:var(--text-muted);">Lines from goods receipts and subcontract receipts that need inspection, cert, or quality review surface here.</p>
                    </div>
                }
                else
                {
                    <div class="ds-table">
                        <div class="ds-table__scroll">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Source</th>
                                        <th>Header</th>
                                        <th>PO / PRO</th>
                                        <th>Seq</th>
                                        <th>Supplier</th>
                                        <th>Part · Rev</th>
                                        <th>Lot</th>
                                        <th>Received</th>
                                        <th>On hold</th>
                                        <th>Reason</th>
                                        <th>Aged</th>
                                        <th>Next action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var r in iht.Rows)
                                {
                                    <tr data-testid="pcc-inspection-hold-@r.SourceKind-@r.SourceLineId">
                                        <td>
                                            <span style="font-size:0.75rem;color:var(--text-muted);">@(r.SourceKind == Abs.FixedAssets.Services.Purchasing.InspectionHoldSourceKind.PurchaseOrderReceipt ? "PO Receipt" : "Subcontract")</span>
                                        </td>
                                        <td><strong>@r.SourceHeaderNumber</strong></td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(r.PurchaseOrderNumber))
                                            { <text>PO @r.PurchaseOrderNumber</text> }
                                            @if (r.ProductionOrderId.HasValue)
                                            {
                                                if (!string.IsNullOrEmpty(r.PurchaseOrderNumber)) { <br /> }
                                                <a href="/Production/Details/@r.ProductionOrderId">@(r.ProductionOrderNumber ?? $"PRO #{r.ProductionOrderId}")</a>
                                            }
                                            @if (string.IsNullOrEmpty(r.PurchaseOrderNumber) && !r.ProductionOrderId.HasValue)
                                            { <text>—</text> }
                                        </td>
                                        <td>@(r.OperationSequence?.ToString() ?? "—")</td>
                                        <td>@(r.SupplierName ?? "—")</td>
                                        <td><span style="font-family:var(--font-mono,monospace);">@(r.PartNumber ?? "—")</span> @r.Revision</td>
                                        <td>@(r.LotNumber ?? "—")</td>
                                        <td>@r.QuantityReceived.ToString("N2")</td>
                                        <td><strong>@r.QuantityOnHold.ToString("N2")</strong></td>
                                        <td>@r.HoldReason</td>
                                        <td>@(r.DaysOnHold >= 7
                                                ? Html.Raw($"<span style=\"color:var(--danger);\">{r.DaysOnHold} d</span>")
                                                : Html.Raw($"{r.DaysOnHold} d"))</td>
                                        <td><em style="color:var(--text-muted);">@r.NextActionHint</em></td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    @* ─── PR-13 POs tab body ─────────────────────────────────────────── *@
    else if (Model.ActiveTab == Abs.FixedAssets.Pages.Purchasing.ControlCenterModel.TabPos
             && Model.PosTab is { } pos)
    {
        <section class="ds-card cockpit__group" data-group="@Model.ActiveTab">
            <div class="ds-card__body">
                <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:12px;">
                    <h2 style="font-size:1.2rem;font-weight:600;margin:0;" data-testid="pcc-tab-title-pos">Purchase orders
                        <span style="color:var(--text-muted);font-weight:400;">
                            · @pos.TotalCount active · <strong style="color:var(--text-primary);">@pos.OpenTotalValue.ToString("N0") PO value</strong>
                            @if (pos.PendingApprovalCount > 0)
                            { <text> · <span style="color:var(--warning);">@pos.PendingApprovalCount pending approval</span></text> }
                            @if (pos.LateCount > 0)
                            { <text> · <span style="color:var(--danger);">@pos.LateCount late</span></text> }
                        </span>
                    </h2>
                    <span style="color:var(--text-muted);font-size:0.875rem;">
                        @if (pos.Rows.Count == 0) { <text>No active POs</text> }
                        else { <text>Showing @(Model.Skip + 1)–@(Model.Skip + pos.Rows.Count) of @pos.TotalCount</text> }
                    </span>
                </div>
                @if (pos.Rows.Count == 0)
                {
                    <div style="text-align:center;padding:48px 24px;">
                        <i class="fas fa-file-invoice" style="font-size:48px;color:var(--success);"></i>
                        <p style="margin-top:12px;font-weight:600;">No active purchase orders.</p>
                        <p style="color:var(--text-muted);">POs surface here while they're in any open lifecycle state — Draft, PendingApproval, Approved, Sent, PartiallyReceived, Received, Invoiced.</p>
                    </div>
                }
                else
                {
                    <div class="ds-table">
                        <div class="ds-table__scroll">
                            <table>
                                <thead>
                                    <tr>
                                        <th>PO #</th>
                                        <th>Vendor</th>
                                        <th>Status</th>
                                        <th>Order date</th>
                                        <th>Required / Promise</th>
                                        <th>Days late</th>
                                        <th>Lines</th>
                                        <th>Total</th>
                                        <th>Approved</th>
                                        <th>Next action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var r in pos.Rows)
                                {
                                    <tr data-testid="pcc-pos-row-@r.PurchaseOrderId">
                                        <td><a href="/Purchasing/Details/@r.PurchaseOrderId"><strong>@r.PoNumber</strong></a></td>
                                        <td>@(r.VendorName ?? $"#{r.VendorId}")</td>
                                        <td><span style="display:inline-block;padding:2px 8px;border-radius:10px;font-size:0.75rem;font-weight:600;@(BadgeStyle(Abs.FixedAssets.Pages.Purchasing.ControlCenterModel.PoStatusTone(r.Status)))">@r.Status</span></td>
                                        <td>@r.OrderDate.ToString("yyyy-MM-dd")</td>
                                        <td>
                                            @if (r.PromiseDate.HasValue)
                                            { <text>P: @r.PromiseDate.Value.ToString("yyyy-MM-dd")</text> }
                                            else if (r.RequiredDate.HasValue)
                                            { <text>R: @r.RequiredDate.Value.ToString("yyyy-MM-dd")</text> }
                                            else
                                            { <text>—</text> }
                                        </td>
                                        <td>
                                            @if (r.DaysLate.HasValue)
                                            { <span style="color:var(--danger);">@r.DaysLate d</span> }
                                            else { <text>—</text> }
                                        </td>
                                        <td>@r.LineCount</td>
                                        <td>@r.Currency $@r.Total.ToString("N2")</td>
                                        <td>
                                            @if (r.ApprovedAt.HasValue)
                                            { <text>@r.ApprovedAt.Value.ToString("yyyy-MM-dd")</text> }
                                            else { <text>—</text> }
                                        </td>
                                        <td><em style="color:var(--text-muted);">@r.NextActionHint</em></td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    @* ─── PR-13 Cost Exceptions tab body ─────────────────────────────── *@
    else if (Model.ActiveTab == Abs.FixedAssets.Pages.Purchasing.ControlCenterModel.TabCostExceptions
             && Model.CostExceptionsTab is { } cet)
    {
        <section class="ds-card cockpit__group" data-group="@Model.ActiveTab">
            <div class="ds-card__body">
                <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:12px;">
                    <h2 style="font-size:1.2rem;font-weight:600;margin:0;" data-testid="pcc-tab-title-cost-exceptions">Cost exceptions
                        <span style="color:var(--text-muted);font-weight:400;">
                            · @cet.TotalCount total
                            @if (cet.HighSeverityCount > 0)
                            { <text> · <span style="color:var(--danger);">@cet.HighSeverityCount high</span></text> }
                            @if (cet.MediumSeverityCount > 0)
                            { <text> · <span style="color:var(--warning);">@cet.MediumSeverityCount medium</span></text> }
                            @if (cet.LowSeverityCount > 0)
                            { <text> · @cet.LowSeverityCount low</text> }
                        </span>
                    </h2>
                    <span style="color:var(--text-muted);font-size:0.875rem;">
                        @if (cet.Rows.Count == 0) { <text>No cost exceptions in scope</text> }
                        else { <text>Showing 1–@cet.Rows.Count of @cet.TotalCount</text> }
                    </span>
                </div>
                @if (cet.Rows.Count == 0)
                {
                    <div style="text-align:center;padding:48px 24px;">
                        <i class="fas fa-check-circle" style="font-size:48px;color:var(--success);"></i>
                        <p style="margin-top:12px;font-weight:600;">No cost exceptions.</p>
                        <p style="color:var(--text-muted);">Variance pending, late vendor WIP, and supplier-performance alerts surface here as they arise.</p>
                    </div>
                }
                else
                {
                    <div class="ds-table">
                        <div class="ds-table__scroll">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Kind</th>
                                        <th>Severity</th>
                                        <th>Demand</th>
                                        <th>PO / PO Line</th>
                                        <th>Vendor</th>
                                        <th>Description</th>
                                        <th>Detected</th>
                                        <th>Cost impact</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var r in cet.Rows)
                                {
                                    <tr data-testid="pcc-cost-exception-@r.ExceptionKind-@(r.DemandId ?? r.PurchaseOrderId ?? 0)">
                                        <td>@r.ExceptionKind</td>
                                        <td><span style="display:inline-block;padding:2px 8px;border-radius:10px;font-size:0.75rem;font-weight:600;@(BadgeStyle(Abs.FixedAssets.Pages.Purchasing.ControlCenterModel.ExceptionSeverityTone(r.Severity)))">@r.Severity</span></td>
                                        <td>@(r.DemandId?.ToString() ?? "—")</td>
                                        <td>
                                            @if (r.PurchaseOrderId.HasValue)
                                            { <text>PO #@r.PurchaseOrderId</text> }
                                            @if (r.PurchaseOrderLineId.HasValue)
                                            { <text> · L#@r.PurchaseOrderLineId</text> }
                                            @if (!r.PurchaseOrderId.HasValue && !r.PurchaseOrderLineId.HasValue)
                                            { <text>—</text> }
                                        </td>
                                        <td>@(r.VendorId?.ToString() ?? "—")</td>
                                        <td>@r.Description</td>
                                        <td>@r.DetectedUtc.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td>@(r.CostImpactUsd.HasValue ? $"${r.CostImpactUsd.Value:N2}" : "—")</td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    @* ─── Supply Demand / Buy-to-Job / Expedites / Approvals grid (PR-11/PR-13) ─ *@
    else if (Model.ActiveTabIsLive && Model.Queue is { } pq)
    {
        var queueLabel = Model.ActiveTab switch
        {
            Abs.FixedAssets.Pages.Purchasing.ControlCenterModel.TabBuyToJob => "Buy-to-Job demand",
            Abs.FixedAssets.Pages.Purchasing.ControlCenterModel.TabExpedites => "Expedite queue",
            Abs.FixedAssets.Pages.Purchasing.ControlCenterModel.TabApprovals => "Awaiting approval",
            _ => "Supply Demand",
        };
        var emptyCopy = Model.ActiveTab switch
        {
            Abs.FixedAssets.Pages.Purchasing.ControlCenterModel.TabBuyToJob =>
                "When a Production Order is released, its BOM lines materialize as buy-to-job demand rows here.",
            Abs.FixedAssets.Pages.Purchasing.ControlCenterModel.TabExpedites =>
                "Demand lines with shortage Late or Critical surface here — late or at-risk supply ready to expedite.",
            Abs.FixedAssets.Pages.Purchasing.ControlCenterModel.TabApprovals =>
                "PO/requisition lines waiting on approval show here — clear them or escalate.",
            _ => "Open demand from Production Orders, projects, and MRP surfaces here as it appears.",
        };

        <section class="ds-card cockpit__group" data-group="@Model.ActiveTab">
            <div class="ds-card__body">

                <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:12px;">
                    <h2 style="font-size:1.2rem;font-weight:600;margin:0;">@queueLabel
                        <span style="color:var(--text-muted);font-weight:400;">· @pq.TotalCount row(s)</span>
                    </h2>
                    <span style="color:var(--text-muted);font-size:0.875rem;">
                        @if (Model.Queue.Rows.Count == 0) { <text>No matching demand right now</text> }
                        else { <text>Showing @(Model.Skip + 1)–@(Model.Skip + Model.Queue.Rows.Count) of @pq.TotalCount</text> }
                    </span>
                </div>

                @if (Model.Queue.Rows.Count == 0)
                {
                    <div style="text-align:center;padding:48px 24px;">
                        <i class="fas fa-check-circle" style="font-size:48px;color:var(--success);"></i>
                        <p style="margin-top:12px;font-weight:600;">No unresolved @queueLabel.ToLower() in scope.</p>
                        <p style="color:var(--text-muted);">@emptyCopy</p>
                    </div>
                }
                else
                {
                    <div class="ds-table">
                        <div class="ds-table__scroll">
                            <table>
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Demand</th>
                                        <th>PRO</th>
                                        <th>Op</th>
                                        <th>Part / Rev</th>
                                        <th>Open qty</th>
                                        <th>Required</th>
                                        <th>Supply</th>
                                        <th>Buyer state</th>
                                        <th>Next action</th>
                                        <th style="text-align:right;">Row actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var row in Model.Queue.Rows)
                                {
                                    <tr data-testid="pcc-row-@row.DemandId">
                                        <td>@row.DemandId</td>
                                        <td><strong>@row.DemandNumber</strong></td>
                                        <td>
                                            <a href="@Abs.FixedAssets.Pages.Purchasing.ControlCenterModel.ActionLink_ViewPro(row)">
                                                @(row.ProductionOrderNumber ?? $"#{row.ProductionOrderId}")
                                            </a>
                                        </td>
                                        <td>@(row.OperationSequence?.ToString() ?? "—")</td>
                                        <td>
                                            <span style="font-family:var(--font-mono,monospace);">@(row.PartNumber ?? "—")</span>
                                            @if (!string.IsNullOrEmpty(row.Revision))
                                            {
                                                <span style="color:var(--text-muted);"> @row.Revision</span>
                                            }
                                        </td>
                                        <td>
                                            @row.OpenQuantity.ToString("N2")
                                            @if (!string.IsNullOrEmpty(row.Uom))
                                            {
                                                <span style="color:var(--text-muted);"> @row.Uom</span>
                                            }
                                        </td>
                                        <td>
                                            @if (row.RequiredDate.HasValue)
                                            {
                                                <span style="@(row.DaysLate > 0 ? "color:var(--danger);" : "")">@row.RequiredDate.Value.ToString("yyyy-MM-dd")</span>
                                                @if (row.DaysLate > 0)
                                                {
                                                    <span style="color:var(--danger);"> (@row.DaysLate d late)</span>
                                                }
                                            }
                                            else { <text>—</text> }
                                        </td>
                                        <td>
                                            <span style="display:inline-block;padding:2px 8px;border-radius:10px;font-size:0.75rem;font-weight:600;@(BadgeStyle(Abs.FixedAssets.Pages.Purchasing.ControlCenterModel.SupplyStatusTone(row.SupplyStatus)))">
                                                @row.SupplyStatus
                                            </span>
                                        </td>
                                        <td>
                                            <span style="display:inline-block;padding:2px 8px;border-radius:10px;font-size:0.75rem;font-weight:600;@(BadgeStyle(Abs.FixedAssets.Pages.Purchasing.ControlCenterModel.BuyerActionStateTone(row.BuyerActionState)))">
                                                @row.BuyerActionState
                                            </span>
                                        </td>
                                        <td><em style="color:var(--text-muted);">@row.NextActionHint</em></td>
                                        <td style="text-align:right;">
                                            <div class="ds-btn-group ds-btn-group--end">
                                                <a class="ds-btn" href="@Abs.FixedAssets.Pages.Purchasing.ControlCenterModel.ActionLink_ViewPro(row)" data-testid="action-view-pro-@row.DemandId">
                                                    <i class="fas fa-eye"></i> View PRO
                                                </a>
                                                @* Codex thread #2 (P2): preserve tab + filter state across the
                                                   POST→redirect cycle. Hidden inputs mirror the bound props so
                                                   RedirectToPage rebuilds the same query the user was on. *@
                                                @if (row.BuyerActionState == BuyerActionState.Open)
                                                {
                                                    <form method="post" asp-page-handler="AssignSelf" style="display:inline;">
                                                        <input type="hidden" name="TransitionDemandId" value="@row.DemandId" />
                                                        <input type="hidden" name="TransitionNotes" value="Self-assigned from Purchasing CC" />
                                                        <input type="hidden" name="TabKey" value="@Model.ActiveTab" />
                                                        @if (Model.SiteId.HasValue) { <input type="hidden" name="SiteId" value="@Model.SiteId" /> }
                                                        @if (Model.BuyerUserId.HasValue) { <input type="hidden" name="BuyerUserId" value="@Model.BuyerUserId" /> }
                                                        <input type="hidden" name="Skip" value="@Model.Skip" />
                                                        <button type="submit" class="ds-btn" data-testid="action-assign-@row.DemandId">
                                                            <i class="fas fa-user-check"></i> Assign me
                                                        </button>
                                                    </form>
                                                }
                                                else if (row.BuyerActionState == BuyerActionState.Assigned)
                                                {
                                                    <form method="post" asp-page-handler="StartWork" style="display:inline;">
                                                        <input type="hidden" name="TransitionDemandId" value="@row.DemandId" />
                                                        <input type="hidden" name="TransitionNotes" value="Started from Purchasing CC" />
                                                        <input type="hidden" name="TabKey" value="@Model.ActiveTab" />
                                                        @if (Model.SiteId.HasValue) { <input type="hidden" name="SiteId" value="@Model.SiteId" /> }
                                                        @if (Model.BuyerUserId.HasValue) { <input type="hidden" name="BuyerUserId" value="@Model.BuyerUserId" /> }
                                                        <input type="hidden" name="Skip" value="@Model.Skip" />
                                                        <button type="submit" class="ds-btn" data-testid="action-startwork-@row.DemandId">
                                                            <i class="fas fa-play"></i> Start work
                                                        </button>
                                                    </form>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    @* Pagination moved to a single block after the if-else chain
                       so PR-12 tabs (Subcontract / Vendor WIP / Receipts /
                       Inspection Holds) get the same Previous/Next affordance
                       as Supply Demand / Buy-to-Job. *@
                }
            </div>
        </section>
    }
    @* PR-13 closes the soon-state — all 10 §21 tabs are now live. The
       !ActiveTabIsLive branch is kept as a defensive fallback for unknown
       tab keys (URL typos) but renders a neutral "not found" canvas. *@
    else if (!Model.ActiveTabIsLive)
    {
        <section class="ds-card">
            <div class="ds-card__body">
                <div style="text-align:center;padding:48px 24px;">
                    <i class="fas fa-circle-question" style="font-size:48px;color:var(--text-muted);"></i>
                    <h3 style="font-size:1.2rem;margin-top:12px;">Unknown tab</h3>
                    <p style="color:var(--text-muted);">
                        The tab key <code>@Model.ActiveTab</code> isn't recognized. Pick one from the strip above.
                    </p>
                </div>
            </div>
        </section>
    }

    @* Unified pagination for every live tab (P2.1 fix — PR-12 tabs also need
       Previous/Next so a tenant with >50 active rows can reach the older
       entries). HasPrev / HasNext / PrevSkip / NextSkip are tab-aware on the
       page model so this single block serves all 6 live tabs. *@
    @if (Model.ActiveTabIsLive && (Model.HasPrev || Model.HasNext))
    {
        <div style="display:flex;justify-content:space-between;margin-top:16px;" data-testid="pcc-pagination">
            <span>
                @if (Model.HasPrev)
                {
                    <a class="ds-btn" href="?tab=@Model.ActiveTab&SiteId=@Model.SiteId&BuyerUserId=@Model.BuyerUserId&Skip=@Model.PrevSkip" data-testid="pcc-prev">
                        <i class="fas fa-chevron-left"></i> Previous
                    </a>
                }
            </span>
            <span>
                @if (Model.HasNext)
                {
                    <a class="ds-btn" href="?tab=@Model.ActiveTab&SiteId=@Model.SiteId&BuyerUserId=@Model.BuyerUserId&Skip=@Model.NextSkip" data-testid="pcc-next">
                        Next <i class="fas fa-chevron-right"></i>
                    </a>
                }
            </span>
        </div>
    }

</div>
