@page
@model Abs.FixedAssets.Pages.Account.AccessDeniedModel
@{
    Layout = "_ModernLayout";
    ViewData["Title"] = "Access Denied";
    ViewData["HideSidebar"] = true;
    ViewData["HideDefaultPageHeader"] = true;
}

<div class="access-denied-card">
    <div class="icon-container">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
    </div>
    <h1>Access Denied</h1>
    <p>You don't have permission to access this page. Please contact your administrator if you believe this is an error.</p>
    <div>
        <a href="/" class="btn-p btn-p--primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            Go to Dashboard
        </a>
        <a asp-page="/Account/Logout" class="btn-p btn-p--secondary">Sign Out</a>
    </div>
</div>
