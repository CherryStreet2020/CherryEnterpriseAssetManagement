@page
@model Abs.FixedAssets.Pages.Account.LoginModel
@using Abs.FixedAssets.Pages.Shared.Primitives
@{
    Layout = "_ModernLayout";
    ViewData["Title"] = "Login";
    ViewData["HideSidebar"] = true;
    ViewData["HideDefaultPageHeader"] = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/modules/auth.css" asp-append-version="true" />
}

@* PR #116d.22 — Phase 3 finale: /Account/Login rebuilt on the design system.
   Luxury treatment: radial glow ambient, brand-line top accent, StatusPill env badge,
   ds-card error tone, ds-btn primary signin, ds-card demo accounts with StatusPill role badges. *@
<div class="login-page-wrapper login-page--luxury">
    <div class="login-ambient-glow" aria-hidden="true"></div>
    <div class="login-hero login-hero--luxury">
        <div class="login-brand-line" aria-hidden="true"></div>
        <div class="login-hero-header">
            <div class="login-env-pill">
                @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel
                {
                    Label = Model.ShowDemoAccounts ? "Demo Environment" : "Secure · Production",
                    Tone = Model.ShowDemoAccounts ? "warning" : "success",
                    ShowDot = true
                })
            </div>
            <div class="login-hero-logo">
                <img src="/images/abs-logo-full.png" alt="ABS Machining" data-csp-style="height: 55px; max-width: 90%; object-fit: contain;">
            </div>
            <h1 class="login-hero-title">Welcome Back</h1>
            <p class="login-hero-subtitle">Sign in to ABS Machining Enterprise Asset Management</p>
        </div>
        <div class="login-hero-form">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="ds-card login-error-card" data-tone="danger" style="margin-bottom: 20px; padding: 12px 14px; display: flex; align-items: center; gap: 10px; font-size: 13px; color: var(--text-primary);">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="flex-shrink: 0; color: var(--ds-danger, #f87171);">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    @Model.ErrorMessage
                </div>
            }

            <form method="post">
                <div class="login-form-group">
                    <label class="login-form-label">Username</label>
                    <input asp-for="Username" class="login-form-control" placeholder="Enter your username" autofocus />
                </div>
                <div class="login-form-group">
                    <label class="login-form-label">Password</label>
                    <input asp-for="Password" type="password" class="login-form-control" placeholder="Enter your password" />
                </div>
                <button type="submit" class="ds-btn login-signin-btn" data-variant="primary" style="width: 100%; justify-content: center; gap: 8px; padding: 14px 16px; font-size: 14px; font-weight: 600; margin-top: 8px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
                    </svg>
                    Sign In
                </button>
            </form>

            @* PR #100 (B-04): Demo Accounts card is rendered only when
               Login:ShowDemoAccounts is true OR the host is Development.
               Production deployments never expose the three click-to-fill
               credentials, but staging/demo tenants can opt in via config. *@
            @if (Model.ShowDemoAccounts)
            {
                <div class="login-divider">
                    <span>Click a role to autofill</span>
                </div>

                <div class="login-demo-grid">
                    <button type="button" class="ds-card login-demo-card" data-tone="brand" onclick="fillCredentials('admin', 'admin123')" style="padding: 12px 14px; display: flex; align-items: center; gap: 12px; cursor: pointer; text-align: left; width: 100%; border: none; background: var(--ds-card-bg);">
                        @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel { Label = "Admin", Tone = "brand", ShowDot = false })
                        <div style="flex: 1; display: flex; flex-direction: column; gap: 1px;">
                            <strong style="font-size: 13px; color: var(--text-primary); font-family: var(--font-mono, ui-monospace, monospace);">admin</strong>
                            <span style="font-size: 11.5px; color: var(--text-muted);">Full access to every module</span>
                        </div>
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: var(--text-muted);">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                    </button>
                    <button type="button" class="ds-card login-demo-card" data-tone="success" onclick="fillCredentials('accountant', 'acc123')" style="padding: 12px 14px; display: flex; align-items: center; gap: 12px; cursor: pointer; text-align: left; width: 100%; border: none; background: var(--ds-card-bg);">
                        @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel { Label = "Accountant", Tone = "success", ShowDot = false })
                        <div style="flex: 1; display: flex; flex-direction: column; gap: 1px;">
                            <strong style="font-size: 13px; color: var(--text-primary); font-family: var(--font-mono, ui-monospace, monospace);">accountant</strong>
                            <span style="font-size: 11.5px; color: var(--text-muted);">Create, edit, run depreciation</span>
                        </div>
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: var(--text-muted);">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                    </button>
                    <button type="button" class="ds-card login-demo-card" data-tone="neutral" onclick="fillCredentials('viewer', 'view123')" style="padding: 12px 14px; display: flex; align-items: center; gap: 12px; cursor: pointer; text-align: left; width: 100%; border: none; background: var(--ds-card-bg);">
                        @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel { Label = "Viewer", Tone = "neutral", ShowDot = false })
                        <div style="flex: 1; display: flex; flex-direction: column; gap: 1px;">
                            <strong style="font-size: 13px; color: var(--text-primary); font-family: var(--font-mono, ui-monospace, monospace);">viewer</strong>
                            <span style="font-size: 11.5px; color: var(--text-muted);">Read-only across the platform</span>
                        </div>
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: var(--text-muted);">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                    </button>
                </div>
            }
            <div class="login-footer-note">
                Enterprise Asset Management · ABS Machining
                <span style="margin: 0 6px; opacity: 0.5;">·</span>
                <span style="font-family: var(--font-mono, ui-monospace, monospace); font-size: 11px;">v3.0</span>
            </div>
        </div>
    </div>
</div>

@if (Model.ShowDemoAccounts)
{
    <script>
        function fillCredentials(username, password) {
            document.getElementById('Username').value = username;
            document.getElementById('Password').value = password;
        }
    </script>
}
