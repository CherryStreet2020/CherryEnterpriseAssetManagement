@page
@model Abs.FixedAssets.Pages.Account.LoginModel
@{
    Layout = "_ModernLayout";
    ViewData["Title"] = "Login";
    ViewData["HideSidebar"] = true;
    ViewData["HideDefaultPageHeader"] = true;
}

@section Styles {
    <link rel="stylesheet" href="~/css/modules/auth.css" asp-append-version="true" />
}

<div class="login-page-wrapper">
    <div class="login-hero">
        <div class="login-hero-header">
            <div class="login-hero-logo">
                <img src="/images/abs-logo-full.png" alt="ABS Machining" style="height: 55px; max-width: 90%; object-fit: contain;">
            </div>
            <h1 class="login-hero-title">Welcome Back</h1>
            <p class="login-hero-subtitle">Sign in to ABS Machining Enterprise Asset Management</p>
        </div>
        <div class="login-hero-form">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="login-error">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    @Model.ErrorMessage
                </div>
            }

            <form method="post">
                <div class="login-form-group">
                    <label class="login-form-label">Username</label>
                    <input asp-for="Username" class="login-form-control" placeholder="Enter your username" autofocus />
                </div>
                <div class="login-form-group">
                    <label class="login-form-label">Password</label>
                    <input asp-for="Password" type="password" class="login-form-control" placeholder="Enter your password" />
                </div>
                <button type="submit" class="login-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
                    </svg>
                    Sign In
                </button>
            </form>

            <div class="login-divider">
                <span>Demo Accounts</span>
            </div>

            <div class="demo-accounts-grid">
                <button type="button" class="demo-account-btn" onclick="fillCredentials('admin', 'admin123')">
                    <span class="demo-badge admin">Admin</span>
                    <div class="demo-info">
                        <strong>admin</strong>
                        <span>Full access to all features</span>
                    </div>
                    <svg class="demo-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                </button>
                <button type="button" class="demo-account-btn" onclick="fillCredentials('accountant', 'acc123')">
                    <span class="demo-badge accountant">Accountant</span>
                    <div class="demo-info">
                        <strong>accountant</strong>
                        <span>Create, edit, run depreciation</span>
                    </div>
                    <svg class="demo-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                </button>
                <button type="button" class="demo-account-btn" onclick="fillCredentials('viewer', 'view123')">
                    <span class="demo-badge viewer">Viewer</span>
                    <div class="demo-info">
                        <strong>viewer</strong>
                        <span>Read-only access</span>
                    </div>
                    <svg class="demo-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function fillCredentials(username, password) {
        document.getElementById('Username').value = username;
        document.getElementById('Password').value = password;
    }
</script>
