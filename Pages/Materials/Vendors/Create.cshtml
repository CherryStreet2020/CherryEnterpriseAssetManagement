@page
@model Abs.FixedAssets.Pages.Materials.Vendors.CreateModel
@{
    ViewData["Title"] = "New Vendor";
    ViewData["TabTitle"] = "New Vendor";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";

    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = "New Vendor",
        ["Subtitle"] = "Create a new vendor record",
        ["TypeLabel"] = "Materials & Purchasing",
        ["ShowBackLink"] = true,
        ["BackLinkFallback"] = "/Materials/Vendors",
        ["BackLinkLabel"] = "Vendors"
    };
}

@await Html.PartialAsync("_ScreenHeader", headerVd)

@if (!string.IsNullOrEmpty(TempData["Error"]?.ToString()))
{
    <div class="alert alert-danger" style="margin-bottom:1rem;">@TempData["Error"]</div>
}

<form method="post">
    <div class="pe-card">
        <div class="pe-card__header"><span class="pe-card__title"><span class="accent-dot accent-dot--blue"></span> Vendor Information</span></div>
        <div class="pe-card__body">
            <div class="form-row-p">
                <div class="form-group-p">
                    <label class="form-label-p">Code <span class="required">*</span></label>
                    <input type="text" name="code" class="form-input-p" required maxlength="20" value="@Model.NextCode" />
                </div>
                <div class="form-group-p">
                    <label class="form-label-p">Name <span class="required">*</span></label>
                    <input type="text" name="name" class="form-input-p" required maxlength="100" />
                </div>
            </div>
            <div class="form-row-p">
                <div class="form-group-p">
                    <label class="form-label-p">Vendor Type</label>
                    <select name="vendorType" class="form-input-p" asp-items="Model.VendorTypeOptions" data-cherry-select data-placeholder="Search vendor types..."></select>
                </div>
                <div class="form-group-p">
                    <label class="form-label-p">Payment Terms</label>
                    <select name="paymentTerms" class="form-input-p" asp-items="Model.PaymentTermsOptions" data-cherry-select data-placeholder="Search payment terms..."></select>
                </div>
            </div>
            <div class="form-row-p">
                <div class="form-group-p">
                    <label class="form-label-p">Tax ID / EIN</label>
                    <input type="text" name="taxId" class="form-input-p" maxlength="50" />
                </div>
                <div class="form-group-p">
                    <label class="form-label-p">Credit Limit</label>
                    <input type="number" name="creditLimit" class="form-input-p" step="0.01" min="0" />
                </div>
            </div>
            <div class="form-group-p" style="padding-top:0.5rem;">
                <label class="form-check-label-p" style="display:flex; align-items:center; gap:0.5rem; cursor:pointer;">
                    <input type="checkbox" name="is1099Vendor" value="true" class="form-check-input" />
                    1099 Vendor
                </label>
            </div>
        </div>
    </div>

    <div class="pe-card">
        <div class="pe-card__header"><span class="pe-card__title"><span class="accent-dot accent-dot--amber"></span> Contact Information</span></div>
        <div class="pe-card__body">
            <div class="form-row-p">
                <div class="form-group-p">
                    <label class="form-label-p">Contact Name</label>
                    <input type="text" name="contactName" class="form-input-p" maxlength="100" />
                </div>
                <div class="form-group-p">
                    <label class="form-label-p">Phone</label>
                    <input type="text" name="phone" class="form-input-p" maxlength="50" />
                </div>
            </div>
            <div class="form-row-p">
                <div class="form-group-p">
                    <label class="form-label-p">Email</label>
                    <input type="email" name="email" class="form-input-p" maxlength="100" />
                </div>
                <div class="form-group-p">
                    <label class="form-label-p">Website</label>
                    <input type="text" name="website" class="form-input-p" maxlength="200" />
                </div>
            </div>
        </div>
    </div>

    <div class="pe-card">
        <div class="pe-card__header"><span class="pe-card__title"><span class="accent-dot accent-dot--green"></span> Address</span></div>
        <div class="pe-card__body">
            <div class="form-group-p">
                <label class="form-label-p">Street Address</label>
                <input type="text" name="address" class="form-input-p" maxlength="200" />
            </div>
            <div class="form-row-p">
                <div class="form-group-p">
                    <label class="form-label-p">City</label>
                    <input type="text" name="city" class="form-input-p" maxlength="50" />
                </div>
                <div class="form-group-p">
                    <label class="form-label-p">State / Province</label>
                    <input type="text" name="state" class="form-input-p" maxlength="50" />
                </div>
            </div>
            <div class="form-row-p">
                <div class="form-group-p">
                    <label class="form-label-p">Postal Code</label>
                    <input type="text" name="postalCode" class="form-input-p" maxlength="20" />
                </div>
                <div class="form-group-p">
                    <label class="form-label-p">Country</label>
                    <input type="text" name="country" class="form-input-p" maxlength="50" value="United States" />
                </div>
            </div>
        </div>
    </div>

    <div class="pe-card">
        <div class="pe-card__header"><span class="pe-card__title"><span class="accent-dot accent-dot--red"></span> Notes</span></div>
        <div class="pe-card__body">
            <div class="form-group-p">
                <textarea name="notes" class="form-input-p" rows="3" maxlength="500"></textarea>
            </div>
        </div>
    </div>

    <div class="form-actions-sticky">
        <a href="/Materials/Vendors" class="btn-p btn-p--secondary">Cancel</a>
        <button type="submit" class="btn-p btn-p--primary">
            <i class="fas fa-check"></i> Create Vendor
        </button>
    </div>
</form>
