@model Abs.FixedAssets.Pages.Materials.Vendors.EditModel
@{
    var v = Model.Vendor;
    var canEdit = User.IsInRole("Admin") || User.IsInRole("Accountant");
}
<div class="hero-tags">
    @if (v.IsPreferred) {
        <span class="hero-tag success">PREFERRED</span>
    }
    @if (v.Is1099Vendor) {
        <span class="hero-tag info">1099</span>
    }
</div>
<div class="hero-btns">
    <a href="/Materials/Vendors" class="hero-btn hero-btn-ghost">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Vendors
    </a>
    @if (canEdit && !Model.IsEditMode) {
        <a href="?mode=edit&tab=@Model.ActiveTab" class="hero-btn hero-btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
            Edit
        </a>
    }
    @if (canEdit) {
        <form method="post" asp-page-handler="Duplicate" asp-route-id="@v.Id" style="display:inline;">
            <button type="submit" class="hero-btn hero-btn-ghost">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
                Duplicate
            </button>
        </form>
        <form method="post" asp-page-handler="ToggleStatus" asp-route-id="@v.Id" style="display:inline;">
            <button type="submit" class="hero-btn hero-btn-danger">
                @(v.IsActive ? "Deactivate" : "Activate")
            </button>
        </form>
    }
</div>
