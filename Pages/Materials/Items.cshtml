@page
@model Abs.FixedAssets.Pages.Materials.ItemsModel
@using Abs.FixedAssets.Models
@using Abs.FixedAssets.Models.Revisions
@using Abs.FixedAssets.Helpers
@using Abs.FixedAssets.Pages.Shared.Primitives
@{
    ViewData["Title"] = "Item Master";
    ViewData["TabTitle"] = "Items";
    Layout = "_ModernLayout";
    ViewData["HasScreenHeader"] = true;
    
    var totalItems = Model.TotalCount;
    var activeItems = Model.ActiveCount;
    var withRevisions = Model.WithRevisionsCount;
    var statusText = $"{activeItems} Active";
    var statusTone = activeItems > 0 ? "success" : "neutral";
    
    // PR #116d.20 — drop KpisPartial; render KPIs horizontally in body for better layout.
    var inactiveItems = totalItems - activeItems;

    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = "Item Master",
        ["Subtitle"] = "Browse and manage parts, materials, and cross-references",
        ["TypeLabel"] = "Materials Management",
        ["StatusText"] = statusText,
        ["StatusTone"] = statusTone,
        ["ContextPartial"] = "/Pages/Materials/_ItemsContext.cshtml",
        ["ActionsPartial"] = "/Pages/Materials/_ItemsActions.cshtml"
    };
}

@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="ds-card" data-tone="success" style="margin-top: 14px; padding: 12px 16px; color: var(--text-primary);">@Model.SuccessMessage</div>
}

@* PR #116d.20 — 4 KPITiles with clickable filter shortcuts via Href. Inactive
   tile tone-flips when there ARE inactive items so the count is visually flagged. *@
<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-top: 20px;">
    @await Html.PartialAsync("Primitives/_KPITile", new KpiTileModel
    {
        Label = "Total Items",
        Value = totalItems.ToString("N0"),
        DeltaText = Model.HasFilters ? "filtered view" : "click to clear filters",
        DeltaDirection = "flat",
        SparkTone = "info",
        Href = "/Materials/Items"
    })
    @await Html.PartialAsync("Primitives/_KPITile", new KpiTileModel
    {
        Label = "Active Items",
        Value = activeItems.ToString("N0"),
        DeltaText = Model.StatusFilter == "Active" ? "filter applied" : "click to filter active",
        DeltaDirection = "flat",
        SparkTone = "success",
        Href = "/Materials/Items?statusFilter=Active"
    })
    @await Html.PartialAsync("Primitives/_KPITile", new KpiTileModel
    {
        Label = "Inactive Items",
        Value = inactiveItems.ToString("N0"),
        DeltaText = inactiveItems > 0 ? "▼ click to review" : "▲ no inactive items",
        DeltaDirection = inactiveItems > 0 ? "down" : "up",
        SparkTone = inactiveItems > 0 ? "warning" : "muted",
        Href = inactiveItems > 0 ? "/Materials/Items?statusFilter=Inactive" : null
    })
    @await Html.PartialAsync("Primitives/_KPITile", new KpiTileModel
    {
        Label = "With Revisions",
        Value = withRevisions.ToString("N0"),
        DeltaText = totalItems > 0 ? $"{(withRevisions * 100.0 / totalItems).ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)}% revision-controlled" : "no items yet",
        DeltaDirection = "flat",
        SparkTone = "brand"
    })
</div>

@* PR #116d.20 — Item catalog wrapped in DataCard with brand tone. Header
   subtitle adapts to filtered vs unfiltered view. *@
<div class="ds-card" data-tone="brand" style="margin-top: 24px; padding: 0;">
    <div style="padding: 18px 22px; border-bottom: 1px solid var(--border);">
        <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500;">Materials Management</div>
        <div style="font-size: 17px; font-weight: 700; color: var(--text-primary); margin-top: 4px;">@(Model.HasFilters ? "Filtered Items" : "All Items")</div>
        <div style="color: var(--text-muted); font-size: 13px; margin-top: 4px;">
            @(Model.HasFilters ? "Results matching your filter criteria" : "Browse and manage all items in the master file")
        </div>
    </div>
    
    @* PR #116d.20.1 — Single-row toolbar: server-side search + 3 selects + Filter button on ONE clean row.
       Kills the duplicate EnhancedGrid "Search all columns..." bar via `searchable: false` in the init script below. *@
    <form method="get" class="grid-filter-toolbar grid-filter-toolbar--solo">
        <div class="grid-filter-search">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input type="text" name="search" value="@Model.SearchQuery" placeholder="Search Part #, Description, MPN, VPN..." />
        </div>
        <div class="grid-filter-chips">
            <select name="statusFilter" class="grid-filter-select" asp-items="Model.StatusFilterOptions"></select>
            <select name="typeFilter" class="grid-filter-select" asp-items="Model.TypeFilterOptions"></select>
            <select name="vendorId" class="grid-filter-select" data-cherry-select data-placeholder="Search vendors...">
                <option value="">All Vendors</option>
                @foreach (var vendor in Model.Vendors)
                {
                    <option value="@vendor.Id" selected="@(Model.VendorIdFilter == vendor.Id)">@vendor.Name</option>
                }
            </select>
            <button type="submit" class="ds-btn ds-btn--primary ds-btn--sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
                </svg>
                Filter
            </button>
            @if (Model.HasFilters)
            {
                <a href="/Materials/Items" class="ds-btn ds-btn--ghost ds-btn--sm">Clear</a>
            }
        </div>
    </form>
    
    <div data-csp-style="overflow-x: auto;">
        @{ var returnUrl = $"{HttpContext.Request.Path}{HttpContext.Request.QueryString}"; }
        <table class="data-table premium-table" id="itemsGrid" data-enhanced-grid="true" data-row-click="true">
            <thead>
                <tr>
                    <th data-csp-style="width: 50px;" data-col="Image" data-filter="none" data-export="false"></th>
                    <th data-csp-style="width: 140px;" data-col="Part Number" data-filter="text">Part Number</th>
                    <th data-csp-style="min-width: 200px;" data-col="Description" data-filter="text">Description</th>
                    <th data-csp-style="width: 80px;" data-col="Type" data-filter="select" data-filter-options="Part|Service|Asset|Kit">Type</th>
                    <th data-csp-style="width: 60px;" data-col="UoM" data-filter="text">UoM</th>
                    <th data-csp-style="width: 80px;" data-col="Current Rev" data-filter="text">Current Rev</th>
                    <th data-csp-style="width: 70px; text-align: right;" data-col="Lead Time" data-filter="number">Lead Time</th>
                    <th data-csp-style="width: 90px; text-align: right;" data-col="Last Price" data-filter="number">Last Price</th>
                    <th data-csp-style="width: 100px;" data-col="Stock Policy" data-filter="select" data-filter-options="Stock|Nonstock|Critical">Stock Policy</th>
                    <th data-csp-style="width: 80px; text-align: center;" data-col="Buyability" data-filter="none">Buyability</th>
                    <th data-csp-style="width: 60px; text-align: center;" data-col="MPNs" data-filter="none">MPNs</th>
                    <th data-csp-style="width: 60px; text-align: center;" data-col="VPNs" data-filter="none">VPNs</th>
                    <th data-csp-style="min-width: 140px;" data-col="Preferred Vendor" data-filter="text">Preferred Vendor</th>
                    <th data-csp-style="width: 60px; text-align: center;" data-col="Catalog" data-filter="none" data-export="false">Catalog</th>
                    <th data-csp-style="width: 90px;" class="no-sort" data-col="Status" data-filter="select" data-filter-options="Active|Inactive">Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    var imageUrl = Model.GetPreferredImageUrl(item.Id);
                    var catalogUrl = Model.GetPreferredCatalogUrl(item.Id);
                    var buyability = Model.GetBuyabilityScore(item.Id);
                    var effective = Model.GetEffectiveValues(item.Id);
                    <tr data-row-id="@item.Id" data-row-href="@Url.Page("/Materials/ItemEdit", new { id = item.Id, returnUrl = returnUrl })">
                        <td data-csp-style="text-align: center;" data-no-row-nav>
                            @if (!string.IsNullOrEmpty(imageUrl))
                            {
                                <img src="@imageUrl" alt="@item.PartNumber" data-csp-style="width: 36px; height: 36px; object-fit: cover; border-radius: 6px; border: 1px solid var(--border-primary, #e2e8f0);" loading="lazy" />
                            }
                            else
                            {
                                <div class="bg-surface-alt" data-csp-style="width: 36px; height: 36px; border-radius: 6px; display: inline-flex; align-items: center; justify-content: center; border: 1px solid var(--border-primary, #e2e8f0);">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#94a3b8">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                                    </svg>
                                </div>
                            }
                        </td>
                        <td><strong class="text-primary">@item.PartNumber</strong></td>
                        <td data-csp-style="max-width: 280px;">
                            <div data-csp-style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-weight: 500;" title="@item.Description">
                                @item.Description
                            </div>
                        </td>
                        <td data-csp-style="color: var(--text-secondary);">@item.Type</td>
                        <td>@item.StockUOM</td>
                        <td>
                            @if (item.CurrentReleasedRevision != null)
                            {
                                @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel { Label = item.CurrentReleasedRevision.RevisionCode, Tone = "success", ShowDot = false })
                            }
                            else
                            {
                                <span style="color: var(--text-muted);">—</span>
                            }
                        </td>
                        <td data-csp-style="text-align: right; font-variant-numeric: tabular-nums;">
                            @if (effective?.LeadTimeDays > 0)
                            {
                                <span title="Source: @effective.LeadTimeSource">@effective.LeadTimeDays d</span>
                                @if (effective.LeadTimeSource == "Preferred Vendor")
                                {
                                    <span class="text-blue" data-csp-style="font-size: 8px; vertical-align: super;" title="From preferred vendor">V</span>
                                }
                            }
                            else if (item.LeadTimeDays > 0)
                            {
                                <span>@item.LeadTimeDays d</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td data-csp-style="text-align: right; font-variant-numeric: tabular-nums;">
                            @if (effective?.LastPrice.HasValue == true)
                            {
                                <span title="Source: @effective.LastPriceSource">$@effective.LastPrice.Value.ToString("N2")</span>
                                @if (effective.LastPriceSource == "Preferred Vendor")
                                {
                                    <span class="text-blue" data-csp-style="font-size: 8px; vertical-align: super;" title="From preferred vendor">V</span>
                                }
                            }
                            else if (item.LastPrice.HasValue)
                            {
                                <span>$@item.LastPrice.Value.ToString("N2")</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            @{
                                var policyTone = item.StockPolicy switch
                                {
                                    StockPolicy.Stock => "success",
                                    StockPolicy.CriticalSpare => "warning",
                                    StockPolicy.Nonstock => "neutral",
                                    _ => "neutral"
                                };
                                var policyLabel = item.StockPolicy switch
                                {
                                    StockPolicy.CriticalSpare => "Critical",
                                    _ => item.StockPolicy.ToString()
                                };
                            }
                            @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel { Label = policyLabel, Tone = policyTone, ShowDot = true })
                        </td>
                        <td data-csp-style="text-align: center;">
                            @if (buyability != null)
                            {
                                <span class="badge @buyability.TierBadgeClass" data-csp-style="font-size: 9px; padding: 3px 6px;" title="@buyability.Score pts - @string.Join(", ", buyability.MissingFactors.Take(3).Select(f => f.Name))">
                                    @buyability.Tier.Substring(0, 1)@buyability.Score
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td data-csp-style="text-align: center;">@Model.GetMpnCount(item.Id)</td>
                        <td data-csp-style="text-align: center;">@Model.GetVpnCount(item.Id)</td>
                        <td data-csp-style="color: var(--text-secondary);">
                            @if (!string.IsNullOrEmpty(Model.GetPreferredVendorName(item.Id)))
                            {
                                <span>@Model.GetPreferredVendorName(item.Id)</span>
                            }
                            else if (item.PrimaryVendor != null)
                            {
                                <span>@item.PrimaryVendor.Name</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td data-csp-style="text-align: center;" onclick="event.stopPropagation();">
                            @if (!string.IsNullOrEmpty(catalogUrl))
                            {
                                <a href="@catalogUrl" target="_blank" rel="noopener noreferrer" class="ds-btn ds-btn--ghost ds-btn--sm" data-csp-style="padding: 4px 8px;" title="Open vendor catalog">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                    </svg>
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel
                            {
                                Label = item.IsActive ? "Active" : "Inactive",
                                Tone = item.IsActive ? "success" : "neutral",
                                ShowDot = true
                            })
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    @if (!Model.Items.Any())
    {
        @* PR #116d.20 — EmptyState v2 with smart variant based on filter context. *@
        <div style="padding: 24px;">
            @await Html.PartialAsync("Primitives/_EmptyStateV2", new EmptyStateModel
            {
                Icon = Model.HasFilters ? "search" : "folder",
                Tone = "info",
                Title = Model.HasFilters ? "No items match your filters" : "No items in the catalog yet",
                Body = Model.HasFilters
                    ? "Try widening the search criteria or clearing filters. Items might match if you remove vendor / status / type constraints."
                    : "Get started by adding your first part, material, or asset to the master file.",
                CtaLabel = Model.HasFilters ? "Reset Filters" : "Add First Item",
                CtaHref = Model.HasFilters ? "/Materials/Items" : "/Materials/ItemEdit",
                SecondaryLabel = "Back to Dashboard",
                SecondaryHref = "/"
            })
        </div>
    }
    
    @if (Model.Items.Any())
    {
        <div class="grid-pagination">
            <div class="grid-pagination-info">
                Showing @Model.Items.Count of @Model.TotalCount items
                @if (Model.CurrentPage > 1 || Model.HasMorePages)
                {
                    <text> (Page @Model.CurrentPage)</text>
                }
            </div>
            <div class="grid-pagination-controls">
                @if (Model.CurrentPage > 1)
                {
                    <a href="@Model.GetPageUrl(Model.CurrentPage - 1)" class="ds-btn ds-btn--ghost ds-btn--sm">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                        </svg>
                        Previous
                    </a>
                }
                @if (Model.HasMorePages)
                {
                    <a href="@Model.GetPageUrl(Model.CurrentPage + 1)" class="ds-btn ds-btn--ghost ds-btn--sm">
                        Next
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </a>
                }
            </div>
        </div>
    }
</div>

@* PR #116d.20 — Tip restyled as small info DataCard. *@
<div class="ds-card" data-tone="info" style="margin-top: 18px; padding: 14px 18px; display: flex; align-items: center; gap: 12px;">
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: var(--ds-info, #60a5fa); flex-shrink: 0;">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <div style="color: var(--text-secondary); font-size: 13px; line-height: 1.5;">
        <strong style="color: var(--text-primary);">Tip:</strong> Click any item to view its full details — manufacturer parts, vendor parts, and revision history. Use filters above to narrow the catalog quickly.
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function() {
    // PR #116d.20.1 — searchable:false kills the duplicate "Search all columns..." bar.
    // The server-side form toolbar above already owns search + Status/Type/Vendor filters.
    initEnhancedGrid('itemsGrid', {
        searchable: false,
        sortable: true,
        exportable: true,
        columnVisibility: true,
        clickableRows: true
    });
});
</script>
}
