@page
@model Abs.FixedAssets.Pages.Materials.ItemsModel
@using Abs.FixedAssets.Models
@using Abs.FixedAssets.Models.Revisions
@using Abs.FixedAssets.Helpers
@{
    ViewData["Title"] = "Item Master";
    ViewData["TabTitle"] = "Items";
    Layout = "_ModernLayout";
    ViewData["HasScreenHeader"] = true;
    
    var totalItems = Model.TotalCount;
    var activeItems = Model.ActiveCount;
    var withRevisions = Model.WithRevisionsCount;
    var statusText = $"{activeItems} Active";
    var statusTone = activeItems > 0 ? "success" : "neutral";
    
    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = "Item Master",
        ["Subtitle"] = "Browse and manage parts, materials, and cross-references",
        ["TypeLabel"] = "Materials Management",
        ["StatusText"] = statusText,
        ["StatusTone"] = statusTone,
        ["ContextPartial"] = "/Pages/Materials/_ItemsContext.cshtml",
        ["KpisPartial"] = "/Pages/Materials/_ItemsKpis.cshtml",
        ["ActionsPartial"] = "/Pages/Materials/_ItemsActions.cshtml"
    };
}

@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success pe-alert pe-alert--success">@Model.SuccessMessage</div>
}

<div class="quick-stats-row-4">
    <a href="/Materials/Items" class="quick-stat-card clickable @(!Model.HasFilters ? "stat-active" : "")">
        <div class="quick-stat-icon primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
        </div>
        <div class="quick-stat-content">
            <div class="quick-stat-value primary">@totalItems.ToString("N0")</div>
            <div class="quick-stat-label">Total Items</div>
        </div>
    </a>
    <a href="/Materials/Items?statusFilter=Active" class="quick-stat-card clickable @(Model.StatusFilter == "Active" ? "stat-active" : "")">
        <div class="quick-stat-icon success">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </div>
        <div class="quick-stat-content">
            <div class="quick-stat-value success">@activeItems.ToString("N0")</div>
            <div class="quick-stat-label">Active Items</div>
        </div>
    </a>
    <a href="/Materials/Items?statusFilter=Inactive" class="quick-stat-card clickable @(Model.StatusFilter == "Inactive" ? "stat-active" : "")">
        <div class="quick-stat-icon warning">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
            </svg>
        </div>
        <div class="quick-stat-content">
            <div class="quick-stat-value warning">@((totalItems - activeItems).ToString("N0"))</div>
            <div class="quick-stat-label">Inactive Items</div>
        </div>
    </a>
    <div class="quick-stat-card">
        <div class="quick-stat-icon info">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
        </div>
        <div class="quick-stat-content">
            <div class="quick-stat-value info">@withRevisions.ToString("N0")</div>
            <div class="quick-stat-label">With Revisions</div>
        </div>
    </div>
</div>

<div class="section-card pe-card">
    <div class="section-card-header pe-card__header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
            </svg>
            @(Model.HasFilters ? "Filtered Items" : "All Items")
        </h3>
        <p style="color: var(--text-muted); font-size: 13px; margin: 0;">
            @(Model.HasFilters ? "Results matching your filter criteria" : "Browse and manage all items in the master file")
        </p>
    </div>
    
    <form method="get" class="grid-filter-toolbar">
        <div class="grid-filter-left">
            <div class="grid-filter-search">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <input type="text" name="search" value="@Model.SearchQuery" placeholder="Search Part #, Description, MPN, VPN..." />
            </div>
        </div>
        <div class="grid-filter-right">
            <select name="statusFilter" class="grid-filter-select" asp-items="Model.StatusFilterOptions"></select>
            <select name="typeFilter" class="grid-filter-select" asp-items="Model.TypeFilterOptions"></select>
            <select name="vendorId" class="grid-filter-select" data-cherry-select data-placeholder="Search vendors...">
                <option value="">All Vendors</option>
                @foreach (var vendor in Model.Vendors)
                {
                    <option value="@vendor.Id" selected="@(Model.VendorIdFilter == vendor.Id)">@vendor.Name</option>
                }
            </select>
            <button type="submit" class="btn-p btn-p--primary btn-p--sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
                </svg>
                Filter
            </button>
            @if (Model.HasFilters)
            {
                <a href="/Materials/Items" class="btn-p btn-p--ghost btn-p--sm">Clear</a>
            }
        </div>
    </form>
    
    <div style="overflow-x: auto;">
        @{ var returnUrl = $"{HttpContext.Request.Path}{HttpContext.Request.QueryString}"; }
        <table class="data-table premium-table" id="itemsGrid" data-enhanced-grid="true" data-row-click="true">
            <thead>
                <tr>
                    <th style="width: 50px;" data-col="Image" data-filter="none" data-export="false"></th>
                    <th style="width: 140px;" data-col="Part Number" data-filter="text">Part Number</th>
                    <th style="min-width: 200px;" data-col="Description" data-filter="text">Description</th>
                    <th style="width: 80px;" data-col="Type" data-filter="select" data-filter-options="Part|Service|Asset|Kit">Type</th>
                    <th style="width: 60px;" data-col="UoM" data-filter="text">UoM</th>
                    <th style="width: 80px;" data-col="Current Rev" data-filter="text">Current Rev</th>
                    <th style="width: 70px; text-align: right;" data-col="Lead Time" data-filter="number">Lead Time</th>
                    <th style="width: 90px; text-align: right;" data-col="Last Price" data-filter="number">Last Price</th>
                    <th style="width: 100px;" data-col="Stock Policy" data-filter="select" data-filter-options="Stock|Nonstock|Critical">Stock Policy</th>
                    <th style="width: 80px; text-align: center;" data-col="Buyability" data-filter="none">Buyability</th>
                    <th style="width: 60px; text-align: center;" data-col="MPNs" data-filter="none">MPNs</th>
                    <th style="width: 60px; text-align: center;" data-col="VPNs" data-filter="none">VPNs</th>
                    <th style="min-width: 140px;" data-col="Preferred Vendor" data-filter="text">Preferred Vendor</th>
                    <th style="width: 60px; text-align: center;" data-col="Catalog" data-filter="none" data-export="false">Catalog</th>
                    <th style="width: 90px;" class="no-sort" data-col="Status" data-filter="select" data-filter-options="Active|Inactive">Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    var imageUrl = Model.GetPreferredImageUrl(item.Id);
                    var catalogUrl = Model.GetPreferredCatalogUrl(item.Id);
                    var buyability = Model.GetBuyabilityScore(item.Id);
                    var effective = Model.GetEffectiveValues(item.Id);
                    <tr data-row-id="@item.Id" data-row-href="@Url.Page("/Materials/ItemEdit", new { id = item.Id, returnUrl = returnUrl })">
                        <td style="text-align: center;" data-no-row-nav>
                            @if (!string.IsNullOrEmpty(imageUrl))
                            {
                                <img src="@imageUrl" alt="@item.PartNumber" style="width: 36px; height: 36px; object-fit: cover; border-radius: 6px; border: 1px solid var(--border-primary, #e2e8f0);" loading="lazy" />
                            }
                            else
                            {
                                <div class="bg-surface-alt" style="width: 36px; height: 36px; border-radius: 6px; display: inline-flex; align-items: center; justify-content: center; border: 1px solid var(--border-primary, #e2e8f0);">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#94a3b8">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                                    </svg>
                                </div>
                            }
                        </td>
                        <td><strong class="text-primary">@item.PartNumber</strong></td>
                        <td style="max-width: 280px;">
                            <div style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-weight: 500;" title="@item.Description">
                                @item.Description
                            </div>
                        </td>
                        <td style="color: var(--text-secondary);">@item.Type</td>
                        <td>@item.StockUOM</td>
                        <td>
                            @if (item.CurrentReleasedRevision != null)
                            {
                                <span class="badge badge-success">@item.CurrentReleasedRevision.RevisionCode</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td style="text-align: right; font-variant-numeric: tabular-nums;">
                            @if (effective?.LeadTimeDays > 0)
                            {
                                <span title="Source: @effective.LeadTimeSource">@effective.LeadTimeDays d</span>
                                @if (effective.LeadTimeSource == "Preferred Vendor")
                                {
                                    <span class="text-blue" style="font-size: 8px; vertical-align: super;" title="From preferred vendor">V</span>
                                }
                            }
                            else if (item.LeadTimeDays > 0)
                            {
                                <span>@item.LeadTimeDays d</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td style="text-align: right; font-variant-numeric: tabular-nums;">
                            @if (effective?.LastPrice.HasValue == true)
                            {
                                <span title="Source: @effective.LastPriceSource">$@effective.LastPrice.Value.ToString("N2")</span>
                                @if (effective.LastPriceSource == "Preferred Vendor")
                                {
                                    <span class="text-blue" style="font-size: 8px; vertical-align: super;" title="From preferred vendor">V</span>
                                }
                            }
                            else if (item.LastPrice.HasValue)
                            {
                                <span>$@item.LastPrice.Value.ToString("N2")</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            @{
                                var policyClass = item.StockPolicy switch
                                {
                                    StockPolicy.Stock => "badge-success",
                                    StockPolicy.CriticalSpare => "badge-warning",
                                    StockPolicy.Nonstock => "badge-secondary",
                                    _ => "badge-secondary"
                                };
                                var policyLabel = item.StockPolicy switch
                                {
                                    StockPolicy.CriticalSpare => "Critical",
                                    _ => item.StockPolicy.ToString()
                                };
                            }
                            <span class="badge @policyClass" style="font-size: 10px;">@policyLabel</span>
                        </td>
                        <td style="text-align: center;">
                            @if (buyability != null)
                            {
                                <span class="badge @buyability.TierBadgeClass" style="font-size: 9px; padding: 3px 6px;" title="@buyability.Score pts - @string.Join(", ", buyability.MissingFactors.Take(3).Select(f => f.Name))">
                                    @buyability.Tier.Substring(0, 1)@buyability.Score
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td style="text-align: center;">@Model.GetMpnCount(item.Id)</td>
                        <td style="text-align: center;">@Model.GetVpnCount(item.Id)</td>
                        <td style="color: var(--text-secondary);">
                            @if (!string.IsNullOrEmpty(Model.GetPreferredVendorName(item.Id)))
                            {
                                <span>@Model.GetPreferredVendorName(item.Id)</span>
                            }
                            else if (item.PrimaryVendor != null)
                            {
                                <span>@item.PrimaryVendor.Name</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td style="text-align: center;" onclick="event.stopPropagation();">
                            @if (!string.IsNullOrEmpty(catalogUrl))
                            {
                                <a href="@catalogUrl" target="_blank" rel="noopener noreferrer" class="btn-p btn-p--ghost btn-p--sm" style="padding: 4px 8px;" title="Open vendor catalog">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                    </svg>
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge badge-success">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-secondary">Inactive</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    @if (!Model.Items.Any())
    {
        <div class="pe-empty" style="padding:1.5rem;">
            <i class="fas fa-cube pe-empty__icon" style="font-size:1.2rem;"></i>
            <div class="pe-empty__text">
                <h3>No items found</h3>
                <p>
                    @if (Model.HasFilters)
                    {
                        <text>No items match your current filters. Try adjusting your search criteria.</text>
                    }
                    else
                    {
                        <text>Get started by adding your first item to the master file.</text>
                    }
                </p>
                @if (Model.HasFilters)
                {
                    <a href="/Materials/Items" class="btn-premium btn-premium-secondary">Reset Filters</a>
                }
                else
                {
                    <a href="/Materials/ItemEdit" class="btn-premium btn-premium-primary">Add First Item</a>
                }
            </div>
        </div>
    }
    
    @if (Model.Items.Any())
    {
        <div class="grid-pagination">
            <div class="grid-pagination-info">
                Showing @Model.Items.Count of @Model.TotalCount items
                @if (Model.CurrentPage > 1 || Model.HasMorePages)
                {
                    <text> (Page @Model.CurrentPage)</text>
                }
            </div>
            <div class="grid-pagination-controls">
                @if (Model.CurrentPage > 1)
                {
                    <a href="@Model.GetPageUrl(Model.CurrentPage - 1)" class="btn-p btn-p--ghost btn-p--sm">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                        </svg>
                        Previous
                    </a>
                }
                @if (Model.HasMorePages)
                {
                    <a href="@Model.GetPageUrl(Model.CurrentPage + 1)" class="btn-p btn-p--ghost btn-p--sm">
                        Next
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </a>
                }
            </div>
        </div>
    }
</div>

<div class="section-card pe-card">
    <div class="section-card-body pe-card__body" style="padding: 16px 24px;">
        <div style="display: flex; align-items: center; gap: 12px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="var(--primary)">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
                <strong style="color: var(--primary);">Tip:</strong>
                <span style="color: var(--text-secondary);">Click on any item to view its full details including manufacturer parts, vendor parts, and revision history. Use filters to quickly find specific items.</span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function() {
    initEnhancedGrid('itemsGrid', {
        searchable: true,
        sortable: true,
        exportable: true,
        columnVisibility: true,
        clickableRows: true
    });
});
</script>
}
