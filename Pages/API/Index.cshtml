@page
@model Abs.FixedAssets.Pages.API.IndexModel
@{
    ViewData["Title"] = "API Integration";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
    var totalKeys = Model.ApiKeys.Count;
    var activeKeys = Model.ApiKeys.Count(k => k.IsActive);

    var headerVd = new ViewDataDictionary(ViewData) {
        { "TypeLabel", "Integration" },
        { "HeaderTitle", "API Integration" },
        { "Subtitle", "Connect external systems to CherryAI Fixed Assets via REST API" },
        { "StatusText", $"{activeKeys} Active" },
        { "StatusTone", "active" },
        { "ContextPartial", "API/_ApiIndexContext" },
        { "KpisPartial", "API/_ApiIndexKpis" },
        { "ActionsPartial", "API/_ApiIndexActions" },
        { "PageModel", Model }
    };
}

@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@if (!string.IsNullOrEmpty(Model.NewKeyValue))
{
    <div class="alert alert-success" data-csp-style="margin-bottom: 1.5rem;">
        <strong>New API Key Created!</strong> Copy it now - you won't see it again:<br/>
        <code class="bg-green-soft" data-csp-style="font-size: 1.1rem; padding: 0.5rem; display: inline-block; margin-top: 0.5rem;">@Model.NewKeyValue</code>
    </div>
}

<div class="section-card" data-csp-style="margin-bottom: 24px;">
    <div class="section-card-header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
            </svg>
            API Keys
        </h3>
        <form method="post" asp-page-handler="CreateKey" data-csp-style="display: flex; gap: 0.5rem; align-items: center;">
            <input type="text" name="keyName" placeholder="Key name" class="form-control" data-csp-style="width: 200px;" required />
            @* PR #101: optional company-scope narrowing. Empty = the key reads every company visible to the tenant. *@
            <label data-csp-style="font-size: 0.85rem; color: var(--lux-text-muted, #6b7280);" for="apiKeyCompanyId">Company scope</label>
            <select id="apiKeyCompanyId" name="companyId" class="form-control" data-csp-style="width: 240px;" asp-items="Model.CompanyOptions"></select>
            <button type="submit" class="btn-p btn-p--primary">Generate Key</button>
        </form>
    </div>
    <div class="section-card-body" data-csp-style="padding: 0;">
        @if (Model.ApiKeys.Any())
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Prefix</th>
                        <th>Tenant</th>
                        <th>Company Scope</th>
                        <th>Created</th>
                        <th>Last Used</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var key in Model.ApiKeys)
                    {
                        <tr>
                            <td><strong>@key.Name</strong></td>
                            <td><code>@key.KeyPrefix***</code></td>
                            <td>
                                @if (key.TenantId == 0)
                                {
                                    <span class="badge badge-warning" title="Pre-PR-#101 key; re-issue required">Needs reissue</span>
                                }
                                else
                                {
                                    <span>@key.TenantId</span>
                                }
                            </td>
                            <td>
                                @if (key.CompanyId.HasValue)
                                {
                                    <span>@(Model.CompanyNames.TryGetValue(key.CompanyId.Value, out var n) ? n : $"Company #{key.CompanyId}")</span>
                                }
                                else
                                {
                                    <span class="text-theme-muted">All visible</span>
                                }
                            </td>
                            <td>@key.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td>@(key.LastUsedAt?.ToString("MMM dd HH:mm") ?? "Never")</td>
                            <td>
                                @if (key.IsActive)
                                {
                                    <span class="badge badge-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-neutral">Revoked</span>
                                }
                            </td>
                            <td>
                                @if (key.IsActive)
                                {
                                    <form method="post" asp-page-handler="RevokeKey" data-csp-style="display: inline;">
                                        <input type="hidden" name="keyId" value="@key.Id" />
                                        <button type="submit" class="btn-p btn-p--danger btn-p--sm" onclick="return confirm('Revoke this API key?')">Revoke</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state text-theme-muted" data-csp-style="padding: 2rem; text-align: center;">
                <p>No API keys yet. Create one to get started.</p>
            </div>
        }
    </div>
</div>

<div class="section-card">
    <div class="section-card-header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            API Documentation
        </h3>
        <span class="status-badge info">REST API v1</span>
    </div>
    <div class="section-card-body">
        <p data-csp-style="margin-bottom: 1.5rem;">Use these REST API endpoints to integrate with external ERP systems.</p>

        <h4>Authentication</h4>
        <p>Include your API key in the <code>X-API-Key</code> header with every request.</p>
        <pre data-csp-style="background: var(--lux-surface-alt, #f8fafc); padding: 1rem; border-radius: 8px; overflow-x: auto;">
curl -H "X-API-Key: cfa_your_api_key_here" \
     http://127.0.0.1:5000/api/v1/assets</pre>

        <h4 data-csp-style="margin-top: 1.5rem;">Endpoints</h4>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Method</th>
                    <th>Endpoint</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><span class="badge badge-success">GET</span></td>
                    <td><code>/api/v1/assets</code></td>
                    <td>List all assets (supports pagination, location, status filters)</td>
                </tr>
                <tr>
                    <td><span class="badge badge-success">GET</span></td>
                    <td><code>/api/v1/assets/{id}</code></td>
                    <td>Get a single asset by ID</td>
                </tr>
                <tr>
                    <td><span class="badge badge-primary">POST</span></td>
                    <td><code>/api/v1/assets</code></td>
                    <td>Create a new asset</td>
                </tr>
                <tr>
                    <td><span class="badge badge-warning">PUT</span></td>
                    <td><code>/api/v1/assets/{id}</code></td>
                    <td>Update an existing asset</td>
                </tr>
                <tr>
                    <td><span class="badge badge-danger">DELETE</span></td>
                    <td><code>/api/v1/assets/{id}</code></td>
                    <td>Mark asset as disposed</td>
                </tr>
            </tbody>
        </table>

        <h4 data-csp-style="margin-top: 1.5rem;">Query Parameters (GET /assets)</h4>
        <ul>
            <li><code>page</code> - Page number (default: 1)</li>
            <li><code>pageSize</code> - Items per page (default: 50, max: 100)</li>
            <li><code>location</code> - Filter by location</li>
            <li><code>status</code> - Filter by status (Active, Disposed, FullyDepreciated)</li>
        </ul>

        <h4 data-csp-style="margin-top: 1.5rem;">Create Asset Example</h4>
        <pre data-csp-style="background: var(--lux-surface-alt, #f8fafc); padding: 1rem; border-radius: 8px; overflow-x: auto;">
curl -X POST \
     -H "X-API-Key: cfa_your_api_key_here" \
     -H "Content-Type: application/json" \
     -d '{
       "assetNumber": "FA-1001",
       "description": "CNC Milling Machine",
       "model": "VMC-850",
       "acquisitionCost": 125000,
       "inServiceDate": "2026-01-15",
       "usefulLifeMonths": 120,
       "location": "Building A"
     }' \
     http://127.0.0.1:5000/api/v1/assets</pre>
    </div>
</div>

