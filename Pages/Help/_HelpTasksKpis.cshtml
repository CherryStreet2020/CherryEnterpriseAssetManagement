@model Abs.FixedAssets.Pages.Help.TasksModel
<div class="kpi-card">
    <div class="kpi-label">Type</div>
    <div class="kpi-value">Task</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Difficulty</div>
    <div class="kpi-value success">Easy</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Est. Time</div>
    <div class="kpi-value">2-5 min</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Related</div>
    <div class="kpi-value info">@Model.RelatedTasks.Count()</div>
</div>
