@page
@model Abs.FixedAssets.Pages.Help.ImplementationModel
@{
    ViewData["Title"] = "Implementation Guide";
    ViewData["TabTitle"] = "Implementation Guide";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
    
    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = "Implementation Guide",
        ["Subtitle"] = "Your complete step-by-step manual for enterprise asset management success",
        ["TypeLabel"] = "Guide",
        ["StatusText"] = "Interactive",
        ["StatusTone"] = "info",
        ["ContextPartial"] = "/Pages/Help/_HelpImplementationContext.cshtml",
        ["KpisPartial"] = "/Pages/Help/_HelpImplementationKpis.cshtml",
        ["ActionsPartial"] = "/Pages/Help/_HelpImplementationActions.cshtml"
    };
}

<link rel="stylesheet" href="/css/help-enterprise.css" />

@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

<div class="impl-layout">
    <nav class="impl-sticky-nav" id="impl-sticky-nav">
        <div class="impl-nav-header">
            <h3>Your Progress</h3>
            <div class="impl-progress-ring" id="impl-progress-percent">0%</div>
        </div>
        
        <div class="impl-nav-search">
            <input type="text" id="impl-search" placeholder="Search guide...">
        </div>
        
        <ul class="impl-nav-list">
            <li class="impl-nav-item active" data-section="getting-started">
                <span class="nav-number">1</span>
                <span class="nav-label">Getting Started</span>
                <span class="nav-progress-indicator"></span>
            </li>
            <li class="impl-nav-item" data-section="company-setup">
                <span class="nav-number">2</span>
                <span class="nav-label">Company Setup</span>
                <span class="nav-progress-indicator"></span>
            </li>
            <li class="impl-nav-item" data-section="module-config">
                <span class="nav-number">3</span>
                <span class="nav-label">Module Configuration</span>
                <span class="nav-progress-indicator"></span>
            </li>
            <li class="impl-nav-item" data-section="master-data">
                <span class="nav-number">4</span>
                <span class="nav-label">Master Data Setup</span>
                <span class="nav-progress-indicator"></span>
            </li>
            <li class="impl-nav-item" data-section="depreciation">
                <span class="nav-number">5</span>
                <span class="nav-label">Depreciation Books</span>
                <span class="nav-progress-indicator"></span>
            </li>
            <li class="impl-nav-item" data-section="inventory-setup">
                <span class="nav-number">6</span>
                <span class="nav-label">Inventory & Parts</span>
                <span class="nav-progress-indicator"></span>
            </li>
            <li class="impl-nav-item" data-section="procurement">
                <span class="nav-number">7</span>
                <span class="nav-label">Procurement Setup</span>
                <span class="nav-progress-indicator"></span>
            </li>
            <li class="impl-nav-item" data-section="data-import">
                <span class="nav-number">8</span>
                <span class="nav-label">Data Import</span>
                <span class="nav-progress-indicator"></span>
            </li>
            <li class="impl-nav-item" data-section="users-security">
                <span class="nav-number">9</span>
                <span class="nav-label">Users & Security</span>
                <span class="nav-progress-indicator"></span>
            </li>
            <li class="impl-nav-item" data-section="testing">
                <span class="nav-number">10</span>
                <span class="nav-label">Testing & Validation</span>
                <span class="nav-progress-indicator"></span>
            </li>
            <li class="impl-nav-item" data-section="go-live">
                <span class="nav-number">11</span>
                <span class="nav-label">Go-Live</span>
                <span class="nav-progress-indicator"></span>
            </li>
        </ul>
        
        <div class="impl-nav-actions">
            <button class="impl-nav-btn" id="impl-print-btn">
                <i class="fas fa-print"></i> Print
            </button>
            <button class="impl-nav-btn" id="impl-reset-btn">
                <i class="fas fa-redo"></i> Reset
            </button>
        </div>
    </nav>
    
    <div class="impl-content">
        <div class="impl-progress-banner">
            <div class="impl-progress-banner-icon">
                <i class="fas fa-tasks"></i>
            </div>
            <div class="impl-progress-banner-text">
                <h2>Implementation Progress</h2>
                <p id="impl-progress-text">0 of 0 tasks completed</p>
            </div>
            <div class="impl-progress-bar-container">
                <div class="impl-progress-bar-track">
                    <div class="impl-progress-bar-fill" id="impl-progress-bar" style="width: 0%"></div>
                </div>
                <div class="impl-progress-bar-label">Check tasks as you complete them</div>
            </div>
        </div>

        <section class="impl-section" id="getting-started">
            <div class="impl-section-header">
                <div class="impl-section-number">1</div>
                <div class="impl-section-title">
                    <h2>Getting Started</h2>
                    <p>Prepare for a successful implementation</p>
                </div>
            </div>
            <div class="impl-section-body">
                <div class="impl-subsection">
                    <h3><i class="fas fa-users subsection-icon"></i> Assemble Your Team</h3>
                    <p>A successful implementation requires the right people. Identify these key roles:</p>
                    
                    <div class="impl-grid">
                        <div class="impl-card">
                            <h4><i class="fas fa-user-tie text-blue"></i> Project Lead</h4>
                            <p>Oversees implementation, makes decisions, coordinates between departments.</p>
                            <ul>
                                <li>Typically: Controller or CFO</li>
                                <li>Time: 2-4 hours/week</li>
                            </ul>
                        </div>
                        <div class="impl-card">
                            <h4><i class="fas fa-calculator text-green"></i> Accounting Lead</h4>
                            <p>Defines GL mapping, depreciation policies, reconciliation requirements.</p>
                            <ul>
                                <li>Typically: Senior Accountant</li>
                                <li>Time: 8-10 hours/week</li>
                            </ul>
                        </div>
                        <div class="impl-card">
                            <h4><i class="fas fa-industry text-amber"></i> Operations Contact</h4>
                            <p>Provides asset details, locations, serial numbers, equipment knowledge.</p>
                            <ul>
                                <li>Typically: Plant Manager</li>
                                <li>Time: 4-6 hours total</li>
                            </ul>
                        </div>
                        <div class="impl-card">
                            <h4><i class="fas fa-file-invoice-dollar text-purple"></i> Tax Advisor</h4>
                            <p>Confirms MACRS classes (US) or CCA classes (Canada), validates elections.</p>
                            <ul>
                                <li>Typically: CPA or Tax Specialist</li>
                                <li>Time: 2-3 hours total</li>
                            </ul>
                        </div>
                    </div>
                    
                    <div class="impl-checklist">
                        <label class="impl-checklist-item">
                            <input type="checkbox" data-check-id="team-lead">
                            <div class="check-content">
                                <span class="check-label">Identify Project Lead</span>
                                <span class="check-hint">Assign a decision-maker to oversee implementation</span>
                            </div>
                        </label>
                        <label class="impl-checklist-item">
                            <input type="checkbox" data-check-id="team-accounting">
                            <div class="check-content">
                                <span class="check-label">Assign Accounting Lead</span>
                                <span class="check-hint">Select someone to define GL mapping and depreciation policies</span>
                            </div>
                        </label>
                        <label class="impl-checklist-item">
                            <input type="checkbox" data-check-id="team-ops">
                            <div class="check-content">
                                <span class="check-label">Identify Operations Contact</span>
                                <span class="check-hint">Someone who knows the assets and locations</span>
                            </div>
                        </label>
                        <label class="impl-checklist-item">
                            <input type="checkbox" data-check-id="team-tax">
                            <div class="check-content">
                                <span class="check-label">Engage Tax Advisor</span>
                                <span class="check-hint">For MACRS/CCA class confirmations</span>
                            </div>
                        </label>
                    </div>
                </div>
                
                <div class="impl-subsection">
                    <h3><i class="fas fa-folder-open subsection-icon"></i> Gather Required Documents</h3>
                    <p>Collect these documents before starting configuration:</p>
                    
                    <div class="impl-expandable">
                        <div class="impl-expandable-header">
                            <h4><i class="fas fa-file-alt"></i> Financial Information</h4>
                            <i class="fas fa-chevron-down expand-icon"></i>
                        </div>
                        <div class="impl-expandable-body">
                            <div class="impl-checklist">
                                <label class="impl-checklist-item">
                                    <input type="checkbox" data-check-id="doc-gl">
                                    <div class="check-content">
                                        <span class="check-label">GL Account Listing</span>
                                        <span class="check-hint">Complete chart of accounts from your ERP or accounting system</span>
                                    </div>
                                </label>
                                <label class="impl-checklist-item">
                                    <input type="checkbox" data-check-id="doc-fiscal">
                                    <div class="check-content">
                                        <span class="check-label">Fiscal Year Details</span>
                                        <span class="check-hint">Start/end dates, accounting period structure</span>
                                    </div>
                                </label>
                                <label class="impl-checklist-item">
                                    <input type="checkbox" data-check-id="doc-depr-policy">
                                    <div class="check-content">
                                        <span class="check-label">Depreciation Policy Document</span>
                                        <span class="check-hint">Your company's standard depreciation methods by asset type</span>
                                    </div>
                                </label>
                            </div>
                        </div>
                    </div>
                    
                    <div class="impl-expandable">
                        <div class="impl-expandable-header">
                            <h4><i class="fas fa-boxes"></i> Asset Information</h4>
                            <i class="fas fa-chevron-down expand-icon"></i>
                        </div>
                        <div class="impl-expandable-body">
                            <div class="impl-checklist">
                                <label class="impl-checklist-item">
                                    <input type="checkbox" data-check-id="doc-assets">
                                    <div class="check-content">
                                        <span class="check-label">Complete Asset Listing</span>
                                        <span class="check-hint">Export from current system or Excel file with all assets</span>
                                    </div>
                                </label>
                                <label class="impl-checklist-item">
                                    <input type="checkbox" data-check-id="doc-locations">
                                    <div class="check-content">
                                        <span class="check-label">Location List</span>
                                        <span class="check-hint">Buildings, departments, cost centers</span>
                                    </div>
                                </label>
                                <label class="impl-checklist-item">
                                    <input type="checkbox" data-check-id="doc-accum">
                                    <div class="check-content">
                                        <span class="check-label">Accumulated Depreciation</span>
                                        <span class="check-hint">By asset for both GAAP and Tax books</span>
                                    </div>
                                </label>
                            </div>
                        </div>
                    </div>
                    
                    <div class="impl-expandable">
                        <div class="impl-expandable-header">
                            <h4><i class="fas fa-flag-usa"></i> US Tax Information (MACRS)</h4>
                            <i class="fas fa-chevron-down expand-icon"></i>
                        </div>
                        <div class="impl-expandable-body">
                            <div class="impl-checklist">
                                <label class="impl-checklist-item">
                                    <input type="checkbox" data-check-id="doc-macrs">
                                    <div class="check-content">
                                        <span class="check-label">MACRS Property Class Assignments</span>
                                        <span class="check-hint">3, 5, 7, 10, 15, 20, 27.5, 39-year classes for each asset category</span>
                                        <a href="/UsTax" class="check-link"><i class="fas fa-external-link-alt"></i> View MACRS Reference</a>
                                    </div>
                                </label>
                                <label class="impl-checklist-item">
                                    <input type="checkbox" data-check-id="doc-179">
                                    <div class="check-content">
                                        <span class="check-label">Section 179 Elections</span>
                                        <span class="check-hint">Current year assets elected for immediate expensing</span>
                                    </div>
                                </label>
                                <label class="impl-checklist-item">
                                    <input type="checkbox" data-check-id="doc-bonus">
                                    <div class="check-content">
                                        <span class="check-label">Bonus Depreciation Records</span>
                                        <span class="check-hint">Assets with bonus depreciation by year placed in service</span>
                                    </div>
                                </label>
                                <label class="impl-checklist-item">
                                    <input type="checkbox" data-check-id="doc-4562">
                                    <div class="check-content">
                                        <span class="check-label">Form 4562</span>
                                        <span class="check-hint">Most recent Depreciation and Amortization form</span>
                                    </div>
                                </label>
                            </div>
                        </div>
                    </div>
                    
                    <div class="impl-expandable">
                        <div class="impl-expandable-header">
                            <h4><i class="fas fa-leaf"></i> Canadian Tax Information (CCA)</h4>
                            <i class="fas fa-chevron-down expand-icon"></i>
                        </div>
                        <div class="impl-expandable-body">
                            <div class="impl-checklist">
                                <label class="impl-checklist-item">
                                    <input type="checkbox" data-check-id="doc-cca">
                                    <div class="check-content">
                                        <span class="check-label">CCA Class Assignments</span>
                                        <span class="check-hint">Canadian capital cost allowance classes for each asset type</span>
                                        <a href="/CCA" class="check-link"><i class="fas fa-external-link-alt"></i> View CCA Reference</a>
                                    </div>
                                </label>
                                <label class="impl-checklist-item">
                                    <input type="checkbox" data-check-id="doc-ucc">
                                    <div class="check-content">
                                        <span class="check-label">Current UCC Balances</span>
                                        <span class="check-hint">Undepreciated Capital Cost by class</span>
                                    </div>
                                </label>
                                <label class="impl-checklist-item">
                                    <input type="checkbox" data-check-id="doc-t2s8">
                                    <div class="check-content">
                                        <span class="check-label">T2 Schedule 8</span>
                                        <span class="check-hint">Most recent CCA schedule</span>
                                    </div>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="impl-section" id="company-setup">
            <div class="impl-section-header">
                <div class="impl-section-number">2</div>
                <div class="impl-section-title">
                    <h2>Company Setup</h2>
                    <p>Configure your organizational structure</p>
                </div>
            </div>
            <div class="impl-section-body">
                <div class="impl-subsection">
                    <h3><i class="fas fa-building subsection-icon"></i> Choose Your Company Structure</h3>
                    <p>CherryAI supports both single-company and multi-company (holding company) structures with Smart Mode that automatically adapts.</p>
                    
                    <div class="impl-grid">
                        <div class="impl-card">
                            <h4>Single Company Mode</h4>
                            <p>For standalone businesses with one legal entity.</p>
                            <ul>
                                <li>Simpler setup and navigation</li>
                                <li>No holding/subsidiary complexity</li>
                                <li>Standard GL accounts only</li>
                                <li>Ideal for single-location manufacturers</li>
                            </ul>
                        </div>
                        <div class="impl-card recommended">
                            <h4>Multi-Company Mode</h4>
                            <p>For holding companies with operating subsidiaries.</p>
                            <ul>
                                <li>Separate books per subsidiary</li>
                                <li>Intercompany accounts automatic</li>
                                <li>Consolidated reporting</li>
                                <li>Each company can have different stocking settings</li>
                            </ul>
                        </div>
                    </div>
                    
                    <div class="impl-info-box">
                        <i class="fas fa-info-circle info-icon"></i>
                        <div class="info-content">
                            <strong>Smart Mode Detection</strong>
                            <p>CherryAI automatically detects your mode based on company count. Item Master is shared globally, while stocking settings (reorder points, preferred vendors) are per-company in multi-company mode.</p>
                        </div>
                    </div>
                    
                    <div class="impl-checklist">
                        <label class="impl-checklist-item">
                            <input type="checkbox" data-check-id="company-create">
                            <div class="check-content">
                                <span class="check-label">Create Primary Company</span>
                                <span class="check-hint">Set up your main company with name, address, and fiscal year</span>
                                <a href="/Admin/Company" class="check-link"><i class="fas fa-external-link-alt"></i> Company Settings</a>
                            </div>
                        </label>
                        <label class="impl-checklist-item">
                            <input type="checkbox" data-check-id="company-structure">
                            <div class="check-content">
                                <span class="check-label">Choose Company Structure</span>
                                <span class="check-hint">Single Company or Multi-Company (Holding)</span>
                            </div>
                        </label>
                        <label class="impl-checklist-item">
                            <input type="checkbox" data-check-id="company-subs">
                            <div class="check-content">
                                <span class="check-label">Create Subsidiaries (if multi-company)</span>
                                <span class="check-hint">Add each operating company under the holding company</span>
                            </div>
                        </label>
                        <label class="impl-checklist-item">
                            <input type="checkbox" data-check-id="company-fiscal">
                            <div class="check-content">
                                <span class="check-label">Configure Fiscal Calendar</span>
                                <span class="check-hint">Set fiscal year, accounting periods (monthly, quarterly, 13-period)</span>
                                <a href="/Admin/Company" class="check-link"><i class="fas fa-external-link-alt"></i> Accounting Periods</a>
                            </div>
                        </label>
                    </div>
                </div>
            </div>
        </section>

        <section class="impl-section" id="module-config">
            <div class="impl-section-header">
                <div class="impl-section-number">3</div>
                <div class="impl-section-title">
                    <h2>Module Configuration</h2>
                    <p>Enable the features you need</p>
                </div>
            </div>
            <div class="impl-section-body">
                <div class="impl-subsection">
                    <h3><i class="fas fa-cogs subsection-icon"></i> Financial Mode Selection</h3>
                    <p>Choose how CherryAI integrates with your existing systems. This controls which modules are available.</p>
                    
                    <div class="impl-grid">
                        <div class="impl-card recommended">
                            <h4>Standalone Mode</h4>
                            <p>CherryAI handles all asset-related purchasing and payables.</p>
                            <ul>
                                <li>Full vendor management</li>
                                <li>Purchase orders & approvals</li>
                                <li>Goods receiving workflow</li>
                                <li>Accounts payable & 3-way matching</li>
                                <li>Purchase requisitions</li>
                            </ul>
                        </div>
                        <div class="impl-card">
                            <h4>ERP Integration Mode</h4>
                            <p>CherryAI focuses on assets while your ERP handles procurement.</p>
                            <ul>
                                <li>Streamlined asset-focused interface</li>
                                <li>Procurement modules hidden</li>
                                <li>Journal entries export to ERP</li>
                                <li>Vendor data stays in your ERP</li>
                            </ul>
                        </div>
                    </div>
                </div>
                
                <div class="impl-subsection">
                    <h3><i class="fas fa-toggle-on subsection-icon"></i> Module Toggles</h3>
                    <p>Enable or disable individual modules based on your needs. Note: Some modules have dependencies.</p>
                    
                    <div class="impl-info-box warning">
                        <i class="fas fa-exclamation-triangle info-icon"></i>
                        <div class="info-content">
                            <strong>Module Dependencies</strong>
                            <p><strong>Purchasing</strong> and <strong>Accounts Payable</strong> both require the <strong>Vendors</strong> module. If you disable Vendors, these modules will also become unavailable. The system will warn you before making changes.</p>
                        </div>
                    </div>
                    
                    <div class="impl-table">
                        <table>
                            <thead>
                                <tr>
                                    <th>Module</th>
                                    <th>Description</th>
                                    <th>Requires</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><strong>Vendors</strong></td>
                                    <td>Manage vendor master data, contacts, payment terms</td>
                                    <td>-</td>
                                </tr>
                                <tr>
                                    <td><strong>Purchasing</strong></td>
                                    <td>Purchase orders, goods receiving, requisitions</td>
                                    <td>Vendors</td>
                                </tr>
                                <tr>
                                    <td><strong>Accounts Payable</strong></td>
                                    <td>Invoice entry, 3-way matching, payments, aging</td>
                                    <td>Vendors</td>
                                </tr>
                                <tr>
                                    <td><strong>Work Orders</strong></td>
                                    <td>Maintenance work orders, labor tracking, parts usage</td>
                                    <td>-</td>
                                </tr>
                                <tr>
                                    <td><strong>MRO Inventory</strong></td>
                                    <td>Item Master, stock levels, barcode scanning</td>
                                    <td>-</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    
                    <div class="impl-checklist">
                        <label class="impl-checklist-item">
                            <input type="checkbox" data-check-id="module-mode">
                            <div class="check-content">
                                <span class="check-label">Select Financial Mode</span>
                                <span class="check-hint">Choose Standalone or ERP Integration</span>
                                <a href="/Admin/Company" class="check-link"><i class="fas fa-external-link-alt"></i> Company Settings</a>
                            </div>
                        </label>
                        <label class="impl-checklist-item">
                            <input type="checkbox" data-check-id="module-vendors">
                            <div class="check-content">
                                <span class="check-label">Configure Vendors Module</span>
                                <span class="check-hint">Enable if you'll manage vendors in CherryAI</span>
                            </div>
                        </label>
                        <label class="impl-checklist-item">
                            <input type="checkbox" data-check-id="module-purchasing">
                            <div class="check-content">
                                <span class="check-label">Configure Purchasing Module</span>
                                <span class="check-hint">Enable for PO management and requisitions</span>
                            </div>
                        </label>
                        <label class="impl-checklist-item">
                            <input type="checkbox" data-check-id="module-ap">
                            <div class="check-content">
                                <span class="check-label">Configure Accounts Payable Module</span>
                                <span class="check-hint">Enable for invoice management and payments</span>
                            </div>
                        </label>
                        <label class="impl-checklist-item">
                            <input type="checkbox" data-check-id="module-wo">
                            <div class="check-content">
                                <span class="check-label">Configure Work Orders Module</span>
                                <span class="check-hint">Enable for maintenance work order tracking</span>
                            </div>
                        </label>
                        <label class="impl-checklist-item">
                            <input type="checkbox" data-check-id="module-inv">
                            <div class="check-content">
                                <span class="check-label">Configure MRO Inventory Module</span>
                                <span class="check-hint">Enable for spare parts and consumables management</span>
                            </div>
                        </label>
                    </div>
                </div>
            </div>
        </section>

        <section class="impl-section" id="master-data">
            <div class="impl-section-header">
                <div class="impl-section-number">4</div>
                <div class="impl-section-title">
                    <h2>Master Data Setup</h2>
                    <p>Configure core reference data</p>
                </div>
            </div>
            <div class="impl-section-body">
                <div class="impl-subsection">
                    <h3><i class="fas fa-sitemap subsection-icon"></i> Chart of Accounts</h3>
                    <p>Set up GL accounts for asset transactions, depreciation, and gain/loss entries.</p>
                    
                    <div class="impl-checklist">
                        <label class="impl-checklist-item">
                            <input type="checkbox" data-check-id="gl-review">
                            <div class="check-content">
                                <span class="check-label">Review Pre-loaded GL Accounts</span>
                                <span class="check-hint">CherryAI includes 82+ standard accounts; review and customize</span>
                                <a href="/Admin/GlAccounts" class="check-link"><i class="fas fa-external-link-alt"></i> GL Accounts</a>
                            </div>
                        </label>
                        <label class="impl-checklist-item">
                            <input type="checkbox" data-check-id="gl-asset">
                            <div class="check-content">
                                <span class="check-label">Configure Asset Accounts (1xxx)</span>
                                <span class="check-hint">Fixed asset, accumulated depreciation accounts by category</span>
                            </div>
                        </label>
                        <label class="impl-checklist-item">
                            <input type="checkbox" data-check-id="gl-expense">
                            <div class="check-content">
