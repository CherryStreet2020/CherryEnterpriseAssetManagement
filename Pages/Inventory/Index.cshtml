@page
@model Abs.FixedAssets.Pages.Inventory.IndexModel
@using Abs.FixedAssets.Pages.Shared.Primitives
@{
    ViewData["Title"] = "Physical Inventory";
    ViewData["TabTitle"] = "Physical Inventory";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";

    var totalAssets = Model.Stats.TotalAssets;
    var assetsWithBarcode = Model.Stats.AssetsWithBarcode;
    var recentScans = Model.Stats.RecentScans;
    var openInventories = Model.Stats.OpenInventories;
    var barcodeCoveragePct = totalAssets > 0 ? (assetsWithBarcode * 100.0 / totalAssets) : 0;
    var openListsCount = Model.InventoryLists.Count(l => l.Status != InventoryStatus.Completed);

    var statusText = $"{totalAssets} Assets";
    var statusTone = totalAssets > 0 ? "active" : "neutral";

    // PR #116d.21 — Drop KpisPartial; render KPIs horizontally in body for better layout.
    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = "Physical Inventory",
        ["Subtitle"] = "Barcode tracking, inventory lists, and asset reconciliation",
        ["TypeLabel"] = "Inventory",
        ["StatusText"] = statusText,
        ["StatusTone"] = statusTone,
        ["ContextPartial"] = "/Pages/Inventory/_InventoryIndexContext.cshtml",
        ["ActionsPartial"] = "/Pages/Inventory/_InventoryIndexActions.cshtml"
    };
}

@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@* PR #116d.21 — Flash message restyled on the design system. *@
@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="ds-card" data-tone="success" style="margin-top: 14px; padding: 12px 16px; color: var(--text-primary);">@Model.Message</div>
}

@* PR #116d.21 — 4 KPITiles in body. Open lists flips to warning when count > 0. *@
<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-top: 20px;">
    @await Html.PartialAsync("Primitives/_KPITile", new KpiTileModel
    {
        Label = "Total Assets",
        Value = totalAssets.ToString("N0"),
        DeltaText = totalAssets > 0 ? "tracked in inventory" : "no assets yet",
        DeltaDirection = "flat",
        SparkTone = "info"
    })
    @await Html.PartialAsync("Primitives/_KPITile", new KpiTileModel
    {
        Label = "Assets with Barcode",
        Value = assetsWithBarcode.ToString("N0"),
        DeltaText = totalAssets > 0 ? $"{barcodeCoveragePct.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)}% coverage" : "no barcode coverage",
        DeltaDirection = barcodeCoveragePct >= 90 ? "up" : barcodeCoveragePct >= 50 ? "flat" : "down",
        SparkTone = barcodeCoveragePct >= 90 ? "success" : barcodeCoveragePct >= 50 ? "info" : "warning"
    })
    @await Html.PartialAsync("Primitives/_KPITile", new KpiTileModel
    {
        Label = "Recent Scans",
        Value = recentScans.ToString("N0"),
        DeltaText = recentScans > 0 ? "▲ last 30 days" : "no scans recently",
        DeltaDirection = recentScans > 0 ? "up" : "flat",
        SparkTone = recentScans > 0 ? "success" : "muted"
    })
    @await Html.PartialAsync("Primitives/_KPITile", new KpiTileModel
    {
        Label = "Open Inventory Lists",
        Value = openListsCount.ToString("N0"),
        DeltaText = openListsCount > 0 ? "▼ awaiting reconciliation" : "▲ all lists closed",
        DeltaDirection = openListsCount > 0 ? "down" : "up",
        SparkTone = openListsCount > 0 ? "warning" : "success",
        Href = openListsCount > 0 ? "#inventory-lists" : null
    })
</div>

@* PR #116d.21 — Quick Actions: 3 DataCards with ds-btn variants. *@
<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; margin-top: 24px;">
    <div class="ds-card" data-tone="neutral" style="padding: 22px;">
        <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500;">Maintenance Action</div>
        <div style="font-size: 17px; font-weight: 700; color: var(--text-primary); margin-top: 6px;">Generate Barcodes</div>
        <p style="color: var(--text-secondary); margin: 8px 0 14px; font-size: 13px; line-height: 1.5;">Auto-assign barcode numbers for every asset that doesn't have one yet.</p>
        <form method="post" asp-page-handler="GenerateBarcodes">
            <button type="submit" class="ds-btn" data-variant="secondary">Generate Barcodes</button>
        </form>
    </div>
    <div class="ds-card" data-tone="brand" style="padding: 22px;">
        <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500;">Reconciliation</div>
        <div style="font-size: 17px; font-weight: 700; color: var(--text-primary); margin-top: 6px;">New Inventory List</div>
        <p style="color: var(--text-secondary); margin: 8px 0 14px; font-size: 13px; line-height: 1.5;">Create a new physical inventory count for a location, department, or asset class.</p>
        <a href="/Inventory/CreateList" class="ds-btn" data-variant="primary">Create Inventory List</a>
    </div>
    <div class="ds-card" data-tone="info" style="padding: 22px;">
        <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500;">Field Operation</div>
        <div style="font-size: 17px; font-weight: 700; color: var(--text-primary); margin-top: 6px;">Scan Asset</div>
        <p style="color: var(--text-secondary); margin: 8px 0 14px; font-size: 13px; line-height: 1.5;">Record a barcode scan to update asset location, condition, and last-seen timestamp.</p>
        <a href="/Inventory/Scan" class="ds-btn" data-variant="secondary">Start Scanning</a>
    </div>
</div>

@* PR #116d.21 — Inventory Lists wrapped in DataCard with brand tone. *@
<div id="inventory-lists" class="ds-card" data-tone="brand" style="margin-top: 24px; padding: 0;">
    <div style="padding: 18px 22px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap;">
        <div>
            <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500;">Reconciliation</div>
            <div style="font-size: 17px; font-weight: 700; color: var(--text-primary); margin-top: 4px;">Inventory Lists</div>
            <div style="font-size: 13px; color: var(--text-secondary); margin-top: 4px;">Physical counts, open and closed</div>
        </div>
        @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel
        {
            Label = Model.InventoryLists.Count == 1 ? "List" : "Lists",
            MonoNum = Model.InventoryLists.Count.ToString(),
            Tone = openListsCount > 0 ? "warning" : "info",
            ShowDot = true
        })
    </div>
    @if (Model.InventoryLists.Any())
    {
        <div style="padding: 0;">
            @{ var returnUrl = $"{HttpContext.Request.Path}{HttpContext.Request.QueryString}"; }
            <table class="data-table premium-table" id="inventoryGrid" data-enhanced-grid="true" data-row-click="true">
                <thead>
                    <tr>
                        <th data-col="Name" data-filter="text">Name</th>
                        <th data-col="Location" data-filter="text">Location</th>
                        <th data-col="Status" data-filter="select" data-filter-options="Open|InProgress|Completed">Status</th>
                        <th data-col="Total Assets" data-filter="number">Total Assets</th>
                        <th data-col="Scanned" data-filter="number">Scanned</th>
                        <th data-col="Found" data-filter="number">Found</th>
                        <th data-col="Missing" data-filter="number">Missing</th>
                        <th data-col="Created" data-filter="text">Created</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var list in Model.InventoryLists)
                    {
                        var statusToneList = list.Status == InventoryStatus.Completed
                            ? "success"
                            : list.Status == InventoryStatus.InProgress
                                ? "warning"
                                : "info";
                        <tr data-row-id="@list.Id" data-row-href="@Url.Page("/Inventory/List", new { id = list.Id, returnUrl = returnUrl })">
                            <td><strong style="color: var(--text-primary);">@list.Name</strong></td>
                            <td style="color: var(--text-secondary);">@(list.Location ?? "—")</td>
                            <td>
                                @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel
                                {
                                    Label = list.Status.ToString(),
                                    Tone = statusToneList,
                                    ShowDot = true
                                })
                            </td>
                            <td style="color: var(--text-secondary); font-family: var(--font-mono, ui-monospace, monospace);">@list.TotalAssets</td>
                            <td style="color: var(--text-secondary); font-family: var(--font-mono, ui-monospace, monospace);">@list.ScannedAssets</td>
                            <td style="color: var(--ds-success, #34d399); font-family: var(--font-mono, ui-monospace, monospace);">@list.FoundAssets</td>
                            <td style="color: @(list.MissingAssets > 0 ? "var(--ds-danger, #f87171)" : "var(--text-muted)"); font-family: var(--font-mono, ui-monospace, monospace);">@list.MissingAssets</td>
                            <td style="color: var(--text-secondary);">@list.CreatedDate.ToString("MM/dd/yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        @* PR #116d.21 — EmptyState v2 for no-lists path. *@
        <div style="padding: 24px;">
            @await Html.PartialAsync("Primitives/_EmptyStateV2", new EmptyStateModel
            {
                Icon = "folder",
                Tone = "info",
                Title = "No inventory lists yet",
                Body = "Create your first physical inventory list to start tracking, scanning, and reconciling assets across locations.",
                CtaLabel = "Create First List",
                CtaHref = "/Inventory/CreateList",
                SecondaryLabel = "Back to Dashboard",
                SecondaryHref = "/"
            })
        </div>
    }
</div>

@* PR #116d.21 — Barcode Standards reference card on design system. *@
<div class="ds-card" data-tone="info" style="margin-top: 24px; padding: 22px;">
    <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500;">Reference</div>
    <div style="font-size: 17px; font-weight: 700; color: var(--text-primary); margin-top: 6px;">Barcode Standards</div>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 24px; margin-top: 16px;">
        <div>
            <div style="font-size: 13px; font-weight: 600; color: var(--text-primary); margin-bottom: 8px;">Supported Barcode Types</div>
            <ul style="margin: 0; padding-left: 18px; color: var(--text-secondary); font-size: 13px; line-height: 1.7;">
                <li><strong style="color: var(--text-primary);">Code 128</strong> — Standard for asset tags (default)</li>
                <li><strong style="color: var(--text-primary);">QR Code</strong> — For mobile scanning</li>
                <li><strong style="color: var(--text-primary);">Code 39</strong> — Legacy systems</li>
                <li><strong style="color: var(--text-primary);">Data Matrix</strong> — High density labels</li>
            </ul>
        </div>
        <div>
            <div style="font-size: 13px; font-weight: 600; color: var(--text-primary); margin-bottom: 8px;">Barcode Number Format</div>
            <p style="margin: 0 0 6px; color: var(--text-secondary); font-size: 13px;">Default format: <code style="font-family: var(--font-mono, ui-monospace, monospace); color: var(--ds-brand, #60a5fa); background: rgba(96,165,250,0.08); padding: 2px 6px; border-radius: 4px;">FA-000001</code></p>
            <p style="margin: 0; color: var(--text-muted); font-size: 12px;">FA = Fixed Asset prefix · 6-digit sequential number</p>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function() {
    if (document.getElementById('inventoryGrid')) {
        initEnhancedGrid('inventoryGrid', {
            searchable: true,
            sortable: true,
            exportable: true,
            columnVisibility: true,
            clickableRows: true
        });
    }
});
</script>
}
