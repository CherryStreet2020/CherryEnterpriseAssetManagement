@using Abs.FixedAssets.Models
@{
    var list = ViewData["InventoryList"] as InventoryList;
    var progress = list?.TotalAssets > 0 
        ? ((double)list.ScannedAssets / list.TotalAssets * 100) 
        : 0;
}
@if (list != null)
{
    <div class="screen-header__actions">
        <div class="hero-tags">
            <span class="hero-tag @(list.Status == InventoryStatus.Completed ? "success" : list.Status == InventoryStatus.InProgress ? "priority" : "info")">@progress.ToString("F0")% COMPLETE</span>
        </div>
        <div class="hero-btns">
            <a href="/Inventory" class="hero-btn hero-btn-ghost">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Back to Lists
            </a>
            @if (list.Status == InventoryStatus.InProgress)
            {
                <button type="button" class="hero-btn hero-btn-primary" onclick="toggleInlineForm('scanForm')">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z" />
                    </svg>
                    Record Scan
                </button>
            }
        </div>
    </div>
}
