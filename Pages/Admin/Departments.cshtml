@page
@model Abs.FixedAssets.Pages.Admin.DepartmentsModel
@{
    ViewData["Title"] = "Departments";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
    var totalDepts = Model.Departments.Count;
    var activeDepts = Model.Departments.Count(d => d.IsActive);
    
    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = "Departments",
        ["Subtitle"] = "Manage organizational departments for cost allocation and reporting",
        ["TypeLabel"] = "Administration",
        ["StatusText"] = $"{activeDepts} Active",
        ["StatusTone"] = "active",
        ["ContextPartial"] = "/Pages/Admin/_AdminDepartmentsContext.cshtml",
        ["KpisPartial"] = "/Pages/Admin/_AdminDepartmentsKpis.cshtml",
        ["ActionsPartial"] = "/Pages/Admin/_AdminDepartmentsActions.cshtml"
    };
}

@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="section-card pe-card">
    <div class="section-card-header pe-card__header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
            </svg>
            All Departments
        </h3>
        <span class="status-badge info">@totalDepts DEPARTMENTS</span>
    </div>
    <div class="section-card-body pe-card__body" data-csp-style="padding: 0;">
    <table class="data-table premium-table">
        <thead>
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th>Type</th>
                <th>Cost Center</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var dept in Model.Departments)
            {
                <tr>
                    <td><strong>@dept.Code</strong></td>
                    <td>@dept.Name</td>
                    <td><span class="badge badge-outline">@dept.Type</span></td>
                    <td>@(dept.CostCenter?.Name ?? "-")</td>
                    <td>
                        @if (dept.IsActive)
                        {
                            <span class="badge badge-success">Active</span>
                        }
                        else
                        {
                            <span class="badge badge-danger">Inactive</span>
                        }
                    </td>
                    <td class="actions-cell">
                        <button type="button" class="btn-p btn-p--secondary btn-p--sm" onclick="editDepartment(@dept.Id, '@dept.Code', '@dept.Name.Replace("'", "\\'")', '@(dept.Description?.Replace("'", "\\'") ?? "")', '@(dept.TypeLookupValueId ?? 0)', @(dept.CostCenterId?.ToString() ?? "null"), @dept.IsActive.ToString().ToLower())">Edit</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    </div>
</div>

<div id="createForm" class="inline-form-panel" data-csp-style="display: none;">
    <div class="inline-form-panel-content">
        <div class="inline-form-header">
            <div class="inline-form-header-content">
                <div class="inline-form-header-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                    </svg>
                </div>
                <div class="inline-form-header-text">
                    <h3>Add Department</h3>
                    <p>Create a new department for cost allocation</p>
                </div>
            </div>
            <button type="button" class="inline-form-close" onclick="toggleInlineForm('createForm')">&times;</button>
        </div>
        <form method="post" asp-page-handler="Create">
            <div class="inline-form-body">
                <div class="inline-form-grid">
                    <div class="form-group form-group-p">
                        <label>Code *</label>
                        <input type="text" name="code" class="form-control form-input-p" required maxlength="20" />
                    </div>
                    <div class="form-group form-group-p">
                        <label>Name *</label>
                        <input type="text" name="name" class="form-control form-input-p" required maxlength="100" />
                    </div>
                    <div class="form-group form-group-p">
                        <label>Type *</label>
                        <select name="typeLookupValueId" class="form-control form-input-p" required asp-items="Model.TypeOptions" data-cherry-select data-placeholder="Search types..."></select>
                    </div>
                    <div class="form-group form-group-p">
                        <label>Cost Center</label>
                        <select name="costCenterId" class="form-control form-input-p" data-cherry-select data-placeholder="Search cost centers...">
                            <option value="">-- None --</option>
                            @foreach (var cc in Model.CostCenters)
                            {
                                <option value="@cc.Id">@cc.Code - @cc.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group form-group-p full-width">
                        <label>Description</label>
                        <textarea name="description" class="form-control form-input-p" rows="2" maxlength="200"></textarea>
                    </div>
                </div>
            </div>
            <div class="inline-form-footer">
                <button type="button" class="btn-p btn-p--secondary" onclick="toggleInlineForm('createForm')">Cancel</button>
                <button type="submit" class="btn-p btn-p--primary">Create Department</button>
            </div>
        </form>
    </div>
</div>

<div id="editForm" class="inline-form-panel" data-csp-style="display: none;">
    <div class="inline-form-panel-content">
        <div class="inline-form-header">
            <div class="inline-form-header-content">
                <div class="inline-form-header-icon edit">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                </div>
                <div class="inline-form-header-text">
                    <h3>Edit Department</h3>
                    <p>Update department details</p>
                </div>
            </div>
            <button type="button" class="inline-form-close" onclick="toggleInlineForm('editForm')">&times;</button>
        </div>
        <form method="post" asp-page-handler="Update">
            <input type="hidden" id="editId" name="id" />
            <div class="inline-form-body">
                <div class="inline-form-grid">
                    <div class="form-group form-group-p">
                        <label>Code *</label>
                        <input type="text" id="editCode" name="code" class="form-control form-input-p" required maxlength="20" />
                    </div>
                    <div class="form-group form-group-p">
                        <label>Name *</label>
                        <input type="text" id="editName" name="name" class="form-control form-input-p" required maxlength="100" />
                    </div>
                    <div class="form-group form-group-p">
                        <label>Type *</label>
                        <select id="editType" name="typeLookupValueId" class="form-control form-input-p" required asp-items="Model.TypeOptions" data-cherry-select data-placeholder="Search types..."></select>
                    </div>
                    <div class="form-group form-group-p">
                        <label>Cost Center</label>
                        <select id="editCostCenterId" name="costCenterId" class="form-control form-input-p" data-cherry-select data-placeholder="Search cost centers...">
                            <option value="">-- None --</option>
                            @foreach (var cc in Model.CostCenters)
                            {
                                <option value="@cc.Id">@cc.Code - @cc.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group form-group-p">
                        <label>Status</label>
                        <select id="editIsActive" name="isActive" class="form-control form-input-p" asp-items="Model.ActiveInactiveOptions"></select>
                    </div>
                    <div class="form-group form-group-p full-width">
                        <label>Description</label>
                        <textarea id="editDescription" name="description" class="form-control form-input-p" rows="2" maxlength="200"></textarea>
                    </div>
                </div>
            </div>
            <div class="inline-form-footer">
                <button type="button" class="btn-p btn-p--secondary" onclick="toggleInlineForm('editForm')">Cancel</button>
                <button type="submit" class="btn-p btn-p--primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<script>
function editDepartment(id, code, name, description, type, costCenterId, isActive) {
    document.getElementById('editId').value = id;
    document.getElementById('editCode').value = code;
    document.getElementById('editName').value = name;
    document.getElementById('editDescription').value = description;
    document.getElementById('editType').value = type;
    document.getElementById('editCostCenterId').value = costCenterId || '';
    document.getElementById('editIsActive').value = isActive.toString();
    toggleInlineForm('editForm');
}
</script>
