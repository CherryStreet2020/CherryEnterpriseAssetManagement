@{
    var model = ViewData["PageModel"] as Abs.FixedAssets.Pages.Admin.RequisitionsModel;
    var totalRequisitions = model?.Requisitions.Count ?? 0;
    var pendingRequisitions = model?.Requisitions.Count(r => r.Status == Abs.FixedAssets.Models.RequisitionStatus.Pending) ?? 0;
    var approvedRequisitions = model?.Requisitions.Count(r => r.Status == Abs.FixedAssets.Models.RequisitionStatus.Approved) ?? 0;
    var autoGenerated = model?.Requisitions.Count(r => r.Source != Abs.FixedAssets.Models.RequisitionSource.Manual) ?? 0;
}
<div class="kpi-card">
    <div class="kpi-label">Total</div>
    <div class="kpi-value">@totalRequisitions</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Pending</div>
    <div class="kpi-value warning">@pendingRequisitions</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Approved</div>
    <div class="kpi-value success">@approvedRequisitions</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Auto-Generated</div>
    <div class="kpi-value">@autoGenerated</div>
</div>
