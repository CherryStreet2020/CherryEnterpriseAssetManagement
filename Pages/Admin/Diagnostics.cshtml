@page
@model Abs.FixedAssets.Pages.Admin.DiagnosticsModel
@{
    ViewData["Title"] = "Administration";
    ViewData["TabTitle"] = "System Diagnostics";
    ViewData["HideDefaultPageHeader"] = true;
    Layout = "_ModernLayout";
}

<div class="legacy-banner" style="margin-bottom: 1.5rem;">
    <div style="display: flex; align-items: center; gap: 0.75rem;">
        <svg xmlns="http://www.w3.org/2000/svg" style="width: 24px; height: 24px; flex-shrink: 0;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <span style="font-weight: 500;">Legacy page: not used in the current workflow.</span>
    </div>
    <a href="/Admin" class="legacy-banner-link">Go to Admin Hub</a>
</div>

@if (Model.IsDangerZone)
{
<div class="danger-banner">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
    </svg>
    <div>
        <strong>DANGER ZONE:</strong> @Model.DangerReason
    </div>
</div>
}

<div class="diagnostics-hero">
    <h1>System Diagnostics</h1>
    <p>Real-time database and application health status</p>
    
    <div class="info-grid" style="margin-top: 1.5rem;">
        <div class="info-card">
            <div class="info-card-label">Environment</div>
            <div class="info-card-value">@(string.IsNullOrEmpty(Model.EnvironmentName) ? "Production" : Model.EnvironmentName)</div>
        </div>
        <div class="info-card">
            <div class="info-card-label">Database Host</div>
            <div class="info-card-value">@Model.DatabaseHost</div>
        </div>
        <div class="info-card">
            <div class="info-card-label">Database Name</div>
            <div class="info-card-value">@Model.DatabaseName</div>
        </div>
        <div class="info-card">
            <div class="info-card-label">Total Tables</div>
            <div class="info-card-value">@Model.TotalTableCount</div>
        </div>
        <div class="info-card">
            <div class="info-card-label">App Version</div>
            <div class="info-card-value">@Model.AppVersion</div>
        </div>
        <div class="info-card">
            <div class="info-card-label">Applied Migrations</div>
            <div class="info-card-value">@Model.AppliedMigrations.Count</div>
        </div>
    </div>
</div>

<div class="section-card">
    <div class="section-card-header">Applied Migrations (@Model.AppliedMigrations.Count)</div>
    <div class="section-card-body">
        <div class="migration-list">
            @foreach (var migration in Model.AppliedMigrations)
            {
            <div class="migration-item">
                <span>@migration.MigrationId</span>
                <span class="migration-version">EF @migration.ProductVersion</span>
            </div>
            }
        </div>
    </div>
</div>

<div class="section-card">
    <div class="section-card-header">Core EAM Loop Health</div>
    <div class="section-card-body">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1rem; margin-bottom: 1.5rem;">
            <div style="text-align: center; padding: 1rem; background: var(--lux-surface-alt, #f8fafc); border-radius: 8px;">
                <div class="@(Model.AssetCount > 0 ? "text-dark-emerald" : "text-red")" style="font-size: 2rem; font-weight: 700;">@Model.AssetCount</div>
                <div class="text-theme-muted" style="font-size: 0.75rem; text-transform: uppercase;">Assets</div>
            </div>
            <div style="text-align: center; padding: 1rem; background: var(--lux-surface-alt, #f8fafc); border-radius: 8px;">
                <div class="@(Model.PMTemplateCount > 0 ? "text-dark-emerald" : "text-red")" style="font-size: 2rem; font-weight: 700;">@Model.PMTemplateCount</div>
                <div class="text-theme-muted" style="font-size: 0.75rem; text-transform: uppercase;">PM Templates</div>
            </div>
            <div style="text-align: center; padding: 1rem; background: var(--lux-surface-alt, #f8fafc); border-radius: 8px;">
                <div class="@(Model.PMTemplateAssetCount > 0 ? "text-dark-emerald" : "text-red")" style="font-size: 2rem; font-weight: 700;">@Model.PMTemplateAssetCount</div>
                <div class="text-theme-muted" style="font-size: 0.75rem; text-transform: uppercase;">PM Assignments</div>
            </div>
            <div style="text-align: center; padding: 1rem; background: var(--lux-surface-alt, #f8fafc); border-radius: 8px;">
                <div class="text-theme-primary" style="font-size: 2rem; font-weight: 700;">@Model.MaintenanceEventCount</div>
                <div class="text-theme-muted" style="font-size: 0.75rem; text-transform: uppercase;">Work Orders</div>
            </div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
            <div class="@(Model.CoreLoopReady ? "bg-green-soft" : "bg-amber-soft")" style="padding: 1rem; border-radius: 8px; border: 1px solid @(Model.CoreLoopReady ? "var(--success-soft, #bbf7d0)" : "var(--warning-soft, #fde047)");">
                <div class="text-theme-muted" style="font-size: 0.75rem; text-transform: uppercase; margin-bottom: 0.25rem;">Core Loop Ready</div>
                <div class="@(Model.CoreLoopReady ? "text-dark-emerald" : "text-dark-amber")" style="font-weight: 600;">
                    @(Model.CoreLoopReady ? "YES - Templates & Assignments exist" : "NO - Missing templates or assignments")
                </div>
            </div>
            <div class="@(Model.PMTALinkedWOCount > 0 ? "bg-green-soft" : "bg-surface-alt")" style="padding: 1rem; border-radius: 8px; border: 1px solid @(Model.PMTALinkedWOCount > 0 ? "var(--success-soft, #bbf7d0)" : "var(--lux-border, #e2e8f0)");">
                <div class="text-theme-muted" style="font-size: 0.75rem; text-transform: uppercase; margin-bottom: 0.25rem;">PMTA Linkage Health</div>
                <div class="@(Model.PMTALinkedWOCount > 0 ? "text-dark-emerald" : "text-theme-muted")" style="font-weight: 600;">
                    @Model.PMTALinkedWOCount WOs with PMTA: linkage
                </div>
            </div>
        </div>
    </div>
</div>

<div class="section-card">
    <div class="section-card-header">Configuration & Warnings</div>
    <div class="section-card-body">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1rem;">
            <div class="@(Model.ThrowOnFirstWarning ? "bg-amber-soft" : "bg-green-soft")" style="padding: 1rem; border-radius: 8px; border: 1px solid @(Model.ThrowOnFirstWarning ? "var(--warning-soft, #fde047)" : "var(--success-soft, #bbf7d0)");">
                <div class="text-theme-muted" style="font-size: 0.75rem; text-transform: uppercase; margin-bottom: 0.25rem;">EF Warning Mode</div>
                <div class="@(Model.ThrowOnFirstWarning ? "text-dark-amber" : "text-dark-emerald")" style="font-weight: 600;">
                    @(Model.ThrowOnFirstWarning ? "THROW (Debug Mode)" : "Log (Normal)")
                </div>
                <div class="text-theme-muted" style="font-size: 0.75rem; margin-top: 0.25rem;">
                    THROW_EF_FIRST_WARNING=@(Model.ThrowOnFirstWarning ? "true" : "false")
                </div>
            </div>
            <div style="padding: 1rem; background: var(--lux-surface-alt, #f8fafc); border-radius: 8px; border: 1px solid var(--lux-border, #e2e8f0);">
                <div class="text-theme-muted" style="font-size: 0.75rem; text-transform: uppercase; margin-bottom: 0.25rem;">Seeding Status</div>
                <div class="text-theme-primary" style="font-weight: 600;">@Model.SeedingStatus</div>
                <div class="text-theme-muted" style="font-size: 0.75rem; margin-top: 0.25rem;">
                    AUTO_SEED_ON_EMPTY=@(Model.AutoSeedEnabled ? "true" : "false")
                </div>
            </div>
        </div>
    </div>
</div>

<div class="section-card">
    <div class="section-card-header" style="display: flex; justify-content: space-between; align-items: center;">
        <span>Seed Coverage Health</span>
        <div style="display: flex; gap: 0.5rem;">
            @if (Model.CriticalMissingCount > 0)
            {
                <span class="badge-red">
                    @Model.CriticalMissingCount CRITICAL
                </span>
            }
            @if (Model.WarningCount > 0)
            {
                <span class="badge-amber">
                    @Model.WarningCount WARNING
                </span>
            }
            @if (Model.CriticalMissingCount == 0 && Model.WarningCount == 0)
            {
                <span class="badge-green">
                    ALL OK
                </span>
            }
        </div>
    </div>
    <div class="section-card-body">
        <div style="margin-bottom: 1rem; padding: 0.75rem 1rem; background: var(--lux-surface-alt, #f8fafc); border-radius: 8px; font-size: 0.875rem;">
            <strong>Last Seed Run:</strong> 
            @if (Model.LastSeedRun.HasValue)
            {
                <span>@Model.LastSeedRun.Value.ToString("yyyy-MM-dd HH:mm:ss") UTC</span>
            }
            else
            {
                <span class="text-dark-amber">Never</span>
            }
        </div>
        
        <h4 class="text-theme-secondary" style="font-size: 0.875rem; font-weight: 600; margin-bottom: 0.75rem;">Critical Masters</h4>
        <div class="master-grid">
            @foreach (var master in Model.CriticalMasters)
            {
                <div class="master-item @master.CssClass">
                    <span class="master-name">
                        @master.Name
                        @if (master.IsCritical)
                        {
                            <span class="text-red" style="font-size: 0.625rem; vertical-align: super;">*</span>
                        }
                    </span>
                    <span class="master-count @(master.Count == 0 ? "health-critical" : master.IsHealthy ? "health-ok" : "health-warning")">
                        @master.Count
                    </span>
                </div>
            }
        </div>
        <p class="text-theme-muted" style="font-size: 0.75rem; margin-top: 0.75rem;">* Critical masters required for basic operations</p>
    </div>
</div>

<div class="section-card">
    <div class="section-card-header">Recent Bulk Operations (Latest 10)</div>
    <div class="section-card-body" style="padding: 0;">
        <table class="bulk-ops-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Type</th>
                    <th>Date</th>
                    <th>Affected</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var op in Model.RecentBulkOperations)
                {
                    var isSeed = op.Description?.Contains("SEED") == true;
                    <tr>
                        <td>@op.Id</td>
                        <td>@op.OperationType</td>
                        <td>@op.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@op.AssetsAffected</td>
                        <td>
                            @if (isSeed)
                            {
                                <span class="seed-badge">SEED</span>
                            }
                            @(op.Description?.Length > 60 ? op.Description.Substring(0, 60) + "..." : op.Description)
                        </td>
                    </tr>
                }
                @if (!Model.RecentBulkOperations.Any())
                {
                    <tr>
                        <td colspan="5" class="text-theme-muted" style="text-align: center; padding: 2rem;">No bulk operations recorded</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="section-card">
    <div class="section-card-header">Entity Counts (@Model.EntityCounts.Count DbSets)</div>
    <div class="section-card-body">
        <input type="text" class="search-box" id="entitySearch" placeholder="Search entities..." oninput="filterEntities()" />
        <div class="entity-grid" id="entityGrid">
            @foreach (var entity in Model.EntityCounts)
            {
            <div class="entity-item" data-name="@entity.EntityName.ToLower()">
                <span class="entity-name">@entity.EntityName</span>
                <span class="entity-count @(entity.Count == 0 ? "zero" : entity.Count > 100 ? "high" : "")">
                    @(entity.Count >= 0 ? entity.Count.ToString("N0") : "ERR")
                </span>
            </div>
            }
        </div>
    </div>
</div>

<div class="section-card" style="margin-top: 1.5rem;">
    <div class="section-card-header">
        <h3 class="section-card-title">Technical Mapping (Admin Only)</h3>
    </div>
    <div class="section-card-body text-theme-muted" style="font-size: 0.8rem;">
        <p style="margin: 0 0 0.5rem 0;">Internal entity names for developer reference:</p>
        <ul style="margin: 0; padding-left: 1.5rem; line-height: 1.8;">
            <li><strong>Work Orders</strong> are stored as <code class="code-inline">MaintenanceEvents</code></li>
            <li><strong>Assets</strong> are stored as <code class="code-inline">Assets</code></li>
            <li><strong>CIP Projects</strong> are stored as <code class="code-inline">CipProjects</code></li>
            <li><strong>PM Templates</strong> are stored as <code class="code-inline">PMTemplates</code></li>
        </ul>
    </div>
</div>

<script>
function filterEntities() {
    const query = document.getElementById('entitySearch').value.toLowerCase();
    document.querySelectorAll('.entity-item').forEach(item => {
        const name = item.getAttribute('data-name');
        item.style.display = name.includes(query) ? '' : 'none';
    });
}
</script>
