@page
@model Abs.FixedAssets.Pages.Admin.SeedDataModel
@{
    ViewData["Title"] = "Seed Test Data";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
    var totalTables = Model.TableCounts.Count;
    var tablesWithData = Model.TableCounts.Count(t => t.Value > 0);
    var statusTone = tablesWithData == totalTables ? "active" : tablesWithData > 0 ? "warning" : "inactive";
}

@{
    var headerVd = new ViewDataDictionary(ViewData)
    {
        { "HeaderTitle", "Seed Test Data" },
        { "Subtitle", "Create properly linked test data across all tables to verify data structure integrity" },
        { "TypeLabel", "Administration" },
        { "StatusText", $"{tablesWithData}/{totalTables} Tables Populated" },
        { "StatusTone", statusTone },
        { "KpisPartial", "Admin/_AdminSeedDataKpis" },
        { "ActionsPartial", "Admin/_AdminSeedDataActions" }
    };
}
@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@if (TempData["Success"] != null)
{
    <div class="alert alert-success mb-4">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mb-4">@TempData["Error"]</div>
}

<div class="grid grid-cols-2 gap-4 mb-4">
    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
                </svg>
                Current Data Status
            </h3>
            <span class="status-badge info">@totalTables TABLES</span>
        </div>
        <div class="section-card-body" style="padding: 0;">
            <table class="data-table">
                <thead>
                    <tr><th>Table</th><th>Count</th><th>Status</th></tr>
                </thead>
                <tbody>
                    @foreach (var table in Model.TableCounts)
                    {
                        var statusClass = table.Value > 0 ? "badge-success" : "badge-warning";
                        var statusText = table.Value > 0 ? "Has Data" : "Empty";
                        <tr>
                            <td>@table.Key</td>
                            <td>@table.Value.ToString("N0")</td>
                            <td><span class="badge @statusClass">@statusText</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
                Seed Operations
            </h3>
            <span class="status-badge info">7 STEPS</span>
        </div>
        <div class="section-card-body">
            <p class="text-muted mb-3">These operations will create realistic test data with proper relationships between tables.</p>

            <form method="post" asp-page-handler="SeedItemCategories" class="mb-3">
                <button type="submit" class="btn btn-primary w-full">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="display: inline; vertical-align: middle; margin-right: 6px;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" /></svg>
                    1. Seed Item Categories
                </button>
                <p class="text-sm text-muted mt-1">Creates 8 parts categories (Bearings, Filters, Belts, etc.)</p>
            </form>

            <form method="post" asp-page-handler="SeedItems" class="mb-3">
                <button type="submit" class="btn btn-primary w-full">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="display: inline; vertical-align: middle; margin-right: 6px;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>
                    2. Seed Items (Parts)
                </button>
                <p class="text-sm text-muted mt-1">Creates 50 parts linked to categories, vendors, and locations</p>
            </form>

            <form method="post" asp-page-handler="SeedInventory" class="mb-3">
                <button type="submit" class="btn btn-primary w-full">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="display: inline; vertical-align: middle; margin-right: 6px;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z" /></svg>
                    3. Seed Inventory Levels
                </button>
                <p class="text-sm text-muted mt-1">Creates stock records for all items at various locations</p>
            </form>

            <form method="post" asp-page-handler="SeedKits" class="mb-3">
                <button type="submit" class="btn btn-primary w-full">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="display: inline; vertical-align: middle; margin-right: 6px;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
                    4. Seed Kits & Assemblies
                </button>
                <p class="text-sm text-muted mt-1">Creates 5 maintenance kits with multiple items each</p>
            </form>

            <form method="post" asp-page-handler="SeedWorkOrderParts" class="mb-3">
                <button type="submit" class="btn btn-primary w-full">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="display: inline; vertical-align: middle; margin-right: 6px;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                    5. Consume Inventory (Work Orders)
                </button>
                <p class="text-sm text-muted mt-1">Issues parts to work orders, creates transactions, updates stock</p>
            </form>

            <form method="post" asp-page-handler="GenerateReorderAlerts" class="mb-3">
                <button type="submit" class="btn-p btn-p--secondary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="display: inline; vertical-align: middle; margin-right: 6px;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
                    6. Generate Reorder Alerts
                </button>
                <p class="text-sm text-muted mt-1">Scans inventory and creates alerts for items below reorder point</p>
            </form>

            <form method="post" asp-page-handler="SeedRequisitions" class="mb-3">
                <button type="submit" class="btn btn-primary w-full">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="display: inline; vertical-align: middle; margin-right: 6px;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" /></svg>
                    7. Create Purchase Requisitions
                </button>
                <p class="text-sm text-muted mt-1">Creates requisitions with workflow states (Draft → Pending → Approved)</p>
            </form>

            <hr class="my-4" />

            <form method="post" asp-page-handler="ClearNewData" class="mb-3">
                <button type="submit" class="btn-p btn-p--danger" onclick="return confirm('This will delete Items, Inventory, Kits, WorkOrderParts, and Requisitions. Continue?')">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="display: inline; vertical-align: middle; margin-right: 6px;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                    Clear New Tables Only
                </button>
                <p class="text-sm text-muted mt-1">Removes Items, Inventory, Kits, WorkOrderParts, Requisitions (keeps Assets, Maintenance, Vendors)</p>
            </form>
        </div>
    </div>
</div>
