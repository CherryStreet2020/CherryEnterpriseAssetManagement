@page "/Admin/MakeBuyEngineProbe"
@model Abs.FixedAssets.Pages.Admin.MakeBuyEngineProbeModel
@using Abs.FixedAssets.Services.Production
@using Abs.FixedAssets.Models.Production
@{
    ViewData["Title"] = "Make-or-Buy Engine Probe";
    ViewData["TabTitle"] = "Make-or-Buy Engine Probe";
    Layout = "_ModernLayout";
}

@*
    Theme B7 Wave C PR-8 — IMakeBuyDecisionService. The six-factor make-or-buy engine;
    F2 capacity reads the real R4-10 Load% / R4-11 finite schedule.
*@

<header class="ds-page-header">
    <div class="ds-page-header__inner">
        <h1 class="ds-page-header__title">Make-or-Buy Engine Probe — B7 R-C PR-8</h1>
        <p class="ds-page-header__subtitle">
            <code>IMakeBuyDecisionService.DecideAsync</code> — F1 eligibility · <strong>F2 capacity (real R4 Load%)</strong> ·
            F3 cost delta · F4 break-even · F5 lead-time fit · F6 quality/risk → BuyScore + explainable rationale,
            with hard gates (source-controlled → MAKE, drum-offload → BUY).
        </p>
    </div>
</header>

<main class="ds-page">
    @if (Model.Outcome is not null)
    {
        <section class="ds-card ds-mb-4"><div class="ds-card__body">
            <p class="@(Model.OutcomeIsError ? "ds-text-danger" : "ds-text-success")"><strong>@(Model.OutcomeIsError ? "✗" : "✓")</strong> @Model.Outcome</p>
        </div></section>
    }

    <section class="ds-card ds-mb-4"><div class="ds-card__body">
        <h2 class="ds-h2">Decision flow</h2>
        <p class="ds-text-muted">Company <strong>#@(Model.CompanyId == 0 ? "—" : Model.CompanyId.ToString())</strong> ·
            probe item: <strong>@(Model.ProbeItemId == null ? "—" : "#" + Model.ProbeItemId)</strong> ·
            source-controlled: <strong>@Model.ProbeSourceControlled</strong> · qty 50 · due +21d</p>
        <form method="post" class="ds-btn-row">
            <button type="submit" asp-page-handler="Setup" class="ds-btn ds-btn--primary">1 · Set up worked example</button>
            <button type="submit" asp-page-handler="DecideWhatIf" class="ds-btn">2 · Decide (what-if)</button>
            <button type="submit" asp-page-handler="DecidePersist" class="ds-btn">3 · Decide &amp; persist</button>
            <button type="submit" asp-page-handler="ToggleSourceControlled" class="ds-btn">4 · Toggle source-controlled + decide</button>
            <button type="submit" asp-page-handler="ExplainLatest" class="ds-btn">5 · Explain latest</button>
            <button type="submit" asp-page-handler="Reload" class="ds-btn">Reload</button>
        </form>
    </div></section>

    @if (Model.Result is not null)
    {
        var r = Model.Result;
        <section class="ds-card ds-mb-4"><div class="ds-card__body">
            <h2 class="ds-h2">
                Verdict: <span class="@(r.Outcome == MakeBuyOutcome.Buy ? "ds-text-warning" : "ds-text-success")">@r.Outcome</span>
                @(r.WasHardGated ? "(hard-gated)" : "")
            </h2>
            <p>Buy score <strong>@r.BuyScore.ToString("0.00")</strong> · confidence @r.Confidence.ToString("0.00")
               @(r.PersistedDecisionId != null ? $"· persisted #{r.PersistedDecisionId}" : "")</p>
            <p class="ds-text-muted">@r.RationaleText</p>
            <table class="ds-table">
                <thead><tr><th>Snapshot</th><th>Value</th></tr></thead>
                <tbody>
                    <tr><td>Make cost (fully loaded)</td><td>@(r.MakeCostFullyLoaded?.ToString("N2") ?? "—")</td></tr>
                    <tr><td>Buy cost (landed)</td><td>@(r.BuyCostLanded?.ToString("N2") ?? "—")</td></tr>
                    <tr><td>Bottleneck WC / load</td><td>@(r.BottleneckWorkCenterCode ?? "—") @(r.BottleneckLoadPct?.ToString("0.#") ?? "")@(r.BottleneckLoadPct != null ? "%" : "")@(r.RoutedThroughDrum ? " (drum)" : "")</td></tr>
                    <tr><td>Make completion / Vendor delivery</td><td>@(r.MakeCompletionDate?.ToString("yyyy-MM-dd") ?? "—") / @(r.VendorDeliveryDate?.ToString("yyyy-MM-dd") ?? "—")</td></tr>
                    <tr><td>Chosen supplier / quote</td><td>@(r.ChosenSupplierId?.ToString() ?? "—") / @(r.ChosenQuoteId?.ToString() ?? "—")</td></tr>
                </tbody>
            </table>
        </div></section>

        <section class="ds-card"><div class="ds-card__body">
            <h2 class="ds-h2">Factor breakdown</h2>
            <table class="ds-table">
                <thead><tr><th>Factor</th><th>Score (→BUY)</th><th>Weight</th><th>Weighted</th><th>Reason</th></tr></thead>
                <tbody>
                    @foreach (var f in r.Factors)
                    {
                        <tr>
                            <td><strong>@f.Code</strong> @f.Label</td>
                            <td>@f.Score.ToString("0.00")</td>
                            <td>@f.Weight.ToString("0.00")</td>
                            <td>@f.WeightedImpact.ToString("0.000")</td>
                            <td class="ds-text-muted">@f.Reason</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div></section>
    }
</main>
