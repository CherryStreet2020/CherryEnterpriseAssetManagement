@model Abs.FixedAssets.Pages.Admin.TenantsModel
@{
    var totalTenants = Model.Tenants.Count;
    var activeTenants = Model.Tenants.Count(t => t.IsActive);
    var totalCompanies = Model.Tenants.Sum(t => t.Companies?.Count ?? 0);
}
<div class="kpi-card">
    <div class="kpi-label">Total</div>
    <div class="kpi-value">@totalTenants</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Active</div>
    <div class="kpi-value success">@activeTenants</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Companies</div>
    <div class="kpi-value info">@totalCompanies</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Current</div>
    <div class="kpi-value primary">@Model.CurrentTenantId</div>
</div>
