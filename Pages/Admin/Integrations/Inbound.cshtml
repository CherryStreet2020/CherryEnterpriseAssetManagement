@page
@model Abs.FixedAssets.Pages.Admin.Integrations.InboundModel
@{
    ViewData["Title"] = "Inbound Event Queue";
    ViewData["TabTitle"] = "Inbound Queue";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
}

@{
    var headerVd = new ViewDataDictionary(ViewData)
    {
        { "HeaderTitle", "Inbound Event Queue" },
        { "Subtitle", "Monitor and manage incoming webhook events" },
        { "TypeLabel", "Integrations" },
        { "StatusText", Model.IsLabEnvironment ? "LAB" : "" },
        { "StatusTone", "info" },
        { "KpisPartial", "Admin/Integrations/_AdminIntegrationsInboundKpis" },
        { "ActionsPartial", "Admin/Integrations/_AdminIntegrationsInboundActions" }
    };
}
@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@if (!Model.IsLabEnvironment)
{
    <div class="content-area">
        <div class="bg-red-50 border border-red-200 rounded-xl p-6 text-center">
            <h2 class="text-xl font-bold text-red-700 mb-2">Access Restricted</h2>
            <p class="text-red-600">Inbound queue management is only available in LAB environment.</p>
        </div>
    </div>
    return;
}

<div class="content-area">
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="mb-4 p-3 bg-green-50 border border-green-200 rounded-lg text-green-700">
            @Model.SuccessMessage
        </div>
    }

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 mb-4">
        <div class="border-b border-slate-200 px-4">
            <nav class="flex gap-4">
                <a href="?tab=pending" class="px-3 py-3 text-sm font-medium border-b-2 @(Model.CurrentTab == "pending" ? "border-blue-500 text-blue-600" : "border-transparent text-slate-500 hover:text-slate-700")">
                    Pending (@Model.PendingCount)
                </a>
                <a href="?tab=processed" class="px-3 py-3 text-sm font-medium border-b-2 @(Model.CurrentTab == "processed" ? "border-blue-500 text-blue-600" : "border-transparent text-slate-500 hover:text-slate-700")">
                    Processed
                </a>
                <a href="?tab=failed" class="px-3 py-3 text-sm font-medium border-b-2 @(Model.CurrentTab == "failed" ? "border-blue-500 text-blue-600" : "border-transparent text-slate-500 hover:text-slate-700")">
                    Failed (@Model.FailedCount)
                </a>
                <a href="?tab=deadletter" class="px-3 py-3 text-sm font-medium border-b-2 @(Model.CurrentTab == "deadletter" ? "border-blue-500 text-blue-600" : "border-transparent text-slate-500 hover:text-slate-700")">
                    Dead Letter (@Model.DeadLetterCount)
                </a>
            </nav>
        </div>

        <table class="min-w-full divide-y divide-slate-200">
            <thead class="bg-slate-50">
                <tr>
                    <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">ID</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Integration</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Event Type</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">External ID</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Received</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Attempts</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Last Error</th>
                    <th class="px-4 py-3 text-right text-xs font-medium text-slate-500 uppercase">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
                @foreach (var evt in Model.Events)
                {
                    <tr>
                        <td class="px-4 py-3 text-sm font-mono">@evt.Id</td>
                        <td class="px-4 py-3 text-sm">@evt.IntegrationEndpoint?.Name</td>
                        <td class="px-4 py-3">
                            <code class="text-xs bg-slate-100 px-2 py-1 rounded">@evt.EventType</code>
                        </td>
                        <td class="px-4 py-3 text-xs font-mono text-slate-500">@(evt.ExternalEntityId ?? "-")</td>
                        <td class="px-4 py-3 text-xs text-slate-500">@evt.ReceivedAt.ToString("MMM d, HH:mm:ss")</td>
                        <td class="px-4 py-3 text-sm">@evt.AttemptCount</td>
                        <td class="px-4 py-3 text-xs text-red-600 max-w-xs truncate" title="@evt.LastError">
                            @(evt.LastError ?? "-")
                        </td>
                        <td class="px-4 py-3 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <button type="button" onclick="showPayload(@evt.Id)" class="text-xs px-2 py-1 rounded border border-slate-200 text-slate-600 hover:bg-slate-50">
                                    View
                                </button>
                                @if (evt.Status == Abs.FixedAssets.Models.InboundEventStatus.Failed || evt.Status == Abs.FixedAssets.Models.InboundEventStatus.DeadLetter)
                                {
                                    <form method="post" asp-page-handler="Retry" class="inline">
                                        <input type="hidden" name="eventId" value="@evt.Id" />
                                        <input type="hidden" name="tab" value="@Model.CurrentTab" />
                                        <button type="submit" class="text-xs px-2 py-1 rounded border border-green-200 text-green-600 hover:bg-green-50">
                                            Retry
                                        </button>
                                    </form>
                                }
                                @if (evt.Status == Abs.FixedAssets.Models.InboundEventStatus.Processed)
                                {
                                    <form method="post" asp-page-handler="Replay" class="inline">
                                        <input type="hidden" name="eventId" value="@evt.Id" />
                                        <input type="hidden" name="tab" value="@Model.CurrentTab" />
                                        <button type="submit" class="text-xs px-2 py-1 rounded border border-blue-200 text-blue-600 hover:bg-blue-50">
                                            Replay
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Events.Any())
                {
                    <tr>
                        <td colspan="8" class="px-4 py-8 text-center text-slate-500">
                            No events in this queue.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div id="payloadFormPanel" class="inline-form-panel" style="display: none;">
    <div class="bg-white rounded-xl shadow-xl max-w-2xl w-full mx-4 p-6 max-h-[80vh] overflow-auto">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-bold text-slate-900">Event Payload</h2>
            <button type="button" onclick="hidePayloadForm()" class="text-slate-400 hover:text-slate-600">&times;</button>
        </div>
        <pre id="payloadContent" class="bg-slate-900 text-green-400 p-4 rounded-lg text-xs font-mono overflow-x-auto"></pre>
    </div>
</div>

<script>
    const payloads = {
        @foreach (var evt in Model.Events)
        {
            @:@evt.Id: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(evt.RawBodyJson)),
        }
    };

    function showPayload(id) {
        try {
            const formatted = JSON.stringify(JSON.parse(payloads[id]), null, 2);
            document.getElementById('payloadContent').textContent = formatted;
        } catch {
            document.getElementById('payloadContent').textContent = payloads[id];
        }
        document.getElementById('payloadFormPanel').style.display = '';
        document.getElementById('payloadFormPanel');
    }

    function hidePayloadForm() {
        document.getElementById('payloadFormPanel').style.display = 'none';
        document.getElementById('payloadFormPanel');
    }
</script>
