@{
    var model = ViewData["PageModel"] as Abs.FixedAssets.Pages.Admin.KitsModel;
    var totalKits = model?.Kits.Count ?? 0;
    var activeKits = model?.Kits.Count(k => k.IsActive) ?? 0;
}
<div class="kpi-card">
    <div class="kpi-label">Total</div>
    <div class="kpi-value">@totalKits</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Active</div>
    <div class="kpi-value success">@activeKits</div>
</div>
