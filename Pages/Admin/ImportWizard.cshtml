@page
@model Abs.FixedAssets.Pages.Admin.ImportWizardModel
@using Abs.FixedAssets.Services
@{
    ViewData["Title"] = "Import Wizard";
    ViewData["TabTitle"] = "Import Wizard";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";

    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = "Import Wizard",
        ["Subtitle"] = "Step-by-step master data import with templates, validation, and preview",
        ["TypeLabel"] = "Administration",
        ["StatusText"] = $"Step {Model.CurrentStep + 1} of {TemplateService.Steps.Length}",
        ["StatusTone"] = "info"
    };

    var steps = TemplateService.Steps;
    var activeStep = Model.CurrentStep >= 0 && Model.CurrentStep < steps.Length ? steps[Model.CurrentStep] : steps[0];
    var activeEntity = activeStep.Key;
    var entityCount = Model.EntityCounts.GetValueOrDefault(activeEntity, 0);

    string StepState(string key) => Model.StepStates.GetValueOrDefault(key, "notstarted");
}

@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success" style="margin-bottom:1rem;">@success</div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger" style="margin-bottom:1rem;">@error</div>
}

<div class="iw-progress">
    <div class="iw-progress-bar" style="width:@((Model.CurrentStep) * 100.0 / steps.Length)%"></div>
</div>

<div class="iw-layout">
    <div class="iw-sidebar">
        <div class="iw-sidebar-title"><i class="fas fa-list-ol"></i> Import Steps</div>
        @for (int i = 0; i < steps.Length; i++)
        {
            var s = steps[i];
            var state = StepState(s.Key);
            var isCurrent = i == Model.CurrentStep;
            var cnt = Model.EntityCounts.GetValueOrDefault(s.Key, 0);
            <a href="/Admin/ImportWizard?step=@i"
               class="iw-step @(isCurrent ? "iw-step--active" : "") @(state == "completed" ? "iw-step--done" : "") @(state == "skipped" ? "iw-step--skip" : "") @(state == "haserrors" ? "iw-step--err" : "")">
                <span class="iw-step-num">
                    @if (state == "completed") { <i class="fas fa-check"></i> }
                    else if (state == "skipped") { <i class="fas fa-forward"></i> }
                    else if (state == "haserrors") { <i class="fas fa-exclamation-triangle"></i> }
                    else { @(i + 1) }
                </span>
                <span class="iw-step-info">
                    <span class="iw-step-label">@s.Label</span>
                    <span class="iw-step-count">@cnt records</span>
                </span>
            </a>
        }
    </div>

    <div class="iw-main">
        <div class="pe-card" style="padding:1.5rem;">
            <div class="iw-step-header">
                <div>
                    <div class="iw-step-title"><i class="fas @activeStep.Icon" style="color:var(--cherry-red, #cf3339); margin-right:0.5rem;"></i> Step @(Model.CurrentStep + 1): @activeStep.Label</div>
                    <div class="iw-step-desc">@activeStep.Description</div>
                </div>
                <div class="iw-step-badge">
                    <span style="font-size:1.5rem; font-weight:700; font-variant-numeric:tabular-nums; color:var(--text-primary);">@entityCount</span>
                    <span style="font-size:0.65rem; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; color:var(--text-muted);">Current Records</span>
                </div>
            </div>

            <div class="iw-section">
                <div class="iw-section-label"><i class="fas fa-download"></i> 1. Download Template</div>
                <p style="font-size:0.85rem; color:var(--text-secondary); margin:0 0 0.75rem;">
                    Download the Excel template, fill it out with your data, then upload it below.
                    <strong style="color:var(--cherry-red);">Red columns</strong> are required.
                    <span style="color:var(--info);">Blue columns</span> are optional.
                </p>
                <a href="/Admin/ImportWizard?handler=DownloadTemplate&entity=@activeEntity"
                   class="btn-p btn-p--primary btn-p--sm">
                    <i class="fas fa-file-excel"></i> Download @activeStep.Label Template (.xlsx)
                </a>
            </div>

            <div class="iw-section">
                <div class="iw-section-label"><i class="fas fa-upload"></i> 2. Upload & Validate</div>
                <form method="post" enctype="multipart/form-data" id="uploadForm">
                    <input type="hidden" name="entity" value="@activeEntity" />
                    <input type="hidden" name="step" value="@Model.CurrentStep" />
                    <div class="iw-upload-zone" id="dropZone">
                        <i class="fas fa-cloud-upload-alt" style="font-size:2rem; color:var(--text-muted); margin-bottom:0.5rem;"></i>
                        <div style="font-size:0.9rem; color:var(--text-primary); font-weight:600;">Drop your Excel file here</div>
                        <div style="font-size:0.8rem; color:var(--text-muted); margin:0.25rem 0 0.75rem;">or click to browse</div>
                        <input type="file" name="file" id="fileInput" accept=".xlsx,.xls,.csv" style="display:none;" />
                        <button type="button" onclick="document.getElementById('fileInput').click()" class="btn-p btn-p--secondary btn-p--sm">
                            <i class="fas fa-folder-open"></i> Choose File
                        </button>
                        <div id="fileName" style="font-size:0.8rem; color:var(--text-muted); margin-top:0.5rem;"></div>
                    </div>
                    <div style="display:flex; gap:0.5rem; margin-top:0.75rem;">
                        <button type="submit" asp-page-handler="Validate" class="btn-p btn-p--secondary btn-p--sm" id="validateBtn" disabled>
                            <i class="fas fa-check-double"></i> Validate
                        </button>
                        <button type="submit" asp-page-handler="Import" class="btn-p btn-p--primary btn-p--sm" id="importBtn" disabled>
                            <i class="fas fa-file-import"></i> Import Data
                        </button>
                    </div>
                </form>
            </div>

            @if (Model.ValidationResult != null)
            {
                <div class="iw-section">
                    <div class="iw-section-label"><i class="fas fa-clipboard-check"></i> Validation Results</div>
                    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:0.75rem; margin-bottom:1rem;">
                        <div class="iw-stat iw-stat--success">
                            <div class="iw-stat-val">@Model.ValidationResult.ValidRows</div>
                            <div class="iw-stat-lbl">Valid Rows</div>
                        </div>
                        <div class="iw-stat iw-stat--danger">
                            <div class="iw-stat-val">@Model.ValidationResult.ErrorRows</div>
                            <div class="iw-stat-lbl">Error Rows</div>
                        </div>
                        <div class="iw-stat">
                            <div class="iw-stat-val">@Model.ValidationResult.TotalRows</div>
                            <div class="iw-stat-lbl">Total Rows</div>
                        </div>
                    </div>
                    @if (Model.ValidationResult.Errors.Any())
                    {
                        <div class="iw-errors">
                            <div class="iw-errors-title"><i class="fas fa-times-circle"></i> Errors (@Model.ValidationResult.Errors.Count)</div>
                            <table class="line-table" style="font-size:0.8rem;">
                                <thead>
                                    <tr>
                                        <th style="width:60px;">Row</th>
                                        <th style="width:150px;">Column</th>
                                        <th>Error</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var err in Model.ValidationResult.Errors.Take(50))
                                    {
                                        <tr>
                                            <td>@err.Row</td>
                                            <td>@err.Column</td>
                                            <td style="color:var(--danger, #ef4444);">@err.Message</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            @if (Model.ValidationResult.Errors.Count > 50)
                            {
                                <div style="font-size:0.8rem; color:var(--text-muted); padding:0.5rem;">Showing first 50 of @Model.ValidationResult.Errors.Count errors</div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="iw-valid-msg">
                            <i class="fas fa-check-circle" style="color:var(--success); margin-right:0.5rem;"></i>
                            All @Model.ValidationResult.ValidRows rows passed validation. You can now import.
                        </div>
                    }
                </div>
            }

            @if (Model.LastImportResult != null)
            {
                <div class="iw-section">
                    <div class="iw-section-label"><i class="fas fa-database"></i> Import Results</div>
                    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:0.75rem; margin-bottom:1rem;">
                        <div class="iw-stat iw-stat--success">
                            <div class="iw-stat-val">@Model.LastImportResult.ImportedCount</div>
                            <div class="iw-stat-lbl">Imported</div>
                        </div>
                        <div class="iw-stat iw-stat--warning">
                            <div class="iw-stat-val">@Model.LastImportResult.SkippedCount</div>
                            <div class="iw-stat-lbl">Skipped</div>
                        </div>
                        <div class="iw-stat iw-stat--danger">
                            <div class="iw-stat-val">@Model.LastImportResult.FailedCount</div>
                            <div class="iw-stat-lbl">Failed</div>
                        </div>
                    </div>
                    @if (Model.LastImportResult.Errors.Any())
                    {
                        <div class="iw-errors">
                            <div class="iw-errors-title"><i class="fas fa-times-circle"></i> Errors</div>
                            <table class="line-table" style="font-size:0.8rem;">
                                <thead>
                                    <tr>
                                        <th style="width:60px;">Row</th>
                                        <th style="width:150px;">Column</th>
                                        <th>Error</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var err in Model.LastImportResult.Errors.Take(50))
                                    {
                                        <tr>
                                            <td>@err.Row</td>
                                            <td>@err.Column</td>
                                            <td style="color:var(--danger, #ef4444);">@err.Message</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            }

            <div class="iw-nav">
                @if (Model.CurrentStep > 0)
                {
                    <a href="/Admin/ImportWizard?step=@(Model.CurrentStep - 1)" class="btn-p btn-p--secondary btn-p--sm">
                        <i class="fas fa-arrow-left"></i> Previous
                    </a>
                }
                else
                {
                    <span></span>
                }
                <div style="display:flex; gap:0.5rem;">
                    <form method="post" style="display:inline;">
                        <input type="hidden" name="entity" value="@activeEntity" />
                        <input type="hidden" name="step" value="@Model.CurrentStep" />
                        <button type="submit" asp-page-handler="Skip" class="btn-p btn-p--secondary btn-p--sm">
                            <i class="fas fa-forward"></i> Skip Step
                        </button>
                    </form>
                    @if (Model.CurrentStep < steps.Length - 1)
                    {
                        <a href="/Admin/ImportWizard?step=@(Model.CurrentStep + 1)" class="btn-p btn-p--primary btn-p--sm">
                            Next <i class="fas fa-arrow-right"></i>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.iw-progress { height:4px; background:var(--border-subtle, rgba(255,255,255,0.06)); border-radius:2px; margin-bottom:1rem; overflow:hidden; }
.iw-progress-bar { height:100%; background:var(--cherry-red, #cf3339); border-radius:2px; transition:width 0.3s; }

.iw-layout { display:grid; grid-template-columns:260px 1fr; gap:1rem; min-height:600px; }

.iw-sidebar {
    background:var(--surface-card, rgba(255,255,255,0.03));
    border:1px solid var(--border-subtle, rgba(255,255,255,0.06));
    border-radius:10px; padding:0.75rem; overflow-y:auto;
}
.iw-sidebar-title {
    font-size:0.65rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em;
    color:var(--text-muted); padding:0.5rem 0.5rem 0.75rem; display:flex; align-items:center; gap:0.4rem;
}

.iw-step {
    display:flex; align-items:center; gap:0.6rem; padding:0.5rem 0.6rem; border-radius:8px;
    text-decoration:none; margin-bottom:0.2rem; transition:all 0.15s; cursor:pointer;
    border:1px solid transparent;
}
.iw-step:hover { background:var(--surface-hover, rgba(255,255,255,0.04)); }
.iw-step--active { background:var(--cherry-red, #cf3339) !important; border-color:var(--cherry-red) !important; }
.iw-step--active * { color:#fff !important; }
.iw-step--done .iw-step-num { background:var(--success, #22c55e); color:#fff; }
.iw-step--skip .iw-step-num { background:var(--text-muted); color:#fff; }
.iw-step--err .iw-step-num { background:var(--danger, #ef4444); color:#fff; }

.iw-step-num {
    width:28px; height:28px; border-radius:50%; display:flex; align-items:center; justify-content:center;
    font-size:0.7rem; font-weight:700; flex-shrink:0;
    background:var(--surface-input, rgba(255,255,255,0.05)); color:var(--text-muted);
    border:1px solid var(--border-default, rgba(255,255,255,0.1));
}
.iw-step-info { display:flex; flex-direction:column; overflow:hidden; }
.iw-step-label { font-size:0.8rem; font-weight:600; color:var(--text-primary); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.iw-step-count { font-size:0.65rem; color:var(--text-muted); }

.iw-main { min-width:0; }

.iw-step-header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:1.25rem; gap:1rem; }
.iw-step-title { font-size:1.1rem; font-weight:700; color:var(--text-primary); margin-bottom:0.25rem; }
.iw-step-desc { font-size:0.85rem; color:var(--text-secondary); }
.iw-step-badge { display:flex; flex-direction:column; align-items:center; padding:0.5rem 1rem; background:var(--surface-input, rgba(255,255,255,0.05)); border-radius:8px; border:1px solid var(--border-subtle, rgba(255,255,255,0.06)); }

.iw-section { padding:1rem 0; border-top:1px solid var(--border-subtle, rgba(255,255,255,0.06)); }
.iw-section-label {
    font-size:0.65rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em;
    color:var(--cherry-red, #cf3339); margin-bottom:0.75rem; display:flex; align-items:center; gap:0.4rem;
}

.iw-upload-zone {
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    padding:2rem; border:2px dashed var(--border-default, rgba(255,255,255,0.1));
    border-radius:10px; text-align:center; transition:all 0.2s; cursor:pointer;
}
.iw-upload-zone:hover, .iw-upload-zone.dragover { border-color:var(--cherry-red, #cf3339); background:rgba(207,51,57,0.05); }

.iw-stat {
    padding:0.75rem; text-align:center; border-radius:8px;
    background:var(--surface-input, rgba(255,255,255,0.05)); border:1px solid var(--border-subtle, rgba(255,255,255,0.06));
}
.iw-stat-val { font-size:1.5rem; font-weight:700; font-variant-numeric:tabular-nums; color:var(--text-primary); }
.iw-stat-lbl { font-size:0.6rem; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; color:var(--text-muted); }
.iw-stat--success .iw-stat-val { color:var(--success, #22c55e); }
.iw-stat--danger .iw-stat-val { color:var(--danger, #ef4444); }
.iw-stat--warning .iw-stat-val { color:var(--warning, #f59e0b); }

.iw-errors { background:rgba(239,68,68,0.05); border:1px solid rgba(239,68,68,0.15); border-radius:8px; padding:0.75rem; }
.iw-errors-title { font-size:0.7rem; font-weight:700; color:var(--danger, #ef4444); margin-bottom:0.5rem; display:flex; align-items:center; gap:0.3rem; }

.iw-valid-msg {
    padding:0.75rem 1rem; background:rgba(34,197,94,0.08); border:1px solid rgba(34,197,94,0.2);
    border-radius:8px; font-size:0.85rem; color:var(--success, #22c55e); font-weight:500;
    display:flex; align-items:center;
}

.iw-nav { display:flex; justify-content:space-between; align-items:center; padding-top:1rem; border-top:1px solid var(--border-subtle, rgba(255,255,255,0.06)); margin-top:0.5rem; }

html:not(.dark) .iw-sidebar { background:#fff; border-color:#e2e8f0; }
html:not(.dark) .iw-step:hover { background:#f8fafc; }
html:not(.dark) .iw-upload-zone { border-color:#e2e8f0; }
html:not(.dark) .iw-upload-zone:hover { background:rgba(207,51,57,0.03); }
html:not(.dark) .iw-stat { background:#f8fafc; border-color:#e2e8f0; }
html:not(.dark) .iw-step-badge { background:#f8fafc; border-color:#e2e8f0; }

@@media (max-width: 768px) {
    .iw-layout { grid-template-columns:1fr; }
    .iw-sidebar { display:none; }
}
</style>

@section Scripts {
<script>
var fileInput = document.getElementById('fileInput');
var dropZone = document.getElementById('dropZone');
var validateBtn = document.getElementById('validateBtn');
var importBtn = document.getElementById('importBtn');
var fileNameEl = document.getElementById('fileName');

fileInput.addEventListener('change', function() {
    if (fileInput.files.length > 0) {
        fileNameEl.textContent = fileInput.files[0].name;
        validateBtn.disabled = false;
        importBtn.disabled = false;
    }
});

dropZone.addEventListener('click', function(e) {
    if (e.target === dropZone || e.target.tagName === 'I' || e.target.tagName === 'DIV') {
        fileInput.click();
    }
});

dropZone.addEventListener('dragover', function(e) { e.preventDefault(); dropZone.classList.add('dragover'); });
dropZone.addEventListener('dragleave', function() { dropZone.classList.remove('dragover'); });
dropZone.addEventListener('drop', function(e) {
    e.preventDefault();
    dropZone.classList.remove('dragover');
    if (e.dataTransfer.files.length > 0) {
        fileInput.files = e.dataTransfer.files;
        fileNameEl.textContent = e.dataTransfer.files[0].name;
        validateBtn.disabled = false;
        importBtn.disabled = false;
    }
});

@if (TempData["ValidationPassed"] != null)
{
    <text>importBtn.classList.add('btn-p--primary');importBtn.classList.remove('btn-p--secondary');</text>
}
</script>
}
