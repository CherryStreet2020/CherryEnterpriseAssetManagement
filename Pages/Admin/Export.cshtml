@page
@model Abs.FixedAssets.Pages.Admin.ExportModel
@{
    ViewData["Title"] = "File Export";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
    var totalRecords = Model.AssetCount + Model.ItemCount + Model.VendorCount + Model.MaintenanceCount;

    var headerVd = new ViewDataDictionary(ViewData) {
        { "TypeLabel", "Tools" },
        { "HeaderTitle", "File Export" },
        { "Subtitle", "Export data to CSV files for reporting and backup" },
        { "StatusText", "Ready" },
        { "StatusTone", "info" },
        { "ContextPartial", "Admin/_AdminExportContext" },
        { "KpisPartial", "Admin/_AdminExportKpis" },
        { "ActionsPartial", "Admin/_AdminExportActions" },
        { "PageModel", Model }
    };
}

@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

<div class="section-card mb-4">
    <div class="section-card-header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
            Master Data Exports
        </h3>
        <span class="status-badge info">3 CATEGORIES</span>
    </div>
    <div class="section-card-body">
        <div class="grid grid-cols-3 gap-4">
            <div class="card">
                <div class="card-body">
                    <h3><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="text-blue" data-csp-style="display: inline; vertical-align: middle; margin-right: 8px;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg> Assets</h3>
                    <p class="text-muted">Export all fixed assets with full details</p>
                    <p class="text-sm">@Model.AssetCount assets available</p>
                    <form method="post" asp-page-handler="ExportAssets" class="mt-2">
                        <select name="Format" class="form-control mb-2">
                            <option value="csv">CSV</option>
                        </select>
                        <button type="submit" class="btn-p btn-p--secondary">Export Assets</button>
                    </form>
                </div>
            </div>
            <div class="card">
                <div class="card-body">
                    <h3><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="text-amber" data-csp-style="display: inline; vertical-align: middle; margin-right: 8px;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg> Items</h3>
                    <p class="text-muted">Export inventory items and stock levels</p>
                    <p class="text-sm">@Model.ItemCount items available</p>
                    <form method="post" asp-page-handler="ExportItems" class="mt-2">
                        <select name="Format" class="form-control mb-2">
                            <option value="csv">CSV</option>
                        </select>
                        <button type="submit" class="btn-p btn-p--secondary">Export Items</button>
                    </form>
                </div>
            </div>
            <div class="card">
                <div class="card-body">
                    <h3><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="text-green" data-csp-style="display: inline; vertical-align: middle; margin-right: 8px;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg> Vendors</h3>
                    <p class="text-muted">Export vendor master data</p>
                    <p class="text-sm">@Model.VendorCount vendors available</p>
                    <form method="post" asp-page-handler="ExportVendors" class="mt-2">
                        <select name="Format" class="form-control mb-2">
                            <option value="csv">CSV</option>
                        </select>
                        <button type="submit" class="btn-p btn-p--secondary">Export Vendors</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="section-card">
    <div class="section-card-header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Transaction Exports
        </h3>
        <span class="status-badge info">2 CATEGORIES</span>
    </div>
    <div class="section-card-body">
        <div class="grid grid-cols-2 gap-4">
            <div class="card">
                <div class="card-body">
                    <h3><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="text-purple" data-csp-style="display: inline; vertical-align: middle; margin-right: 8px;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg> Work Orders</h3>
                    <p class="text-muted">Export work order history and maintenance records</p>
                    <p class="text-sm">@Model.MaintenanceCount records available</p>
                    <form method="post" asp-page-handler="ExportMaintenance" class="mt-2">
                        <div class="form-group">
                            <label class="form-label">Date Range</label>
                            <div class="grid grid-cols-2 gap-2">
                                <input type="date" name="StartDate" class="form-control" />
                                <input type="date" name="EndDate" class="form-control" />
                            </div>
                        </div>
                        <button type="submit" class="btn-p btn-p--secondary">Export Maintenance</button>
                    </form>
                </div>
            </div>
            <div class="card">
                <div class="card-body">
                    <h3><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="text-cyan" data-csp-style="display: inline; vertical-align: middle; margin-right: 8px;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" /></svg> Depreciation Schedule</h3>
                    <p class="text-muted">Export depreciation data for all books</p>
                    <form method="post" asp-page-handler="ExportDepreciation" class="mt-2">
                        <div class="form-group">
                            <label class="form-label">Book</label>
                            <select name="BookId" class="form-control">
                                <option value="">All Books</option>
                                @foreach (var book in Model.Books)
                                {
                                    <option value="@book.Id">@book.Name</option>
                                }
                            </select>
                        </div>
                        <button type="submit" class="btn-p btn-p--secondary">Export Depreciation</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
