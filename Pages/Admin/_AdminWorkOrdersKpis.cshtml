@model Abs.FixedAssets.Pages.Admin.WorkOrdersModel
@{
}
<div class="kpi-card">
    <div class="kpi-label">Open</div>
    <div class="kpi-value">@Model.OpenCount</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">In Progress</div>
    <div class="kpi-value warning">@Model.InProgressCount</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Completed</div>
    <div class="kpi-value success">@Model.CompletedCount</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Parts Cost (MTD)</div>
    <div class="kpi-value money">@Model.TotalPartsCost.ToString("C0")</div>
</div>
