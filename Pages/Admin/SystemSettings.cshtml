@page
@model Abs.FixedAssets.Pages.Admin.SystemSettingsModel
@{
    ViewData["Title"] = "System Settings";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
    var lockedCount = Model.LockedPeriods.Count(p => p.IsLocked);
    var statusText = lockedCount > 0 ? $"{lockedCount} Locked" : "All Open";
    var statusTone = lockedCount > 0 ? "warning" : "success";
}

@{
    var headerVd = new ViewDataDictionary(ViewData)
    {
        { "HeaderTitle", "System Settings" },
        { "Subtitle", "Configure system behavior, period locking, and defaults" },
        { "TypeLabel", "Administration" },
        { "StatusText", statusText },
        { "StatusTone", statusTone },
        { "KpisPartial", "Admin/_AdminSystemSettingsKpis" },
        { "ActionsPartial", "Admin/_AdminSystemSettingsActions" }
    };
}
@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}

<div class="settings-grid">
    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
                Period Locking
            </h3>
        </div>
        <div class="section-card-body">
            <p class="setting-description">Lock accounting periods to prevent modifications to transactions. Once locked, no assets, depreciation, or journal entries can be modified for that period.</p>
            
            <form method="post" asp-page-handler="LockPeriod" class="lock-form" id="lockForm">
                <div class="form-row">
                    <div class="form-group">
                        <label>Period (YYYYMM)</label>
                        <input type="number" name="period" class="form-control" placeholder="202601" value="@(DateTime.Now.Year * 100 + DateTime.Now.Month)" />
                    </div>
                    <div class="form-group">
                        <label>&nbsp;</label>
                        <button type="submit" class="btn-p btn-p--secondary">Lock Period</button>
                    </div>
                </div>
            </form>

            @if (Model.LockedPeriods.Any())
            {
                <div class="locked-periods">
                    <h4>Locked Periods</h4>
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Period</th>
                                <th>Locked At</th>
                                <th>Locked By</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var period in Model.LockedPeriods)
                            {
                                <tr>
                                    <td><strong>@period.Period</strong></td>
                                    <td>@period.LockedAt.ToString("MM/dd/yyyy")</td>
                                    <td>@(period.LockedBy ?? "System")</td>
                                    <td><span class="badge @(period.IsLocked ? "badge-danger" : "badge-success")">@(period.IsLocked ? "Locked" : "Unlocked")</span></td>
                                    <td>
                                        <form method="post" asp-page-handler="UnlockPeriod" style="display: inline;">
                                            <input type="hidden" name="id" value="@period.Id" />
                                            <button type="submit" class="btn-p btn-p--danger btn-p--sm" onclick="return confirm('Unlock this period? Users will be able to modify transactions.')">Unlock</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted" style="margin-top: 16px;">No periods are currently locked.</p>
            }
        </div>
    </div>

    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                </svg>
                Depreciation Settings
            </h3>
        </div>
        <div class="section-card-body">
            <p class="setting-description">Configure default depreciation behavior. These settings can be overridden at the company or asset level.</p>
            
            <div class="setting-item">
                <div class="setting-label">Auto-Run Monthly Depreciation</div>
                <div class="setting-control">
                    <label class="toggle">
                        <input type="checkbox" checked />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>
            
            <div class="setting-item">
                <div class="setting-label">Calculate Depreciation on Weekends</div>
                <div class="setting-control">
                    <label class="toggle">
                        <input type="checkbox" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>
            
            <div class="setting-item">
                <div class="setting-label">Round Depreciation to Nearest Dollar</div>
                <div class="setting-control">
                    <label class="toggle">
                        <input type="checkbox" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>
        </div>
    </div>

    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
                </svg>
                Data Retention
            </h3>
        </div>
        <div class="section-card-body">
            <p class="setting-description">Configure how long historical data is retained. Disposed assets and old audit logs can be automatically archived.</p>
            
            <div class="form-group">
                <label>Archive disposed assets after (years)</label>
                <select class="form-control" style="max-width: 200px;" asp-items="Model.RetentionOptions"></select>
            </div>
            
            <div class="form-group">
                <label>Retain audit logs for (years)</label>
                <select class="form-control" style="max-width: 200px;" asp-items="Model.RetentionOptions"></select>
            </div>
        </div>
    </div>
</div>
