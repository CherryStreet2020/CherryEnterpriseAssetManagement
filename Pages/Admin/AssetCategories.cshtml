@page
@model Abs.FixedAssets.Pages.Admin.AssetCategoriesModel
@{
    ViewData["Title"] = "Asset Categories";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
    var totalCategories = Model.AssetCategories.Count;
    var activeCategories = Model.AssetCategories.Count(c => c.IsActive);
    
    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = "Asset Categories",
        ["Subtitle"] = "Define asset categories with default depreciation settings and GL mappings",
        ["TypeLabel"] = "Administration",
        ["StatusText"] = $"{activeCategories} Active",
        ["StatusTone"] = "active",
        ["ContextPartial"] = "/Pages/Admin/_AdminAssetCategoriesContext.cshtml",
        ["KpisPartial"] = "/Pages/Admin/_AdminAssetCategoriesKpis.cshtml",
        ["ActionsPartial"] = "/Pages/Admin/_AdminAssetCategoriesActions.cshtml"
    };
}

@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="section-card">
    <div class="section-card-header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
            </svg>
            All Categories
        </h3>
        <span class="status-badge info">@totalCategories CATEGORIES</span>
    </div>
    <div class="section-card-body" style="padding: 0;">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>MACRS Class</th>
                    <th>Useful Life</th>
                    <th>Salvage %</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var category in Model.AssetCategories)
                {
                    <tr>
                        <td><strong>@category.Code</strong></td>
                        <td>@category.Name</td>
                        <td><span class="badge badge-outline">@category.DefaultMacrsClass</span></td>
                        <td>@(category.DefaultUsefulLifeMonths / 12) years</td>
                        <td>@category.DefaultSalvagePercent%</td>
                        <td>
                            @if (category.IsActive)
                            {
                                <span class="badge badge-success">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-danger">Inactive</span>
                            }
                        </td>
                        <td class="actions-cell">
                            <button type="button" class="btn-p btn-p--secondary btn-p--sm" 
                                onclick="editCategory(@category.Id, '@category.Code', '@category.Name.Replace("'", "\\'")', '@(category.Description?.Replace("'", "\\'") ?? "")', @((int)category.DefaultMacrsClass), @category.DefaultUsefulLifeMonths, @category.DefaultSalvagePercent, @(category.AssetGlAccountId?.ToString() ?? "null"), @(category.AccumDepGlAccountId?.ToString() ?? "null"), @(category.DepExpGlAccountId?.ToString() ?? "null"), @category.IsActive.ToString().ToLower())">Edit</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div id="createForm" class="inline-form-panel" style="display: none;">
    <div class="inline-form-panel-content">
        <div class="inline-form-header">
            <div class="inline-form-header-content">
                <div class="inline-form-header-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                    </svg>
                </div>
                <div class="inline-form-header-text">
                    <h3>Add Asset Category</h3>
                    <p>Define a new asset category with depreciation defaults</p>
                </div>
            </div>
            <button type="button" class="inline-form-close" onclick="toggleInlineForm('createForm')">&times;</button>
        </div>
        <form method="post" asp-page-handler="Create">
            <div class="inline-form-body">
                <div class="inline-form-section">
                    <div class="inline-form-section-title">Basic Information</div>
                    <div class="inline-form-grid">
                        <div class="form-group">
                            <label>Code *</label>
                            <input type="text" name="code" class="form-control" required maxlength="20" />
                        </div>
                        <div class="form-group">
                            <label>Name *</label>
                            <input type="text" name="name" class="form-control" required maxlength="100" />
                        </div>
                        <div class="form-group full-width">
                            <label>Description</label>
                            <textarea name="description" class="form-control" rows="2" maxlength="200"></textarea>
                        </div>
                    </div>
                </div>
                <div class="inline-form-section">
                    <div class="inline-form-section-title">Depreciation Defaults</div>
                    <div class="inline-form-grid">
                        <div class="form-group">
                            <label>MACRS Property Class</label>
                            <select name="macrsClass" class="form-control">
                                @foreach (var macrs in Enum.GetValues<Abs.FixedAssets.Models.MacrsPropertyClass>())
                                {
                                    <option value="@((int)macrs)">@macrs</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Useful Life (Months)</label>
                            <input type="number" name="usefulLifeMonths" class="form-control" value="84" min="1" max="600" />
                        </div>
                        <div class="form-group">
                            <label>Salvage Percent</label>
                            <input type="number" name="salvagePercent" class="form-control" value="0" min="0" max="100" step="0.01" />
                        </div>
                    </div>
                </div>
                <div class="inline-form-section">
                    <div class="inline-form-section-title">GL Account Mappings</div>
                    <div class="inline-form-grid">
                        <div class="form-group">
                            <label>Asset GL Account</label>
                            <select name="assetGlAccountId" class="form-control" data-cherry-select data-placeholder="Search GL accounts...">
                                <option value="">-- None --</option>
                                @foreach (var gl in Model.GlAccounts)
                                {
                                    <option value="@gl.Id">@gl.AccountNumber - @gl.Name</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Accum Depreciation GL</label>
                            <select name="accumDepGlAccountId" class="form-control" data-cherry-select data-placeholder="Search GL accounts...">
                                <option value="">-- None --</option>
                                @foreach (var gl in Model.GlAccounts)
                                {
                                    <option value="@gl.Id">@gl.AccountNumber - @gl.Name</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Depreciation Expense GL</label>
                            <select name="depExpGlAccountId" class="form-control" data-cherry-select data-placeholder="Search GL accounts...">
                                <option value="">-- None --</option>
                                @foreach (var gl in Model.GlAccounts)
                                {
                                    <option value="@gl.Id">@gl.AccountNumber - @gl.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
            </div>
            <div class="inline-form-footer">
                <button type="button" class="btn-p btn-p--secondary" onclick="toggleInlineForm('createForm')">Cancel</button>
                <button type="submit" class="btn-p btn-p--primary">Create Category</button>
            </div>
        </form>
    </div>
</div>

<div id="editForm" class="inline-form-panel" style="display: none;">
    <div class="inline-form-panel-content">
        <div class="inline-form-header">
            <div class="inline-form-header-content">
                <div class="inline-form-header-icon edit">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                </div>
                <div class="inline-form-header-text">
                    <h3>Edit Asset Category</h3>
                    <p>Update category details</p>
                </div>
            </div>
            <button type="button" class="inline-form-close" onclick="toggleInlineForm('editForm')">&times;</button>
        </div>
        <form method="post" asp-page-handler="Update">
            <input type="hidden" id="editId" name="id" />
            <div class="inline-form-body">
                <div class="inline-form-section">
                    <div class="inline-form-section-title">Basic Information</div>
                    <div class="inline-form-grid">
                        <div class="form-group">
                            <label>Code *</label>
                            <input type="text" id="editCode" name="code" class="form-control" required maxlength="20" />
                        </div>
                        <div class="form-group">
                            <label>Name *</label>
                            <input type="text" id="editName" name="name" class="form-control" required maxlength="100" />
                        </div>
                        <div class="form-group">
                            <label>Status</label>
                            <select id="editIsActive" name="isActive" class="form-control" asp-items="Model.ActiveInactiveOptions"></select>
                        </div>
                        <div class="form-group full-width">
                            <label>Description</label>
                            <textarea id="editDescription" name="description" class="form-control" rows="2" maxlength="200"></textarea>
                        </div>
                    </div>
                </div>
                <div class="inline-form-section">
                    <div class="inline-form-section-title">Depreciation Defaults</div>
                    <div class="inline-form-grid">
                        <div class="form-group">
                            <label>MACRS Property Class</label>
                            <select id="editMacrsClass" name="macrsClass" class="form-control">
                                @foreach (var macrs in Enum.GetValues<Abs.FixedAssets.Models.MacrsPropertyClass>())
                                {
                                    <option value="@((int)macrs)">@macrs</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Useful Life (Months)</label>
                            <input type="number" id="editUsefulLifeMonths" name="usefulLifeMonths" class="form-control" min="1" max="600" />
                        </div>
                        <div class="form-group">
                            <label>Salvage Percent</label>
                            <input type="number" id="editSalvagePercent" name="salvagePercent" class="form-control" min="0" max="100" step="0.01" />
                        </div>
                    </div>
                </div>
                <div class="inline-form-section">
                    <div class="inline-form-section-title">GL Account Mappings</div>
                    <div class="inline-form-grid">
                        <div class="form-group">
                            <label>Asset GL Account</label>
                            <select id="editAssetGlAccountId" name="assetGlAccountId" class="form-control" data-cherry-select data-placeholder="Search GL accounts...">
                                <option value="">-- None --</option>
                                @foreach (var gl in Model.GlAccounts)
                                {
                                    <option value="@gl.Id">@gl.AccountNumber - @gl.Name</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Accum Depreciation GL</label>
                            <select id="editAccumDepGlAccountId" name="accumDepGlAccountId" class="form-control" data-cherry-select data-placeholder="Search GL accounts...">
                                <option value="">-- None --</option>
                                @foreach (var gl in Model.GlAccounts)
                                {
                                    <option value="@gl.Id">@gl.AccountNumber - @gl.Name</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Depreciation Expense GL</label>
                            <select id="editDepExpGlAccountId" name="depExpGlAccountId" class="form-control" data-cherry-select data-placeholder="Search GL accounts...">
                                <option value="">-- None --</option>
                                @foreach (var gl in Model.GlAccounts)
                                {
                                    <option value="@gl.Id">@gl.AccountNumber - @gl.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
            </div>
            <div class="inline-form-footer">
                <button type="button" class="btn-p btn-p--secondary" onclick="toggleInlineForm('editForm')">Cancel</button>
                <button type="submit" class="btn-p btn-p--primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<script>
function editCategory(id, code, name, description, macrsClass, usefulLifeMonths, salvagePercent, assetGlAccountId, accumDepGlAccountId, depExpGlAccountId, isActive) {
    document.getElementById('editId').value = id;
    document.getElementById('editCode').value = code;
    document.getElementById('editName').value = name;
    document.getElementById('editDescription').value = description;
    document.getElementById('editMacrsClass').value = macrsClass;
    document.getElementById('editUsefulLifeMonths').value = usefulLifeMonths;
    document.getElementById('editSalvagePercent').value = salvagePercent;
    document.getElementById('editAssetGlAccountId').value = assetGlAccountId || '';
    document.getElementById('editAccumDepGlAccountId').value = accumDepGlAccountId || '';
    document.getElementById('editDepExpGlAccountId').value = depExpGlAccountId || '';
    document.getElementById('editIsActive').value = isActive.toString();
    toggleInlineForm('editForm');
}
</script>
