@model Abs.FixedAssets.Pages.Admin.SitesModel
@using Abs.FixedAssets.Models
<div class="kpi-card">
    <div class="kpi-label">Total</div>
    <div class="kpi-value">@Model.Sites.Count</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Active</div>
    <div class="kpi-value success">@Model.Sites.Count(s => s.Status == SiteStatus.Active)</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Manufacturing</div>
    <div class="kpi-value info">@Model.Sites.Where(s => s.Type == SiteType.Manufacturing).Count()</div>
</div>
