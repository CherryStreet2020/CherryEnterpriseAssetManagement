@page
@model Abs.FixedAssets.Pages.Admin.Webhooks.DeliveriesModel
@{
    ViewData["Title"] = "Webhook Deliveries";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
}

@{
    var subtitle = Model.Subscription != null
        ? $"{Model.Subscription.Name} - {Model.Subscription.Url}"
        : $"Aggregate view across {Model.Subscriptions.Count} subscription(s) — last 100 attempts";
    var headerVd = new ViewDataDictionary(ViewData)
    {
        { "HeaderTitle", "Delivery History" },
        { "Subtitle", subtitle },
        { "TypeLabel", "Webhooks" },
        { "ContextPartial", "Admin/Webhooks/_AdminWebhooksDeliveriesContext" },
        { "KpisPartial", "Admin/Webhooks/_AdminWebhooksDeliveriesKpis" }
    };
}
@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

<div class="content-area">
    @if (Model.IsAggregateView)
    {
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden" data-csp-style="margin-bottom: 16px;">
            <div class="p-4 border-b border-slate-200">
                <h2 class="text-lg font-semibold text-slate-800">Subscriptions</h2>
                <p class="text-sm text-slate-500" data-csp-style="margin-top: 4px;">
                    Click a subscription to view its dedicated delivery history.
                </p>
            </div>
            @if (Model.Subscriptions.Count == 0)
            {
                <div class="p-6 text-center">
                    <p class="text-slate-500">No webhook subscriptions configured. <a href="/Admin/Webhooks/Index" class="text-blue-600 hover:underline">Create one</a>.</p>
                </div>
            }
            else
            {
                <table class="w-full">
                    <thead class="bg-slate-50">
                        <tr>
                            <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">Name</th>
                            <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">URL</th>
                            <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">Active</th>
                            <th class="px-4 py-2 text-right text-xs font-medium text-slate-500 uppercase">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var sub in Model.Subscriptions)
                        {
                            <tr class="hover:bg-slate-50">
                                <td class="px-4 py-2 text-sm text-slate-800">@sub.Name</td>
                                <td class="px-4 py-2 text-sm text-slate-600"><code>@sub.Url</code></td>
                                <td class="px-4 py-2 text-sm">@(sub.IsActive ? "Yes" : "No")</td>
                                <td class="px-4 py-2 text-sm" data-csp-style="text-align: right;">
                                    <a href="/Admin/Webhooks/Deliveries?id=@sub.Id" class="text-blue-600 hover:underline">View deliveries →</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="p-6 border-b border-slate-200">
            <h2 class="text-lg font-semibold text-slate-800">@(Model.IsAggregateView ? "Last 100 Delivery Attempts (All Subscriptions)" : "Last 50 Delivery Attempts")</h2>
        </div>

        @if (Model.Deliveries.Count == 0)
        {
            <div class="p-12 text-center">
                <p class="text-slate-500">No delivery attempts recorded yet.</p>
            </div>
        }
        else
        {
            <table class="w-full">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Time</th>
                        @if (Model.IsAggregateView)
                        {
                            <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Subscription</th>
                        }
                        <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Event Type</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Attempt</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Status</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Duration</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Error</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase">Payload</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var log in Model.Deliveries)
                    {
                        var isSuccess = log.ResponseStatusCode >= 200 && log.ResponseStatusCode < 300;
                        <tr class="hover:bg-slate-50">
                            <td class="px-4 py-3 text-sm text-slate-600">@log.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            @if (Model.IsAggregateView)
                            {
                                <td class="px-4 py-3 text-sm text-slate-700">
                                    <a href="/Admin/Webhooks/Deliveries?id=@log.WebhookSubscriptionId" class="text-blue-600 hover:underline">
                                        @(log.WebhookSubscription?.Name ?? "(unknown)")
                                    </a>
                                </td>
                            }
                            <td class="px-4 py-3 text-sm">
                                <code class="px-2 py-0.5 bg-slate-100 rounded text-xs">@(log.OutboxEvent?.EventType ?? "N/A")</code>
                            </td>
                            <td class="px-4 py-3 text-sm text-slate-600">#@log.AttemptNumber</td>
                            <td class="px-4 py-3 text-sm">
                                @if (log.ResponseStatusCode != null)
                                {
                                    <span class="px-2 py-1 rounded text-xs font-medium @(isSuccess ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700")">
                                        @log.ResponseStatusCode
                                    </span>
                                }
                                else
                                {
                                    <span class="px-2 py-1 rounded text-xs font-medium bg-gray-100 text-gray-700">Error</span>
                                }
                            </td>
                            <td class="px-4 py-3 text-sm text-slate-600">@log.DurationMs ms</td>
                            <td class="px-4 py-3 text-sm text-red-600 max-w-xs truncate" title="@log.Error">
                                @(log.Error ?? "-")
                            </td>
                            <td class="px-4 py-3 text-sm">
                                @if (!string.IsNullOrEmpty(log.PayloadSent))
                                {
                                    <button onclick="viewPayload(@log.Id)" class="text-blue-600 hover:underline text-xs">View</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<div id="payloadFormPanel" class="inline-form-panel" data-csp-style="display: none;">
    <div class="bg-white rounded-xl w-full max-w-3xl mx-4 shadow-xl">
        <div class="p-4 border-b border-slate-200 flex items-center justify-between">
            <h3 class="text-lg font-semibold text-slate-800">Delivered Payload</h3>
            <button onclick="closePayloadForm()" class="text-slate-400 hover:text-slate-600 text-2xl">&times;</button>
        </div>
        <div class="p-4">
            <pre id="payloadContent" class="bg-slate-100 p-4 rounded-lg overflow-auto max-h-96 text-sm font-mono"></pre>
        </div>
    </div>
</div>

<script>
    function viewPayload(id) {
        fetch('?handler=Payload&id=' + id)
            .then(r => r.text())
            .then(json => {
                try {
                    var formatted = JSON.stringify(JSON.parse(json), null, 2);
                    document.getElementById('payloadContent').textContent = formatted;
                } catch {
                    document.getElementById('payloadContent').textContent = json;
                }
                document.getElementById('payloadFormPanel').style.display = '';
                document.getElementById('payloadFormPanel');
            });
    }
    function closePayloadForm() {
        document.getElementById('payloadFormPanel').style.display = 'none';
        document.getElementById('payloadFormPanel');
    }
</script>
