@page
@model Abs.FixedAssets.Pages.Admin.Webhooks.CatalogModel
@{
    ViewData["Title"] = "Webhook Event Catalog";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
}

@{
    var headerVd = new ViewDataDictionary(ViewData)
    {
        { "HeaderTitle", "Webhook Event Catalog" },
        { "Subtitle", "Authoritative list of every event CherryAI EAM emits, with payload schemas." },
        { "TypeLabel", "System Administration" }
    };
}
@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

<div class="content-area">
    <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 mb-6">
        <p class="text-sm text-blue-900">
            Auto-generated from the
            <code class="bg-white border border-blue-100 rounded px-1 text-xs">DomainEventRegistry</code>.
            Records decorated with
            <code class="bg-white border border-blue-100 rounded px-1 text-xs">[DomainEvent(eventType, version)]</code>
            appear here automatically. See
            <code class="bg-white border border-blue-100 rounded px-1 text-xs">docs/design/OUTBOX_TYPED_PAYLOADS.md</code>
            for the design.
        </p>
        <p class="text-sm text-blue-900 mt-2">
            <strong>@Model.Events.Count</strong> event(s) registered.
        </p>
    </div>

    @foreach (var evt in Model.Events)
    {
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm mb-6 overflow-hidden">
            <div class="px-6 py-4 bg-gray-50 border-b border-gray-200 flex items-center justify-between">
                <div>
                    <code class="text-base font-mono font-semibold text-gray-900">@evt.EventType</code>
                    <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">v@(evt.Version)</span>
                </div>
                <div class="text-xs text-gray-500">
                    Entity: <code class="font-mono">@evt.EntityType</code>
                    &nbsp;·&nbsp;
                    CLR: <code class="font-mono">@evt.ClrTypeName</code>
                </div>
            </div>
            <table class="min-w-full text-sm">
                <thead>
                    <tr class="bg-gray-50 border-b border-gray-200">
                        <th class="px-6 py-2 text-left text-xs font-medium text-gray-500 uppercase">Field</th>
                        <th class="px-6 py-2 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
                        <th class="px-6 py-2 text-left text-xs font-medium text-gray-500 uppercase">Nullable</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var prop in evt.Properties)
                    {
                        <tr>
                            <td class="px-6 py-2 font-mono text-gray-900">@prop.Name</td>
                            <td class="px-6 py-2 font-mono text-gray-600">@prop.Type</td>
                            <td class="px-6 py-2 text-gray-600">
                                @if (prop.Nullable)
                                {
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">yes</span>
                                }
                                else
                                {
                                    <span class="text-gray-400">no</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (Model.Events.Count == 0)
    {
        <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-6 text-center">
            <p class="text-yellow-800">No events registered. Check that <code>DomainEventRegistry</code> is wired in <code>Program.cs</code>.</p>
        </div>
    }
</div>
