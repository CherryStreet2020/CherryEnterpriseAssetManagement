@{
    var model = ViewData["PageModel"] as Abs.FixedAssets.Pages.Admin.InventoryModel;
}
<div class="hero-tags">
    @if (model?.OutOfStockCount > 0)
    {
        <span class="hero-tag critical">@(model.OutOfStockCount) Out of Stock</span>
    }
</div>
<div class="hero-btns">
    <a href="/Admin" class="hero-btn hero-btn-ghost">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Admin
    </a>
    <button type="button" class="hero-btn hero-btn-ghost" onclick="toggleInlineForm('cycleCountForm')">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
        </svg>
        Cycle Count
    </button>
    <button type="button" class="hero-btn hero-btn-primary" onclick="toggleInlineForm('transactionForm')">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"/>
        </svg>
        New Transaction
    </button>
</div>
