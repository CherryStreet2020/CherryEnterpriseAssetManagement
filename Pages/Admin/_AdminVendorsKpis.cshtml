@model Abs.FixedAssets.Pages.Admin.VendorsModel
<div class="kpi-card">
    <div class="kpi-label">Total</div>
    <div class="kpi-value">@Model.Vendors.Count</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Active</div>
    <div class="kpi-value success">@Model.Vendors.Count(v => v.IsActive)</div>
</div>
