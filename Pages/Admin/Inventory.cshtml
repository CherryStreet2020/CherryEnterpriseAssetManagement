@page
@model Abs.FixedAssets.Pages.Admin.InventoryModel
@{
    ViewData["Title"] = "Stock Transactions";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";

    var headerVd = new ViewDataDictionary(ViewData) {
        { "TypeLabel", "Inventory & Stores" },
        { "HeaderTitle", "Stock Transactions" },
        { "Subtitle", "Monitor inventory levels and manage stock transactions" },
        { "StatusText", Model.LowStockCount > 0 ? $"{Model.LowStockCount} Low Stock" : "All Stocked" },
        { "StatusTone", Model.LowStockCount > 0 ? "warning" : "success" },
        { "ContextPartial", "Admin/_AdminInventoryContext" },
        { "KpisPartial", "Admin/_AdminInventoryKpis" },
        { "ActionsPartial", "Admin/_AdminInventoryActions" },
        { "PageModel", Model }
    };
}

@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

@if (Model.LowStockItems.Any())
{
    <div class="section-card border-left-amber">
        <div class="section-card-header bg-amber-soft">
            <h3 class="section-card-title text-dark-amber">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                </svg>
                Low Stock Alerts
            </h3>
            <span class="status-badge warning">@Model.LowStockItems.Count ITEMS NEED REORDERING</span>
        </div>
        <div class="section-card-body" data-csp-style="padding: 0;">
            <table class="data-table">
                <thead>
                    <tr>
                        <th data-csp-style="width: 120px;">Part #</th>
                        <th>Description</th>
                        <th data-csp-style="text-align: right; width: 100px;">On Hand</th>
                        <th data-csp-style="text-align: right; width: 100px;">Reorder Pt</th>
                        <th data-csp-style="text-align: right; width: 100px;">Reorder Qty</th>
                        <th data-csp-style="width: 120px;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.LowStockItems.Take(10))
                    {
                        <tr>
                            <td><strong>@item.PartNumber</strong></td>
                            <td>@item.Description</td>
                            <td data-csp-style="text-align: right;"><span class="badge badge-danger">@item.OnHand.ToString("N0")</span></td>
                            <td data-csp-style="text-align: right;">@item.ReorderPoint.ToString("N0")</td>
                            <td data-csp-style="text-align: right;">@item.ReorderQty.ToString("N0")</td>
                            <td>
                                <button type="button" class="btn-p btn-p--secondary btn-p--sm" onclick="openReceiptForm('@item.ItemId', '@item.PartNumber', @item.ReorderQty)">
                                    Receive
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="section-card">
    <div class="section-card-header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
            </svg>
            All Stock Levels
        </h3>
        <span class="status-badge info">@Model.StockLevels.Count() RECORDS</span>
    </div>
    <div class="section-card-body" data-csp-style="padding: 0;">
        <table class="data-table" id="inventoryGrid">
            <thead>
                <tr>
                    <th data-csp-style="width: 120px;">Part #</th>
                    <th data-csp-style="min-width: 200px;">Description</th>
                    <th data-csp-style="width: 120px;">Warehouse</th>
                    <th data-csp-style="width: 80px;">Bin</th>
                    <th data-csp-style="text-align: right; width: 90px;">On Hand</th>
                    <th data-csp-style="text-align: right; width: 90px;">Reserved</th>
                    <th data-csp-style="text-align: right; width: 90px;">Available</th>
                    <th data-csp-style="text-align: right; width: 90px;">On Order</th>
                    <th data-csp-style="width: 100px;" class="no-sort">Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var inv in Model.StockLevels)
                {
                    var statusClass = inv.QuantityOnHand <= 0 ? "badge-danger" : 
                                      inv.QuantityOnHand <= inv.ReorderPoint ? "badge-warning" : "badge-success";
                    var statusText = inv.QuantityOnHand <= 0 ? "Out" : 
                                     inv.QuantityOnHand <= inv.ReorderPoint ? "Low" : "OK";
                    <tr>
                        <td><strong>@inv.PartNumber</strong></td>
                        <td>@inv.Description</td>
                        <td>@(inv.Warehouse ?? "-")</td>
                        <td>@(inv.Bin ?? "-")</td>
                        <td data-csp-style="text-align: right;">@inv.QuantityOnHand.ToString("N0")</td>
                        <td data-csp-style="text-align: right;">@inv.QuantityReserved.ToString("N0")</td>
                        <td data-csp-style="text-align: right;">@inv.QuantityAvailable.ToString("N0")</td>
                        <td data-csp-style="text-align: right;">@inv.QuantityOnOrder.ToString("N0")</td>
                        <td><span class="badge @statusClass">@statusText</span></td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.StockLevels.Any())
        {
            <div class="pe-empty" data-csp-style="padding:1.5rem;">
                <i class="fas fa-chart-line pe-empty__icon" data-csp-style="font-size:1.2rem;"></i>
                <div class="pe-empty__text">No inventory records. Create items in the Item Master and add inventory transactions to track stock levels.</div>
            </div>
        }
    </div>
</div>

<div class="section-card">
    <div class="section-card-header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
            Recent Transactions
        </h3>
        <span class="status-badge info">@Model.RecentTransactions.Count() RECENT</span>
    </div>
    <div class="section-card-body" data-csp-style="padding: 0;">
        <table class="data-table" id="transactionGrid">
            <thead>
                <tr>
                    <th data-csp-style="width: 100px;">Transaction #</th>
                    <th data-csp-style="width: 100px;">Date</th>
                    <th data-csp-style="width: 80px;">Type</th>
                    <th data-csp-style="width: 100px;">Part #</th>
                    <th>Description</th>
                    <th data-csp-style="text-align: right; width: 80px;">Qty</th>
                    <th data-csp-style="text-align: right; width: 100px;">Unit Cost</th>
                    <th data-csp-style="width: 120px;">Reference</th>
                    <th data-csp-style="width: 100px;">By</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var txn in Model.RecentTransactions)
                {
                    var typeClass = txn.Type == Abs.FixedAssets.Models.TransactionType.Receipt ? "badge-success" :
                                    txn.Type == Abs.FixedAssets.Models.TransactionType.Issue ? "badge-danger" :
                                    txn.Type == Abs.FixedAssets.Models.TransactionType.Adjust ? "badge-warning" : "badge-info";
                    <tr>
                        <td><strong>@txn.TransactionNumber</strong></td>
                        <td>@txn.TransactionDate.ToString("MM/dd/yyyy")</td>
                        <td><span class="badge @typeClass">@txn.Type</span></td>
                        <td>@txn.Item?.PartNumber</td>
                        <td>@txn.Item?.Description</td>
                        <td data-csp-style="text-align: right;">@txn.Quantity.ToString("N2")</td>
                        <td data-csp-style="text-align: right;">@txn.UnitCost.ToString("C2")</td>
                        <td>@(txn.ReferenceNumber ?? "-")</td>
                        <td>@txn.TransactedBy</td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.RecentTransactions.Any())
        {
            <div class="pe-empty" data-csp-style="padding:1rem;">
                <div class="pe-empty__text">No transactions recorded yet.</div>
            </div>
        }
    </div>
</div>

<div id="transactionForm" class="inline-form-panel" data-csp-style="display: none;">
    <div class="inline-form-panel-content">
        <div class="inline-form-header">
            <div class="inline-form-header-content">
                <div class="inline-form-header-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"/>
                    </svg>
                </div>
                <div class="inline-form-header-text">
                    <h3>New Inventory Transaction</h3>
                    <p>Record a stock movement</p>
                </div>
            </div>
            <button type="button" class="inline-form-close" onclick="toggleInlineForm('transactionForm')">&times;</button>
        </div>
        <form method="post" asp-page-handler="Transaction">
            <div class="inline-form-body">
                <div class="inline-form-grid">
                    <div class="form-group full-width">
                        <label>Item</label>
                        <select id="txnItemId" name="itemId" class="form-control" required data-cherry-select data-placeholder="Search items...">
                            <option value="">-- Select Item --</option>
                            @foreach (var item in Model.Items)
                            {
                                <option value="@item.Id">@item.PartNumber - @item.Description</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Transaction Type</label>
                        <select id="txnType" name="typeLookupValueId" class="form-control" required asp-items="Model.TransactionTypeOptions"></select>
                    </div>
                    <div class="form-group">
                        <label>Quantity</label>
                        <input type="number" id="txnQuantity" name="quantity" class="form-control" step="0.01" required />
                    </div>
                    <div class="form-group">
                        <label>Unit Cost</label>
                        <input type="number" id="txnUnitCost" name="unitCost" class="form-control" step="0.01" value="0" />
                    </div>
                    <div class="form-group">
                        <label>Warehouse</label>
                        <input type="text" id="txnWarehouse" name="warehouse" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Bin</label>
                        <input type="text" id="txnBin" name="bin" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Reference #</label>
                        <input type="text" id="txnReference" name="referenceNumber" class="form-control" placeholder="PO#, WO#, etc." />
                    </div>
                    <div class="form-group full-width">
                        <label>Notes</label>
                        <textarea id="txnNotes" name="notes" class="form-control" rows="2"></textarea>
                    </div>
                </div>
            </div>
            <div class="inline-form-footer">
                <button type="button" class="btn-p btn-p--secondary" onclick="toggleInlineForm('transactionForm')">Cancel</button>
                <button type="submit" class="btn-p btn-p--primary">Record Transaction</button>
            </div>
        </form>
    </div>
</div>

<div id="cycleCountForm" class="inline-form-panel" data-csp-style="display: none;">
    <div class="inline-form-panel-content">
        <div class="inline-form-header">
            <div class="inline-form-header-content">
                <div class="inline-form-header-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                    </svg>
                </div>
                <div class="inline-form-header-text">
                    <h3>Cycle Count Entry</h3>
                    <p>Record a physical inventory count</p>
                </div>
            </div>
            <button type="button" class="inline-form-close" onclick="toggleInlineForm('cycleCountForm')">&times;</button>
        </div>
        <form method="post" asp-page-handler="CycleCount">
            <div class="inline-form-body">
                <div class="inline-form-grid">
                    <div class="form-group full-width">
                        <label>Item</label>
                        <select id="ccItemId" name="itemId" class="form-control" required data-cherry-select data-placeholder="Search items...">
                            <option value="">-- Select Item --</option>
                            @foreach (var item in Model.Items)
                            {
                                <option value="@item.Id">@item.PartNumber - @item.Description</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Counted Quantity</label>
                        <input type="number" id="ccCountedQty" name="countedQuantity" class="form-control" step="0.01" required />
                    </div>
                    <div class="form-group">
                        <label>Warehouse</label>
                        <input type="text" id="ccWarehouse" name="warehouse" class="form-control" />
                    </div>
                    <div class="form-group full-width">
                        <label>Bin</label>
                        <input type="text" id="ccBin" name="bin" class="form-control" />
                    </div>
                    <div class="form-group full-width">
                        <label>Count Notes</label>
                        <textarea id="ccNotes" name="notes" class="form-control" rows="2"></textarea>
                    </div>
                </div>
            </div>
            <div class="inline-form-footer">
                <button type="button" class="btn-p btn-p--secondary" onclick="toggleInlineForm('cycleCountForm')">Cancel</button>
                <button type="submit" class="btn-p btn-p--primary">Submit Count</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/enhanced-grid.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            initEnhancedGrid('inventoryGrid', {
                searchable: true,
                sortable: true,
                exportable: true
            });
            initEnhancedGrid('transactionGrid', {
                searchable: true,
                sortable: true,
                exportable: true
            });
        });

        function openReceiptForm(itemId, partNumber, qty) {
            document.getElementById('txnItemId').value = itemId;
            document.getElementById('txnType').value = '0';
            document.getElementById('txnQuantity').value = qty;
            toggleInlineForm('transactionForm');
        }
    </script>
}
