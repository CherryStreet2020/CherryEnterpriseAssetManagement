@model Abs.FixedAssets.Pages.Admin.Outbox.IndexModel
@{
}
<div class="kpi-card">
    <div class="kpi-label">Pending</div>
    <div class="kpi-value">@Model.PendingCount</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Sent</div>
    <div class="kpi-value success">@Model.SentCount</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Failed</div>
    <div class="kpi-value warning">@Model.FailedCount</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Dead Letter</div>
    <div class="kpi-value danger">@Model.DeadLetterCount</div>
</div>
