@page
@model Abs.FixedAssets.Pages.Admin.ApprovalsModel
@{
    ViewData["Title"] = "Approvals";
    ViewData["TabTitle"] = "Approvals";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
    var workflowCount = 3;
    
    var statusText = $"{workflowCount} Workflows";
    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = "Approvals",
        ["Subtitle"] = "Configure approval requirements for disposals, transfers, and improvements",
        ["TypeLabel"] = "Administration & Tools",
        ["StatusText"] = statusText,
        ["StatusTone"] = "success",
        ["ContextPartial"] = "/Pages/Admin/_AdminApprovalsContext.cshtml",
        ["KpisPartial"] = "/Pages/Admin/_AdminApprovalsKpis.cshtml",
        ["ActionsPartial"] = "/Pages/Admin/_AdminApprovalsActions.cshtml"
    };
}

@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

<div class="settings-grid">
    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
                Disposal Approvals
            </h3>
        </div>
        <div class="section-card-body">
            <p class="setting-description">Configure when asset disposals require approval before processing.</p>
            
            <div class="form-group">
                <label>Require approval for disposals over</label>
                <div class="input-group">
                    <span class="input-prefix">$</span>
                    <input type="number" class="form-control" value="@Model.DisposalThreshold.ToString("F0")" />
                </div>
            </div>
            
            <div class="setting-item">
                <div class="setting-label">Require manager approval</div>
                <div class="setting-control">
                    <label class="toggle">
                        <input type="checkbox" checked="@Model.RequireManagerApproval" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>
            
            <div class="setting-item">
                <div class="setting-label">Require finance approval</div>
                <div class="setting-control">
                    <label class="toggle">
                        <input type="checkbox" checked="@Model.RequireFinanceApproval" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>
        </div>
    </div>

    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                </svg>
                Transfer Approvals
            </h3>
        </div>
        <div class="section-card-body">
            <p class="setting-description">Configure when asset transfers between locations or departments require approval.</p>
            
            <div class="form-group">
                <label>Require approval for transfers of assets valued over</label>
                <div class="input-group">
                    <span class="input-prefix">$</span>
                    <input type="number" class="form-control" value="@Model.TransferThreshold.ToString("F0")" />
                </div>
            </div>
            
            <div class="setting-item">
                <div class="setting-label">Require approval for cross-department transfers</div>
                <div class="setting-control">
                    <label class="toggle">
                        <input type="checkbox" checked />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>
            
            <div class="setting-item">
                <div class="setting-label">Require approval for cross-location transfers</div>
                <div class="setting-control">
                    <label class="toggle">
                        <input type="checkbox" checked />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>
        </div>
    </div>

    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
                </svg>
                Capital Improvement Approvals
            </h3>
        </div>
        <div class="section-card-body">
            <p class="setting-description">Configure when capital improvements require approval before being capitalized.</p>
            
            <div class="form-group">
                <label>Require approval for improvements over</label>
                <div class="input-group">
                    <span class="input-prefix">$</span>
                    <input type="number" class="form-control" value="@Model.ImprovementThreshold.ToString("F0")" />
                </div>
            </div>
            
            <div class="setting-item">
                <div class="setting-label">Require approval for useful life extensions</div>
                <div class="setting-control">
                    <label class="toggle">
                        <input type="checkbox" checked />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>
        </div>
    </div>

    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
                Approval Routing
            </h3>
        </div>
        <div class="section-card-body">
            <p class="setting-description">Configure who receives approval requests and in what order.</p>
            
            <div class="approval-chain">
                <div class="approval-step">
                    <span class="step-number">1</span>
                    <div class="step-content">
                        <strong>Department Manager</strong>
                        <span class="step-desc">First level approval for all requests</span>
                    </div>
                </div>
                <div class="approval-step">
                    <span class="step-number">2</span>
                    <div class="step-content">
                        <strong>Finance Controller</strong>
                        <span class="step-desc">Required for amounts over threshold</span>
                    </div>
                </div>
                <div class="approval-step">
                    <span class="step-number">3</span>
                    <div class="step-content">
                        <strong>CFO / Executive</strong>
                        <span class="step-desc">Required for major disposals and acquisitions</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
