@page
@model Abs.FixedAssets.Pages.Admin.RegulatoryProfiles.EditModel
@using Abs.FixedAssets.Pages.Shared.Primitives
@using Abs.FixedAssets.Models.Production
@{
    ViewData["Title"] = Model.PageTitle;
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";

    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = Model.PageTitle,
        ["Subtitle"] = Model.IsNew
            ? "Pick a regime, set retention, write the gate rules. The service layer enforces."
            : Model.Name,
        ["TypeLabel"] = "Compliance",
        ["StatusText"] = Model.IsActive ? "Active" : "Inactive",
        ["StatusTone"] = Model.IsActive ? "active" : "neutral",
    };
}

@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="ds-card" data-tone="danger" style="margin-top: 14px; padding: 12px 16px; color: var(--text-primary);">@Model.ErrorMessage</div>
}

<form method="post" style="margin-top: 20px;">
    <input type="hidden" asp-for="Id" />

    <div class="ds-card" data-tone="brand" style="padding: 0;">
        <div style="padding: 18px 22px; border-bottom: 1px solid var(--border);">
            <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500;">Identification</div>
            <div style="font-size: 17px; font-weight: 700; color: var(--text-primary); margin-top: 4px;">Profile Basics</div>
        </div>
        <div style="padding: 22px; display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 18px;">
            <div>
                <label for="rp-name" style="display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500; margin-bottom: 6px;">Name</label>
                <input id="rp-name" type="text" asp-for="Name" required maxlength="64"
                       aria-label="Profile name"
                       placeholder="e.g., FDA 21 CFR 820 — Medical Devices QSR"
                       style="width: 100%; padding: 10px 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface-2, rgba(0,0,0,0.18)); color: var(--text-primary); font-size: 14px;" />
            </div>
            <div>
                <label for="rp-regime" style="display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500; margin-bottom: 6px;">Regulatory Regime</label>
                <select id="rp-regime" asp-for="Regime"
                        aria-label="Regulatory regime"
                        asp-items="@(Html.GetEnumSelectList<RegulatoryRegime>())"
                        style="width: 100%; padding: 10px 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface-2, rgba(0,0,0,0.18)); color: var(--text-primary); font-size: 14px;"></select>
            </div>
            <div style="grid-column: 1 / -1;">
                <label for="rp-description" style="display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500; margin-bottom: 6px;">Description</label>
                <textarea id="rp-description" asp-for="Description" rows="2" maxlength="500"
                          aria-label="Profile description"
                          placeholder="One-line description of what this regime covers."
                          style="width: 100%; padding: 10px 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface-2, rgba(0,0,0,0.18)); color: var(--text-primary); font-size: 14px; font-family: inherit;"></textarea>
            </div>
            <div>
                <label for="rp-retention" style="display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500; margin-bottom: 6px;">Minimum Retention (years)</label>
                <input id="rp-retention" type="number" asp-for="MinimumRetentionYears" min="0" max="100"
                       aria-label="Minimum retention years"
                       placeholder="e.g., 10"
                       style="width: 100%; padding: 10px 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface-2, rgba(0,0,0,0.18)); color: var(--text-primary); font-size: 14px; font-family: var(--font-mono, ui-monospace, monospace);" />
            </div>
            <div>
                <label style="display: flex; align-items: center; gap: 10px; padding: 14px 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface-2, rgba(0,0,0,0.18)); cursor: pointer;">
                    <input type="checkbox" asp-for="IsExternalRegime" style="width: 18px; height: 18px; accent-color: var(--ds-brand, #60a5fa);" />
                    <div>
                        <div style="font-size: 13px; font-weight: 600; color: var(--text-primary);">External Regime</div>
                        <div style="font-size: 11.5px; color: var(--text-muted);">Issued by a real regulator (FDA, EASA, EU REACH). Uncheck for internal corporate policy.</div>
                    </div>
                </label>
            </div>
        </div>
    </div>

    <div class="ds-card" data-tone="info" style="margin-top: 20px; padding: 0;">
        <div style="padding: 18px 22px; border-bottom: 1px solid var(--border);">
            <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500;">Gate Rules</div>
            <div style="font-size: 17px; font-weight: 700; color: var(--text-primary); margin-top: 4px;">Runtime Gates (JSON)</div>
            <div style="color: var(--text-muted); font-size: 13px; margin-top: 4px;">
                The service layer reads this to enforce per-record behavior. See <code style="font-family: var(--font-mono, ui-monospace, monospace);">Models/Production/RegulatoryProfile.cs</code> for the shape.
            </div>
        </div>
        <div style="padding: 22px;">
            <label for="rp-gates" class="visually-hidden" style="position: absolute; width: 1px; height: 1px; overflow: hidden;">Gates JSON</label>
            <textarea id="rp-gates" asp-for="GatesJson" rows="10"
                      aria-label="Gates JSON configuration"
                      spellcheck="false"
                      style="width: 100%; padding: 12px 14px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface-2, rgba(0,0,0,0.18)); color: var(--text-primary); font-size: 13px; font-family: var(--font-mono, ui-monospace, monospace); line-height: 1.6;"></textarea>
            <div style="margin-top: 8px; font-size: 12px; color: var(--text-muted);">
                Common keys: <code>requireSerialOnReceipt</code> · <code>requireHeatNumberOnReceipt</code> · <code>requireMrbDispositionOnQuarantine</code> · <code>requirePyrometryChart</code> · <code>auditEvents</code>
            </div>
        </div>
    </div>

    <div style="margin-top: 20px; display: flex; gap: 10px; justify-content: flex-end; flex-wrap: wrap;">
        <a href="/Admin/RegulatoryProfiles" class="ds-btn" data-variant="ghost">Cancel</a>
        @if (!Model.IsNew)
        {
            <button type="submit" asp-page-handler="ToggleActive" class="ds-btn" data-variant="secondary">
                @(Model.IsActive ? "Deactivate" : "Activate")
            </button>
        }
        <button type="submit" class="ds-btn" data-variant="primary">
            @(Model.IsNew ? "Create Profile" : "Save Changes")
        </button>
    </div>
</form>

@* Voice context payload (per ADR-014). *@
<script type="application/json" id="voice-context-payload">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.BuildContextPayload()))
</script>
