@page
@model Abs.FixedAssets.Pages.Admin.StockReceipts.IndexModel
@using Abs.FixedAssets.Pages.Shared.Primitives
@using Abs.FixedAssets.Models.Production
@{
    ViewData["Title"] = "Stock Receipts";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";

    var total = Model.TotalCount;
    var available = Model.AvailableCount;
    var quarantined = Model.QuarantinedCount;
    var fullyFaceted = Model.FullyFacetedCount;
    var facetPct = total > 0 ? (fullyFaceted * 100.0 / total) : 0;

    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = "Stock Receipts",
        ["Subtitle"] = "Physical-lot ledger — profile-driven traceability across every vertical (steel heat, pharma NDC, food TLC, etc.)",
        ["TypeLabel"] = "Production · Traceability",
        ["StatusText"] = $"{total} Receipts",
        ["StatusTone"] = total > 0 ? "active" : "neutral",
    };
}

@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="ds-card" data-tone="danger" data-csp-style="margin-top: 14px; padding: 12px 16px; color: var(--text-primary);">@Model.ErrorMessage</div>
}

<div data-csp-style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-top: 20px;">
    @await Html.PartialAsync("Primitives/_KPITile", new KpiTileModel
    {
        Label = "Total Receipts",
        Value = total.ToString("N0"),
        DeltaText = total > 0 ? "in physical-lot ledger" : "no receipts yet",
        DeltaDirection = "flat",
        SparkTone = "info"
    })
    @await Html.PartialAsync("Primitives/_KPITile", new KpiTileModel
    {
        Label = "Available",
        Value = available.ToString("N0"),
        DeltaText = total > 0 ? $"{(total > 0 ? (available * 100.0 / total) : 0).ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)}% of stock" : "—",
        DeltaDirection = available > 0 ? "up" : "flat",
        SparkTone = "success"
    })
    @await Html.PartialAsync("Primitives/_KPITile", new KpiTileModel
    {
        Label = "With Required Facets",
        Value = fullyFaceted.ToString("N0"),
        DeltaText = total > 0 ? $"{facetPct.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)}% fully traceable" : "—",
        DeltaDirection = facetPct >= 80 ? "up" : facetPct >= 40 ? "flat" : "down",
        SparkTone = facetPct >= 80 ? "success" : facetPct >= 40 ? "info" : "warning"
    })
    @await Html.PartialAsync("Primitives/_KPITile", new KpiTileModel
    {
        Label = "Quarantined",
        Value = quarantined.ToString("N0"),
        DeltaText = quarantined > 0 ? "failed inspection" : "all clear",
        DeltaDirection = quarantined > 0 ? "down" : "flat",
        SparkTone = quarantined > 0 ? "danger" : "muted"
    })
</div>

<div class="ds-card" data-tone="brand" data-csp-style="margin-top: 24px; padding: 0;">
    <div data-csp-style="padding: 18px 22px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap;">
        <div>
            <div data-csp-style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500;">Production · Traceability</div>
            <div data-csp-style="font-size: 17px; font-weight: 700; color: var(--text-primary); margin-top: 4px;">Receiving Ledger</div>
            <div data-csp-style="color: var(--text-muted); font-size: 13px; margin-top: 4px;">Profile-driven facets — each receipt's columns are sourced from its industry profile's PromotedFacets</div>
        </div>
        @*
            Sprint 11 PR #7 — kill-list cutover.
            The "+ New Receipt" entry that used to open /Admin/StockReceipts/Edit
            now points to the Receiving Control Center's PO-driven wizard.
            All receipt creation flows through /Receiving/By-Po (80% workflow)
            or /Receiving/Blind (5% workflow) per ADR-016 §D6.
        *@
        <a href="/Receiving/By-Po" class="ds-btn" data-variant="primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
            New Receipt
        </a>
    </div>

    @if (Model.Rows.Any())
    {
        <div data-csp-style="overflow-x: auto;">
            <table class="data-table premium-table">
                <thead>
                    <tr>
                        <th data-csp-style="width: 140px;">Receipt #</th>
                        <th data-csp-style="width: 110px;">Status</th>
                        <th data-csp-style="width: 100px;">Profile</th>
                        <th data-csp-style="min-width: 180px;">Item / Material</th>
                        <th data-csp-style="width: 140px;">Facet A</th>
                        <th data-csp-style="width: 140px;">Facet B</th>
                        <th data-csp-style="width: 130px; text-align: right;">Qty Remaining</th>
                        <th data-csp-style="width: 140px;">Received</th>
                        <th data-csp-style="width: 90px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Rows)
                    {
                        var statusTone = r.Status switch
                        {
                            StockReceiptStatus.Available => "success",
                            StockReceiptStatus.Reserved => "info",
                            StockReceiptStatus.PartiallyConsumed => "warning",
                            StockReceiptStatus.FullyConsumed => "neutral",
                            StockReceiptStatus.Quarantined => "danger",
                            StockReceiptStatus.Scrapped => "danger",
                            StockReceiptStatus.Returned => "neutral",
                            _ => "neutral"
                        };
                        var pctRemaining = r.QuantityReceived > 0
                            ? (double)(r.QuantityRemaining / r.QuantityReceived) * 100
                            : 0;
                        <tr>
                            <td><strong data-csp-style="color: var(--text-primary); font-family: var(--font-mono, ui-monospace, monospace);">@r.ReceiptNumber</strong></td>
                            <td>
                                @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel { Label = r.Status.ToString(), Tone = statusTone, ShowDot = true })
                            </td>
                            <td>
                                @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel { Label = r.ProfileCode, Tone = "info", ShowDot = false })
                            </td>
                            <td data-csp-style="color: var(--text-secondary);">
                                <div data-csp-style="color: var(--text-primary); font-weight: 500;">@(r.ItemDescription ?? $"Item #{r.ItemId}")</div>
                                @if (!string.IsNullOrEmpty(r.MaterialMasterShopCode))
                                {
                                    <div data-csp-style="font-size: 12px; color: var(--text-muted); margin-top: 2px;">@r.MaterialMasterShopCode @(r.MaterialMasterAstm != null ? "· " + r.MaterialMasterAstm : "")</div>
                                }
                            </td>
                            <td data-csp-style="color: var(--text-secondary); font-family: var(--font-mono, ui-monospace, monospace); font-size: 13px;">
                                <div data-csp-style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted);">@r.FacetALabel</div>
                                <div data-csp-style="color: var(--text-primary); margin-top: 2px;">@(r.FacetA ?? "—")</div>
                            </td>
                            <td data-csp-style="color: var(--text-secondary); font-family: var(--font-mono, ui-monospace, monospace); font-size: 13px;">
                                <div data-csp-style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted);">@r.FacetBLabel</div>
                                <div data-csp-style="color: var(--text-primary); margin-top: 2px;">@(r.FacetB ?? "—")</div>
                                @if (!string.IsNullOrEmpty(r.SourcePoNumber))
                                {
                                    <div data-csp-style="font-size: 12px; color: var(--text-muted); margin-top: 2px;">PO @r.SourcePoNumber</div>
                                }
                            </td>
                            <td data-csp-style="text-align: right; font-family: var(--font-mono, ui-monospace, monospace); color: var(--text-secondary);">
                                <div data-csp-style="color: var(--text-primary);">@r.QuantityRemaining.ToString("N2") @(r.Uom ?? "")</div>
                                <div data-csp-style="font-size: 12px; color: var(--text-muted); margin-top: 2px;">@pctRemaining.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)% of @r.QuantityReceived.ToString("N2")</div>
                            </td>
                            <td data-csp-style="color: var(--text-secondary); font-size: 13px;">@r.ReceivedAt.ToLocalTime().ToString("yyyy-MM-dd")</td>
                            <td>
                                <a href="/Admin/StockReceipts/Edit?id=@r.Id" class="ds-btn" data-variant="ghost" data-csp-style="padding: 4px 10px; font-size: 12px;">Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div data-csp-style="padding: 24px;">
            @await Html.PartialAsync("Primitives/_EmptyStateV2", new EmptyStateModel
            {
                Icon = "folder",
                Tone = "info",
                Title = "No stock receipts yet",
                Body = "Receipts capture the industry-specific facets (heat #, NDC, GTIN, TLC, harvest date, etc.) for each physical lot that arrives. They’re the audit join key for every nest cut downstream and the foundation for ASME / FDA / DSCSA / AS9100 traceability.",
                CtaLabel = "Create First Receipt",
                CtaHref = "/Receiving/By-Po",
                SecondaryLabel = "Back to Admin",
                SecondaryHref = "/Admin"
            })
        </div>
    }
</div>

<script type="application/json" id="voice-context-payload">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.BuildContextPayload()))
</script>
