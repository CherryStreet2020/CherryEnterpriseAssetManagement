@page "/Admin/VendorWipProbe"
@model Abs.FixedAssets.Pages.Admin.VendorWipProbeModel
@using Abs.FixedAssets.Models
@{
    ViewData["Title"] = "Vendor WIP Probe";
    ViewData["TabTitle"] = "Vendor WIP Probe";
    Layout = "_ModernLayout";
}

<header class="ds-page-header">
    <div class="ds-page-header__inner">
        <h1 class="ds-page-header__title">Vendor WIP Probe</h1>
        <p class="ds-page-header__subtitle">
            Sprint 15.1 PR-5 — Physical lot tracking at vendor. Ship-to-vendor / receive-back / accept-reject / vendor process scrap. Per-(PRO+op+supplier+lot+rev) balance with 11-state inventory lifecycle. <strong>CLOSES Wave 1 of 20-PR purchasing cascade.</strong>
        </p>
    </div>
</header>

<main class="ds-page">

    @if (!string.IsNullOrEmpty(Model.Outcome))
    {
        <section class="ds-card ds-mt-3"><div class="ds-card__body">
            @if (Model.OutcomeIsError)
            { <p class="ds-text-danger" data-testid="vw-outcome-error">@Model.Outcome</p> }
            else
            { <p class="ds-text-success" data-testid="vw-outcome-ok">@Model.Outcome</p> }
        </div></section>
    }

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">Summary Stats</h2>
        <table class="ds-table">
            <tbody>
                <tr><td>Total Vendor Locations</td><td data-testid="vw-locations">@Model.TotalLocations</td></tr>
                <tr><td>Total Balances</td><td>@Model.TotalBalances</td></tr>
                <tr><td>Balances at Vendor</td><td>@Model.BalancesAtVendor</td></tr>
                <tr><td>Balances Received Back</td><td>@Model.BalancesReceivedBack</td></tr>
                <tr><td>Total Transactions</td><td>@Model.TotalTransactions</td></tr>
                <tr><td>Total Value At Vendor</td><td>@Model.TotalValueAtVendor.ToString("C")</td></tr>
            </tbody>
        </table>
    </div></section>

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">1. Register Vendor Location</h2>
        <p class="ds-text-muted">Per §14 — vendor facility where our WIP lands. Idempotent per (company, supplier, code).</p>
        <form method="post" asp-page-handler="RegisterLocation">
            <div class="ds-form-row"><label class="ds-label">Supplier ID</label><input type="number" class="ds-input" asp-for="RegLocSupplierId" /></div>
            <div class="ds-form-row"><label class="ds-label">Location Code</label><input class="ds-input" asp-for="RegLocCode" /></div>
            <div class="ds-form-row"><label class="ds-label">Address</label><input class="ds-input" asp-for="RegLocAddress" /></div>
            <div class="ds-form-row"><label class="ds-label">WIP Allowed</label><input type="checkbox" asp-for="RegLocWipAllowed" /></div>
            <div class="ds-form-row"><label class="ds-label">Default Transit Days</label><input type="number" class="ds-input" asp-for="RegLocTransitDays" /></div>
            <button type="submit" class="ds-btn ds-btn-primary" data-testid="btn-register-loc">Register Vendor Location</button>
        </form>
    </div></section>

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">2. Ship WIP to Vendor</h2>
        <form method="post" asp-page-handler="Ship">
            <div class="ds-form-row"><label class="ds-label">PRO ID</label><input type="number" class="ds-input" asp-for="ShipProId" /></div>
            <div class="ds-form-row"><label class="ds-label">Op Seq</label><input type="number" class="ds-input" asp-for="ShipOpSeq" /></div>
            <div class="ds-form-row"><label class="ds-label">Supplier ID</label><input type="number" class="ds-input" asp-for="ShipSupplierId" /></div>
            <div class="ds-form-row"><label class="ds-label">Vendor Location ID (optional)</label><input type="number" class="ds-input" asp-for="ShipVendorLocationId" /></div>
            <div class="ds-form-row"><label class="ds-label">Part Number</label><input class="ds-input" asp-for="ShipPartNumber" /></div>
            <div class="ds-form-row"><label class="ds-label">Revision</label><input class="ds-input" asp-for="ShipRevision" /></div>
            <div class="ds-form-row"><label class="ds-label">Lot Number</label><input class="ds-input" asp-for="ShipLotNumber" /></div>
            <div class="ds-form-row"><label class="ds-label">Quantity</label><input type="number" step="0.0001" class="ds-input" asp-for="ShipQty" /></div>
            <div class="ds-form-row"><label class="ds-label">Unit Value ($)</label><input type="number" step="0.0001" class="ds-input" asp-for="ShipUnitValue" /></div>
            <div class="ds-form-row"><label class="ds-label">Subcontract Op ID (optional)</label><input type="number" class="ds-input" asp-for="ShipSubcontractOpId" /></div>
            <button type="submit" class="ds-btn ds-btn-primary" data-testid="btn-ship">Ship to Vendor</button>
        </form>
    </div></section>

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">3. Receive from Vendor</h2>
        <form method="post" asp-page-handler="Receive">
            <div class="ds-form-row"><label class="ds-label">Balance ID</label><input type="number" class="ds-input" asp-for="RecvBalanceId" /></div>
            <div class="ds-form-row"><label class="ds-label">Qty Received</label><input type="number" step="0.0001" class="ds-input" asp-for="RecvQty" /></div>
            <div class="ds-form-row"><label class="ds-label">Qty Accepted</label><input type="number" step="0.0001" class="ds-input" asp-for="RecvAccepted" /></div>
            <div class="ds-form-row"><label class="ds-label">Qty Rejected</label><input type="number" step="0.0001" class="ds-input" asp-for="RecvRejected" /></div>
            <button type="submit" class="ds-btn ds-btn-primary" data-testid="btn-receive">Receive from Vendor</button>
        </form>
    </div></section>

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">4. Record Scrap at Vendor</h2>
        <form method="post" asp-page-handler="Scrap">
            <div class="ds-form-row"><label class="ds-label">Balance ID</label><input type="number" class="ds-input" asp-for="ScrapBalanceId" /></div>
            <div class="ds-form-row"><label class="ds-label">Qty Scrapped</label><input type="number" step="0.0001" class="ds-input" asp-for="ScrapQty" /></div>
            <div class="ds-form-row"><label class="ds-label">Reason</label><input class="ds-input" asp-for="ScrapReason" /></div>
            <button type="submit" class="ds-btn ds-btn-warning" data-testid="btn-scrap">Record Scrap</button>
        </form>
    </div></section>

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">5. Load Balance Summary</h2>
        <form method="post" asp-page-handler="LoadBalance">
            <div class="ds-form-row"><label class="ds-label">Balance ID</label><input type="number" class="ds-input" asp-for="LoadBalanceId" /></div>
            <button type="submit" class="ds-btn ds-btn-secondary" data-testid="btn-load-balance">Load Balance</button>
        </form>
        @if (Model.LoadedBalance != null)
        {
            var b = Model.LoadedBalance;
            <table class="ds-table ds-mt-2">
                <tbody>
                    <tr><td>Balance ID</td><td>@b.BalanceId</td></tr>
                    <tr><td>PRO / Op</td><td>@b.ProductionOrderId / @b.OperationSequence</td></tr>
                    <tr><td>Supplier</td><td>@b.SupplierId</td></tr>
                    <tr><td>Part</td><td>@(b.PartNumber ?? "—")</td></tr>
                    <tr><td>Shipped</td><td>@b.QuantityShipped.ToString("N4")</td></tr>
                    <tr><td>At Vendor (NOW)</td><td><strong>@b.QuantityAtVendor.ToString("N4")</strong></td></tr>
                    <tr><td>Received Back</td><td>@b.QuantityReceivedBack.ToString("N4")</td></tr>
                    <tr><td>Accepted / Rejected</td><td>@b.QuantityAccepted.ToString("N4") / @b.QuantityRejected.ToString("N4")</td></tr>
                    <tr><td>Scrapped at Vendor</td><td>@b.QuantityScrappedAtVendor.ToString("N4")</td></tr>
                    <tr><td>Lost</td><td>@b.QuantityLost.ToString("N4")</td></tr>
                    <tr><td>Inventory Status</td><td>@b.InventoryStatus</td></tr>
                    <tr><td>Aging Days</td><td>@b.AgingDaysAtVendor</td></tr>
                </tbody>
            </table>
        }
    </div></section>

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">6. Load Balances By PRO</h2>
        <form method="post" asp-page-handler="LoadByPro">
            <div class="ds-form-row"><label class="ds-label">PRO ID</label><input type="number" class="ds-input" asp-for="LoadByProId" /></div>
            <button type="submit" class="ds-btn ds-btn-secondary" data-testid="btn-load-pro">By PRO</button>
        </form>
    </div></section>

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">7. Load Balances By Supplier</h2>
        <form method="post" asp-page-handler="LoadBySupplier">
            <div class="ds-form-row"><label class="ds-label">Supplier ID</label><input type="number" class="ds-input" asp-for="LoadBySupplierId" /></div>
            <button type="submit" class="ds-btn ds-btn-secondary" data-testid="btn-load-sup">By Supplier</button>
        </form>
        @if (Model.LoadedBalances.Any())
        {
            <table class="ds-table ds-mt-2">
                <thead><tr><th>ID</th><th>PRO</th><th>Op</th><th>Sup</th><th>Part</th><th>Shipped</th><th>At Vendor</th><th>Received</th><th>Status</th></tr></thead>
                <tbody>
                    @foreach (var b in Model.LoadedBalances)
                    {
                        <tr>
                            <td>@b.Id</td><td>@b.ProductionOrderId</td><td>@b.OperationSequence</td><td>@b.SupplierId</td>
                            <td>@(b.PartNumber ?? "—")</td><td>@b.QuantityShipped.ToString("N4")</td>
                            <td>@b.QuantityAtVendor.ToString("N4")</td><td>@b.QuantityReceivedBack.ToString("N4")</td>
                            <td>@b.InventoryStatus</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div></section>

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">8. Load Transaction History</h2>
        <form method="post" asp-page-handler="LoadTransactions">
            <div class="ds-form-row"><label class="ds-label">Balance ID</label><input type="number" class="ds-input" asp-for="LoadTxnsBalanceId" /></div>
            <button type="submit" class="ds-btn ds-btn-secondary" data-testid="btn-load-txns">Load Transactions</button>
        </form>
        @if (Model.LoadedTransactions.Any())
        {
            <table class="ds-table ds-mt-2">
                <thead><tr><th>ID</th><th>Number</th><th>Type</th><th>Qty</th><th>Unit$</th><th>Ext$</th><th>UTC</th></tr></thead>
                <tbody>
                    @foreach (var t in Model.LoadedTransactions)
                    {
                        <tr>
                            <td>@t.Id</td><td>@t.TransactionNumber</td><td>@t.TransactionType</td>
                            <td>@t.Quantity.ToString("N4")</td><td>@t.UnitValue.ToString("N4")</td>
                            <td>@t.ExtendedValue.ToString("N2")</td>
                            <td>@t.TransactionUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div></section>

</main>
