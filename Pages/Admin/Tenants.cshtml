@page
@model Abs.FixedAssets.Pages.Admin.TenantsModel
@using Abs.FixedAssets.Models
@{
    ViewData["Title"] = "Tenants";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
    var activeTenants = Model.Tenants.Count(t => t.IsActive);
}

@{
    var headerVd = new ViewDataDictionary(ViewData)
    {
        { "HeaderTitle", "Tenants" },
        { "Subtitle", "Manage tenant organizations for multi-tenant deployment" },
        { "TypeLabel", "Administration" },
        { "StatusText", $"{activeTenants} Active" },
        { "StatusTone", "active" },
        { "KpisPartial", "Admin/_AdminTenantsKpis" },
        { "ActionsPartial", "Admin/_AdminTenantsActions" }
    };
}
@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="data-panel">
    <div class="panel-header">
        <h2 class="panel-title">Tenant List</h2>
    </div>
    <div class="panel-body">
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Companies</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tenant in Model.Tenants)
                {
                    <tr>
                        <td>@tenant.Id</td>
                        <td><strong>@tenant.Code</strong></td>
                        <td>@tenant.Name</td>
                        <td>@(tenant.Description ?? "-")</td>
                        <td>@(tenant.Companies?.Count ?? 0)</td>
                        <td>
                            @if (tenant.IsActive)
                            {
                                <span class="status-badge status-active">Active</span>
                            }
                            else
                            {
                                <span class="status-badge status-inactive">Inactive</span>
                            }
                        </td>
                        <td>
                            <button type="button" class="btn-p btn-p--secondary btn-p--sm" onclick="openEditForm(@tenant.Id, '@tenant.Code', '@tenant.Name', '@(tenant.Description?.Replace("'", "\\'") ?? "")', @tenant.IsActive.ToString().ToLower())">
                                Edit
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div id="addTenantForm" class="inline-form-panel-content" data-csp-style="display:none;">
    <div class="inline-form-backdrop" onclick="toggleInlineForm('addTenantForm')"></div>
    <div class="inline-form-panel-content">
        <div class="inline-form-header">
            <h3 class="inline-form-title">Add Tenant</h3>
            <button type="button" class="inline-form-close" onclick="toggleInlineForm('addTenantForm')">&times;</button>
        </div>
        <form method="post" asp-page-handler="Create">
            <div class="inline-form-body">
                <div class="form-group">
                    <label>Code <span class="required">*</span></label>
                    <input type="text" name="code" class="form-control" required maxlength="20" pattern="[A-Za-z0-9_-]+" title="Letters, numbers, dashes and underscores only" />
                </div>
                <div class="form-group">
                    <label>Name <span class="required">*</span></label>
                    <input type="text" name="name" class="form-control" required maxlength="100" />
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea name="description" class="form-control" maxlength="500" rows="3"></textarea>
                </div>
            </div>
            <div class="inline-form-footer">
                <button type="button" class="btn-p btn-p--secondary" onclick="toggleInlineForm('addTenantForm')">Cancel</button>
                <button type="submit" class="btn-p btn-p--primary">Create Tenant</button>
            </div>
        </form>
    </div>
</div>

<div id="editTenantForm" class="inline-form-panel-content" data-csp-style="display:none;">
    <div class="inline-form-backdrop" onclick="toggleInlineForm('editTenantForm')"></div>
    <div class="inline-form-panel-content">
        <div class="inline-form-header">
            <h3 class="inline-form-title">Edit Tenant</h3>
            <button type="button" class="inline-form-close" onclick="toggleInlineForm('editTenantForm')">&times;</button>
        </div>
        <form method="post" asp-page-handler="Update">
            <input type="hidden" name="id" id="editId" />
            <div class="inline-form-body">
                <div class="form-group">
                    <label>Code <span class="required">*</span></label>
                    <input type="text" name="code" id="editCode" class="form-control" required maxlength="20" />
                </div>
                <div class="form-group">
                    <label>Name <span class="required">*</span></label>
                    <input type="text" name="name" id="editName" class="form-control" required maxlength="100" />
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea name="description" id="editDescription" class="form-control" maxlength="500" rows="3"></textarea>
                </div>
                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" name="isActive" id="editIsActive" value="true" />
                        Active
                    </label>
                </div>
            </div>
            <div class="inline-form-footer">
                <button type="button" class="btn-p btn-p--secondary" onclick="toggleInlineForm('editTenantForm')">Cancel</button>
                <button type="submit" class="btn-p btn-p--primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function openEditForm(id, code, name, description, isActive) {
    document.getElementById('editId').value = id;
    document.getElementById('editCode').value = code;
    document.getElementById('editName').value = name;
    document.getElementById('editDescription').value = description;
    document.getElementById('editIsActive').checked = isActive;
    toggleInlineForm('editTenantForm');
}
</script>
}
