@page
@model Abs.FixedAssets.Pages.Admin.ItemCategoriesModel
@{
    ViewData["Title"] = "Item Categories";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
    var totalCategories = Model.Categories.Count;
    var activeCategories = Model.Categories.Count(c => c.IsActive);
    
    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = "Item Categories",
        ["Subtitle"] = "Organize inventory items into categories for better management",
        ["TypeLabel"] = "Administration",
        ["StatusText"] = $"{activeCategories} Active",
        ["StatusTone"] = "active",
        ["ContextPartial"] = "/Pages/Admin/_AdminItemCategoriesContext.cshtml",
        ["KpisPartial"] = "/Pages/Admin/_AdminItemCategoriesKpis.cshtml",
        ["ActionsPartial"] = "/Pages/Admin/_AdminItemCategoriesActions.cshtml"
    };
}

@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="section-card">
    <div class="section-card-header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
            </svg>
            All Categories
        </h3>
        <span class="status-badge info">@totalCategories CATEGORIES</span>
    </div>
    <div class="section-card-body" data-csp-style="padding: 0;">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Parent</th>
                    <th>Inventory GL</th>
                    <th>Expense GL</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in Model.Categories)
                {
                    <tr>
                        <td><strong>@cat.Code</strong></td>
                        <td>@cat.Name</td>
                        <td>@(cat.Description ?? "-")</td>
                        <td>@(cat.ParentCategory?.Name ?? "-")</td>
                        <td>@(cat.DefaultGlAccount?.AccountNumber ?? "-")</td>
                        <td>@(cat.ExpenseGlAccount?.AccountNumber ?? "-")</td>
                        <td>
                            @if (cat.IsActive)
                            {
                                <span class="badge badge-success">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-danger">Inactive</span>
                            }
                        </td>
                        <td class="actions-cell">
                            <button type="button" class="btn-p btn-p--secondary btn-p--sm" 
                                onclick="editCategory(@cat.Id, '@cat.Code', '@cat.Name.Replace("'", "\\'")', '@(cat.Description?.Replace("'", "\\'") ?? "")', @(cat.ParentCategoryId?.ToString() ?? "null"), @(cat.DefaultGlAccountId?.ToString() ?? "null"), @(cat.ExpenseGlAccountId?.ToString() ?? "null"), @cat.IsActive.ToString().ToLower())">Edit</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div id="createForm" class="inline-form-panel" data-csp-style="display: none;">
    <div class="inline-form-panel-content">
        <div class="inline-form-header">
            <div class="inline-form-header-content">
                <div class="inline-form-header-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                    </svg>
                </div>
                <div class="inline-form-header-text">
                    <h3>Add Item Category</h3>
                    <p>Create a new item category for organizing inventory</p>
                </div>
            </div>
            <button type="button" class="inline-form-close" onclick="toggleInlineForm('createForm')">&times;</button>
        </div>
        <form method="post" asp-page-handler="Create">
            <div class="inline-form-body">
                <div class="inline-form-grid">
                    <div class="form-group">
                        <label>Code *</label>
                        <input type="text" name="code" class="form-control" required maxlength="20" />
                    </div>
                    <div class="form-group">
                        <label>Name *</label>
                        <input type="text" name="name" class="form-control" required maxlength="100" />
                    </div>
                    <div class="form-group">
                        <label>Parent Category</label>
                        <select name="parentCategoryId" class="form-control">
                            <option value="">-- None --</option>
                            @foreach (var cat in Model.Categories.Where(c => c.IsActive))
                            {
                                <option value="@cat.Id">@cat.Code - @cat.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Inventory GL Account</label>
                        <select name="defaultGlAccountId" class="form-control" data-cherry-select data-placeholder="Search GL accounts...">
                            <option value="">-- None --</option>
                            @foreach (var gl in Model.GlAccounts)
                            {
                                <option value="@gl.Id">@gl.AccountNumber - @gl.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Expense GL Account</label>
                        <select name="expenseGlAccountId" class="form-control" data-cherry-select data-placeholder="Search GL accounts...">
                            <option value="">-- None --</option>
                            @foreach (var gl in Model.GlAccounts)
                            {
                                <option value="@gl.Id">@gl.AccountNumber - @gl.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group full-width">
                        <label>Description</label>
                        <textarea name="description" class="form-control" rows="2" maxlength="500"></textarea>
                    </div>
                </div>
            </div>
            <div class="inline-form-footer">
                <button type="button" class="btn-p btn-p--secondary" onclick="toggleInlineForm('createForm')">Cancel</button>
                <button type="submit" class="btn-p btn-p--primary">Create Category</button>
            </div>
        </form>
    </div>
</div>

<div id="editForm" class="inline-form-panel" data-csp-style="display: none;">
    <div class="inline-form-panel-content">
        <div class="inline-form-header">
            <div class="inline-form-header-content">
                <div class="inline-form-header-icon edit">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                </div>
                <div class="inline-form-header-text">
                    <h3>Edit Item Category</h3>
                    <p>Update category details</p>
                </div>
            </div>
            <button type="button" class="inline-form-close" onclick="toggleInlineForm('editForm')">&times;</button>
        </div>
        <form method="post" asp-page-handler="Update">
            <input type="hidden" id="editId" name="id" />
            <div class="inline-form-body">
                <div class="inline-form-grid">
                    <div class="form-group">
                        <label>Code *</label>
                        <input type="text" id="editCode" name="code" class="form-control" required maxlength="20" />
                    </div>
                    <div class="form-group">
                        <label>Name *</label>
                        <input type="text" id="editName" name="name" class="form-control" required maxlength="100" />
                    </div>
                    <div class="form-group">
                        <label>Parent Category</label>
                        <select id="editParentCategoryId" name="parentCategoryId" class="form-control">
                            <option value="">-- None --</option>
                            @foreach (var cat in Model.Categories.Where(c => c.IsActive))
                            {
                                <option value="@cat.Id">@cat.Code - @cat.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Inventory GL Account</label>
                        <select id="editDefaultGlAccountId" name="defaultGlAccountId" class="form-control" data-cherry-select data-placeholder="Search GL accounts...">
                            <option value="">-- None --</option>
                            @foreach (var gl in Model.GlAccounts)
                            {
                                <option value="@gl.Id">@gl.AccountNumber - @gl.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Expense GL Account</label>
                        <select id="editExpenseGlAccountId" name="expenseGlAccountId" class="form-control" data-cherry-select data-placeholder="Search GL accounts...">
                            <option value="">-- None --</option>
                            @foreach (var gl in Model.GlAccounts)
                            {
                                <option value="@gl.Id">@gl.AccountNumber - @gl.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Status</label>
                        <select id="editIsActive" name="isActive" class="form-control" asp-items="Model.ActiveInactiveOptions"></select>
                    </div>
                    <div class="form-group full-width">
                        <label>Description</label>
                        <textarea id="editDescription" name="description" class="form-control" rows="2" maxlength="500"></textarea>
                    </div>
                </div>
            </div>
            <div class="inline-form-footer">
                <button type="button" class="btn-p btn-p--secondary" onclick="toggleInlineForm('editForm')">Cancel</button>
                <button type="submit" class="btn-p btn-p--primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<script>
function editCategory(id, code, name, description, parentCategoryId, defaultGlAccountId, expenseGlAccountId, isActive) {
    document.getElementById('editId').value = id;
    document.getElementById('editCode').value = code;
    document.getElementById('editName').value = name;
    document.getElementById('editDescription').value = description;
    document.getElementById('editParentCategoryId').value = parentCategoryId || '';
    document.getElementById('editDefaultGlAccountId').value = defaultGlAccountId || '';
    document.getElementById('editExpenseGlAccountId').value = expenseGlAccountId || '';
    document.getElementById('editIsActive').value = isActive.toString();
    toggleInlineForm('editForm');
}
</script>
