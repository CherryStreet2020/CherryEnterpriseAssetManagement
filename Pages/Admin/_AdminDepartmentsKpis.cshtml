@model Abs.FixedAssets.Pages.Admin.DepartmentsModel
<div class="kpi-card">
    <div class="kpi-label">Total</div>
    <div class="kpi-value">@Model.Departments.Count</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Active</div>
    <div class="kpi-value success">@Model.Departments.Count(d => d.IsActive)</div>
</div>
