@page
@model Abs.FixedAssets.Pages.Admin.TechniciansModel
@{
    ViewData["Title"] = "Technicians";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
    var totalTechs = Model.Technicians.Count;
    var activeTechs = Model.Technicians.Count(t => t.Active);
    
    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = "Technicians",
        ["Subtitle"] = "Manage maintenance technicians and their assignments",
        ["TypeLabel"] = "Administration",
        ["StatusText"] = $"{activeTechs} Active",
        ["StatusTone"] = "active",
        ["ContextPartial"] = "/Pages/Admin/_AdminTechniciansContext.cshtml",
        ["KpisPartial"] = "/Pages/Admin/_AdminTechniciansKpis.cshtml",
        ["ActionsPartial"] = "/Pages/Admin/_AdminTechniciansActions.cshtml"
    };
}

@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="section-card">
    <div class="section-card-header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
            </svg>
            All Technicians
        </h3>
        <span class="status-badge info">@totalTechs TECHNICIANS</span>
    </div>
    <div class="section-card-body" data-csp-style="padding: 0;">
    <table class="data-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Specialty</th>
                <th>Department</th>
                <th>Hourly Rate</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tech in Model.Technicians)
            {
                <tr>
                    <td><strong>@tech.Name</strong></td>
                    <td>@(tech.Email ?? "-")</td>
                    <td>@(tech.Phone ?? "-")</td>
                    <td>@(tech.Specialty ?? "-")</td>
                    <td>@(tech.Department ?? "-")</td>
                    <td>@(tech.HourlyRate?.ToString("C2") ?? "-")</td>
                    <td>
                        @if (tech.Active)
                        {
                            <span class="badge badge-success">Active</span>
                        }
                        else
                        {
                            <span class="badge badge-danger">Inactive</span>
                        }
                    </td>
                    <td class="actions-cell">
                        <button type="button" class="btn-p btn-p--secondary btn-p--sm" onclick="editTechnician(@tech.Id, '@tech.Name.Replace("'", "\\'")', '@(tech.Email ?? "")', '@(tech.Phone ?? "")', '@(tech.Specialty ?? "")', '@(tech.Department ?? "")', '@(tech.HourlyRate?.ToString() ?? "")', '@(tech.Notes?.Replace("'", "\\'").Replace("\n", "\\n") ?? "")', @tech.Active.ToString().ToLower())">Edit</button>
                        <form method="post" asp-page-handler="ToggleActive" data-csp-style="display: inline;">
                            <input type="hidden" name="technicianId" value="@tech.Id" />
                            <button type="submit" class="btn-p btn-p--sm @(tech.Active ? "btn-p--danger" : "btn-p--primary")">
                                @(tech.Active ? "Deactivate" : "Activate")
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div id="createForm" class="inline-form-panel" data-csp-style="display: none;">
    <div class="inline-form-panel-content">
        <div class="inline-form-header">
            <div class="inline-form-header-content">
                <div class="inline-form-header-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                    </svg>
                </div>
                <div class="inline-form-header-text">
                    <h3>Add Technician</h3>
                    <p>Create a new maintenance technician</p>
                </div>
            </div>
            <button type="button" class="inline-form-close" onclick="toggleInlineForm('createForm')">&times;</button>
        </div>
        <form method="post" asp-page-handler="Create">
            <div class="inline-form-body">
                <div class="inline-form-section">
                    <div class="inline-form-section-title">Personal Information</div>
                    <div class="inline-form-grid">
                        <div class="form-group">
                            <label>Name *</label>
                            <input type="text" name="name" class="form-control" required />
                        </div>
                        <div class="form-group">
                            <label>Email</label>
                            <input type="email" name="email" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Phone</label>
                            <input type="text" name="phone" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Hourly Rate</label>
                            <div class="input-group-currency">
                                <span class="currency-prefix">$</span>
                                <input type="number" name="hourlyRate" class="form-control" step="0.01" min="0" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="inline-form-section">
                    <div class="inline-form-section-title">Work Details</div>
                    <div class="inline-form-grid">
                        <div class="form-group">
                            <label>Specialty</label>
                            <input type="text" name="specialty" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Department</label>
                            <input type="text" name="department" class="form-control" />
                        </div>
                        <div class="form-group full-width">
                            <label>Notes</label>
                            <textarea name="notes" class="form-control" rows="3"></textarea>
                        </div>
                    </div>
                </div>
            </div>
            <div class="inline-form-footer">
                <button type="button" class="btn-p btn-p--secondary" onclick="toggleInlineForm('createForm')">Cancel</button>
                <button type="submit" class="btn-p btn-p--primary">Create Technician</button>
            </div>
        </form>
    </div>
</div>

<div id="editForm" class="inline-form-panel" data-csp-style="display: none;">
    <div class="inline-form-panel-content">
        <div class="inline-form-header">
            <div class="inline-form-header-content">
                <div class="inline-form-header-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                </div>
                <div class="inline-form-header-text">
                    <h3>Edit Technician</h3>
                    <p>Update technician details</p>
                </div>
            </div>
            <button type="button" class="inline-form-close" onclick="toggleInlineForm('editForm')">&times;</button>
        </div>
        <form method="post" asp-page-handler="Update">
            <input type="hidden" name="technicianId" id="editTechnicianId" />
            <div class="inline-form-body">
                <div class="inline-form-section">
                    <div class="inline-form-section-title">Personal Information</div>
                    <div class="inline-form-grid">
                        <div class="form-group">
                            <label>Name *</label>
                            <input type="text" name="name" id="editName" class="form-control" required />
                        </div>
                        <div class="form-group">
                            <label>Email</label>
                            <input type="email" name="email" id="editEmail" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Phone</label>
                            <input type="text" name="phone" id="editPhone" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Hourly Rate</label>
                            <div class="input-group-currency">
                                <span class="currency-prefix">$</span>
                                <input type="number" name="hourlyRate" id="editHourlyRate" class="form-control" step="0.01" min="0" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="inline-form-section">
                    <div class="inline-form-section-title">Work Details</div>
                    <div class="inline-form-grid">
                        <div class="form-group">
                            <label>Specialty</label>
                            <input type="text" name="specialty" id="editSpecialty" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Department</label>
                            <input type="text" name="department" id="editDepartment" class="form-control" />
                        </div>
                        <div class="form-group full-width">
                            <label>Notes</label>
                            <textarea name="notes" id="editNotes" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="form-group full-width">
                            <label class="checkbox-label">
                                <input type="checkbox" name="active" id="editActive" value="true" />
                                <span>Technician is active</span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="inline-form-footer">
                <button type="button" class="btn-p btn-p--secondary" onclick="toggleInlineForm('editForm')">Cancel</button>
                <button type="submit" class="btn-p btn-p--primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<script>
function editTechnician(id, name, email, phone, specialty, department, hourlyRate, notes, active) {
    document.getElementById('editTechnicianId').value = id;
    document.getElementById('editName').value = name;
    document.getElementById('editEmail').value = email;
    document.getElementById('editPhone').value = phone;
    document.getElementById('editSpecialty').value = specialty;
    document.getElementById('editDepartment').value = department;
    document.getElementById('editHourlyRate').value = hourlyRate;
    document.getElementById('editNotes').value = notes;
    document.getElementById('editActive').checked = active;
    toggleInlineForm('editForm');
}
</script>
