@page
@model Abs.FixedAssets.Pages.Admin.DemoDataModel
@{
    ViewData["Title"] = "Demo Data Pack";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";

    var statusText = Model.EnvironmentProfile == "LAB" ? "LAB Environment" :
                     Model.EnvironmentProfile == "DEMO" ? "DEMO (Protected)" :
                     Model.EnvironmentProfile;
    var statusTone = Model.EnvironmentProfile == "LAB" ? "info" :
                     Model.EnvironmentProfile == "DEMO" ? "warning" : "danger";

    var headerVd = new ViewDataDictionary(ViewData) {
        { "TypeLabel", "Administration" },
        { "HeaderTitle", "Demo Data Pack v1" },
        { "Subtitle", "Seed persistent demo data: Assets, PM Templates, PM Schedules, and Work Orders" },
        { "StatusText", statusText },
        { "StatusTone", statusTone },
        { "ContextPartial", "Admin/_AdminDemoDataContext" },
        { "KpisPartial", "Admin/_AdminDemoDataKpis" },
        { "ActionsPartial", "Admin/_AdminDemoDataActions" },
        { "PageModel", Model }
    };
}

<link rel="stylesheet" href="/css/premium-components.css" />

@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@if (TempData["Success"] != null)
{
    <div class="alert alert-success mb-4">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mb-4">@TempData["Error"]</div>
}

@if (Model.GuardResult != null && !Model.GuardResult.Allowed)
{
    <div class="section-card mb-4 bg-red-soft" data-csp-style="border: 2px solid var(--danger, #ef4444);">
        <div class="section-card-header bg-red-soft">
            <h3 class="section-card-title text-dark-red">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
                Demo Data Seeding Blocked
            </h3>
        </div>
        <div class="section-card-body">
            <p class="text-dark-red" data-csp-style="font-weight: 500;">@Model.GuardResult.Reason</p>
            <p class="text-muted">Demo data seeding is only available in LAB/Development environments with Admin role.</p>
        </div>
    </div>
}

<div class="grid grid-cols-2 gap-6 mb-6">
    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">Demo Pack v1 Contents</h3>
        </div>
        <div class="section-card-body">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Entity Type</th>
                        <th class="text-right">Seed Count</th>
                        <th class="text-right">Current Count</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>Assets</strong> (DEMO-* prefix)</td>
                        <td class="text-right">20</td>
                        <td class="text-right">@(Model.DataSummary?.DemoAssetCount ?? 0) / @(Model.DataSummary?.TotalAssetCount ?? 0)</td>
                    </tr>
                    <tr>
                        <td><strong>PM Templates</strong> (PM-* prefix)</td>
                        <td class="text-right">10</td>
                        <td class="text-right">@(Model.DataSummary?.DemoPMTemplateCount ?? 0) / @(Model.DataSummary?.TotalPMTemplateCount ?? 0)</td>
                    </tr>
                    <tr>
                        <td><strong>PM Schedules</strong></td>
                        <td class="text-right">10</td>
                        <td class="text-right">@(Model.DataSummary?.DemoPMScheduleCount ?? 0) / @(Model.DataSummary?.TotalPMScheduleCount ?? 0)</td>
                    </tr>
                    <tr>
                        <td><strong>Work Orders</strong> (PM-generated)</td>
                        <td class="text-right">Variable</td>
                        <td class="text-right">@(Model.DataSummary?.DemoWorkOrderCount ?? 0) / @(Model.DataSummary?.TotalWorkOrderCount ?? 0)</td>
                    </tr>
                </tbody>
            </table>
            <div class="mt-4 text-muted" data-csp-style="font-size: 0.875rem;">
                <p><strong>Idempotent:</strong> Running multiple times will not create duplicates. Existing records are updated or skipped.</p>
                <p><strong>Stable Keys:</strong> Assets use AssetNumber, Templates use Code, Schedules use Name.</p>
            </div>
        </div>
    </div>

    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">Actions</h3>
        </div>
        <div class="section-card-body">
            @if (Model.GuardResult?.Allowed == true)
            {
                <form method="post" asp-page-handler="Preview" class="mb-4">
                    <button type="submit" class="btn-p btn-p--secondary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="me-2">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                        </svg>
                        Preview Demo Pack v1 (No Writes)
                    </button>
                </form>

                <form method="post" asp-page-handler="Execute">
                    <div class="form-check mb-3">
                        <input type="checkbox" class="form-check-input" id="generateWorkOrders" asp-for="GenerateDueWorkOrders" />
                        <label class="form-check-label" for="generateWorkOrders">
                            Generate Due Work Orders (Next 30 Days)
                        </label>
                    </div>
                    <button type="submit" class="btn btn-primary w-100" onclick="return confirm('This will seed demo data to the database. Continue?');">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="me-2">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                        </svg>
                        Run Demo Pack v1 (Writes to DB)
                    </button>
                </form>
            }
            else
            {
                <div class="text-center text-muted py-4">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="mx-auto mb-3 text-muted">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                    <p>Demo seeding is locked in this environment.</p>
                </div>
            }
        </div>
    </div>
</div>

@if (Model.PreviewResult != null)
{
    <div class="section-card mb-6">
        <div class="section-card-header bg-green-soft">
            <h3 class="section-card-title text-dark-emerald">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
                Preview Results (Read-Only)
            </h3>
        </div>
        <div class="section-card-body">
            <div class="grid grid-cols-3 gap-4 mb-4">
                <div class="kpi-card bg-green-soft">
                    <div class="kpi-label">Would Create</div>
                    <div class="kpi-value text-dark-emerald">@Model.PreviewResult.TotalWouldCreate</div>
                </div>
                <div class="kpi-card bg-amber-soft">
                    <div class="kpi-label">Would Update</div>
                    <div class="kpi-value text-dark-amber">@Model.PreviewResult.TotalWouldUpdate</div>
                </div>
                <div class="kpi-card bg-gray-soft">
                    <div class="kpi-label">Would Skip</div>
                    <div class="kpi-value text-theme-primary">@Model.PreviewResult.TotalWouldSkip</div>
                </div>
            </div>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Step</th>
                        <th>Domain</th>
                        <th class="text-right">Would Create</th>
                        <th class="text-right">Would Update</th>
                        <th class="text-right">Would Skip</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var step in Model.PreviewResult.StepPreviews)
                    {
                        <tr>
                            <td>@step.StepName</td>
                            <td>@step.DomainName</td>
                            <td class="text-right">@step.WouldCreate</td>
                            <td class="text-right">@step.WouldUpdate</td>
                            <td class="text-right">@step.WouldSkip</td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (Model.ExecutionTime.HasValue)
            {
                <p class="text-muted mt-3">Preview completed in @Model.ExecutionTime.Value.TotalMilliseconds.ToString("F0")ms</p>
            }
        </div>
    </div>
}

@if (Model.ExecuteResult != null)
{
    <div class="section-card mb-6">
        <div class="section-card-header @(Model.ExecuteResult.Success ? "bg-green-soft" : "bg-red-soft")">
            <h3 class="section-card-title @(Model.ExecuteResult.Success ? "text-dark-emerald" : "text-dark-red")">
                @if (Model.ExecuteResult.Success)
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                }
                else
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                }
                Execution Results
            </h3>
        </div>
        <div class="section-card-body">
            <div class="grid grid-cols-4 gap-4 mb-4">
                <div class="kpi-card bg-green-soft">
                    <div class="kpi-label">Inserted</div>
                    <div class="kpi-value text-dark-emerald">@Model.ExecuteResult.TotalInserted</div>
                </div>
                <div class="kpi-card bg-amber-soft">
                    <div class="kpi-label">Updated</div>
                    <div class="kpi-value text-dark-amber">@Model.ExecuteResult.TotalUpdated</div>
                </div>
                <div class="kpi-card bg-gray-soft">
                    <div class="kpi-label">Skipped</div>
                    <div class="kpi-value text-theme-primary">@Model.ExecuteResult.TotalSkipped</div>
                </div>
                @if (Model.GeneratedWorkOrders.HasValue)
                {
                    <div class="kpi-card bg-blue-soft">
                        <div class="kpi-label">Work Orders</div>
                        <div class="kpi-value text-blue">@Model.GeneratedWorkOrders</div>
                    </div>
                }
            </div>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Step</th>
                        <th>Domain</th>
                        <th class="text-right">Inserted</th>
                        <th class="text-right">Updated</th>
                        <th class="text-right">Skipped</th>
                        <th class="text-right">Failed</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var step in Model.ExecuteResult.StepResults)
                    {
                        <tr>
                            <td>@step.StepName</td>
                            <td>@step.DomainName</td>
                            <td class="text-right">@step.Inserted</td>
                            <td class="text-right">@step.Updated</td>
                            <td class="text-right">@step.Skipped</td>
                            <td class="text-right @(step.Failed > 0 ? "text-danger" : "")">@step.Failed</td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (Model.ExecutionTime.HasValue)
            {
                <p class="text-muted mt-3">Execution completed in @Model.ExecutionTime.Value.TotalMilliseconds.ToString("F0")ms</p>
            }
        </div>
    </div>
}

<!-- Demo Pack v2 Section -->
<div class="section-card mb-6" data-csp-style="border: 2px solid var(--purple, #8b5cf6);">
    <div class="section-card-header gradient-btn-purple">
        <h3 class="section-card-title text-white">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
            Demo Pack v2: Items + Sourcing
        </h3>
    </div>
    <div class="section-card-body">
        <p class="mb-3">Seeds Items, Manufacturers, MPNs, VPNs, AVL entries, Alternates, and Supersession chains.</p>
        
        <div class="grid grid-cols-4 gap-4 mb-4">
            <div class="text-center py-2 bg-surface-alt" data-csp-style="border-radius: 8px;">
                <div class="text-purple" data-csp-style="font-size: 1.5rem; font-weight: 700;">@(Model.DataSummaryV2?.DemoItemCount ?? 0)</div>
                <div class="text-theme-muted" data-csp-style="font-size: 0.75rem;">Demo Items</div>
            </div>
            <div class="text-center py-2 bg-surface-alt" data-csp-style="border-radius: 8px;">
                <div class="text-purple" data-csp-style="font-size: 1.5rem; font-weight: 700;">@(Model.DataSummaryV2?.DemoManufacturerCount ?? 0)</div>
                <div class="text-theme-muted" data-csp-style="font-size: 0.75rem;">Demo Mfrs</div>
            </div>
            <div class="text-center py-2 bg-surface-alt" data-csp-style="border-radius: 8px;">
                <div class="text-purple" data-csp-style="font-size: 1.5rem; font-weight: 700;">@(Model.DataSummaryV2?.TotalMPNCount ?? 0)</div>
                <div class="text-theme-muted" data-csp-style="font-size: 0.75rem;">Total MPNs</div>
            </div>
            <div class="text-center py-2 bg-surface-alt" data-csp-style="border-radius: 8px;">
                <div class="text-purple" data-csp-style="font-size: 1.5rem; font-weight: 700;">@(Model.DataSummaryV2?.TotalVPNCount ?? 0)</div>
                <div class="text-theme-muted" data-csp-style="font-size: 0.75rem;">Total VPNs</div>
            </div>
        </div>
        <div class="grid grid-cols-3 gap-4 mb-4">
            <div class="text-center py-2 bg-surface-alt" data-csp-style="border-radius: 8px;">
                <div class="text-green" data-csp-style="font-size: 1.5rem; font-weight: 700;">@(Model.DataSummaryV2?.TotalAVLCount ?? 0)</div>
                <div class="text-theme-muted" data-csp-style="font-size: 0.75rem;">AVL Entries</div>
            </div>
            <div class="text-center py-2 bg-surface-alt" data-csp-style="border-radius: 8px;">
                <div class="text-amber" data-csp-style="font-size: 1.5rem; font-weight: 700;">@(Model.DataSummaryV2?.TotalAlternateCount ?? 0)</div>
                <div class="text-theme-muted" data-csp-style="font-size: 0.75rem;">Alternates</div>
            </div>
            <div class="text-center py-2 bg-surface-alt" data-csp-style="border-radius: 8px;">
                <div class="text-red" data-csp-style="font-size: 1.5rem; font-weight: 700;">@(Model.DataSummaryV2?.TotalSupersessionCount ?? 0)</div>
                <div class="text-theme-muted" data-csp-style="font-size: 0.75rem;">Supersessions</div>
            </div>
        </div>
        
        @if (Model.GuardResult?.Allowed == true)
        {
            <div class="d-flex gap-3">
                <form method="post" asp-page-handler="PreviewV2" data-csp-style="display: inline;">
                    <button type="submit" class="btn-p btn-p--secondary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="me-1">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                        </svg>
                        Preview V2
                    </button>
                </form>
                <form method="post" asp-page-handler="ExecuteV2" data-csp-style="display: inline;">
                    <button type="submit" class="btn btn-primary btn-purple">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="me-1">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        Execute V2
                    </button>
                </form>
            </div>
        }
    </div>
</div>

@if (Model.PreviewResultV2 != null)
{
    <div class="section-card mb-6">
        <div class="section-card-header bg-purple-soft">
            <h3 class="section-card-title">Demo Pack v2 Preview Results</h3>
        </div>
        <div class="section-card-body">
            <table class="table table-striped">
                <thead><tr><th>Step</th><th>Domain</th><th>Would Create</th><th>Would Update</th><th>Would Skip</th><th>Total</th></tr></thead>
                <tbody>
                    @foreach (var step in Model.PreviewResultV2.StepPreviews)
                    {
                        <tr>
                            <td>@step.StepName</td>
                            <td>@step.DomainName</td>
                            <td class="text-success">@step.WouldCreate</td>
                            <td class="text-warning">@step.WouldUpdate</td>
                            <td class="text-muted">@step.WouldSkip</td>
                            <td>@step.TotalInSeedData</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr data-csp-style="font-weight: bold;">
                        <td colspan="2">Total</td>
                        <td class="text-success">@Model.PreviewResultV2.TotalWouldCreate</td>
                        <td class="text-warning">@Model.PreviewResultV2.TotalWouldUpdate</td>
                        <td class="text-muted">@Model.PreviewResultV2.TotalWouldSkip</td>
                        <td>@Model.PreviewResultV2.StepPreviews.Sum(s => s.TotalInSeedData)</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
}

@if (Model.ExecuteResultV2 != null)
{
    <div class="section-card mb-6">
        <div class="section-card-header @(Model.ExecuteResultV2.Success ? "bg-green-soft" : "bg-red-soft")">
            <h3 class="section-card-title">Demo Pack v2 Execution Results</h3>
        </div>
        <div class="section-card-body">
            <table class="table table-striped">
                <thead><tr><th>Step</th><th>Domain</th><th>Inserted</th><th>Updated</th><th>Skipped</th><th>Failed</th></tr></thead>
                <tbody>
                    @foreach (var step in Model.ExecuteResultV2.StepResults)
                    {
                        <tr>
                            <td>@step.StepName</td>
                            <td>@step.DomainName</td>
                            <td class="text-success">@step.Inserted</td>
                            <td class="text-warning">@step.Updated</td>
                            <td class="text-muted">@step.Skipped</td>
                            <td class="text-danger">@step.Failed</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr data-csp-style="font-weight: bold;">
                        <td colspan="2">Total</td>
                        <td class="text-success">@Model.ExecuteResultV2.TotalInserted</td>
                        <td class="text-warning">@Model.ExecuteResultV2.TotalUpdated</td>
                        <td class="text-muted">@Model.ExecuteResultV2.TotalSkipped</td>
                        <td class="text-danger">@Model.ExecuteResultV2.TotalFailed</td>
                    </tr>
                </tfoot>
            </table>
            @if (Model.ExecutionTimeV2.HasValue)
            {
                <p class="text-muted mt-3">Execution completed in @Model.ExecutionTimeV2.Value.TotalMilliseconds.ToString("F0")ms</p>
            }
        </div>
    </div>
}
