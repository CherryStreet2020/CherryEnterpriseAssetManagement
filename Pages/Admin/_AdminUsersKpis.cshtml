@model Abs.FixedAssets.Pages.Admin.UsersModel
@{
    var totalUsers = Model.Users.Count;
    var activeUsers = Model.Users.Count(u => u.IsActive);
}
<div class="kpi-card">
    <div class="kpi-label">Total</div>
    <div class="kpi-value">@totalUsers</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Active</div>
    <div class="kpi-value success">@activeUsers</div>
</div>
