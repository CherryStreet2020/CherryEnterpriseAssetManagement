@page
@model Abs.FixedAssets.Pages.Admin.Lookups.EditValuesModel
@{
    ViewData["Title"] = $"Manage: {Model.LookupType?.Name}";
    ViewData["Breadcrumb1"] = "Admin";
    ViewData["Breadcrumb1Url"] = "/Admin";
    ViewData["Breadcrumb2"] = "Lookups";
    ViewData["Breadcrumb2Url"] = "/Admin/Lookups";
    ViewData["Breadcrumb3"] = Model.LookupType?.Name ?? "Values";
}

<partial name="_ScreenHeader" model='new Abs.FixedAssets.Models.PageTitle { Title = $"Manage Values: {Model.LookupType?.Name}", Subtitle = $"Key: {Model.LookupType?.Key}" }' />

<div class="page-content" data-csp-style="padding: 1.5rem;">
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success">@Model.SuccessMessage</div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <div class="section-card" data-csp-style="margin-bottom: 1.5rem;">
        <div class="section-card__header">
            <h3 class="section-card__title">Add New Value</h3>
        </div>
        <div class="section-card__body">
            <form method="post" asp-page-handler="AddValue" class="form-grid" data-csp-style="max-width: 800px;">
                <input type="hidden" name="typeId" value="@Model.LookupType?.Id" />
                <div class="form-field">
                    <label class="form-field__label">Code (stable key)</label>
                    <input type="text" name="code" class="form-field__input" placeholder="e.g. ACTIVE" required pattern="[A-Za-z0-9_\-]+" />
                </div>
                <div class="form-field">
                    <label class="form-field__label">Display Name</label>
                    <input type="text" name="name" class="form-field__input" placeholder="e.g. Active" required />
                </div>
                <div class="form-field">
                    <label class="form-field__label">Sort Order</label>
                    <input type="number" name="sortOrder" class="form-field__input" value="0" />
                </div>
                <div class="form-field form-field--full">
                    <label class="form-field__label">Metadata (JSON, optional)</label>
                    <input type="text" name="metadata" class="form-field__input" placeholder='e.g. {"IsTerminal": true}' />
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn-p btn-p--primary">Add Value</button>
                    <a href="/Admin/Lookups" class="btn-p btn-p--secondary">Back to Types</a>
                </div>
            </form>
        </div>
    </div>

    <div class="section-card">
        <div class="section-card__header">
            <h3 class="section-card__title">Values (@Model.Values.Count)</h3>
        </div>
        <div class="section-card__body" data-csp-style="padding: 0;">
            <table class="data-grid" data-grid-id="lookupValues">
                <thead>
                    <tr>
                        <th data-sortable>Code</th>
                        <th data-sortable>Name</th>
                        <th data-sortable>Sort</th>
                        <th>Metadata</th>
                        <th data-sortable>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var val in Model.Values)
                    {
                        <tr>
                            <td><code>@val.Code</code></td>
                            <td>
                                <form method="post" asp-page-handler="UpdateValue" data-csp-style="display:inline-flex;gap:0.5rem;align-items:center;">
                                    <input type="hidden" name="typeId" value="@Model.LookupType?.Id" />
                                    <input type="hidden" name="valueId" value="@val.Id" />
                                    <input type="text" name="name" value="@val.Name" class="form-field__input" data-csp-style="width:180px;" />
                                    <input type="number" name="sortOrder" value="@val.SortOrder" class="form-field__input" data-csp-style="width:60px;" />
                                    <input type="text" name="metadata" value="@(val.Metadata != null ? val.Metadata.RootElement.ToString() : "")" class="form-field__input" data-csp-style="width:200px;" placeholder="JSON" />
                                    <button type="submit" class="btn-p btn-p--secondary btn-p--sm">Save</button>
                                </form>
                            </td>
                            <td>@val.SortOrder</td>
                            <td><code data-csp-style="font-size:0.75rem;">@(val.Metadata != null ? val.Metadata.RootElement.ToString() : "-")</code></td>
                            <td>
                                @if (val.IsActive)
                                {
                                    <span class="badge badge-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-danger">Inactive</span>
                                }
                            </td>
                            <td>
                                <form method="post" asp-page-handler="ToggleValueActive" data-csp-style="display:inline;">
                                    <input type="hidden" name="typeId" value="@Model.LookupType?.Id" />
                                    <input type="hidden" name="valueId" value="@val.Id" />
                                    <button type="submit" class="btn-p btn-p--secondary btn-p--sm">
                                        @(val.IsActive ? "Deactivate" : "Activate")
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
