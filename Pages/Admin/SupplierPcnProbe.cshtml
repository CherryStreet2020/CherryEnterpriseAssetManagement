@page "/Admin/SupplierPcnProbe"
@model Abs.FixedAssets.Pages.Admin.SupplierPcnProbeModel
@using Abs.FixedAssets.Models.Engineering
@{
    ViewData["Title"] = "Supplier PCN Probe";
    ViewData["TabTitle"] = "Supplier PCN Probe";
    Layout = "_ModernLayout";
}

@*
    Sprint 14.3 PR-5 (2026-05-27) — admin probe for ISupplierNotificationService.
    NINE WRITE BUTTONS per Lock 16 corollary:
      1. Create Supplier PCN
      2. Mark Pending (Draft → Pending)
      3. Send PCN (Pending → SentToSupplier, fires outbox event)
      4. Record Acknowledgement (SentToSupplier → SupplierAcknowledged)
      5. Record Impact Assessment (SupplierAcknowledged → ImpactAssessmentReceived)
      6. Approve (ImpactAssessmentReceived → Approved)
      7. Reject (ImpactAssessmentReceived → Rejected)
      8. Close PCN (Approved → Closed)
      9. Get PCN (read form)
*@

<header class="ds-page-header">
    <div class="ds-page-header__inner">
        <h1 class="ds-page-header__title">Supplier PCN Probe</h1>
        <p class="ds-page-header__subtitle">
            Supplier Process Change Notifications (Sprint 14.3).
            Lifecycle: Draft &rarr; Pending &rarr; SentToSupplier &rarr; SupplierAcknowledged
            &rarr; ImpactAssessmentReceived &rarr; Approved &rarr; Closed.
            IATF 16949 &sect;8.5.6.1 process change notification to external providers.
        </p>
    </div>
</header>

<main class="ds-page">

    @if (!string.IsNullOrEmpty(Model.Outcome))
    {
        <section class="ds-card ds-mt-3">
            <div class="ds-card__body">
                @if (Model.OutcomeIsError)
                {
                    <p class="ds-text-danger" data-testid="pcn-outcome-error">@Model.Outcome</p>
                }
                else
                {
                    <p class="ds-text-success" data-testid="pcn-outcome-ok">@Model.Outcome</p>
                }
            </div>
        </section>
    }

    <section class="ds-card">
        <div class="ds-card__body">
            <h2 class="ds-h2">1. Create Supplier PCN</h2>
            <form method="post" asp-page-handler="Create" class="ds-form-grid">
                <div><label>CompanyId</label><input type="number" name="CreateCompanyId" value="@Model.CreateCompanyId" required class="ds-input" /></div>
                <div><label>PCN Number</label><input type="text" name="CreatePcnNumber" value="@Model.CreatePcnNumber" placeholder="PCN-2026-SKF-001" required class="ds-input" /></div>
                <div><label>Title</label><input type="text" name="CreateTitle" value="@Model.CreateTitle" required class="ds-input" /></div>
                <div><label>Description</label><input type="text" name="CreateDescription" value="@Model.CreateDescription" class="ds-input" /></div>
                <div><label>Type</label>
                    <select name="CreateType" class="ds-input">
                        @foreach (var t in System.Enum.GetValues<PcnType>()) { if (t == Model.CreateType) { <option value="@t" selected>@t</option> } else { <option value="@t">@t</option> } }
                    </select>
                </div>
                <div><label>ItemId (BRG-6207-2RS = 9245)</label><input type="number" name="CreateItemId" value="@Model.CreateItemId" class="ds-input" /></div>
                <div><label>VendorId (optional)</label><input type="number" name="CreateVendorId" value="@Model.CreateVendorId" class="ds-input" /></div>
                <div><label>Originating ECR Id (optional)</label><input type="number" name="CreateOriginatingEcrId" value="@Model.CreateOriginatingEcrId" class="ds-input" /></div>
                <div><label>Change Description</label><input type="text" name="CreateChangeDescription" value="@Model.CreateChangeDescription" class="ds-input" /></div>
                <div><label>Impact Description</label><input type="text" name="CreateImpactDescription" value="@Model.CreateImpactDescription" class="ds-input" /></div>
                <div><label>Current Specification</label><input type="text" name="CreateCurrentSpec" value="@Model.CreateCurrentSpec" class="ds-input" /></div>
                <div><label>Proposed Specification</label><input type="text" name="CreateProposedSpec" value="@Model.CreateProposedSpec" class="ds-input" /></div>
                <div><label>FAI Required</label><input type="checkbox" name="CreateFirstArticleRequired" value="true" @(Model.CreateFirstArticleRequired ? "checked" : "") /></div>
                <div><label>PPAP Required</label><input type="checkbox" name="CreatePpapRequired" value="true" @(Model.CreatePpapRequired ? "checked" : "") /></div>
                <div><label>Delivery Method</label>
                    <select name="CreateDeliveryMethod" class="ds-input">
                        @foreach (var m in System.Enum.GetValues<NotificationDeliveryMethod>()) { if (m == Model.CreateDeliveryMethod) { <option value="@m" selected>@m</option> } else { <option value="@m">@m</option> } }
                    </select>
                </div>
                <div class="ds-mt-3"><button type="submit" class="ds-btn ds-btn--primary" data-testid="pcn-btn-create">Create Supplier PCN</button></div>
            </form>
        </div>
    </section>

    <section class="ds-card ds-mt-3">
        <div class="ds-card__body">
            <h2 class="ds-h2">2. Mark Pending (Draft &rarr; Pending)</h2>
            <form method="post" asp-page-handler="MarkPending" class="ds-form-grid">
                <div><label>PCN Id</label><input type="number" name="PendingPcnId" value="@Model.PendingPcnId" required class="ds-input" /></div>
                <div class="ds-mt-3"><button type="submit" class="ds-btn ds-btn--secondary" data-testid="pcn-btn-pending">Mark Pending</button></div>
            </form>
        </div>
    </section>

    <section class="ds-card ds-mt-3">
        <div class="ds-card__body">
            <h2 class="ds-h2">3. Send PCN (Pending &rarr; SentToSupplier)</h2>
            <form method="post" asp-page-handler="Send" class="ds-form-grid">
                <div><label>PCN Id</label><input type="number" name="SendPcnId" value="@Model.SendPcnId" required class="ds-input" /></div>
                <div class="ds-mt-3"><button type="submit" class="ds-btn ds-btn--primary" data-testid="pcn-btn-send">Send PCN</button></div>
            </form>
        </div>
    </section>

    <section class="ds-card ds-mt-3">
        <div class="ds-card__body">
            <h2 class="ds-h2">4. Record Acknowledgement (SentToSupplier &rarr; SupplierAcknowledged)</h2>
            <form method="post" asp-page-handler="Acknowledge" class="ds-form-grid">
                <div><label>PCN Id</label><input type="number" name="AckPcnId" value="@Model.AckPcnId" required class="ds-input" /></div>
                <div><label>Supplier Respondent</label><input type="text" name="AckRespondent" value="@Model.AckRespondent" placeholder="J. Smith, Quality Mgr" class="ds-input" /></div>
                <div class="ds-mt-3"><button type="submit" class="ds-btn ds-btn--secondary" data-testid="pcn-btn-ack">Record Acknowledgement</button></div>
            </form>
        </div>
    </section>

    <section class="ds-card ds-mt-3">
        <div class="ds-card__body">
            <h2 class="ds-h2">5. Record Impact Assessment (SupplierAcknowledged &rarr; ImpactAssessmentReceived)</h2>
            <form method="post" asp-page-handler="RecordImpact" class="ds-form-grid">
                <div><label>PCN Id</label><input type="number" name="ImpactPcnId" value="@Model.ImpactPcnId" required class="ds-input" /></div>
                <div><label>Impact Assessment</label><input type="text" name="ImpactAssessment" value="@Model.ImpactAssessment" placeholder="CNC migration adds $0.12/unit tooling amortization. Lead time unchanged." class="ds-input" /></div>
                <div><label>Cost Impact ($, pos = increase)</label><input type="number" step="0.0001" name="ImpactCost" value="@Model.ImpactCost" placeholder="0.1200" class="ds-input" /></div>
                <div><label>Lead Time Impact (days, pos = longer)</label><input type="number" name="ImpactLeadTimeDays" value="@Model.ImpactLeadTimeDays" placeholder="0" class="ds-input" /></div>
                <div class="ds-mt-3"><button type="submit" class="ds-btn ds-btn--secondary" data-testid="pcn-btn-impact">Record Impact Assessment</button></div>
            </form>
        </div>
    </section>

    <section class="ds-card ds-mt-3">
        <div class="ds-card__body">
            <h2 class="ds-h2">6. Approve (ImpactAssessmentReceived &rarr; Approved)</h2>
            <form method="post" asp-page-handler="Approve" class="ds-form-grid">
                <div><label>PCN Id</label><input type="number" name="ApprovePcnId" value="@Model.ApprovePcnId" required class="ds-input" /></div>
                <div class="ds-mt-3"><button type="submit" class="ds-btn ds-btn--primary" data-testid="pcn-btn-approve">Approve</button></div>
            </form>
        </div>
    </section>

    <section class="ds-card ds-mt-3">
        <div class="ds-card__body">
            <h2 class="ds-h2">7. Reject (ImpactAssessmentReceived &rarr; Rejected)</h2>
            <form method="post" asp-page-handler="Reject" class="ds-form-grid">
                <div><label>PCN Id</label><input type="number" name="RejectPcnId" value="@Model.RejectPcnId" required class="ds-input" /></div>
                <div><label>Rejection Reason</label><input type="text" name="RejectReason" value="@Model.RejectReason" placeholder="Cost impact exceeds budget — renegotiate tooling amortization schedule" required class="ds-input" /></div>
                <div class="ds-mt-3"><button type="submit" class="ds-btn ds-btn--ghost" data-testid="pcn-btn-reject">Reject</button></div>
            </form>
        </div>
    </section>

    <section class="ds-card ds-mt-3">
        <div class="ds-card__body">
            <h2 class="ds-h2">8. Close PCN (Approved &rarr; Closed)</h2>
            <form method="post" asp-page-handler="Close" class="ds-form-grid">
                <div><label>PCN Id</label><input type="number" name="ClosePcnId" value="@Model.ClosePcnId" required class="ds-input" /></div>
                <div><label>First Conforming Shipment Ref (optional)</label><input type="text" name="CloseShipmentRef" value="@Model.CloseShipmentRef" placeholder="PO-2026-SKF-0042 / LOT-2026-0312" class="ds-input" /></div>
                <div class="ds-mt-3"><button type="submit" class="ds-btn ds-btn--ghost" data-testid="pcn-btn-close">Close PCN</button></div>
            </form>
        </div>
    </section>

    <section class="ds-card ds-mt-3">
        <div class="ds-card__body">
            <h2 class="ds-h2">9. Get Supplier PCN by Id</h2>
            <form method="post" asp-page-handler="GetPcn" class="ds-form-grid">
                <div><label>PCN Id</label><input type="number" name="GetPcnId" value="@Model.GetPcnId" required class="ds-input" /></div>
                <div class="ds-mt-3"><button type="submit" class="ds-btn ds-btn--secondary" data-testid="pcn-btn-get">Get PCN</button></div>
            </form>

            @if (Model.PcnView is not null)
            {
                var p = Model.PcnView;
                <div class="ds-mt-3" data-testid="pcn-view-card">
                    <h3 class="ds-h3">Supplier PCN @p.Id (@p.PcnNumber)</h3>
                    <dl class="ds-defs">
                        <dt>Title</dt><dd>@p.Title</dd>
                        <dt>Status / Type</dt><dd>@p.Status / @p.Type</dd>
                        <dt>Vendor</dt><dd>@(p.Vendor?.Code ?? p.VendorId?.ToString() ?? "—")</dd>
                        <dt>Supplier Contact</dt><dd>@(p.SupplierContactName ?? "—") / @(p.SupplierContactEmail ?? "—")</dd>
                        <dt>Item</dt><dd>@(p.ItemId?.ToString() ?? "—")</dd>
                        <dt>ECR</dt><dd>@(p.OriginatingEcrId?.ToString() ?? "—")</dd>
                        <dt>Change Description</dt><dd>@(p.ChangeDescription ?? "—")</dd>
                        <dt>Impact Description</dt><dd>@(p.ImpactDescription ?? "—")</dd>
                        <dt>Current Spec</dt><dd>@(p.CurrentSpecification ?? "—")</dd>
                        <dt>Proposed Spec</dt><dd>@(p.ProposedSpecification ?? "—")</dd>
                        <dt>Proposed Effective Date</dt><dd>@(p.ProposedEffectiveDate?.ToString("u") ?? "—")</dd>
                        <dt>F/F/F</dt><dd>Form=@p.AffectsForm Fit=@p.AffectsFit Function=@p.AffectsFunction</dd>
                        <dt>Safety Impact</dt><dd>@p.SafetyImpact</dd>
                        <dt>FAI / PPAP / QP Update</dt><dd>@p.FirstArticleRequired / @p.PpapRequired / @p.QualityPlanUpdateRequired</dd>
                        <dt>Delivery Method</dt><dd>@p.DeliveryMethod</dd>
                        <dt>Sent By / At</dt><dd>@(p.SentBy ?? "—") / @(p.SentAtUtc?.ToString("u") ?? "—")</dd>
                        <dt>Supplier Acknowledged At</dt><dd>@(p.SupplierAcknowledgedAtUtc?.ToString("u") ?? "—")</dd>
                        <dt>Impact Assessment</dt><dd>@(p.SupplierImpactAssessment ?? "—")</dd>
                        <dt>Est. Cost / LT Impact</dt><dd>@(p.SupplierEstimatedCostImpact?.ToString("N4") ?? "—") / @(p.SupplierEstimatedLeadTimeImpactDays?.ToString() ?? "—")d</dd>
                        <dt>Approved By / At</dt><dd>@(p.ApprovedBy ?? "—") / @(p.ApprovedAtUtc?.ToString("u") ?? "—")</dd>
                        @if (p.Status == PcnStatus.Rejected)
                        {
                            <dt>Rejected By / At</dt><dd>@(p.RejectedBy ?? "—") / @(p.RejectedAtUtc?.ToString("u") ?? "—")</dd>
                            <dt>Rejection Reason</dt><dd>@(p.RejectionReason ?? "—")</dd>
                        }
                        <dt>1st Conforming Shipment</dt><dd>@(p.FirstConformingShipmentRef ?? "—")</dd>
                        <dt>Verified By / At</dt><dd>@(p.VerifiedBy ?? "—") / @(p.VerifiedAtUtc?.ToString("u") ?? "—")</dd>
                        <dt>Outbox Correlation</dt><dd>@(p.OutboxCorrelationId ?? "—")</dd>
                        <dt>Created / Updated</dt><dd>@p.CreatedAt.ToString("u") / @(p.UpdatedAt?.ToString("u") ?? "—")</dd>
                    </dl>
                </div>
            }
        </div>
    </section>
</main>
