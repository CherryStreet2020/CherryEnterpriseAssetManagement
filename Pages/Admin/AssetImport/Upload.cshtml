@page
@model Abs.FixedAssets.Pages.Admin.AssetImport.UploadModel
@{
    ViewData["Title"] = "Upload assets";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";

    var headerVd = new ViewDataDictionary(ViewData) {
        { "TypeLabel", "Administration" },
        { "HeaderTitle", "Upload Asset Excel" },
        { "Subtitle", "Choose an .xlsx file generated from the template" },
        { "StatusText", $"CompanyId {Model.CompanyId}" },
        { "StatusTone", "info" },
        { "ShowBackLink", true },
        { "BackLinkFallback", "/Admin/AssetImport" },
        { "BackLinkLabel", "Back to Asset Import" },
        { "PageModel", Model }
    };
}

<link rel="stylesheet" href="/css/premium-components.css" />

@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mb-4">@TempData["Error"]</div>
}

<div class="section-card">
    <div class="section-card-header">
        <h3 class="section-card-title">Upload Excel</h3>
        <span class="status-badge info">Max 10 MB</span>
    </div>
    <div class="section-card-body">
        <form method="post" enctype="multipart/form-data">
            <div class="form-stack-tight">
                <label for="ExcelFile" class="form-label-tight">Excel file</label>
                <input type="file" id="ExcelFile" name="ExcelFile" accept=".xlsx" required class="form-input" />
            </div>
            <p class="text-theme-muted form-stack-tight" data-csp-style="font-size: 0.875rem;">
                Required columns: <code>AssetNumber</code>, <code>Description</code>.
                Optional: <code>Manufacturer</code>, <code>Model</code>, <code>SerialNumber</code>,
                <code>AcquisitionCost</code>, <code>ReplacementCost</code>, <code>Currency</code>,
                <code>PurchaseDate</code>, <code>InServiceDate</code>, <code>FiscalPurchaseYear</code>,
                <code>UsefulLifeMonths</code>, <code>ImageUrl</code>, <code>LocationCode</code>,
                <code>DepartmentCode</code>, <code>SiteCode</code>, <code>Status</code>,
                <code>LongDescription</code>, <code>TagNumber</code>.
            </p>
            <p class="text-theme-muted form-stack-tight" data-csp-style="font-size: 0.875rem;">
                Don't have a template? <a href="/Admin/AssetImport?handler=Template">Download one here</a>.
            </p>
            <div class="form-actions">
                <button type="submit" class="hero-btn hero-btn-primary">Upload and stage</button>
                <a href="/Admin/AssetImport" class="hero-btn hero-btn-ghost">Cancel</a>
            </div>
        </form>
    </div>
</div>
