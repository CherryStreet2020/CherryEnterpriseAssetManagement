@page
@model Abs.FixedAssets.Pages.Admin.AssetImport.IndexModel
@{
    ViewData["Title"] = "Asset Bulk Import";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";

    var headerVd = new ViewDataDictionary(ViewData) {
        { "TypeLabel", "Administration" },
        { "HeaderTitle", "Asset Bulk Import" },
        { "Subtitle", "Upload an Excel file of fixed assets — preview every row, commit when ready" },
        { "StatusText", $"CompanyId {Model.CompanyId}" },
        { "StatusTone", "info" },
        { "PageModel", Model }
    };
}

<link rel="stylesheet" href="/css/premium-components.css" />

@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@if (TempData["Success"] != null)
{
    <div class="alert alert-success mb-4">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mb-4">@TempData["Error"]</div>
}

<div class="grid grid-cols-4 gap-4 mb-4">
    <div class="kpi-card">
        <div class="kpi-label">Total Batches</div>
        <div class="kpi-value">@Model.Kpis.TotalBatches</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Committed</div>
        <div class="kpi-value success">@Model.Kpis.CommittedBatches</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">In Progress</div>
        <div class="kpi-value info">@Model.Kpis.DraftBatches</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Failed / Discarded</div>
        <div class="kpi-value @(Model.Kpis.FailedOrDiscarded > 0 ? "warning" : "")">@Model.Kpis.FailedOrDiscarded</div>
    </div>
</div>

<div class="section-card mb-4">
    <div class="section-card-header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
            </svg>
            Start a new import
        </h3>
        <span class="status-badge info">Excel</span>
    </div>
    <div class="section-card-body">
        <p class="text-theme-muted" data-csp-style="margin-bottom: 1rem;">
            Download the template, fill in your assets, then upload. The system will validate every
            row before you commit — no surprises.
        </p>
        <div data-csp-style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
            <a href="/Admin/AssetImport?handler=Template" class="hero-btn hero-btn-ghost">
                Download template (.xlsx)
            </a>
            <a href="/Admin/AssetImport/Upload" class="hero-btn hero-btn-primary">
                Upload Excel
            </a>
        </div>
    </div>
</div>

<div class="section-card">
    <div class="section-card-header">
        <h3 class="section-card-title">Recent batches</h3>
    </div>
    <div class="section-card-body" data-csp-style="padding: 0;">
        @if (Model.RecentBatches.Count == 0)
        {
            <p class="text-theme-muted" data-csp-style="padding: 1.5rem; text-align: center;">
                No import batches yet. Use "Upload Excel" above to start.
            </p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>File</th>
                        <th>Rows</th>
                        <th>Valid</th>
                        <th>Errors</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model.RecentBatches)
                    {
                        <tr>
                            <td>#@b.Id</td>
                            <td>@b.FileName</td>
                            <td>@b.RowCount</td>
                            <td class="text-success">@b.ValidRowCount</td>
                            <td class="@(b.ErrorRowCount > 0 ? "text-danger" : "text-muted")">@b.ErrorRowCount</td>
                            <td>
                                @switch (b.Status)
                                {
                                    case Abs.FixedAssets.Models.AssetImport.AssetImportBatchStatus.Draft:
                                        <span class="status-badge info">Draft</span>
                                        break;
                                    case Abs.FixedAssets.Models.AssetImport.AssetImportBatchStatus.Validated:
                                        <span class="status-badge warning">Validated</span>
                                        break;
                                    case Abs.FixedAssets.Models.AssetImport.AssetImportBatchStatus.Committed:
                                        <span class="status-badge success">Committed</span>
                                        break;
                                    case Abs.FixedAssets.Models.AssetImport.AssetImportBatchStatus.Failed:
                                        <span class="status-badge danger">Failed</span>
                                        break;
                                    case Abs.FixedAssets.Models.AssetImport.AssetImportBatchStatus.Discarded:
                                        <span class="status-badge muted">Discarded</span>
                                        break;
                                }
                            </td>
                            <td>@b.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                @if (b.Status == Abs.FixedAssets.Models.AssetImport.AssetImportBatchStatus.Validated
                                  || b.Status == Abs.FixedAssets.Models.AssetImport.AssetImportBatchStatus.Draft
                                  || b.Status == Abs.FixedAssets.Models.AssetImport.AssetImportBatchStatus.Failed)
                                {
                                    <a href="/Admin/AssetImport/Preview/@b.Id" class="hero-btn hero-btn-ghost" data-csp-style="font-size: 0.8125rem; padding: 0.25rem 0.625rem;">Preview</a>
                                }
                                else
                                {
                                    <a href="/Admin/AssetImport/Detail/@b.Id" class="hero-btn hero-btn-ghost" data-csp-style="font-size: 0.8125rem; padding: 0.25rem 0.625rem;">Detail</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
