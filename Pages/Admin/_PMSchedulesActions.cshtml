@model Abs.FixedAssets.Pages.Admin.PMSchedulesModel

@{
    var dueSoon = Model.Previews.Count(p => !p.AlreadyExists);
}

<div class="hero-tags">
    @if (dueSoon > 0)
    {
        <span class="hero-tag warning">@dueSoon DUE SOON</span>
    }
</div>
<div class="hero-btns">
    <a href="/Admin/PMTemplates" class="hero-btn hero-btn-ghost">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Templates
    </a>
    <a href="/Admin/PMScheduleEdit" class="hero-btn hero-btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
        </svg>
        New Schedule
    </a>
</div>
