@page
@model Abs.FixedAssets.Pages.Admin.KitsModel
@{
    ViewData["Title"] = "Kits & Assemblies";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
    var totalKits = Model.Kits.Count;
    var activeKits = Model.Kits.Count(k => k.IsActive);

    var headerVd = new ViewDataDictionary(ViewData) {
        { "TypeLabel", "Administration" },
        { "HeaderTitle", "Kits & Assemblies" },
        { "Subtitle", "Manage pre-configured kits and assemblies for maintenance and repairs" },
        { "StatusText", $"{activeKits} Active" },
        { "StatusTone", "active" },
        { "ContextPartial", "Admin/_AdminKitsContext" },
        { "KpisPartial", "Admin/_AdminKitsKpis" },
        { "ActionsPartial", "Admin/_AdminKitsActions" },
        { "PageModel", Model }
    };
}

@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

<div class="section-card">
    <div class="section-card-header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
            </svg>
            All Kits
        </h3>
        <span class="status-badge info">@totalKits KITS</span>
    </div>
    <div class="section-card-body" data-csp-style="padding: 0;">
        @if (Model.Kits.Any())
        {
            <table class="data-table" id="kitsTable">
                <thead>
                    <tr>
                        <th>Kit Number</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Items</th>
                        <th>Total Cost</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var kit in Model.Kits)
                    {
                        <tr>
                            <td><strong>@kit.KitNumber</strong></td>
                            <td>@kit.Name</td>
                            <td>@(kit.Category?.Name ?? "-")</td>
                            <td>@(kit.Items?.Count ?? 0) items</td>
                            <td>@kit.TotalCost.ToString("C2")</td>
                            <td>
                                @if (kit.IsActive)
                                {
                                    <span class="badge badge-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-secondary">Inactive</span>
                                }
                            </td>
                            <td>
                                <button class="btn-p btn-p--secondary btn-p--sm" onclick="editKit(@kit.Id)">Edit</button>
                                <button class="btn-p btn-p--danger btn-p--sm" onclick="deleteKit(@kit.Id)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="pe-empty" data-csp-style="padding:1.5rem;">
                <i class="fas fa-wrench pe-empty__icon" data-csp-style="font-size:1.2rem;"></i>
                <div class="pe-empty__text">No kits created. Create your first kit to group commonly used parts together.</div>
                <button class="btn-p btn-p--primary" data-csp-style="margin-top:0.75rem;" onclick="toggleInlineForm('addKitForm')">Create Kit</button>
            </div>
        }
    </div>
</div>

<div class="inline-form-panel" id="addKitForm" data-csp-style="display: none;">
    <div class="inline-form-panel-content">
        <div class="inline-form-header">
            <h3 class="inline-form-title">Add New Kit</h3>
            <button type="button" class="inline-form-close" onclick="toggleInlineForm('addKitForm')">&times;</button>
        </div>
        <form method="post" asp-page-handler="Add">
            <div class="inline-form-body">
                <div class="form-group">
                    <label class="form-label">Kit Number</label>
                    <input type="text" name="KitNumber" class="form-control" required />
                </div>
                <div class="form-group">
                    <label class="form-label">Name</label>
                    <input type="text" name="Name" class="form-control" required />
                </div>
                <div class="form-group">
                    <label class="form-label">Description</label>
                    <textarea name="Description" class="form-control" rows="3"></textarea>
                </div>
                <div class="form-group">
                    <label class="form-label">Category</label>
                    <select name="CategoryId" class="form-control">
                        <option value="">-- Select Category --</option>
                        @foreach (var cat in Model.Categories)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                </div>
            </div>
            <div class="inline-form-footer">
                <button type="button" class="btn-p btn-p--secondary" onclick="toggleInlineForm('addKitForm')">Cancel</button>
                <button type="submit" class="btn-p btn-p--primary">Create Kit</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function() {
        if (typeof initEnhancedGrid === 'function') {
            initEnhancedGrid('kitsTable');
        }
    });
    
    function editKit(id) {
        window.location.href = '/Admin/Kits/Edit/' + id;
    }
    
    function deleteKit(id) {
        if (confirm('Are you sure you want to delete this kit?')) {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '/Admin/Kits?handler=Delete&id=' + id;
            document.body.appendChild(form);
            form.submit();
        }
    }
</script>
}
