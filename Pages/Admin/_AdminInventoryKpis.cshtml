@{
    var model = ViewData["PageModel"] as Abs.FixedAssets.Pages.Admin.InventoryModel;
}
<div class="kpi-card">
    <div class="kpi-label">Total SKUs</div>
    <div class="kpi-value">@(model?.TotalSkus.ToString("N0") ?? "0")</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">In Stock</div>
    <div class="kpi-value success">@(model?.InStockCount.ToString("N0") ?? "0")</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Low Stock</div>
    <div class="kpi-value warning">@(model?.LowStockCount.ToString("N0") ?? "0")</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Out of Stock</div>
    <div class="kpi-value danger">@(model?.OutOfStockCount.ToString("N0") ?? "0")</div>
</div>
