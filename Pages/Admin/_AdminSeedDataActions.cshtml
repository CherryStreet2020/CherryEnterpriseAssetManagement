@model Abs.FixedAssets.Pages.Admin.SeedDataModel
@{
    var totalTables = Model.TableCounts.Count;
    var tablesWithData = Model.TableCounts.Count(t => t.Value > 0);
}
<div class="hero-tags">
    @if (tablesWithData < totalTables)
    {
        <span class="hero-tag priority">@(totalTables - tablesWithData) Empty Tables</span>
    }
</div>
<div class="hero-btns">
    <a href="/Admin" class="hero-btn hero-btn-ghost">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Admin
    </a>
    <form method="post" asp-page-handler="SeedAll" style="display: inline;">
        <button type="submit" class="hero-btn hero-btn-success">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
            </svg>
            Seed All Data
        </button>
    </form>
</div>
