@page
@model Abs.FixedAssets.Pages.Admin.UsersModel
@using Abs.FixedAssets.Models
@{
    ViewData["Title"] = "Users & Roles";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
    var totalUsers = Model.Users.Count;
    var activeUsers = Model.Users.Count(u => u.IsActive);
}

@{
    var headerVd = new ViewDataDictionary(ViewData)
    {
        { "HeaderTitle", "Users & Roles" },
        { "Subtitle", "Manage user accounts, roles, and permissions" },
        { "TypeLabel", "Administration & Tools" },
        { "StatusText", $"{activeUsers} Active" },
        { "StatusTone", "active" },
        { "KpisPartial", "Admin/_AdminUsersKpis" },
        { "ActionsPartial", "Admin/_AdminUsersActions" }
    };
}
@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="section-card">
    <div class="section-card-header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
            </svg>
            All Users
        </h3>
        <span class="status-badge info">@totalUsers USERS</span>
    </div>
    <div class="section-card-body" style="padding: 0;">
    <table class="data-table">
        <thead>
            <tr>
                <th>Username</th>
                <th>Full Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Assigned Company</th>
                <th>Status</th>
                <th>Last Login</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td><strong>@user.Username</strong></td>
                    <td>@(user.FullName ?? "-")</td>
                    <td>@(user.Email ?? "-")</td>
                    <td>
                        <span class="badge @(user.Role == "Admin" ? "badge-primary" : user.Role == "Accountant" ? "badge-success" : "badge-secondary")">
                            @user.Role
                        </span>
                    </td>
                    <td>
                        @if (user.AssignedCompany != null)
                        {
                            <span class="badge badge-info">@user.AssignedCompany.Name</span>
                        }
                        else
                        {
                            <span class="badge badge-secondary">All Companies</span>
                        }
                        @if (user.AssignedSite != null)
                        {
                            <br /><span class="badge badge-info" style="margin-top:2px;">@user.AssignedSite.Name</span>
                        }
                    </td>
                    <td>
                        @if (user.IsActive)
                        {
                            <span class="badge badge-success">Active</span>
                        }
                        else
                        {
                            <span class="badge badge-danger">Inactive</span>
                        }
                    </td>
                    <td>@(user.LastLoginAt?.ToString("MMM dd, yyyy h:mm tt") ?? "Never")</td>
                    <td class="actions-cell">
                        <button type="button" class="btn-p btn-p--secondary btn-p--sm" onclick="editUser(@user.Id, '@user.Username', '@(user.Email ?? "")', '@(user.FullName ?? "")', '@user.Role', @user.IsActive.ToString().ToLower(), @(user.AssignedCompanyId?.ToString() ?? "''"), @(user.AssignedSiteId?.ToString() ?? "''"))">Edit</button>
                        <button type="button" class="btn-p btn-p--secondary btn-p--sm" onclick="resetPassword(@user.Id, '@user.Username')">Reset Password</button>
                        <form method="post" asp-page-handler="ToggleActive" style="display: inline;">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <button type="submit" class="btn-p btn-p--sm @(user.IsActive ? "btn-p--danger" : "btn-p--primary")">
                                @(user.IsActive ? "Deactivate" : "Activate")
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div id="createForm" class="inline-form-panel" style="display: none;">
    <div class="inline-form-panel-content">
        <div class="inline-form-header">
            <div class="inline-form-header-content">
                <div class="inline-form-header-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                    </svg>
                </div>
                <div class="inline-form-header-text">
                    <h3>Add User</h3>
                    <p>Create a new system user</p>
                </div>
            </div>
            <button type="button" class="inline-form-close" onclick="toggleInlineForm('createForm')">&times;</button>
        </div>
        <form method="post" asp-page-handler="Create">
            <div class="inline-form-body">
                <div class="inline-form-section">
                    <div class="inline-form-section-title">Account Information</div>
                    <div class="inline-form-grid">
                        <div class="form-group">
                            <label>Username *</label>
                            <input type="text" name="username" class="form-control" required />
                        </div>
                        <div class="form-group">
                            <label>Password *</label>
                            <input type="password" name="password" class="form-control" required minlength="6" />
                        </div>
                        <div class="form-group">
                            <label>Full Name</label>
                            <input type="text" name="fullName" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Email</label>
                            <input type="email" name="email" class="form-control" />
                        </div>
                    </div>
                </div>
                <div class="inline-form-section">
                    <div class="inline-form-section-title">Permissions</div>
                    <div class="inline-form-grid">
                        <div class="form-group">
                            <label>Role</label>
                            <select name="role" class="form-control" asp-items="Model.RoleOptions"></select>
                        </div>
                        <div class="form-group">
                            <label>Assigned Company</label>
                            <select name="assignedCompanyId" class="form-control">
                                <option value="">All Companies (Admin)</option>
                                @foreach (var company in Model.Companies)
                                {
                                    <option value="@company.Id">@company.Name</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Assigned Site</label>
                            <select name="assignedSiteId" class="form-control">
                                <option value="">All Sites (company-level)</option>
                                @foreach (var site in Model.Sites)
                                {
                                    <option value="@site.Id">@site.Name (@site.Company?.Name)</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
            </div>
            <div class="inline-form-footer">
                <button type="button" class="btn-p btn-p--secondary" onclick="toggleInlineForm('createForm')">Cancel</button>
                <button type="submit" class="btn-p btn-p--primary">Create User</button>
            </div>
        </form>
    </div>
</div>

<div id="editForm" class="inline-form-panel" style="display: none;">
    <div class="inline-form-panel-content">
        <div class="inline-form-header">
            <div class="inline-form-header-content">
                <div class="inline-form-header-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                </div>
                <div class="inline-form-header-text">
                    <h3>Edit User</h3>
                    <p>Update user details and permissions</p>
                </div>
            </div>
            <button type="button" class="inline-form-close" onclick="toggleInlineForm('editForm')">&times;</button>
        </div>
        <form method="post" asp-page-handler="Update">
            <input type="hidden" name="userId" id="editUserId" />
            <div class="inline-form-body">
                <div class="inline-form-section">
                    <div class="inline-form-section-title">Account Information</div>
                    <div class="inline-form-grid">
                        <div class="form-group">
                            <label>Username</label>
                            <input type="text" id="editUsername" class="form-control" disabled />
                        </div>
                        <div class="form-group">
                            <label>Email</label>
                            <input type="email" name="email" id="editEmail" class="form-control" />
                        </div>
                        <div class="form-group full-width">
                            <label>Full Name</label>
                            <input type="text" name="fullName" id="editFullName" class="form-control" />
                        </div>
                    </div>
                </div>
                <div class="inline-form-section">
                    <div class="inline-form-section-title">Permissions</div>
                    <div class="inline-form-grid">
                        <div class="form-group">
                            <label>Role</label>
                            <select name="role" id="editRole" class="form-control" asp-items="Model.RoleOptions"></select>
                        </div>
                        <div class="form-group">
                            <label>Assigned Company</label>
                            <select name="assignedCompanyId" id="editAssignedCompanyId" class="form-control">
                                <option value="">All Companies (Admin)</option>
                                @foreach (var company in Model.Companies)
                                {
                                    <option value="@company.Id">@company.Name</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Assigned Site</label>
                            <select name="assignedSiteId" id="editAssignedSiteId" class="form-control">
                                <option value="">All Sites (company-level)</option>
                                @foreach (var site in Model.Sites)
                                {
                                    <option value="@site.Id">@site.Name (@site.Company?.Name)</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="checkbox-label" style="margin-top: 28px;">
                                <input type="checkbox" name="isActive" id="editIsActive" value="true" />
                                <span>User is active</span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="inline-form-footer">
                <button type="button" class="btn-p btn-p--secondary" onclick="toggleInlineForm('editForm')">Cancel</button>
                <button type="submit" class="btn-p btn-p--primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<div id="resetForm" class="inline-form-panel" style="display: none;">
    <div class="inline-form-panel-content">
        <div class="inline-form-header">
            <div class="inline-form-header-content">
                <div class="inline-form-header-icon bg-amber-soft">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="#d97706">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
                    </svg>
                </div>
                <div class="inline-form-header-text">
                    <h3>Reset Password</h3>
                    <p>Set a new password for user: <strong id="resetUsername"></strong></p>
                </div>
            </div>
            <button type="button" class="inline-form-close" onclick="toggleInlineForm('resetForm')">&times;</button>
        </div>
        <form method="post" asp-page-handler="ResetPassword">
            <input type="hidden" name="userId" id="resetUserId" />
            <div class="inline-form-body">
                <div class="inline-form-section">
                    <div class="inline-form-section-title">New Password</div>
                    <div class="inline-form-grid">
                        <div class="form-group full-width">
                            <label>New Password *</label>
                            <input type="password" name="newPassword" class="form-control" required minlength="6" />
                        </div>
                        <div class="form-group full-width">
                            <p class="form-hint">User will be required to change password on next login.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="inline-form-footer">
                <button type="button" class="btn-p btn-p--secondary" onclick="toggleInlineForm('resetForm')">Cancel</button>
                <button type="submit" class="btn-p btn-p--secondary">Reset Password</button>
            </div>
        </form>
    </div>
</div>

<script>
function editUser(id, username, email, fullName, role, isActive, assignedCompanyId, assignedSiteId) {
    document.getElementById('editUserId').value = id;
    document.getElementById('editUsername').value = username;
    document.getElementById('editEmail').value = email;
    document.getElementById('editFullName').value = fullName;
    document.getElementById('editRole').value = role;
    document.getElementById('editIsActive').checked = isActive;
    document.getElementById('editAssignedCompanyId').value = assignedCompanyId || '';
    document.getElementById('editAssignedSiteId').value = assignedSiteId || '';
    toggleInlineForm('editForm');
}

function resetPassword(id, username) {
    document.getElementById('resetUserId').value = id;
    document.getElementById('resetUsername').textContent = username;
    toggleInlineForm('resetForm');
}
</script>
