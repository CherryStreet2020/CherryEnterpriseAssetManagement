@page "/Admin/SeedCfoMotionDemo"
@model Abs.FixedAssets.Pages.Admin.SeedCfoMotionDemoModel
@{
    ViewData["Title"] = "Seed CFO Motion Demo Data";
    ViewData["TabTitle"] = "Seed CFO Demo";
    Layout = "_ModernLayout";
}

@*
    Sprint 12.7 PR #5 — admin trigger for CfoMotionDemoSeeder.

    Pushes the Controller Control Center KPI band to demo-believable
    numbers ON THE DEMO TENANT ONLY (looked up by CompanyCode='PWH-CAN').

    Idempotent — every INSERT guarded by natural-key prefix WHERE NOT EXISTS.
    Re-clicking the button shows "already seeded N rows" per bucket.

    Lock 14 — runs on dev only. Republish-with-Copy syncs to prod at end
    of sprint window.
*@

<header class="ds-page-header">
    <div class="ds-page-header__inner">
        <h1 class="ds-page-header__title">Seed CFO Motion Demo Data</h1>
        <p class="ds-page-header__subtitle">
            Push the demo tenant's Controller Control Center KPI band to
            demo-believable numbers. Targets <code>CompanyCode = "PWH-CAN"</code>
            (the seeded PWH Manufacturing Canada placeholder).
        </p>
    </div>
</header>

<main class="ds-page">
    <section class="ds-card">
        <div class="ds-card__body">
            <h2 class="ds-h2">What this seeder does</h2>
            <ul class="ds-list">
                <li><strong>Cash position</strong> &rarr; adds a balanced JournalEntry that lifts Cash Position to ~$6M.</li>
                <li><strong>AP due this week</strong> &rarr; inserts ~20 VendorInvoices (Approved / PartiallyPaid) due within the next 7 days, summing into the "danger" tone band.</li>
                <li><strong>Open POs</strong> &rarr; adds ~18 PurchaseOrders in Approved / Sent / PartiallyReceived statuses totalling ~$2.5M committed.</li>
                <li><strong>WIP balance</strong> &rarr; creates 5 active CipProjects totalling ~$2.4M in WIP.</li>
            </ul>
            <p class="ds-mt-3">
                Every INSERT is idempotent. Natural keys:
                <code>DEMO-CFO-CASH-2026</code>,
                <code>DEMO-CFO-INV-*</code>,
                <code>DEMO-CFO-PO-*</code>,
                <code>DEMO-CFO-CIP-*</code>. Re-clicking the button is safe.
            </p>
            <p class="ds-text-muted ds-mt-2">
                <strong>Lock 14:</strong> runs on dev only. Republish-with-Copy syncs to prod at end of sprint window.
            </p>
            <p class="ds-text-muted ds-mt-2">
                <strong>Safety:</strong> the seeder verifies <code>Company.Name</code> starts with <code>PWH</code>
                before any write. If the demo tenant's name has been changed, the seeder refuses to run
                rather than write demo rows to a non-placeholder tenant.
            </p>

            <form method="post" class="ds-mt-4">
                <button type="submit" class="ds-btn ds-btn--primary">Seed CFO motion demo data</button>
                <a asp-page="/Controller/Index" class="ds-btn ds-btn--secondary ds-ml-2">Open Controller after seeding</a>
            </form>
        </div>
    </section>

    @if (Model.Result is not null)
    {
        var r = Model.Result;
        <section class="ds-card ds-mt-4">
            <div class="ds-card__body">
                <h2 class="ds-h2">Result</h2>
                <p>
                    Demo tenant: <strong>@r.CompanyCode</strong> &mdash; @r.CompanyName (CompanyId=@r.CompanyId)
                </p>
                <p>
                    Inserted: <strong>@r.TotalInserted</strong> &middot;
                    Skipped (already present): <strong>@r.TotalSkipped</strong>
                </p>
                <table class="ds-table">
                    <thead>
                        <tr><th>Bucket</th><th class="ds-text-right">Inserted</th><th class="ds-text-right">Already present</th></tr>
                    </thead>
                    <tbody>
                        <tr><td>Cash JE lines</td><td class="ds-text-right">@r.CashLinesInserted</td><td class="ds-text-right">@r.CashLinesSkipped</td></tr>
                        <tr><td>Vendor invoices</td><td class="ds-text-right">@r.VendorInvoicesInserted</td><td class="ds-text-right">@r.VendorInvoicesSkipped</td></tr>
                        <tr><td>Purchase orders</td><td class="ds-text-right">@r.PurchaseOrdersInserted</td><td class="ds-text-right">@r.PurchaseOrdersSkipped</td></tr>
                        <tr><td>CIP projects</td><td class="ds-text-right">@r.CipProjectsInserted</td><td class="ds-text-right">@r.CipProjectsSkipped</td></tr>
                    </tbody>
                </table>

                @if (r.Warnings.Count > 0)
                {
                    <h3 class="ds-h3 ds-mt-3">Warnings</h3>
                    <ul class="ds-list ds-text-warning">
                        @foreach (var w in r.Warnings)
                        {
                            <li>@w</li>
                        }
                    </ul>
                }
            </div>
        </section>
    }
</main>
