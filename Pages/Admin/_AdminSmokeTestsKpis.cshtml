@model Abs.FixedAssets.Pages.Admin.SmokeTestsModel
<div id="heroKpis" class="page-hero-kpis" data-csp-style="display: none;">
    <div class="kpi-card">
        <div class="kpi-label">Passed</div>
        <div class="kpi-value" id="kpiPassed" data-csp-style="color: var(--success);">0</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Failed</div>
        <div class="kpi-value" id="kpiFailed" data-csp-style="color: var(--text-muted);">0</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Duration</div>
        <div class="kpi-value" id="kpiDuration">0<span data-csp-style="font-size: 0.6em;">ms</span></div>
    </div>
</div>
