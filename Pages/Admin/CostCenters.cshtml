@page
@model Abs.FixedAssets.Pages.Admin.CostCentersModel
@{
    ViewData["Title"] = "Cost Centers";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
    var totalCenters = Model.CostCenters.Count;
    var activeCenters = Model.CostCenters.Count(c => c.IsActive);
    
    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = "Cost Centers",
        ["Subtitle"] = "Manage cost centers for expense tracking and allocation",
        ["TypeLabel"] = "Administration",
        ["StatusText"] = $"{activeCenters} Active",
        ["StatusTone"] = "active",
        ["ContextPartial"] = "/Pages/Admin/_AdminCostCentersContext.cshtml",
        ["KpisPartial"] = "/Pages/Admin/_AdminCostCentersKpis.cshtml",
        ["ActionsPartial"] = "/Pages/Admin/_AdminCostCentersActions.cshtml"
    };
}

@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="section-card pe-card">
    <div class="section-card-header pe-card__header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
            </svg>
            All Cost Centers
        </h3>
        <span class="status-badge info">@totalCenters CENTERS</span>
    </div>
    <div class="section-card-body pe-card__body" style="padding: 0;">
    <table class="data-table premium-table">
        <thead>
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th>Type</th>
                <th>Location</th>
                <th>Parent</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cc in Model.CostCenters)
            {
                <tr>
                    <td><strong>@cc.Code</strong></td>
                    <td>@cc.Name</td>
                    <td><span class="badge badge-outline">@cc.Type</span></td>
                    <td>@(cc.City != null ? $"{cc.City}, {cc.StateProvince}" : "-")</td>
                    <td>@(cc.ParentCostCenter?.Name ?? "-")</td>
                    <td>
                        @if (cc.IsActive)
                        {
                            <span class="badge badge-success">Active</span>
                        }
                        else
                        {
                            <span class="badge badge-danger">Inactive</span>
                        }
                    </td>
                    <td class="actions-cell">
                        <button type="button" class="btn-p btn-p--secondary btn-p--sm" onclick="editCostCenter(@cc.Id, '@cc.Code', '@cc.Name.Replace("'", "\\'")', '@(cc.Description?.Replace("'", "\\'") ?? "")', '@(cc.TypeLookupValueId ?? 0)', '@(cc.City ?? "")', '@(cc.StateProvince ?? "")', '@(cc.Country ?? "")', @(cc.ParentCostCenterId?.ToString() ?? "null"), @cc.IsActive.ToString().ToLower())">Edit</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div id="createForm" class="inline-form-panel" style="display: none;">
    <div class="inline-form-panel-content">
        <div class="inline-form-header">
            <div class="inline-form-header-content">
                <div class="inline-form-header-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                    </svg>
                </div>
                <div class="inline-form-header-text">
                    <h3>Add Cost Center</h3>
                    <p>Create a new cost center for asset tracking</p>
                </div>
            </div>
            <button type="button" class="inline-form-close" onclick="toggleInlineForm('createForm')">&times;</button>
        </div>
        <form method="post" asp-page-handler="Create">
            <div class="inline-form-body">
                <div class="inline-form-grid">
                    <div class="form-group form-group-p">
                        <label>Code *</label>
                        <input type="text" name="code" class="form-control form-input-p" required maxlength="20" />
                    </div>
                    <div class="form-group form-group-p">
                        <label>Name *</label>
                        <input type="text" name="name" class="form-control form-input-p" required maxlength="100" />
                    </div>
                    <div class="form-group form-group-p">
                        <label>Type *</label>
                        <select name="typeLookupValueId" class="form-control form-input-p" required asp-items="Model.TypeOptions"></select>
                    </div>
                    <div class="form-group form-group-p">
                        <label>Parent Cost Center</label>
                        <select name="parentId" class="form-control form-input-p" data-cherry-select data-placeholder="Search parent centers...">
                            <option value="">-- None --</option>
                            @foreach (var p in Model.CostCenters.Where(c => c.IsActive))
                            {
                                <option value="@p.Id">@p.Code - @p.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group form-group-p">
                        <label>City</label>
                        <input type="text" name="city" class="form-control form-input-p" maxlength="100" />
                    </div>
                    <div class="form-group form-group-p">
                        <label>State/Province</label>
                        <input type="text" name="stateProvince" class="form-control form-input-p" maxlength="50" />
                    </div>
                    <div class="form-group form-group-p">
                        <label>Country</label>
                        <input type="text" name="country" class="form-control form-input-p" maxlength="50" value="USA" />
                    </div>
                    <div class="form-group form-group-p full-width">
                        <label>Description</label>
                        <textarea name="description" class="form-control form-input-p" rows="2" maxlength="200"></textarea>
                    </div>
                </div>
            </div>
            <div class="inline-form-footer">
                <button type="button" class="btn-p btn-p--secondary" onclick="toggleInlineForm('createForm')">Cancel</button>
                <button type="submit" class="btn-p btn-p--primary">Create Cost Center</button>
            </div>
        </form>
    </div>
</div>

<div id="editForm" class="inline-form-panel" style="display: none;">
    <div class="inline-form-panel-content">
        <div class="inline-form-header">
            <div class="inline-form-header-content">
                <div class="inline-form-header-icon edit">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                </div>
                <div class="inline-form-header-text">
                    <h3>Edit Cost Center</h3>
                    <p>Update cost center details</p>
                </div>
            </div>
            <button type="button" class="inline-form-close" onclick="toggleInlineForm('editForm')">&times;</button>
        </div>
        <form method="post" asp-page-handler="Update">
            <input type="hidden" id="editId" name="id" />
            <div class="inline-form-body">
                <div class="inline-form-grid">
                    <div class="form-group form-group-p">
                        <label>Code *</label>
                        <input type="text" id="editCode" name="code" class="form-control form-input-p" required maxlength="20" />
                    </div>
                    <div class="form-group form-group-p">
                        <label>Name *</label>
                        <input type="text" id="editName" name="name" class="form-control form-input-p" required maxlength="100" />
                    </div>
                    <div class="form-group form-group-p">
                        <label>Type *</label>
                        <select id="editType" name="typeLookupValueId" class="form-control form-input-p" required asp-items="Model.TypeOptions"></select>
                    </div>
                    <div class="form-group form-group-p">
                        <label>Parent Cost Center</label>
                        <select id="editParentId" name="parentId" class="form-control form-input-p" data-cherry-select data-placeholder="Search parent centers...">
                            <option value="">-- None --</option>
                            @foreach (var p in Model.CostCenters.Where(c => c.IsActive))
                            {
                                <option value="@p.Id">@p.Code - @p.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group form-group-p">
                        <label>City</label>
                        <input type="text" id="editCity" name="city" class="form-control form-input-p" maxlength="100" />
                    </div>
                    <div class="form-group form-group-p">
                        <label>State/Province</label>
                        <input type="text" id="editStateProvince" name="stateProvince" class="form-control form-input-p" maxlength="50" />
                    </div>
                    <div class="form-group form-group-p">
                        <label>Country</label>
                        <input type="text" id="editCountry" name="country" class="form-control form-input-p" maxlength="50" />
                    </div>
                    <div class="form-group form-group-p">
                        <label>Status</label>
                        <select id="editIsActive" name="isActive" class="form-control form-input-p" asp-items="Model.ActiveInactiveOptions"></select>
                    </div>
                    <div class="form-group form-group-p full-width">
                        <label>Description</label>
                        <textarea id="editDescription" name="description" class="form-control form-input-p" rows="2" maxlength="200"></textarea>
                    </div>
                </div>
            </div>
            <div class="inline-form-footer">
                <button type="button" class="btn-p btn-p--secondary" onclick="toggleInlineForm('editForm')">Cancel</button>
                <button type="submit" class="btn-p btn-p--primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<script>
function editCostCenter(id, code, name, description, type, city, stateProvince, country, parentId, isActive) {
    document.getElementById('editId').value = id;
    document.getElementById('editCode').value = code;
    document.getElementById('editName').value = name;
    document.getElementById('editDescription').value = description;
    document.getElementById('editType').value = type;
    document.getElementById('editCity').value = city;
    document.getElementById('editStateProvince').value = stateProvince;
    document.getElementById('editCountry').value = country;
    document.getElementById('editParentId').value = parentId || '';
    document.getElementById('editIsActive').value = isActive.toString();
    toggleInlineForm('editForm');
}
</script>
