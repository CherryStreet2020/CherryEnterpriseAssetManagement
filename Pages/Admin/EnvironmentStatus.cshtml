@page
@model Abs.FixedAssets.Pages.Admin.EnvironmentStatusModel
@{
    ViewData["Title"] = "Environment Status";
    ViewData["TabTitle"] = "Environment Status";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
    
    var statusText = Model.IsLabEnvironment ? "LAB" : (Model.IsDemoEnvironment ? "DEMO (Protected)" : Model.EnvironmentProfile);
    var statusTone = Model.IsLabEnvironment ? "info" : (Model.IsDemoEnvironment ? "warning" : "neutral");
    
    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = "Environment Status",
        ["Subtitle"] = "Database verification and seed guard status",
        ["TypeLabel"] = "Administration",
        ["StatusText"] = statusText,
        ["StatusTone"] = statusTone,
        ["KpisPartial"] = "/Pages/Admin/_AdminEnvironmentStatusKpis.cshtml",
        ["ActionsPartial"] = "/Pages/Admin/_AdminEnvironmentStatusActions.cshtml"
    };
}

@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

<div class="section-card" data-csp-style="margin-bottom: 24px;">
    <div class="section-card-header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4" />
            </svg>
            Database Connection
        </h3>
    </div>
    <div class="section-card-body">
        <code data-csp-style="display: block; background: var(--bg-muted); padding: 12px; border-radius: 6px; font-size: 12px; word-break: break-all;">
            @Model.MaskedConnectionString
        </code>
    </div>
</div>

<div class="section-card" data-csp-style="margin-bottom: 24px;">
    <div class="section-card-header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            Seed Guard Checks
            @if (Model.GuardResult?.Allowed == true)
            {
                <span class="badge badge-success" data-csp-style="margin-left: 8px;">Allowed</span>
            }
            else
            {
                <span class="badge badge-danger" data-csp-style="margin-left: 8px;">Blocked</span>
            }
        </h3>
    </div>
    <div class="section-card-body">
        @if (Model.GuardResult != null)
        {
            <p data-csp-style="margin-bottom: 16px; padding: 12px; border-radius: 6px; background: @(Model.GuardResult.Allowed ? "var(--success-light)" : "var(--danger-light)"); color: @(Model.GuardResult.Allowed ? "var(--success)" : "var(--danger)");">
                @Model.GuardResult.Reason
            </p>
            
            <div data-csp-style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
                @if (Model.GuardResult.PassedChecks.Any())
                {
                    <div>
                        <h4 data-csp-style="font-size: 12px; color: var(--success); margin-bottom: 8px; text-transform: uppercase;">Passed Checks</h4>
                        @foreach (var check in Model.GuardResult.PassedChecks)
                        {
                            <div data-csp-style="display: flex; align-items: center; gap: 8px; padding: 4px 0; font-size: 13px; color: var(--success);">
                                <svg width="14" height="14" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                                @check
                            </div>
                        }
                    </div>
                }
                @if (Model.GuardResult.FailedChecks.Any())
                {
                    <div>
                        <h4 data-csp-style="font-size: 12px; color: var(--danger); margin-bottom: 8px; text-transform: uppercase;">Failed Checks</h4>
                        @foreach (var check in Model.GuardResult.FailedChecks)
                        {
                            <div data-csp-style="display: flex; align-items: center; gap: 8px; padding: 4px 0; font-size: 13px; color: var(--danger);">
                                <svg width="14" height="14" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
                                @check
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

<div class="section-card">
    <div class="section-card-header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" />
            </svg>
            Table Row Counts
        </h3>
    </div>
    <div class="section-card-body">
        <div data-csp-style="display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 12px;">
            @foreach (var table in Model.TableCounts.OrderByDescending(t => t.Value))
            {
                <div data-csp-style="background: var(--bg-muted); border-radius: 6px; padding: 12px; text-align: center;">
                    <div data-csp-style="font-size: 18px; font-weight: 600; color: var(--text-primary);">@table.Value.ToString("N0")</div>
                    <div data-csp-style="font-size: 11px; color: var(--text-muted); margin-top: 4px;">@table.Key</div>
                </div>
            }
        </div>
    </div>
</div>

<div data-csp-style="margin-top: 24px; padding: 12px; background: var(--bg-muted); border-radius: 6px; font-size: 12px; color: var(--text-muted);">
    <strong>API Endpoint:</strong> <code data-csp-style="background: var(--bg-secondary); padding: 2px 6px; border-radius: 4px;">/Admin/EnvironmentStatus?handler=ApiStatus</code>
</div>
