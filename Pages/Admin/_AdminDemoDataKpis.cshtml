@{
    var model = ViewData["PageModel"] as Abs.FixedAssets.Pages.Admin.DemoDataModel;
}
<div class="kpi-card">
    <div class="kpi-label">Seed Guard</div>
    <div class="kpi-value @(model?.GuardResult?.Allowed == true ? "success" : "danger")">
        @(model?.GuardResult?.Allowed == true ? "Unlocked" : "Locked")
    </div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Demo Assets</div>
    <div class="kpi-value">@(model?.DataSummary?.DemoAssetCount ?? 0)</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">PM Templates</div>
    <div class="kpi-value">@(model?.DataSummary?.DemoPMTemplateCount ?? 0)</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">PM Schedules</div>
    <div class="kpi-value">@(model?.DataSummary?.DemoPMScheduleCount ?? 0)</div>
</div>
