@page "{id:int?}"
@model Abs.FixedAssets.Pages.Admin.PMScheduleEditModel
@using Abs.FixedAssets.Models
@using Abs.FixedAssets.Helpers
@{
    ViewData["Title"] = Model.IsEditMode ? "Edit PM Schedule" : "New PM Schedule";
    ViewData["TabTitle"] = Model.IsEditMode ? "Edit PM Schedule" : "New PM Schedule";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
    
    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = Model.IsEditMode ? "Edit PM Schedule" : "New PM Schedule",
        ["Subtitle"] = Model.IsEditMode ? "Edit preventive maintenance schedule" : "Create a new preventive maintenance schedule",
        ["TypeLabel"] = "Work Execution",
        ["StatusText"] = Model.PageMode,
        ["StatusTone"] = Model.IsEditMode ? "info" : "success",
        ["Breadcrumbs"] = new[] { ("Asset Maintenance", "/Maintenance"), ("PM Schedules", "/Admin/PMSchedules"), (Model.PageMode, "") },
        ["ContextPartial"] = "/Pages/Admin/_PMScheduleEditContext.cshtml",
        ["ActionsPartial"] = "/Pages/Admin/_PMScheduleEditActions.cshtml"
    };
}

@await Html.PartialAsync("_ScreenHeader", headerVd)

<div class="module-header">
    <nav class="module-pills" role="navigation" aria-label="@UiTerms.ModuleName navigation">
        <a href="/Maintenance" class="module-pill">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
            </svg>
            @UiTerms.WorkOrderPlural
        </a>
        <a href="/Admin/PMTemplates" class="module-pill">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            @UiTerms.PMTemplates
        </a>
        <a href="/Maintenance/Assignments" class="module-pill">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
            PM Assignments
        </a>
        <a href="/Maintenance/Schedules" class="module-pill active" aria-current="page">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            @UiTerms.Schedules
        </a>
    </nav>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="post">
    <input type="hidden" asp-for="Input.Id" />

    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Basic Information
            </h3>
        </div>
        <div class="section-card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="Input.Name" class="form-label required">Schedule Name</label>
                        <input asp-for="Input.Name" class="form-control" placeholder="e.g., Weekly Pump Inspection" />
                        <span asp-validation-for="Input.Name" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="Input.PMTemplateId" class="form-label required">PM Template</label>
                        <select asp-for="Input.PMTemplateId" asp-items="Model.TemplateOptions" class="form-select">
                            <option value="">-- Select Template --</option>
                        </select>
                        <span asp-validation-for="Input.PMTemplateId" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-12">
                    <div class="form-group">
                        <label asp-for="Input.Description" class="form-label">Description</label>
                        <textarea asp-for="Input.Description" class="form-control" rows="2" placeholder="Optional description..."></textarea>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="form-label">Company</label>
                        <div class="form-value">@(Model.ExistingSchedule?.Company?.Name ?? "All Companies")</div>
                        <input type="hidden" asp-for="Input.CompanyId" />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="Input.SiteId" class="form-label">Site</label>
                        <select asp-for="Input.SiteId" asp-items="Model.SiteOptions" class="form-select" data-cherry-select data-placeholder="Search sites...">
                            <option value="">-- All Sites --</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label class="form-label">Status</label>
                        <div class="form-check form-switch mt-2">
                            <input asp-for="Input.Active" class="form-check-input" type="checkbox" role="switch" />
                            <label asp-for="Input.Active" class="form-check-label">Active</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                Schedule Configuration
            </h3>
        </div>
        <div class="section-card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="Input.CadenceType" class="form-label required">Cadence Type</label>
                        <select asp-for="Input.CadenceType" asp-items="Model.CadenceOptions" class="form-select" id="cadenceType"></select>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="Input.StartDateUtc" class="form-label required">Start Date</label>
                        <input asp-for="Input.StartDateUtc" type="date" class="form-control" />
                        <span asp-validation-for="Input.StartDateUtc" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div id="intervalDaysSection" class="row g-3 mt-2">
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="Input.IntervalDays" class="form-label">Interval (Days)</label>
                        <input asp-for="Input.IntervalDays" type="number" min="1" max="365" class="form-control" />
                        <small class="text-muted">Work orders generated every N days from start date</small>
                    </div>
                </div>
            </div>

            <div id="weeklySection" class="row g-3 mt-2 d-none">
                <div class="col-12">
                    <label class="form-label">Days of Week</label>
                    <div class="d-flex flex-wrap gap-3">
                        <div class="form-check">
                            <input asp-for="Input.Sunday" class="form-check-input" type="checkbox" />
                            <label asp-for="Input.Sunday" class="form-check-label">Sun</label>
                        </div>
                        <div class="form-check">
                            <input asp-for="Input.Monday" class="form-check-input" type="checkbox" />
                            <label asp-for="Input.Monday" class="form-check-label">Mon</label>
                        </div>
                        <div class="form-check">
                            <input asp-for="Input.Tuesday" class="form-check-input" type="checkbox" />
                            <label asp-for="Input.Tuesday" class="form-check-label">Tue</label>
                        </div>
                        <div class="form-check">
                            <input asp-for="Input.Wednesday" class="form-check-input" type="checkbox" />
                            <label asp-for="Input.Wednesday" class="form-check-label">Wed</label>
                        </div>
                        <div class="form-check">
                            <input asp-for="Input.Thursday" class="form-check-input" type="checkbox" />
                            <label asp-for="Input.Thursday" class="form-check-label">Thu</label>
                        </div>
                        <div class="form-check">
                            <input asp-for="Input.Friday" class="form-check-input" type="checkbox" />
                            <label asp-for="Input.Friday" class="form-check-label">Fri</label>
                        </div>
                        <div class="form-check">
                            <input asp-for="Input.Saturday" class="form-check-input" type="checkbox" />
                            <label asp-for="Input.Saturday" class="form-check-label">Sat</label>
                        </div>
                    </div>
                </div>
            </div>

            <div id="monthlySection" class="row g-3 mt-2 d-none">
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="Input.DayOfMonth" class="form-label">Day of Month</label>
                        <input asp-for="Input.DayOfMonth" type="number" min="1" max="28" class="form-control" />
                        <small class="text-muted">Uses day 28 max to avoid month-end issues</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between mt-4 mb-4">
        <a href="/Admin/PMSchedules" class="btn-p btn-p--secondary">Cancel</a>
        <button type="submit" class="btn btn-primary btn-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            @(Model.IsEditMode ? "Update Schedule" : "Create Schedule")
        </button>
    </div>
</form>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const cadenceSelect = document.getElementById('cadenceType');
            const intervalSection = document.getElementById('intervalDaysSection');
            const weeklySection = document.getElementById('weeklySection');
            const monthlySection = document.getElementById('monthlySection');

            function updateSections() {
                const cadence = parseInt(cadenceSelect.value);
                intervalSection.style.display = cadence === 0 ? 'flex' : 'none';
                weeklySection.style.display = cadence === 1 ? 'flex' : 'none';
                monthlySection.style.display = cadence === 2 ? 'flex' : 'none';
            }

            cadenceSelect.addEventListener('change', updateSections);
            updateSections();
        });
    </script>
}
