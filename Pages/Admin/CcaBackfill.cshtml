@page
@model Abs.FixedAssets.Pages.Admin.CcaBackfillModel
@{
    ViewData["Title"] = "Canadian CCA Backfill";
    ViewData["Section"] = "Admin";
}

<div class="page-shell">
    <div class="breadcrumbs">
        <a asp-page="/Index">Dashboard</a>
        <span class="separator">/</span>
        <a asp-page="/Admin/Index">Admin</a>
        <span class="separator">/</span>
        <span>Canadian CCA Backfill</span>
    </div>

    <div class="page-header">
        <div>
            <h1 class="page-title">Canadian CCA Backfill</h1>
            <p class="page-subtitle">Bootstrap <code>AssetTaxSettings</code> + opening <code>CcaTransaction</code> rows for a Canadian company, then compute <code>CcaClassBalance</code> for every fiscal year from each asset's in-service year through the requested year. Idempotent and safe to re-run.</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success" data-csp-style="background:#0a3d22;color:#a7f3d0;border:1px solid #166534;padding:12px 16px;border-radius:8px;margin-bottom:16px;">
            @Model.SuccessMessage
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger" data-csp-style="background:#3d0a0a;color:#fca5a5;border:1px solid #7f1d1d;padding:12px 16px;border-radius:8px;margin-bottom:16px;">
            @Model.ErrorMessage
        </div>
    }

    <form method="get" class="spec-card" data-csp-style="margin-bottom:16px;">
        <div class="spec-header">
            <span class="accent-dot" data-csp-style="background:var(--brand-red);"></span>
            <h2>Select Canadian company</h2>
        </div>
        <div class="form-grid">
            <div class="field-row">
                <label for="CompanyId">Company</label>
                <select id="CompanyId" name="companyId" class="form-input" onchange="this.form.submit()">
                    @foreach (var c in Model.CanadianCompanies)
                    {
                        <option value="@c.Id" selected="@(c.Id == Model.CompanyId)">@c.Name (@c.CompanyCode)</option>
                    }
                </select>
                <small>Only companies with <code>Country = "CANADA"</code> are listed.</small>
            </div>
        </div>
    </form>

    <div class="kpi-strip" data-csp-style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin-bottom:24px;">
        <div class="stat-card">
            <div class="stat-label">Active Assets</div>
            <div class="stat-value">@Model.PreviewRows.Count.ToString("N0")</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Already Mapped</div>
            <div class="stat-value">@Model.PreviewRows.Count(r => r.AlreadyMapped).ToString("N0")</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Will Create</div>
            <div class="stat-value">@Model.PreviewRows.Count(r => !r.AlreadyMapped).ToString("N0")</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">CcaClassBalance Rows</div>
            <div class="stat-value">@Model.ExistingBalanceCount.ToString("N0")</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Existing CCA Claimed</div>
            <div class="stat-value">$@Model.ExistingTotalCcaClaimed.ToString("N0")</div>
        </div>
    </div>

    <form method="post" class="spec-card">
        <div class="spec-header">
            <span class="accent-dot" data-csp-style="background:var(--brand-red);"></span>
            <h2>Run backfill for @Model.SelectedCompanyName</h2>
        </div>

        <input type="hidden" name="CompanyId" value="@Model.CompanyId" />

        <div class="form-grid">
            <div class="field-row">
                <label asp-for="ThroughFiscalYear">Through Fiscal Year</label>
                <input asp-for="ThroughFiscalYear" type="number" min="2000" max="2100" class="form-input" />
                <small>Compute <code>CcaClassBalance</code> for every year from each asset's in-service year through this year.</small>
            </div>
            <div class="field-row">
                <label class="check-line">
                    <input asp-for="CreateMissingTaxSettings" type="checkbox" />
                    <span>Create missing <code>AssetTaxSettings</code> + opening <code>CcaTransaction(Addition)</code></span>
                </label>
                <label class="check-line">
                    <input asp-for="ComputeBalances" type="checkbox" />
                    <span>Compute <code>CcaClassBalance</code> per (class, fiscal year)</span>
                </label>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Run backfill now</button>
            </div>
        </div>

        @if (Model.PreviewRows.Any())
        {
            <h3 data-csp-style="margin-top:24px;">Per-asset preview &mdash; admin can override the suggested CCA class per row</h3>
            <p class="text-secondary" data-csp-style="font-size:12px;margin-bottom:8px;">
                Already-mapped rows are read-only; their existing <code>AssetTaxSettings.CcaClassId</code> is preserved.
                Override dropdowns only take effect for rows marked <em>Will create</em>.
            </p>
            <div data-csp-style="max-height:560px;overflow-y:auto;border:1px solid var(--border);border-radius:8px;">
                <table class="table table-clean" data-csp-style="font-size:13px;">
                    <thead data-csp-style="position:sticky;top:0;background:var(--bg-elev1);">
                        <tr>
                            <th>Asset #</th>
                            <th>Description</th>
                            <th>Type</th>
                            <th data-csp-style="text-align:right;">Cost</th>
                            <th>In-Service</th>
                            <th>Suggested Class</th>
                            <th>Override</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.PreviewRows)
                        {
                            <tr>
                                <td><strong>@row.AssetNumber</strong></td>
                                <td>@row.Description</td>
                                <td>@row.AssetType</td>
                                <td data-csp-style="text-align:right;font-family:var(--font-mono);">$@row.AcquisitionCost.ToString("N2")</td>
                                <td>@row.InServiceDate.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <span title="@row.SuggestedCcaClassDescription">Class @row.SuggestedCcaClassNumber</span>
                                </td>
                                <td>
                                    @if (row.AlreadyMapped)
                                    {
                                        <span data-csp-style="color:var(--text-secondary);">— locked —</span>
                                    }
                                    else
                                    {
                                        <select name="OverrideClassByAssetId[@row.AssetId]" class="form-input" data-csp-style="padding:4px 8px;font-size:12px;">
                                            @foreach (var c in Model.CcaClassOptions)
                                            {
                                                <option value="@c.Id" selected="@(c.Id == row.SuggestedCcaClassId)">Class @c.ClassNumber &mdash; @c.ShortDescription</option>
                                            }
                                        </select>
                                    }
                                </td>
                                <td>
                                    @if (row.AlreadyMapped)
                                    {
                                        <span class="chip chip-success">Class @row.CurrentCcaClassNumber mapped</span>
                                    }
                                    else
                                    {
                                        <span class="chip" data-csp-style="background:#1e3a8a;color:#bfdbfe;">Will create</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else if (Model.CompanyId > 0)
        {
            <p data-csp-style="margin-top:16px;color:var(--text-secondary);">No active assets found for this company.</p>
        }
    </form>

    @if (Model.LastReport != null)
    {
        <div class="spec-card" data-csp-style="margin-top:24px;">
            <div class="spec-header">
                <span class="accent-dot" data-csp-style="background:#22c55e;"></span>
                <h2>Last run report &mdash; @Model.LastReport.CompanyName</h2>
            </div>
            <table class="table table-clean">
                <tbody>
                    <tr><td>Company</td><td><strong>@Model.LastReport.CompanyName (id=@Model.LastReport.CompanyId)</strong></td></tr>
                    <tr><td>Through Fiscal Year</td><td><strong>@Model.LastReport.ThroughFiscalYear</strong></td></tr>
                    <tr><td>Duration</td><td>@Model.LastReport.Duration.TotalSeconds.ToString("0.00") s</td></tr>
                    <tr><td>Assets scanned</td><td>@Model.LastReport.AssetsScanned</td></tr>
                    <tr><td>Assets already mapped</td><td>@Model.LastReport.AssetsAlreadyMapped</td></tr>
                    <tr><td>Assets newly mapped</td><td><strong>@Model.LastReport.AssetsMapped</strong></td></tr>
                    <tr><td>Assets skipped (zero cost)</td><td>@Model.LastReport.AssetsSkippedNoCost</td></tr>
                    <tr><td>Assets skipped (no class)</td><td>@Model.LastReport.AssetsSkippedNoClass</td></tr>
                    <tr><td>(Class, Fiscal Year) tuples computed</td><td><strong>@Model.LastReport.ClassYearsComputed</strong></td></tr>
                    <tr><td>Total CCA claimed (sum across years)</td><td><strong>$@Model.LastReport.TotalCcaClaimed.ToString("N2")</strong></td></tr>
                </tbody>
            </table>

            @if (Model.LastReport.MappingsByClassNumber.Any())
            {
                <h3 data-csp-style="margin-top:16px;">New mappings by class</h3>
                <table class="table table-clean" data-csp-style="max-width:400px;">
                    <thead><tr><th>Class</th><th data-csp-style="text-align:right;">Assets</th></tr></thead>
                    <tbody>
                        @foreach (var kvp in Model.LastReport.MappingsByClassNumber.OrderBy(k => k.Key))
                        {
                            <tr><td>Class @kvp.Key</td><td data-csp-style="text-align:right;">@kvp.Value</td></tr>
                        }
                    </tbody>
                </table>
            }

            @if (Model.LastReport.Warnings.Any())
            {
                <h3 data-csp-style="margin-top:16px;">Warnings (@Model.LastReport.Warnings.Count)</h3>
                <ul data-csp-style="font-family:var(--font-mono);font-size:12px;max-height:240px;overflow-y:auto;background:var(--bg-elev1);padding:12px;border-radius:8px;">
                    @foreach (var w in Model.LastReport.Warnings.Take(50))
                    {
                        <li>@w</li>
                    }
                    @if (Model.LastReport.Warnings.Count > 50)
                    {
                        <li>… and @(Model.LastReport.Warnings.Count - 50) more</li>
                    }
                </ul>
            }

            @if (Model.LastReport.Errors.Any())
            {
                <h3 data-csp-style="margin-top:16px;color:var(--brand-red);">Errors (@Model.LastReport.Errors.Count)</h3>
                <ul data-csp-style="font-family:var(--font-mono);font-size:12px;color:#fca5a5;">
                    @foreach (var e in Model.LastReport.Errors)
                    {
                        <li>@e</li>
                    }
                </ul>
            }
        </div>
    }
</div>
