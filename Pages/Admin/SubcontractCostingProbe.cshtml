@page "/Admin/SubcontractCostingProbe"
@model Abs.FixedAssets.Pages.Admin.SubcontractCostingProbeModel
@{
    ViewData["Title"] = "Subcontract Costing Integration Probe";
    ViewData["TabTitle"] = "Subcontract Costing Probe";
    Layout = "_ModernLayout";
}

<header class="ds-page-header">
    <div class="ds-page-header__inner">
        <h1 class="ds-page-header__title">Subcontract Costing Integration Probe</h1>
        <p class="ds-page-header__subtitle">
            Sprint 15.2 PR-8 — §12 cost elements wired into Sprint 14.4 CostTransaction engine.
            Service cost / freight to/from / packaging / expedite / cert fees / inspection / scrap /
            vendor credit / overhead / PPV / invoice variance. Post at ship + receive, true-up at
            invoice, settle at PRO close. Idempotency on (sourceType, sourceId, transactionType).
        </p>
    </div>
</header>

<main class="ds-page">

    @if (!string.IsNullOrEmpty(Model.Outcome))
    {
        <section class="ds-card ds-mt-3"><div class="ds-card__body">
            @if (Model.OutcomeIsError)
            { <p class="ds-text-danger" data-testid="scost-outcome-error">@Model.Outcome</p> }
            else
            { <p class="ds-text-success" data-testid="scost-outcome-ok">@Model.Outcome</p> }
        </div></section>
    }

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">Summary Stats</h2>
        <table class="ds-table">
            <tbody>
                <tr><td>Total Subcontract Ops</td><td data-testid="scost-total-ops">@Model.TotalSubcontractOps</td></tr>
                <tr><td>Total Cost Transactions (all)</td><td>@Model.TotalCostTransactions</td></tr>
                <tr><td>Subcontract-Sourced Cost Transactions</td><td data-testid="scost-sub-txns">@Model.SubcontractCostTransactions</td></tr>
                <tr><td>Subcontract Cost Total (USD)</td><td data-testid="scost-total-usd">@Model.SubcontractCostTotalUsd.ToString("N4")</td></tr>
            </tbody>
        </table>
    </div></section>

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">1. Post Shipment Costs (freight-out + packaging + expedite)</h2>
        <p class="ds-text-muted">Called after Step 5 ExecuteShipment. Idempotent on (shipmentId, costType) — re-running posts 0 new.</p>
        <form method="post" asp-page-handler="ShipmentCosts">
            <div class="ds-form-row"><label class="ds-label">Subcontract Op ID</label><input type="number" class="ds-input" asp-for="ShipCostOpId" /></div>
            <div class="ds-form-row"><label class="ds-label">Shipment ID</label><input type="number" class="ds-input" asp-for="ShipCostShipmentId" /></div>
            <div class="ds-form-row"><label class="ds-label">Freight Out (USD)</label><input type="number" step="0.0001" class="ds-input" asp-for="ShipCostFreightOut" /></div>
            <div class="ds-form-row"><label class="ds-label">Packaging (USD)</label><input type="number" step="0.0001" class="ds-input" asp-for="ShipCostPackaging" /></div>
            <div class="ds-form-row"><label class="ds-label">Expedite (USD, optional)</label><input type="number" step="0.0001" class="ds-input" asp-for="ShipCostExpedite" /></div>
            <button type="submit" class="ds-btn ds-btn-primary" data-testid="btn-post-ship-costs">Post Shipment Costs</button>
        </form>
    </div></section>

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">2. Post Receipt Costs (service + freight + cert + inspection + scrap + credit)</h2>
        <p class="ds-text-muted">Called after Step 7 PostReceipt. Service cost = QtyAccepted × ServiceUnitCost.</p>
        <form method="post" asp-page-handler="ReceiptCosts">
            <div class="ds-form-row"><label class="ds-label">Subcontract Op ID</label><input type="number" class="ds-input" asp-for="RecvCostOpId" /></div>
            <div class="ds-form-row"><label class="ds-label">Receipt ID</label><input type="number" class="ds-input" asp-for="RecvCostReceiptId" /></div>
            <div class="ds-form-row"><label class="ds-label">Qty Accepted</label><input type="number" step="0.0001" class="ds-input" asp-for="RecvCostQtyAccepted" /></div>
            <div class="ds-form-row"><label class="ds-label">Service Unit Cost (USD/each)</label><input type="number" step="0.0001" class="ds-input" asp-for="RecvCostServiceUnitCost" /></div>
            <div class="ds-form-row"><label class="ds-label">Freight Return (USD, optional)</label><input type="number" step="0.0001" class="ds-input" asp-for="RecvCostFreightReturn" /></div>
            <div class="ds-form-row"><label class="ds-label">Cert Fee (USD, optional)</label><input type="number" step="0.0001" class="ds-input" asp-for="RecvCostCertFee" /></div>
            <div class="ds-form-row"><label class="ds-label">Inspection Fee (USD, optional)</label><input type="number" step="0.0001" class="ds-input" asp-for="RecvCostInspectionFee" /></div>
            <div class="ds-form-row"><label class="ds-label">Vendor Scrap Charge (USD, optional)</label><input type="number" step="0.0001" class="ds-input" asp-for="RecvCostScrapCharge" /></div>
            <div class="ds-form-row"><label class="ds-label">Vendor Credit (USD, optional)</label><input type="number" step="0.0001" class="ds-input" asp-for="RecvCostVendorCredit" /></div>
            <button type="submit" class="ds-btn ds-btn-primary" data-testid="btn-post-recv-costs">Post Receipt Costs</button>
        </form>
    </div></section>

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">3. Post Invoice True-Up (variance + PPV)</h2>
        <p class="ds-text-muted">Called when supplier invoice arrives. Compares invoiced amount to provisional service cost; posts InvoiceVariance + PurchasePriceVariance for any delta.</p>
        <form method="post" asp-page-handler="InvoiceTrueUp">
            <div class="ds-form-row"><label class="ds-label">Subcontract Op ID</label><input type="number" class="ds-input" asp-for="InvoiceOpId" /></div>
            <div class="ds-form-row"><label class="ds-label">Invoice Amount (USD)</label><input type="number" step="0.0001" class="ds-input" asp-for="InvoiceAmount" /></div>
            <div class="ds-form-row"><label class="ds-label">Qty Invoiced</label><input type="number" step="0.0001" class="ds-input" asp-for="InvoiceQuantity" /></div>
            <div class="ds-form-row"><label class="ds-label">Invoice Number</label><input class="ds-input" asp-for="InvoiceNumber" /></div>
            <button type="submit" class="ds-btn ds-btn-primary" data-testid="btn-post-invoice">Post Invoice True-Up</button>
        </form>
    </div></section>

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">4. Settle at PRO Close</h2>
        <p class="ds-text-muted">Posts VarianceSettlement transaction for residual subcontract WIP. Idempotent — refuses second settle for same op.</p>
        <form method="post" asp-page-handler="SettleAtClose">
            <div class="ds-form-row"><label class="ds-label">Subcontract Op ID</label><input type="number" class="ds-input" asp-for="CloseOpId" /></div>
            <button type="submit" class="ds-btn ds-btn-success" data-testid="btn-settle-close">Settle at Close</button>
        </form>
    </div></section>

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">5. Load Cost Summary (read by §12 element)</h2>
        <form method="post" asp-page-handler="LoadSummary">
            <div class="ds-form-row"><label class="ds-label">Subcontract Op ID</label><input type="number" class="ds-input" asp-for="SummaryOpId" /></div>
            <button type="submit" class="ds-btn ds-btn-secondary" data-testid="btn-load-summary">Load Cost Summary</button>
        </form>
        @if (Model.CostSummary != null)
        {
            <table class="ds-table ds-mt-2">
                <tbody>
                    <tr><td>Service Cost (vendor processing)</td><td data-testid="scost-summary-service">@Model.CostSummary.ServiceCostPosted.ToString("N4")</td></tr>
                    <tr><td>Freight Out</td><td>@Model.CostSummary.FreightOutPosted.ToString("N4")</td></tr>
                    <tr><td>Freight Return</td><td>@Model.CostSummary.FreightReturnPosted.ToString("N4")</td></tr>
                    <tr><td>Packaging / Crating</td><td>@Model.CostSummary.PackagingPosted.ToString("N4")</td></tr>
                    <tr><td>Expedite</td><td>@Model.CostSummary.ExpeditePosted.ToString("N4")</td></tr>
                    <tr><td>Cert Fees</td><td>@Model.CostSummary.CertFeesPosted.ToString("N4")</td></tr>
                    <tr><td>Inspection Fees</td><td>@Model.CostSummary.InspectionFeesPosted.ToString("N4")</td></tr>
                    <tr><td>Vendor Scrap Charge</td><td>@Model.CostSummary.ScrapChargePosted.ToString("N4")</td></tr>
                    <tr><td>Vendor Credit (negative)</td><td>@Model.CostSummary.VendorCreditPosted.ToString("N4")</td></tr>
                    <tr><td>Subcontract Overhead</td><td>@Model.CostSummary.OverheadPosted.ToString("N4")</td></tr>
                    <tr><td>Purchase Price Variance</td><td>@Model.CostSummary.PpvPosted.ToString("N4")</td></tr>
                    <tr><td>Invoice Variance</td><td>@Model.CostSummary.InvoiceVariancePosted.ToString("N4")</td></tr>
                    <tr><td><strong>Total Subcontract Cost</strong></td><td><strong data-testid="scost-summary-total">@Model.CostSummary.TotalSubcontractCost.ToString("N4")</strong></td></tr>
                    <tr><td>Total Transaction Count</td><td>@Model.CostSummary.TotalTransactionCount</td></tr>
                </tbody>
            </table>
        }
    </div></section>

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">6. Idempotency demo: re-post shipment costs</h2>
        <p class="ds-text-muted">Re-runs button #1 with the same inputs. Expected: 0 new transactions posted because each (shipmentId, costType) tuple is already covered.</p>
        <form method="post" asp-page-handler="ShipmentCostsAgain">
            <button type="submit" class="ds-btn ds-btn-secondary" data-testid="btn-ship-costs-again">Re-Post Shipment Costs</button>
        </form>
    </div></section>

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">7. Idempotency demo: re-post receipt costs</h2>
        <form method="post" asp-page-handler="ReceiptCostsAgain">
            <button type="submit" class="ds-btn ds-btn-secondary" data-testid="btn-recv-costs-again">Re-Post Receipt Costs</button>
        </form>
    </div></section>

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">8. Idempotency demo: re-post invoice true-up</h2>
        <form method="post" asp-page-handler="InvoiceTrueUpAgain">
            <button type="submit" class="ds-btn ds-btn-secondary" data-testid="btn-invoice-again">Re-Post Invoice True-Up</button>
        </form>
    </div></section>

</main>
