@page "/Admin/SupplyDemandProbe"
@model Abs.FixedAssets.Pages.Admin.SupplyDemandProbeModel
@using Abs.FixedAssets.Models.Production
@{
    ViewData["Title"] = "Supply Demand Probe";
    ViewData["TabTitle"] = "Supply Demand Probe";
    Layout = "_ModernLayout";
}

<header class="ds-page-header">
    <div class="ds-page-header__inner">
        <h1 class="ds-page-header__title">Supply Demand Probe</h1>
        <p class="ds-page-header__subtitle">
            Sprint 15.1 PR-2 — The unified demand record. Every supply requirement
            from a Production Order materialized into one queryable table. Drives
            buyer/planner dashboards, MRP, and Purchasing Control Center.
        </p>
    </div>
</header>

<main class="ds-page">

    @if (!string.IsNullOrEmpty(Model.Outcome))
    {
        <section class="ds-card ds-mt-3">
            <div class="ds-card__body">
                @if (Model.OutcomeIsError)
                { <p class="ds-text-danger" data-testid="psd-outcome-error">@Model.Outcome</p> }
                else
                { <p class="ds-text-success" data-testid="psd-outcome-ok">@Model.Outcome</p> }
            </div>
        </section>
    }

    <section class="ds-card ds-mt-3">
        <div class="ds-card__body">
            <h2 class="ds-h2">Summary Stats</h2>
            <table class="ds-table">
                <tbody>
                    <tr><td>Total Demands</td><td data-testid="psd-total">@Model.TotalDemands</td></tr>
                    <tr><td>Not Supplied</td><td>@Model.DemandsNotSupplied</td></tr>
                    <tr><td>Committed</td><td>@Model.DemandsCommitted</td></tr>
                    <tr><td>Fully Fulfilled</td><td>@Model.DemandsFullyFulfilled</td></tr>
                    <tr><td>Short / Late</td><td>@Model.DemandsShort</td></tr>
                    <tr><td>Total Allocations</td><td>@Model.TotalAllocations</td></tr>
                    <tr><td>Active Allocations</td><td>@Model.AllocationsActive</td></tr>
                </tbody>
            </table>
        </div>
    </section>

    <section class="ds-card ds-mt-3">
        <div class="ds-card__body">
            <h2 class="ds-h2">1. Generate Demands from Production Order</h2>
            <p class="ds-text-muted">Walks BOM snapshot, creates one ProductionSupplyDemand row per BOM line. Idempotent.</p>
            <form method="post" asp-page-handler="Generate">
                <div class="ds-form-row">
                    <label class="ds-label">Production Order ID</label>
                    <input type="number" class="ds-input" asp-for="GenerateProId" />
                </div>
                <button type="submit" class="ds-btn ds-btn-primary" data-testid="btn-generate">Generate Demands</button>
            </form>
        </div>
    </section>

    <section class="ds-card ds-mt-3">
        <div class="ds-card__body">
            <h2 class="ds-h2">2. Refresh Single Demand</h2>
            <p class="ds-text-muted">Re-reads linked supply, recomputes Source/Supply/Shortage/Cost status.</p>
            <form method="post" asp-page-handler="Refresh">
                <div class="ds-form-row">
                    <label class="ds-label">Demand ID</label>
                    <input type="number" class="ds-input" asp-for="RefreshDemandId" />
                </div>
                <button type="submit" class="ds-btn ds-btn-secondary" data-testid="btn-refresh">Refresh Status</button>
            </form>
        </div>
    </section>

    <section class="ds-card ds-mt-3">
        <div class="ds-card__body">
            <h2 class="ds-h2">3. Refresh All Demands for PRO</h2>
            <form method="post" asp-page-handler="RefreshAll">
                <div class="ds-form-row">
                    <label class="ds-label">Production Order ID</label>
                    <input type="number" class="ds-input" asp-for="RefreshAllProId" />
                </div>
                <button type="submit" class="ds-btn ds-btn-secondary" data-testid="btn-refresh-all">Refresh All</button>
            </form>
        </div>
    </section>

    <section class="ds-card ds-mt-3">
        <div class="ds-card__body">
            <h2 class="ds-h2">4. Allocate Supply to Demand</h2>
            <p class="ds-text-muted">Creates a ProductionSupplyAllocation linking demand to a supply record.</p>
            <form method="post" asp-page-handler="Allocate">
                <div class="ds-form-row">
                    <label class="ds-label">Demand ID</label>
                    <input type="number" class="ds-input" asp-for="AllocateDemandId" />
                </div>
                <div class="ds-form-row">
                    <label class="ds-label">Supply Type</label>
                    <select class="ds-input" asp-for="AllocateSupplyType" asp-items="Html.GetEnumSelectList<AllocationSupplyType>()"></select>
                </div>
                <div class="ds-form-row">
                    <label class="ds-label">Supply Record ID</label>
                    <input type="number" class="ds-input" asp-for="AllocateRecordId" />
                </div>
                <div class="ds-form-row">
                    <label class="ds-label">Supply Line ID (optional)</label>
                    <input type="number" class="ds-input" asp-for="AllocateLineId" />
                </div>
                <div class="ds-form-row">
                    <label class="ds-label">Quantity</label>
                    <input type="number" step="0.0001" class="ds-input" asp-for="AllocateQuantity" />
                </div>
                <button type="submit" class="ds-btn ds-btn-primary" data-testid="btn-allocate">Allocate Supply</button>
            </form>
        </div>
    </section>

    <section class="ds-card ds-mt-3">
        <div class="ds-card__body">
            <h2 class="ds-h2">5. Release Allocation</h2>
            <form method="post" asp-page-handler="Release">
                <div class="ds-form-row">
                    <label class="ds-label">Allocation ID</label>
                    <input type="number" class="ds-input" asp-for="ReleaseAllocationId" />
                </div>
                <button type="submit" class="ds-btn ds-btn-warning" data-testid="btn-release">Release Allocation</button>
            </form>
        </div>
    </section>

    <section class="ds-card ds-mt-3">
        <div class="ds-card__body">
            <h2 class="ds-h2">6/7. Load Demands for PRO</h2>
            <form method="post" asp-page-handler="LoadDemands" style="display:inline-block;">
                <input type="number" class="ds-input" asp-for="LoadProId" style="width:120px" />
                <button type="submit" class="ds-btn ds-btn-secondary" data-testid="btn-load-demands">Load ALL</button>
            </form>
            <form method="post" asp-page-handler="LoadUnresolved" style="display:inline-block; margin-left:.5rem;">
                <button type="submit" class="ds-btn ds-btn-secondary" data-testid="btn-load-unresolved">Load Unresolved Only</button>
            </form>
            @if (Model.LoadedDemands.Any())
            {
                <table class="ds-table ds-mt-2">
                    <thead>
                        <tr>
                            <th>ID</th><th>Number</th><th>Part#</th><th>UOM</th>
                            <th>Req Qty</th><th>Supplied</th><th>Received</th>
                            <th>Policy</th><th>Source</th><th>Supply</th><th>Shortage</th><th>Cost</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.LoadedDemands)
                        {
                            <tr>
                                <td>@d.Id</td>
                                <td>@d.DemandNumber</td>
                                <td>@(d.PartNumber ?? "—")</td>
                                <td>@(d.Uom ?? "—")</td>
                                <td>@d.RequiredQuantity.ToString("N4")</td>
                                <td>@d.SuppliedQuantity.ToString("N4")</td>
                                <td>@d.ReceivedQuantity.ToString("N4")</td>
                                <td>@d.SupplyPolicy</td>
                                <td>@d.SourceStatus</td>
                                <td>@d.SupplyStatus</td>
                                <td>@d.ShortageStatus</td>
                                <td>@d.CostStatus</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </section>

    <section class="ds-card ds-mt-3">
        <div class="ds-card__body">
            <h2 class="ds-h2">8. Load Allocations for Demand</h2>
            <form method="post" asp-page-handler="LoadAllocations">
                <div class="ds-form-row">
                    <label class="ds-label">Demand ID</label>
                    <input type="number" class="ds-input" asp-for="LoadAllocationsDemandId" />
                </div>
                <button type="submit" class="ds-btn ds-btn-secondary" data-testid="btn-load-allocations">Load Allocations</button>
            </form>
            @if (Model.LoadedAllocations.Any())
            {
                <table class="ds-table ds-mt-2">
                    <thead>
                        <tr><th>ID</th><th>Supply Type</th><th>Record</th><th>Line</th><th>Allocated</th><th>Consumed</th><th>Remaining</th><th>Status</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var a in Model.LoadedAllocations)
                        {
                            <tr>
                                <td>@a.Id</td>
                                <td>@a.SupplyType</td>
                                <td>@a.SupplyRecordId</td>
                                <td>@(a.SupplyRecordLineId?.ToString() ?? "—")</td>
                                <td>@a.AllocatedQuantity.ToString("N4")</td>
                                <td>@a.ConsumedQuantity.ToString("N4")</td>
                                <td>@a.RemainingQuantity.ToString("N4")</td>
                                <td>@a.Status</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </section>

</main>
