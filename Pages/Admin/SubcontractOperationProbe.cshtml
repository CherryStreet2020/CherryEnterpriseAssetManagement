@page "/Admin/SubcontractOperationProbe"
@model Abs.FixedAssets.Pages.Admin.SubcontractOperationProbeModel
@using Abs.FixedAssets.Models.Production
@{
    ViewData["Title"] = "Subcontract Operation Probe";
    ViewData["TabTitle"] = "Subcontract Operation Probe";
    Layout = "_ModernLayout";
}

<header class="ds-page-header">
    <div class="ds-page-header__inner">
        <h1 class="ds-page-header__title">Subcontract Operation Probe</h1>
        <p class="ds-page-header__subtitle">
            Sprint 15.1 PR-4 — Outside-processing routing ops with §9 dual-demand pattern.
            Every subcontract creates two linked demands: the vendor's service work AND the
            physical WIP that ships outside. 12-state operation lifecycle (NotReady → Closed).
        </p>
    </div>
</header>

<main class="ds-page">

    @if (!string.IsNullOrEmpty(Model.Outcome))
    {
        <section class="ds-card ds-mt-3"><div class="ds-card__body">
            @if (Model.OutcomeIsError)
            { <p class="ds-text-danger" data-testid="sc-outcome-error">@Model.Outcome</p> }
            else
            { <p class="ds-text-success" data-testid="sc-outcome-ok">@Model.Outcome</p> }
        </div></section>
    }

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">Summary Stats</h2>
        <table class="ds-table">
            <tbody>
                <tr><td>Total Subcontract Ops</td><td data-testid="sc-total">@Model.TotalSubcontractOps</td></tr>
                <tr><td>Ready to Buy</td><td>@Model.OpsReadyToBuy</td></tr>
                <tr><td>At Vendor / Shipped</td><td>@Model.OpsAtVendor</td></tr>
                <tr><td>Complete / Closed</td><td>@Model.OpsComplete</td></tr>
                <tr><td>Total Dual-Demand Bindings</td><td>@Model.TotalSubcontractDemands</td></tr>
                <tr><td>Both Demands Satisfied</td><td>@Model.DemandsBothSatisfied</td></tr>
            </tbody>
        </table>
    </div></section>

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">1. Create Subcontract Operation</h2>
        <p class="ds-text-muted">Idempotent per (PRO, op seq). Creates op in NotReady status.</p>
        <form method="post" asp-page-handler="CreateOp">
            <div class="ds-form-row"><label class="ds-label">PRO ID</label><input type="number" class="ds-input" asp-for="CreateProId" /></div>
            <div class="ds-form-row"><label class="ds-label">Operation Seq</label><input type="number" class="ds-input" asp-for="CreateOpSeq" /></div>
            <div class="ds-form-row"><label class="ds-label">Op Code</label><input class="ds-input" asp-for="CreateOpCode" /></div>
            <div class="ds-form-row"><label class="ds-label">Description</label><input class="ds-input" asp-for="CreateOpDesc" /></div>
            <div class="ds-form-row"><label class="ds-label">Quantity to Ship</label><input type="number" step="0.0001" class="ds-input" asp-for="CreateQty" /></div>
            <div class="ds-form-row"><label class="ds-label">Supplier ID (optional)</label><input type="number" class="ds-input" asp-for="CreateSupplierId" /></div>
            <div class="ds-form-row"><label class="ds-label">Service Item ID (optional)</label><input type="number" class="ds-input" asp-for="CreateServiceItemId" /></div>
            <button type="submit" class="ds-btn ds-btn-primary" data-testid="btn-create-op">Create Subcontract Op</button>
        </form>
    </div></section>

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">2. Create Dual-Demand (§9)</h2>
        <p class="ds-text-muted">Generates ServicePurchaseDemand + WipMovementDemand and binds them via SubcontractDemand. Advances op to ReadyToBuy.</p>
        <form method="post" asp-page-handler="CreateDualDemand">
            <div class="ds-form-row"><label class="ds-label">Subcontract Op ID</label><input type="number" class="ds-input" asp-for="DualDemandOpId" /></div>
            <button type="submit" class="ds-btn ds-btn-primary" data-testid="btn-dual-demand">Create Dual Demand</button>
        </form>
    </div></section>

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">3. Transition Status (manual override)</h2>
        <form method="post" asp-page-handler="Transition">
            <div class="ds-form-row"><label class="ds-label">Op ID</label><input type="number" class="ds-input" asp-for="TransitionOpId" /></div>
            <div class="ds-form-row"><label class="ds-label">New Status</label>
                <select class="ds-input" asp-for="TransitionTo" asp-items="Html.GetEnumSelectList<SubcontractOperationStatus>()"></select>
            </div>
            <button type="submit" class="ds-btn ds-btn-secondary" data-testid="btn-transition">Transition</button>
        </form>
    </div></section>

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">4. Record Shipment to Vendor</h2>
        <form method="post" asp-page-handler="Ship">
            <div class="ds-form-row"><label class="ds-label">Op ID</label><input type="number" class="ds-input" asp-for="ShipOpId" /></div>
            <div class="ds-form-row"><label class="ds-label">Qty Shipped</label><input type="number" step="0.0001" class="ds-input" asp-for="ShipQty" /></div>
            <button type="submit" class="ds-btn ds-btn-primary" data-testid="btn-ship">Record Shipment</button>
        </form>
    </div></section>

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">5. Record Receipt from Vendor</h2>
        <form method="post" asp-page-handler="Receive">
            <div class="ds-form-row"><label class="ds-label">Op ID</label><input type="number" class="ds-input" asp-for="RecvOpId" /></div>
            <div class="ds-form-row"><label class="ds-label">Qty Received</label><input type="number" step="0.0001" class="ds-input" asp-for="RecvReceived" /></div>
            <div class="ds-form-row"><label class="ds-label">Qty Accepted</label><input type="number" step="0.0001" class="ds-input" asp-for="RecvAccepted" /></div>
            <div class="ds-form-row"><label class="ds-label">Qty Rejected</label><input type="number" step="0.0001" class="ds-input" asp-for="RecvRejected" /></div>
            <button type="submit" class="ds-btn ds-btn-primary" data-testid="btn-receive">Record Receipt</button>
        </form>
    </div></section>

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">6. Mark Complete</h2>
        <form method="post" asp-page-handler="Complete">
            <div class="ds-form-row"><label class="ds-label">Op ID</label><input type="number" class="ds-input" asp-for="CompleteOpId" /></div>
            <button type="submit" class="ds-btn ds-btn-success" data-testid="btn-complete">Mark Complete</button>
        </form>
    </div></section>

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">7. Load Status Summary</h2>
        <form method="post" asp-page-handler="LoadStatus">
            <div class="ds-form-row"><label class="ds-label">Op ID</label><input type="number" class="ds-input" asp-for="LoadStatusOpId" /></div>
            <button type="submit" class="ds-btn ds-btn-secondary" data-testid="btn-load-status">Load Status</button>
        </form>
        @if (Model.LoadedStatus != null)
        {
            var s = Model.LoadedStatus;
            <table class="ds-table ds-mt-2">
                <tbody>
                    <tr><td>Op ID</td><td>@s.SubcontractOperationId</td></tr>
                    <tr><td>PRO</td><td>@s.ProductionOrderId</td></tr>
                    <tr><td>Op Seq</td><td>@s.OperationSequence</td></tr>
                    <tr><td>Status</td><td>@s.Status</td></tr>
                    <tr><td>PO Status</td><td>@s.PoStatus</td></tr>
                    <tr><td>Shipment Status</td><td>@s.ShipmentStatus</td></tr>
                    <tr><td>Receipt Status</td><td>@s.ReceiptStatus</td></tr>
                    <tr><td>Qty To Ship / Shipped / Recvd</td><td>@s.QuantityToShip / @s.QuantityShipped / @s.QuantityReceivedBack</td></tr>
                    <tr><td>Accepted / Rejected</td><td>@s.QuantityAccepted / @s.QuantityRejected</td></tr>
                </tbody>
            </table>
        }
    </div></section>

    <section class="ds-card ds-mt-3"><div class="ds-card__body">
        <h2 class="ds-h2">8. Load Ops By PRO</h2>
        <form method="post" asp-page-handler="LoadByPro">
            <div class="ds-form-row"><label class="ds-label">PRO ID</label><input type="number" class="ds-input" asp-for="LoadProId" /></div>
            <button type="submit" class="ds-btn ds-btn-secondary" data-testid="btn-load-pro">Load Ops for PRO</button>
        </form>
        @if (Model.LoadedOps.Any())
        {
            <table class="ds-table ds-mt-2">
                <thead><tr><th>ID</th><th>Seq</th><th>Code</th><th>Supplier</th><th>Status</th><th>Qty</th></tr></thead>
                <tbody>
                    @foreach (var op in Model.LoadedOps)
                    {
                        <tr>
                            <td>@op.Id</td><td>@op.OperationSequence</td><td>@op.OperationCode</td>
                            <td>@(op.SupplierId?.ToString() ?? "—")</td><td>@op.Status</td>
                            <td>@op.QuantityShipped / @op.QuantityToShip</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div></section>

</main>
