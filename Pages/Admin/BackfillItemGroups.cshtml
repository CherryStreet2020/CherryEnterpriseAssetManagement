@page "/Admin/BackfillItemGroups"
@model Abs.FixedAssets.Pages.Admin.BackfillItemGroupsModel
@{
    ViewData["Title"] = "Backfill Item Groups";
    ViewData["TabTitle"] = "Backfill ItemGroups";
    Layout = "_ModernLayout";
}

@*
    B6 Foundation Sprint PR-FS-1.5 (2026-05-26) — admin trigger for
    ItemGroupBackfillSeeder. Two modes:
      - FillNullsOnly: bulk-classifies Items where ItemGroupId IS NULL.
      - Reclassify (PR-FS-1.5.1): walks every Item, re-resolves via the
        new Source-aware convention, updates only on change. Use this
        AFTER running /Admin/BackfillItemSource to flip legacy
        Source=Internal+FG rows to ExternalERP.
*@

<header class="ds-page-header">
    <div class="ds-page-header__inner">
        <h1 class="ds-page-header__title">Backfill Item Groups</h1>
        <p class="ds-page-header__subtitle">
            Bulk-classify Items via the <code>IItemGroupResolver</code> Source-aware
            convention map. FillNullsOnly (default) or Reclassify (PR-FS-1.5.1 sweep).
        </p>
    </div>
</header>

<main class="ds-page">
    <section class="ds-card">
        <div class="ds-card__body">
            <h2 class="ds-h2">What this seeder does</h2>
            <p>
                Maps <code>Item.Type</code> + <code>Item.Source</code> to a default
                <code>ItemGroup.Code</code> per the PR-FS-1.5.1 Source-aware convention:
            </p>
            <ul class="ds-list">
                <li><code>Part / Kit</code> + <code>ExternalERP / Synced</code> &rarr; <code>RAW</code> (purchased part default — SAP <code>ROH</code>)</li>
                <li><code>Part / Kit</code> + <code>Internal</code> &rarr; <code>SUBASSY</code> (sub-assembly placeholder — SAP <code>HALB</code>; tightens when PR-FS-7's <code>IsSellable</code> lands)</li>
                <li><code>Tool</code> &rarr; <code>TOOLING</code></li>
                <li><code>Fastener</code> &rarr; <code>RAW</code></li>
                <li><code>Electrical / Mechanical / Hydraulic / Pneumatic / Bearing</code> &rarr; <code>SPAREPART</code></li>
                <li><code>Consumable / Safety / Lubricant / Chemical / Filter / Belt / Seal</code> &rarr; <code>CONSUMABLE</code></li>
                <li><code>Service</code> &rarr; <code>SERVICE</code></li>
            </ul>
            <p class="ds-text-muted ds-mt-3">
                <strong>FG is reserved for parent-level SELLABLE items only.</strong> The
                resolver never defaults Part &rarr; FG — that requires an explicit
                ItemGroupId at create time. PR-FS-7's <code>IsSellable</code> flag will
                enable auto-detection in a later sprint.
            </p>
            <p class="ds-text-muted ds-mt-2">
                <strong>FillNullsOnly idempotency:</strong> only touches
                <code>ItemGroupId IS NULL</code>. Re-running is safe.
            </p>
            <p class="ds-text-muted ds-mt-2">
                <strong>ReclassifyLegacyBugRows idempotency:</strong> only walks Items
                matching the legacy-bug fingerprint
                (<code>Type IN (Part, Kit) AND Source IN (ExternalERP, Synced) AND
                ItemGroupId == FG</code>). Operator-set classifications on other
                Item types or other ItemGroup buckets are <strong>never</strong>
                touched. Idempotent — re-running matches zero rows after the first
                sweep.
            </p>
            <p class="ds-text-muted ds-mt-2">
                <strong>Lock 14:</strong> runs on dev only. Republish-with-Copy syncs to prod.
            </p>

            <form method="post" class="ds-mt-4">
                <div class="ds-mb-3">
                    <label class="ds-checkbox">
                        <input type="checkbox" name="Reclassify" value="true" />
                        <span>ReclassifyLegacyBugRows (PR-FS-1.5.1 hotfix sweep) — scope to legacy-bug fingerprint only, never touch operator-set classifications.</span>
                    </label>
                </div>
                <button type="submit" class="ds-btn ds-btn--primary">Backfill Item Groups</button>
                <a asp-page="/Admin/BackfillItemSource" class="ds-btn ds-btn--secondary ds-ml-2">Run Source backfill first</a>
                <a asp-page="/Materials/Items" class="ds-btn ds-btn--secondary ds-ml-2">Open Items list after backfill</a>
            </form>
        </div>
    </section>

    @if (Model.Result is not null)
    {
        var r = Model.Result;
        <section class="ds-card ds-mt-4">
            <div class="ds-card__body">
                <h2 class="ds-h2">Result (@r.Mode)</h2>
                @if (r.Mode == Abs.FixedAssets.Services.Seeding.ItemGroupBackfillMode.ReclassifyLegacyBugRows)
                {
                    <p>
                        Items scanned: <strong>@r.TotalItemsScanned</strong> &middot;
                        reclassified: <strong>@r.ItemsReclassified</strong> &middot;
                        unchanged: <strong>@r.ItemsUnchanged</strong> &middot;
                        skipped (no mapping): <strong>@r.ItemsSkippedNoMapping</strong>
                    </p>
                }
                else
                {
                    <p>
                        Items scanned: <strong>@r.TotalItemsScanned</strong> &middot;
                        classified: <strong>@r.ItemsClassified</strong> &middot;
                        already-classified: <strong>@r.ItemsAlreadyClassified</strong> &middot;
                        skipped (no mapping): <strong>@r.ItemsSkippedNoMapping</strong>
                    </p>
                }

                @if (r.PerItemGroupClassified.Count > 0)
                {
                    <h3 class="ds-h3 ds-mt-3">Per ItemGroup classified</h3>
                    <table class="ds-table">
                        <thead>
                            <tr><th>ItemGroup Code</th><th class="ds-text-right">Count</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var kv in r.PerItemGroupClassified)
                            {
                                <tr><td><code>@kv.Key</code></td><td class="ds-text-right">@kv.Value</td></tr>
                            }
                        </tbody>
                    </table>
                }

                @if (r.ReclassifyChanges.Count > 0)
                {
                    <h3 class="ds-h3 ds-mt-3">Reclassify deltas (first 50)</h3>
                    <table class="ds-table">
                        <thead>
                            <tr>
                                <th>Item Id</th>
                                <th>Part Number</th>
                                <th>From</th>
                                <th>To</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in r.ReclassifyChanges.Take(50))
                            {
                                <tr>
                                    <td><code>@c.ItemId</code></td>
                                    <td><code>@c.PartNumber</code></td>
                                    <td><code>@(c.FromCode ?? "<null>")</code></td>
                                    <td><code>@c.ToCode</code></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    @if (r.ReclassifyChanges.Count > 50)
                    {
                        <p class="ds-text-muted">… and @(r.ReclassifyChanges.Count - 50) more.</p>
                    }
                }

                @if (r.SkippedItemIds.Count > 0)
                {
                    <h3 class="ds-h3 ds-mt-3 ds-text-warning">Skipped Item Ids (no mapping)</h3>
                    <p class="ds-text-muted">
                        These Items must be classified manually. Item Type has no convention-matched ItemGroup.
                    </p>
                    <code>@string.Join(", ", r.SkippedItemIds)</code>
                }

                @if (r.Warnings.Count > 0)
                {
                    <h3 class="ds-h3 ds-mt-3 ds-text-warning">Warnings</h3>
                    <ul class="ds-list ds-text-warning">
                        @foreach (var w in r.Warnings)
                        {
                            <li>@w</li>
                        }
                    </ul>
                }
            </div>
        </section>
    }
</main>
