@model Abs.FixedAssets.Pages.Reports.IndexModel
<div class="kpi-card">
    <div class="kpi-label">Assets</div>
    <div class="kpi-value">@Model.TotalAssets</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Total Cost</div>
    <div class="kpi-value money">@Model.TotalCost.ToString("C0")</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Journals</div>
    <div class="kpi-value">@Model.TotalJournals</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">CCA Classes</div>
    <div class="kpi-value info">@Model.TotalCcaClasses</div>
</div>
