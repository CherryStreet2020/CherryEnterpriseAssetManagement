@page
@model Abs.FixedAssets.Pages.Reports.T2Schedule8Model
@{
    ViewData["Title"] = "T2 Schedule 8 - Capital Cost Allowance";
    ViewData["TabTitle"] = "T2 Schedule 8";
    ViewData["Breadcrumb"] = "Tax Reports";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
    
    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = "T2 Schedule 8",
        ["Subtitle"] = "Capital Cost Allowance (CCA) - Canada Revenue Agency prescribed classes and rates",
        ["TypeLabel"] = "Tax Reports",
        ["StatusText"] = "CRA Form",
        ["StatusTone"] = "info",
        ["KpisPartial"] = "/Pages/Reports/_ReportsT2Schedule8Kpis.cshtml",
        ["ActionsPartial"] = "/Pages/Reports/_ReportsT2Schedule8Actions.cshtml"
    };
}

@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
        </div>
        <div class="stat-content">
            <div class="stat-label">Fiscal Year</div>
            <div class="stat-value">@Model.FiscalYear</div>
        </div>
    </div>
    <div class="stat-card stat-success">
        <div class="stat-icon success">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </div>
        <div class="stat-content">
            <div class="stat-label">Opening UCC</div>
            <div class="stat-value">@Model.TotalOpeningUcc.ToString("C0")</div>
        </div>
    </div>
    <div class="stat-card stat-warning">
        <div class="stat-icon warning">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
        </div>
        <div class="stat-content">
            <div class="stat-label">CCA Claimed</div>
            <div class="stat-value">@Model.TotalCcaClaimed.ToString("C0")</div>
        </div>
    </div>
    <div class="stat-card stat-info">
        <div class="stat-icon info">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
        </div>
        <div class="stat-content">
            <div class="stat-label">Closing UCC</div>
            <div class="stat-value">@Model.TotalClosingUcc.ToString("C0")</div>
        </div>
    </div>
</div>

<div class="card" style="margin-bottom: 24px;">
    <div class="card-header">
        <div>
            <h3 class="card-title">T2 Schedule 8 - Capital Cost Allowance (CCA)</h3>
            <p class="card-subtitle">Canada Revenue Agency prescribed classes and rates</p>
        </div>
        <div style="display: flex; gap: 12px; align-items: center;">
            <form method="get" style="display: flex; gap: 12px; align-items: center;">
                <select name="fiscalYear" class="form-select" style="width: 120px;" onchange="this.form.submit()">
                    @for (int y = DateTime.Now.Year; y >= 2020; y--)
                    {
                        <option value="@y" selected="@(y == Model.FiscalYear)">@y</option>
                    }
                </select>
                <select name="companyId" class="form-select" style="width: 200px;" onchange="this.form.submit()">
                    <option value="">All Companies</option>
                    @foreach (var c in Model.Companies)
                    {
                        <option value="@c.Id" selected="@(c.Id == Model.SelectedCompanyId)">@c.Name</option>
                    }
                </select>
            </form>
            <button type="button" class="btn-p btn-p--secondary" onclick="window.print()">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
                </svg>
                Print
            </button>
        </div>
    </div>
</div>

<div class="card" style="margin-bottom: 24px;">
    <div class="card-header">
        <h3 class="card-title">CCA Schedule by Class</h3>
    </div>
    <div style="overflow-x: auto;">
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width: 80px;">Class</th>
                    <th style="text-align: center;">Rate</th>
                    <th style="text-align: right;">Opening UCC</th>
                    <th style="text-align: right;">Additions</th>
                    <th style="text-align: right;">Dispositions</th>
                    <th style="text-align: right;">Half-Year Adj</th>
                    <th style="text-align: right;">Base for CCA</th>
                    <th style="text-align: right;">CCA Claimed</th>
                    <th style="text-align: right;">Recapture</th>
                    <th style="text-align: right;">Terminal Loss</th>
                    <th style="text-align: right;">Closing UCC</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model.ClassBalances)
                {
                    <tr>
                        <td>
                            <span class="badge badge-primary" style="font-size: 14px; padding: 8px 12px;">@b.CcaClass?.ClassNumber</span>
                        </td>
                        <td style="text-align: center;">
                            @if (b.CcaClass != null)
                            {
                                @((b.CcaClass.Rate * 100).ToString("0.##"))@:%
                            }
                        </td>
                        <td style="text-align: right;">@b.OpeningUcc.ToString("C0")</td>
                        <td class="text-green" style="text-align: right;">@b.Additions.ToString("C0")</td>
                        <td class="text-red" style="text-align: right;">@((b.Dispositions > 0 ? "(" : ""))@b.Dispositions.ToString("C0")@((b.Dispositions > 0 ? ")" : ""))</td>
                        <td style="text-align: right;">@b.HalfYearAdjustment.ToString("C0")</td>
                        <td style="text-align: right;">@b.BaseForCca.ToString("C0")</td>
                        <td style="text-align: right; font-weight: 600;">@b.CcaClaimed.ToString("C0")</td>
                        <td class="text-amber" style="text-align: right;">@(b.Recapture.GetValueOrDefault() > 0 ? b.Recapture.GetValueOrDefault().ToString("C0") : "-")</td>
                        <td class="text-red" style="text-align: right;">@(b.TerminalLoss.GetValueOrDefault() > 0 ? b.TerminalLoss.GetValueOrDefault().ToString("C0") : "-")</td>
                        <td style="text-align: right; font-weight: 600;">@b.ClosingUcc.ToString("C0")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="totals-row">
                    <td colspan="2">Totals</td>
                    <td style="text-align: right;">@Model.TotalOpeningUcc.ToString("C0")</td>
                    <td style="text-align: right;">@Model.TotalAdditions.ToString("C0")</td>
                    <td style="text-align: right;">@Model.TotalDispositions.ToString("C0")</td>
                    <td style="text-align: right;">@Model.TotalHalfYearAdj.ToString("C0")</td>
                    <td style="text-align: right;">@Model.TotalBaseForCca.ToString("C0")</td>
                    <td style="text-align: right;">@Model.TotalCcaClaimed.ToString("C0")</td>
                    <td style="text-align: right;">@Model.TotalRecapture.ToString("C0")</td>
                    <td style="text-align: right;">@Model.TotalTerminalLoss.ToString("C0")</td>
                    <td style="text-align: right;">@Model.TotalClosingUcc.ToString("C0")</td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

<div class="card" style="margin-bottom: 24px;">
    <div class="card-header">
        <h3 class="card-title">Assets Added During Year</h3>
    </div>
    @if (Model.AdditionsThisYear.Any())
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Asset Number</th>
                    <th>Description</th>
                    <th>CCA Class</th>
                    <th>Available for Use</th>
                    <th style="text-align: right;">Capital Cost</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model.AdditionsThisYear)
                {
                    <tr>
                        <td><span class="badge badge-primary">@a.Asset?.AssetNumber</span></td>
                        <td>@a.Asset?.Description</td>
                        <td><span class="badge badge-secondary">Class @a.CcaClass?.ClassNumber</span></td>
                        <td>@a.AvailableForUseDate?.ToString("MM/dd/yyyy")</td>
                        <td style="text-align: right; font-weight: 600;">@a.CapitalCost.ToString("C2")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="totals-row">
                    <td colspan="4">Total Additions</td>
                    <td style="text-align: right;">@Model.AdditionsThisYear.Sum(a => a.CapitalCost).ToString("C2")</td>
                </tr>
            </tfoot>
        </table>
    }
    else
    {
        <div class="text-theme-muted" style="padding: 24px; text-align: center;">
            No assets added during this fiscal year.
        </div>
    }
</div>

<div class="card" style="margin-bottom: 24px;">
    <div class="card-header">
        <h3 class="card-title">Dispositions During Year</h3>
    </div>
    @if (Model.DispositionsThisYear.Any())
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Asset Number</th>
                    <th>Description</th>
                    <th>CCA Class</th>
                    <th>Disposal Date</th>
                    <th style="text-align: right;">Capital Cost</th>
                    <th style="text-align: right;">Proceeds</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Model.DispositionsThisYear)
                {
                    <tr>
                        <td><span class="badge badge-primary">@d.Asset?.AssetNumber</span></td>
                        <td>@d.Asset?.Description</td>
                        <td><span class="badge badge-secondary">Class @d.CcaClass?.ClassNumber</span></td>
                        <td>@d.DisposalDate?.ToString("MM/dd/yyyy")</td>
                        <td style="text-align: right;">@d.CapitalCost.ToString("C2")</td>
                        <td style="text-align: right; font-weight: 600;">@(d.Proceeds?.ToString("C2") ?? "-")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="totals-row">
                    <td colspan="4">Total Dispositions</td>
                    <td style="text-align: right;">@Model.DispositionsThisYear.Sum(d => d.CapitalCost).ToString("C2")</td>
                    <td style="text-align: right;">@Model.DispositionsThisYear.Sum(d => d.Proceeds ?? 0).ToString("C2")</td>
                </tr>
            </tfoot>
        </table>
    }
    else
    {
        <div class="text-theme-muted" style="padding: 24px; text-align: center;">
            No dispositions during this fiscal year.
        </div>
    }
</div>

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Summary for T2 Filing</h3>
    </div>
    <table class="data-table">
        <tbody>
            <tr>
                <td>Total Capital Cost Allowance (CCA) Claimed</td>
                <td style="text-align: right; font-weight: 600;">@Model.TotalCcaClaimed.ToString("C2")</td>
            </tr>
            <tr>
                <td>Recapture of CCA (Income)</td>
                <td style="text-align: right;">@Model.TotalRecapture.ToString("C2")</td>
            </tr>
            <tr>
                <td>Terminal Loss (Deduction)</td>
                <td style="text-align: right;">@Model.TotalTerminalLoss.ToString("C2")</td>
            </tr>
            <tr style="font-weight: 700; font-size: 18px; background: var(--btn-primary-bg, #cf3339); color: white;">
                <td>Net CCA Deduction</td>
                <td style="text-align: right;">@((Model.TotalCcaClaimed + Model.TotalTerminalLoss - Model.TotalRecapture).ToString("C2"))</td>
            </tr>
        </tbody>
    </table>
</div>
