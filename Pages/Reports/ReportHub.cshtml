@page
@model Abs.FixedAssets.Pages.Reports.ReportHubModel
@{
    ViewData["Title"] = "Report Center";
    ViewData["Breadcrumb"] = "Report Center";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
}

@{
    var headerVd = new ViewDataDictionary(ViewData)
    {
        { "HeaderTitle", "Report Center" },
        { "Subtitle", "Generate insights, export data, and analyze your fixed asset portfolio" },
        { "TypeLabel", "Analytics" },
        { "StatusText", "Active" },
        { "StatusTone", "active" },
        { "KpisPartial", "Reports/_ReportsReportHubKpis" },
        { "ActionsPartial", "Reports/_ReportsReportHubActions" }
    };
}
@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

<div class="report-section">
    <div class="report-section-header">
        <div class="report-section-icon primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
        </div>
        <div>
            <h2 class="report-section-title">Depreciation Reports</h2>
            <p class="report-section-subtitle">Calculate and preview depreciation across all books</p>
        </div>
    </div>
    <div class="report-grid">
        @foreach (var report in Model.DepreciationReports)
        {
            <a href="@report.Url" class="report-card @report.Color">
                <div class="report-card-icon">
                    @if (report.Icon == "calculator")
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                        </svg>
                    }
                    else if (report.Icon == "calendar")
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                    }
                    else if (report.Icon == "compare")
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                        </svg>
                    }
                </div>
                <div class="report-card-content">
                    <div class="report-card-header">
                        <h3 class="report-card-title">@report.Title</h3>
                        @if (report.IsNew)
                        {
                            <span class="report-badge">New</span>
                        }
                    </div>
                    <p class="report-card-desc">@report.Description</p>
                </div>
                <div class="report-card-arrow">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </div>
            </a>
        }
    </div>
</div>

<div class="report-section">
    <div class="report-section-header">
        <div class="report-section-icon success">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
        </div>
        <div>
            <h2 class="report-section-title">Asset Reports</h2>
            <p class="report-section-subtitle">View and analyze your fixed asset inventory</p>
        </div>
    </div>
    <div class="report-grid">
        @foreach (var report in Model.AssetReports)
        {
            <a href="@report.Url" class="report-card @report.Color">
                <div class="report-card-icon">
                    @if (report.Icon == "list")
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                        </svg>
                    }
                    else if (report.Icon == "chart")
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z" />
                        </svg>
                    }
                    else if (report.Icon == "check")
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    }
                </div>
                <div class="report-card-content">
                    <div class="report-card-header">
                        <h3 class="report-card-title">@report.Title</h3>
                        @if (report.IsNew)
                        {
                            <span class="report-badge">New</span>
                        }
                    </div>
                    <p class="report-card-desc">@report.Description</p>
                </div>
                <div class="report-card-arrow">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </div>
            </a>
        }
    </div>
</div>

<div class="report-section">
    <div class="report-section-header">
        <div class="report-section-icon warning">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </div>
        <div>
            <h2 class="report-section-title">Financial Reports</h2>
            <p class="report-section-subtitle">Journal entries and GL account summaries</p>
        </div>
    </div>
    <div class="report-grid">
        @foreach (var report in Model.FinancialReports)
        {
            <a href="@report.Url" class="report-card @report.Color">
                <div class="report-card-icon">
                    @if (report.Icon == "ledger")
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                        </svg>
                    }
                    else if (report.Icon == "document")
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                    }
                    else if (report.Icon == "bank")
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z" />
                        </svg>
                    }
                    else if (report.Icon == "tax")
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2zM10 8.5a.5.5 0 11-1 0 .5.5 0 011 0zm5 5a.5.5 0 11-1 0 .5.5 0 011 0z" />
                        </svg>
                    }
                </div>
                <div class="report-card-content">
                    <div class="report-card-header">
                        <h3 class="report-card-title">@report.Title</h3>
                        @if (report.IsNew)
                        {
                            <span class="report-badge">New</span>
                        }
                    </div>
                    <p class="report-card-desc">@report.Description</p>
                </div>
                <div class="report-card-arrow">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </div>
            </a>
        }
    </div>
</div>

<div class="section-card mt-4">
    <div class="section-card-header">
        <div>
            <h3 class="card-title">Quick Export</h3>
            <p class="card-subtitle">Export your data in various formats</p>
        </div>
    </div>
    <div class="section-card-body">
        <div class="export-grid">
            <div class="export-option">
                <div class="export-icon excel">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                    </svg>
                </div>
                <div class="export-info">
                    <h4>Excel Export</h4>
                    <p>Export all assets to Excel spreadsheet</p>
                </div>
                <a asp-page="/Assets/Index" asp-page-handler="Export" class="btn-p btn-p--secondary btn-p--sm">Download</a>
            </div>
            <div class="export-option">
                <div class="export-icon csv">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                </div>
                <div class="export-info">
                    <h4>Journal CSV</h4>
                    <p>Export journal entries for GL import</p>
                </div>
                <a asp-page="/Journals/Index" asp-page-handler="Export" class="btn-p btn-p--secondary btn-p--sm">Download</a>
            </div>
        </div>
    </div>
</div>

