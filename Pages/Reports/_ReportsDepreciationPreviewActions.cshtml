@model Abs.FixedAssets.Pages.Reports.DepreciationPreviewModel
@{
    string ShortDate(DateTime dt) => dt.ToString("MM/dd/yy", System.Globalization.CultureInfo.InvariantCulture);
}
<div class="hero-tags">
    <form method="get" data-csp-style="display: flex; gap: 0.5rem; align-items: center;">
        <input type="text"
               name="asOf"
               class="form-control" data-csp-style="width: 150px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); color: white;"
               placeholder="mm/dd/yyyy"
               value="@(Model.AsOf == default ? "" : ShortDate(Model.AsOf))" />
        <button class="hero-btn hero-btn-primary" type="submit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            Apply Date
        </button>
    </form>
</div>
<div class="hero-btns">
    <a class="hero-btn hero-btn-ghost" asp-page="./DepreciationPreview" asp-page-handler="Export"
       asp-route-asOf="@(Model.AsOf == default ? "" : Model.AsOf.ToString("MM/dd/yy"))">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        Export Excel
    </a>
</div>
