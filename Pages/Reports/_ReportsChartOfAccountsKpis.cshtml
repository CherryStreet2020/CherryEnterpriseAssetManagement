@model Abs.FixedAssets.Pages.Reports.ChartOfAccountsModel
<div class="kpi-card">
    <div class="kpi-label">Total</div>
    <div class="kpi-value">@Model.Accounts.Count</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Active</div>
    <div class="kpi-value success">@Model.Accounts.Count(a => a.IsActive)</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Types</div>
    <div class="kpi-value warning">@Model.AccountTypeCounts.Count</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Categories</div>
    <div class="kpi-value info">@Model.CategoryCounts.Count</div>
</div>
