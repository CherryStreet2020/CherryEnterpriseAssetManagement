@page
@model Abs.FixedAssets.Pages.Reports.AssetReliabilityModel
@using Abs.FixedAssets.Pages.Shared.Primitives
@{
    ViewData["Title"] = "Per-Asset Reliability";
    ViewData["TabTitle"] = "Asset Reliability";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = "Per-Asset Reliability",
        ["HeaderSubtitle"] = $"{Model.StartDate:MMM d, yyyy} – {Model.EndDate:MMM d, yyyy} · {Model.Rows.Count} assets · window: {Model.WindowHours:F0} hrs"
    };

    string SortHref(string col)
    {
        var nextDesc = (Model.Sort == col) ? !Model.Desc : true; // toggle when clicking same column
        var dateParams = $"StartDate={Model.StartDate?.ToString("yyyy-MM-dd")}&EndDate={Model.EndDate?.ToString("yyyy-MM-dd")}";
        return $"?Sort={col}&Desc={nextDesc.ToString().ToLower()}&{dateParams}";
    }

    string SortArrow(string col) => Model.Sort == col ? (Model.Desc ? "↓" : "↑") : "";

    // Derived signal: how many assets are below the 90% availability threshold —
    // surfaced on the Availability KPI tile delta so the operator can see at-a-glance
    // how concentrated reliability risk is in the fleet.
    var atRiskCount = Model.Rows.Count(r => r.AvailabilityPercent < 90m);
    var availTone = Model.AvgAvailability >= 95m ? "success"
        : Model.AvgAvailability >= 90m ? "warning"
        : "danger";
    var totalSpend = Model.Rows.Sum(r => r.SpendInWindow);
    var windowDays = (double)(Model.WindowHours / 24m);
}

@await Html.PartialAsync("_ScreenHeader", headerVd)

@* PR #116d.11 — Filter bar restyled on the design system. *@
<form method="get" class="ds-card" data-tone="neutral" style="margin-top: 1rem; display: flex; gap: 1rem; align-items: end; flex-wrap: wrap;">
    <div style="flex: 1; min-width: 160px;">
        <label style="display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500; margin-bottom: 6px;">Start Date</label>
        <input type="date" name="StartDate" value="@Model.StartDate?.ToString("yyyy-MM-dd")" style="width: 100%; padding: 8px 10px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface-2, rgba(0,0,0,0.18)); color: var(--text-primary); font-size: 13px;" />
    </div>
    <div style="flex: 1; min-width: 160px;">
        <label style="display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500; margin-bottom: 6px;">End Date</label>
        <input type="date" name="EndDate" value="@Model.EndDate?.ToString("yyyy-MM-dd")" style="width: 100%; padding: 8px 10px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface-2, rgba(0,0,0,0.18)); color: var(--text-primary); font-size: 13px;" />
    </div>
    <button type="submit" class="ds-btn ds-btn--primary ds-btn--md">Update</button>
    <a href="?StartDate=@(Model.StartDate?.ToString("yyyy-MM-dd"))&EndDate=@(Model.EndDate?.ToString("yyyy-MM-dd"))&Sort=@Model.Sort&Desc=@Model.Desc.ToString().ToLower()&Format=csv" class="ds-btn ds-btn--secondary ds-btn--md">⤓ CSV</a>
</form>

@if (Model.Rows.Count == 0)
{
    @* PR #116d.11 — EmptyState v2 with chart icon. Same dual-CTA pattern as Reliability. *@
    <div style="margin-top: 24px;">
        @await Html.PartialAsync("Primitives/_EmptyStateV2", new EmptyStateModel
        {
            Icon = "chart",
            Tone = "info",
            Title = "No WO activity in this window",
            Body = "Per-asset reliability needs completed WorkOrders with a non-null CompletedDate inside the selected range. Try widening the window or check that maintenance is being closed out in the system.",
            CtaLabel = "Try last 365 days",
            CtaHref = $"?StartDate={DateTime.UtcNow.Date.AddDays(-365):yyyy-MM-dd}&EndDate={DateTime.UtcNow.Date:yyyy-MM-dd}",
            SecondaryLabel = "Back to Reports",
            SecondaryHref = "/Reports"
        })
    </div>
}
else
{
    @* PR #116d.11 — 4 tone-driven KPITiles. Availability tile flips tone based on the
       fleet-average (success/warning/danger), with at-risk count surfaced in its delta. *@
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-top: 20px;">
        @await Html.PartialAsync("Primitives/_KPITile", new KpiTileModel
        {
            Label = "Assets with Activity",
            Value = Model.Rows.Count.ToString("N0"),
            DeltaText = $"{totalSpend.ToString("C0")} total spend",
            DeltaDirection = "flat",
            SparkTone = "info"
        })
        @await Html.PartialAsync("Primitives/_KPITile", new KpiTileModel
        {
            Label = "Avg MTBF",
            Value = Model.AvgMtbf.ToString("N1"),
            Unit = "hrs",
            DeltaText = "across assets w/ 2+ closes",
            DeltaDirection = "flat",
            SparkTone = "brand"
        })
        @await Html.PartialAsync("Primitives/_KPITile", new KpiTileModel
        {
            Label = "Avg Availability",
            Value = Model.AvgAvailability.ToString("N2"),
            Unit = "%",
            DeltaText = atRiskCount > 0 ? $"▼ {atRiskCount} asset(s) below 90%" : "▲ every asset above 90%",
            DeltaDirection = atRiskCount > 0 ? "down" : "up",
            SparkTone = availTone
        })
        @await Html.PartialAsync("Primitives/_KPITile", new KpiTileModel
        {
            Label = "Window Length",
            Value = windowDays.ToString("N0"),
            Unit = "days",
            DeltaText = $"{Model.WindowHours:N0} hrs",
            DeltaDirection = "flat",
            SparkTone = "muted"
        })
    </div>

    @* PR #116d.11 — Sortable spend/reliability table wrapped in a DataCard with brand
       tone. Sort arrows preserve URL params. Availability cell uses design tokens for
       success/warning/danger color tiers (≥95 / ≥90 / below). *@
    <div class="ds-card" data-tone="brand" style="margin-top: 24px; padding: 0;">
        <div style="padding: 18px 22px; border-bottom: 1px solid var(--border);">
            <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500;">Reliability Roll-up</div>
            <div style="font-size: 17px; font-weight: 700; color: var(--text-primary); margin-top: 4px;">Per-Asset Breakdown</div>
            <div style="color: var(--text-muted); font-size: 13px; margin-top: 4px;">
                MTBF, availability, and spend per asset over the window. Click a column header to sort — the table preserves date range and CSV target.
            </div>
        </div>
        <div style="padding: 0;">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: var(--surface-2, rgba(120,120,200,0.04));">
                        <th style="text-align: left; padding: 12px 16px; border-bottom: 1px solid var(--border); font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 600;">
                            <a href="@SortHref("asset")" style="color: inherit; text-decoration: none;">Asset @SortArrow("asset")</a>
                        </th>
                        <th style="text-align: left; padding: 12px 16px; border-bottom: 1px solid var(--border); font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 600;">
                            Description
                        </th>
                        <th style="text-align: right; padding: 12px 16px; border-bottom: 1px solid var(--border); font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 600;">
                            <a href="@SortHref("wos")" style="color: inherit; text-decoration: none;">Corrective WOs @SortArrow("wos")</a>
                        </th>
                        <th style="text-align: right; padding: 12px 16px; border-bottom: 1px solid var(--border); font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 600;">
                            <a href="@SortHref("mtbf")" style="color: inherit; text-decoration: none;">MTBF (hrs) @SortArrow("mtbf")</a>
                        </th>
                        <th style="text-align: right; padding: 12px 16px; border-bottom: 1px solid var(--border); font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 600;">
                            <a href="@SortHref("avail")" style="color: inherit; text-decoration: none;">Availability % @SortArrow("avail")</a>
                        </th>
                        <th style="text-align: right; padding: 12px 16px; border-bottom: 1px solid var(--border); font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 600;">
                            <a href="@SortHref("spend")" style="color: inherit; text-decoration: none;">Spend @SortArrow("spend")</a>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Rows)
                    {
                        var availColorVar = r.AvailabilityPercent >= 95m ? "var(--ds-success, #34d399)"
                            : r.AvailabilityPercent >= 90m ? "var(--ds-warning, #fbbf24)"
                            : "var(--ds-danger, #f87171)";
                        <tr style="border-top: 1px solid var(--border);">
                            <td style="padding: 12px 16px; font-family: var(--font-mono, ui-monospace, monospace); font-size: 13px;">
                                <a href="/Assets/Asset?id=@r.AssetId" style="color: var(--ds-brand, #60a5fa); text-decoration: none; font-weight: 600;">@r.AssetNumber</a>
                            </td>
                            <td style="padding: 12px 16px; color: var(--text-primary);">@r.Description</td>
                            <td style="padding: 12px 16px; text-align: right; font-family: var(--font-mono, ui-monospace, monospace); font-weight: 600; color: var(--text-primary);">@r.CorrectiveWoCount</td>
                            <td style="padding: 12px 16px; text-align: right; font-family: var(--font-mono, ui-monospace, monospace); color: var(--text-primary);">
                                @(r.MtbfHours.HasValue ? r.MtbfHours.Value.ToString("N1") : "—")
                            </td>
                            <td style="padding: 12px 16px; text-align: right; font-weight: 700; font-family: var(--font-mono, ui-monospace, monospace); color: @availColorVar;">
                                @r.AvailabilityPercent.ToString("N2")%
                            </td>
                            <td style="padding: 12px 16px; text-align: right; font-family: var(--font-mono, ui-monospace, monospace); font-weight: 600; color: var(--text-primary);">@r.SpendInWindow.ToString("C0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* PR #116d.11 — Footer legend explaining the three derived metrics. Same prose
       as before, restyled with design-token code chips and StatusPill summary. *@
    <div style="margin-top: 18px; display: flex; gap: 10px; flex-wrap: wrap;">
        @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel { Label = $"At risk · <90% availability · {atRiskCount} asset(s)", Tone = atRiskCount > 0 ? "danger" : "success", ShowDot = true })
        @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel { Label = $"Total spend in window · {totalSpend.ToString("C0")}", Tone = "warning", ShowDot = true, MonoNum = Model.Rows.Count.ToString() })
    </div>

    <p style="margin-top: 14px; color: var(--text-muted); font-size: 13px; line-height: 1.6;">
        <strong style="color: var(--text-secondary);">MTBF</strong>: average hours between consecutive corrective-WO close timestamps. <em>—</em> means fewer than 2 closes in the window; not enough data to compute.
        <strong style="color: var(--text-secondary);">Availability</strong>: (window hours − Σ downtime) ÷ window hours. Downtime per WO = CompletedDate − StartedAt.
        <strong style="color: var(--text-secondary);">Spend</strong>: sum of WO-LBR + WO-ISS-OP JE debits minus WO-RTN/RTN-OP. Same source as the
        <a href="/Reports/Reliability" style="color: var(--ds-brand, #60a5fa); text-decoration: none;">Pareto report</a> and dashboard tile.
    </p>
}
