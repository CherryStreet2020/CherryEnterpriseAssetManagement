@page
@model Abs.FixedAssets.Pages.Approvals.PendingModel
@using Abs.FixedAssets.Pages.Shared.Primitives
@{
    ViewData["Title"] = "Pending Approvals";
    ViewData["TabTitle"] = "Pending Approvals";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";

    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = "Pending Approvals",
        ["HeaderSubtitle"] = $"{Model.Rows.Count} item(s) waiting on you · Acting as: {Model.CurrentUserRoles}"
    };
}

@await Html.PartialAsync("_ScreenHeader", headerVd)

@if (Model.Rows.Count == 0)
{
    @* PR #116d.9 — Inbox-zero empty state via <EmptyState> v2. Success tone
       with sparkle icon so "all clear" feels rewarding rather than vacant. *@
    <div style="margin-top: 24px;">
        @await Html.PartialAsync("Primitives/_EmptyStateV2", new EmptyStateModel
        {
            Icon = "sparkle",
            Tone = "success",
            Title = "Inbox zero",
            Body = "Nothing is waiting on your approval right now. Take the win.",
            CtaLabel = "Back to Dashboard",
            CtaHref = "/"
        })
    </div>
}
else
{
    @* PR #116d.9 — Pending rows rebuilt with <DataCard> brand-tone primitives.
       Each row surfaces the title, entity type as a brand pill, workflow name
       in subtitle, approvals ratio as a mono-numeric chip, and a primary "Review →"
       button styled on the design system. *@
    <div style="display: flex; flex-direction: column; gap: 12px; margin-top: 20px;">
        @foreach (var r in Model.Rows)
        {
            var ratioPct = r.ApprovalsRequired > 0 ? (int)System.Math.Round((double)r.ApprovalsRecorded / r.ApprovalsRequired * 100) : 0;
            var ratioTone = ratioPct >= 100 ? "success" : ratioPct >= 50 ? "warning" : "brand";
            <div class="ds-card" data-tone="brand">
                <div style="display: flex; gap: 20px; align-items: center; flex-wrap: wrap;">
                    <div style="flex: 1; min-width: 240px;">
                        <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
                            <strong style="font-size: 15px; color: var(--text-primary);">@r.Title</strong>
                            @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel { Label = r.TargetEntityType, Tone = "brand", ShowDot = false })
                        </div>
                        <div style="color: var(--text-muted); font-size: 12.5px; margin-top: 4px;">
                            @r.Subtitle · <span style="color: var(--text-secondary);">Workflow: @r.WorkflowName</span>
                        </div>
                    </div>

                    <div style="text-align: right;">
                        <div style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500;">Approvals</div>
                        <div style="margin-top: 6px;">
                            @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel {
                                Label = $"of {r.ApprovalsRequired}",
                                Tone = ratioTone,
                                MonoNum = r.ApprovalsRecorded.ToString()
                            })
                        </div>
                    </div>

                    <a class="ds-btn ds-btn--primary ds-btn--md" href="@r.DetailUrl">
                        Review →
                    </a>
                </div>
            </div>
        }
    </div>
}
