@*
    _CockpitAsnQueuePreview.cshtml — Sprint 12A PR #6 / ADR-018 §D3.

    Receiving-specific ASN preview pane. Mirrors _CockpitPoQueuePreview's
    structure with ASN-specific fields: Carrier · Tracking · Source PO ·
    expected vs received qty per line. "Receive by ASN" CTA links to the
    existing Sprint 11 /Receiving/ByAsn page (which already accepts an
    `?asn={id}` query param).

    Hooks for wwwroot/js/cockpit.js (selectPO). The script id changes from
    __poDetails (PO Queue) to __asnDetails so the two queues stay independent
    on the same /Receiving page DOM.
*@

<div class="cockpit__preview-header">
    <div data-csp-style="display:flex; align-items:center; gap:1rem;">
        <span class="cockpit__preview-po" id="pvPoNum"></span>
        <span class="cockpit__preview-status" id="pvStatus"></span>
    </div>
    <a id="pvReceiveBtn" href="#" class="btn-p btn-p--primary">
        <i class="fas fa-truck-fast"></i> Receive by ASN
    </a>
</div>

<div class="cockpit__preview-info">
    <div class="cockpit__preview-field">
        <span class="cockpit__preview-label">Vendor</span>
        <span class="cockpit__preview-value" id="pvVendor"></span>
    </div>
    <div class="cockpit__preview-field">
        <span class="cockpit__preview-label">Ship Date</span>
        <span class="cockpit__preview-value" id="pvOrderDate"></span>
    </div>
    <div class="cockpit__preview-field">
        <span class="cockpit__preview-label">Expected Arrival</span>
        <span class="cockpit__preview-value" id="pvReqDate"></span>
    </div>
    <div class="cockpit__preview-field">
        <span class="cockpit__preview-label">Ship To</span>
        <span class="cockpit__preview-value" id="pvShipTo"></span>
    </div>
    <div class="cockpit__preview-field">
        <span class="cockpit__preview-label">Total Qty</span>
        <span class="cockpit__preview-value cockpit__preview-value--mono" id="pvTotal"></span>
    </div>
    <div class="cockpit__preview-field">
        <span class="cockpit__preview-label">Carrier</span>
        <span class="cockpit__preview-value" id="pvCarrier">—</span>
    </div>
    <div class="cockpit__preview-field">
        <span class="cockpit__preview-label">Tracking</span>
        <span class="cockpit__preview-value cockpit__preview-value--mono" id="pvTracking">—</span>
    </div>
    <div class="cockpit__preview-field">
        <span class="cockpit__preview-label">Source PO</span>
        <span class="cockpit__preview-value" id="pvSourcePo">—</span>
    </div>
</div>

<div class="cockpit__preview-lines">
    <div class="cockpit__preview-lines-header">
        <span><i class="fas fa-list-check"></i> Manifest</span>
        <span id="pvLineCount" class="cockpit__queue-count"></span>
    </div>
    <div class="cockpit__preview-table-wrap">
        <table class="line-table">
            <thead>
                <tr>
                    <th class="line-table__th" data-csp-style="width:110px">PART #</th>
                    <th class="line-table__th">DESCRIPTION</th>
                    <th class="line-table__th" data-csp-style="width:45px">UOM</th>
                    <th class="line-table__th line-table__th--right" data-csp-style="width:70px">EXPECTED</th>
                    <th class="line-table__th line-table__th--right" data-csp-style="width:65px">RCVD</th>
                    <th class="line-table__th line-table__th--right" data-csp-style="width:75px">REMAINING</th>
                    <th class="line-table__th" data-csp-style="width:110px">LOT / HEAT</th>
                </tr>
            </thead>
            <tbody id="pvLinesBody"></tbody>
        </table>
    </div>
</div>
