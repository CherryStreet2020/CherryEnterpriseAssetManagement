@page "/Receiving/Cockpit-Legacy"
@*
    Sprint 11 PR #7 — kill-list cutover.
    This page used to claim "/Receiving" via Razor Pages file-name routing.
    PR #7 demotes it to /Receiving/Cockpit-Legacy so the Receiving Control
    Center (Pages/Receiving/ControlCenter.cshtml) becomes the primary
    /Receiving surface per ADR-016 §D2 + §D6.
    The Cockpit stays reachable at the new route for any tooling that
    deep-links to it; a future PR may delete it once those callers move.
*@
@model Abs.FixedAssets.Pages.Receiving.IndexModel
@using System.Text.Json
@{
    ViewData["Title"] = "Receiving";
    ViewData["TabTitle"] = "Receiving Cockpit";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";

    var statusText = Model.PendingReceiptCount > 0 ? $"{Model.PendingReceiptCount} Pending" : "Current";
    var statusTone = Model.PendingReceiptCount > 0 ? "warning" : "success";

    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = "Receiving Cockpit",
        ["Subtitle"] = "Receive goods, track shipments, manage exceptions",
        ["TypeLabel"] = "Warehouse",
        ["StatusText"] = statusText,
        ["StatusTone"] = statusTone,
        ["ContextPartial"] = "/Pages/Receiving/_ReceivingIndexContext.cshtml",
        ["KpisPartial"] = "/Pages/Receiving/_ReceivingIndexKpis.cshtml",
        ["ActionsPartial"] = "/Pages/Receiving/_ReceivingIndexActions.cshtml"
    };

    var overdue = Model.PendingPOs.Where(p => p.RequiredDate.HasValue && p.RequiredDate.Value < DateTime.Today).OrderBy(p => p.RequiredDate).ToList();
    var dueToday = Model.PendingPOs.Where(p => p.RequiredDate.HasValue && p.RequiredDate.Value == DateTime.Today).ToList();
    var dueThisWeek = Model.PendingPOs.Where(p => p.RequiredDate.HasValue && p.RequiredDate.Value > DateTime.Today && p.RequiredDate.Value <= DateTime.Today.AddDays(7)).OrderBy(p => p.RequiredDate).ToList();
    var dueLater = Model.PendingPOs.Where(p => !p.RequiredDate.HasValue || p.RequiredDate.Value > DateTime.Today.AddDays(7)).OrderBy(p => p.RequiredDate).ToList();

    var poDetails = Model.PendingPOs.Select(p => new {
        id = p.Id,
        num = p.PONumber,
        vendor = p.Vendor?.Name ?? "—",
        orderDate = p.OrderDate.ToString("MMM dd, yyyy"),
        requiredDate = p.RequiredDate?.ToString("MMM dd, yyyy") ?? "—",
        status = p.Status.ToString(),
        total = p.Total.ToString("N2"),
        shipTo = p.ShipToSite?.Name ?? "—",
        lines = (p.Lines ?? new List<Models.PurchaseOrderLine>()).Select(l => new {
            partNum = l.PartNumber ?? l.Item?.PartNumber ?? "—",
            desc = l.Description ?? l.Item?.Description ?? "—",
            uom = l.UOM ?? "EA",
            ordered = l.QuantityOrdered,
            received = l.QuantityReceived,
            remaining = l.QuantityOrdered - l.QuantityReceived,
            unitPrice = l.UnitPrice,
            lineTotal = l.QuantityOrdered * l.UnitPrice,
            putaway = new[] { l.Item?.Warehouse, l.Item?.DefaultLocation, l.Item?.Bin }.Where(s => !string.IsNullOrEmpty(s)).ToArray()
        }).ToList()
    }).ToList();
}

<script id="__poDetails" type="application/json">@Html.Raw(JsonSerializer.Serialize(poDetails))</script>

@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@* 2026-05-15: post-receive TempData surfacing. The receive page redirects
   here on a fully-received PO; without these alerts, post-receive warnings
   from financial-posting failures are invisible. *@
@if (TempData["Success"] is string success)
{
    <div class="alert alert-success" data-csp-style="margin-bottom:1rem;">@success</div>
}
@if (TempData["Warning"] is string warning)
{
    <div class="alert alert-warning" data-csp-style="margin-bottom:1rem;">⚠️ @warning</div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger" data-csp-style="margin-bottom:1rem;">@error</div>
}

<div class="cockpit">
    <!-- LEFT PANEL — PO QUEUE -->
    <div class="cockpit__queue">
        <div class="cockpit__queue-header">
            <h3 class="cockpit__queue-title"><i class="fas fa-inbox"></i> PO Queue</h3>
            <span class="cockpit__queue-count">@Model.PendingReceiptCount</span>
        </div>

        <div class="cockpit__search">
            <i class="fas fa-search cockpit__search-icon"></i>
            <input type="text" id="poSearch" class="cockpit__search-input" placeholder="Search PO#, vendor..." oninput="filterQueue(this.value)" autocomplete="off" />
        </div>

        <div class="cockpit__queue-list" id="queueList">
            @if (overdue.Any())
            {
                <div class="cockpit__group" data-group="overdue">
                    <div class="cockpit__group-label cockpit__group-label--danger">
                        <i class="fas fa-exclamation-triangle"></i> Overdue (@overdue.Count)
                    </div>
                    @foreach (var po in overdue) { @await Html.PartialAsync("/Pages/Receiving/_QueueCard.cshtml", po) }
                </div>
            }
            @if (dueToday.Any())
            {
                <div class="cockpit__group" data-group="today">
                    <div class="cockpit__group-label cockpit__group-label--warning">
                        <i class="fas fa-clock"></i> Due Today (@dueToday.Count)
                    </div>
                    @foreach (var po in dueToday) { @await Html.PartialAsync("/Pages/Receiving/_QueueCard.cshtml", po) }
                </div>
            }
            @if (dueThisWeek.Any())
            {
                <div class="cockpit__group" data-group="week">
                    <div class="cockpit__group-label cockpit__group-label--info">
                        <i class="fas fa-calendar-week"></i> This Week (@dueThisWeek.Count)
                    </div>
                    @foreach (var po in dueThisWeek) { @await Html.PartialAsync("/Pages/Receiving/_QueueCard.cshtml", po) }
                </div>
            }
            @if (dueLater.Any())
            {
                <div class="cockpit__group" data-group="later">
                    <div class="cockpit__group-label">
                        <i class="fas fa-calendar-alt"></i> Upcoming (@dueLater.Count)
                    </div>
                    @foreach (var po in dueLater) { @await Html.PartialAsync("/Pages/Receiving/_QueueCard.cshtml", po) }
                </div>
            }
            @if (!Model.PendingPOs.Any())
            {
                <div class="cockpit__empty">
                    <i class="fas fa-check-circle" data-csp-style="font-size:2rem; color:var(--success); margin-bottom:0.5rem;"></i>
                    <div>All caught up!</div>
                </div>
            }
        </div>
    </div>

    <!-- RIGHT PANEL — PO PREVIEW + RECEIVE ACTION -->
    <div class="cockpit__main">
        <div id="mainWelcome" class="cockpit__welcome">
            <div class="cockpit__welcome-icon"><i class="fas fa-box-open"></i></div>
            <h2 class="cockpit__welcome-title">Select a PO to preview</h2>
            <p class="cockpit__welcome-sub">Click a purchase order from the queue to see line details and begin receiving.</p>
            <div class="cockpit__welcome-stats">
                <div class="cockpit__stat">
                    <span class="cockpit__stat-value" data-csp-style="color:var(--status-danger);">@overdue.Count</span>
                    <span class="cockpit__stat-label">Overdue</span>
                </div>
                <div class="cockpit__stat">
                    <span class="cockpit__stat-value" data-csp-style="color:var(--warning);">@dueToday.Count</span>
                    <span class="cockpit__stat-label">Due Today</span>
                </div>
                <div class="cockpit__stat">
                    <span class="cockpit__stat-value">@dueThisWeek.Count</span>
                    <span class="cockpit__stat-label">This Week</span>
                </div>
                <div class="cockpit__stat">
                    <span class="cockpit__stat-value" data-csp-style="color:var(--text-muted);">@dueLater.Count</span>
                    <span class="cockpit__stat-label">Upcoming</span>
                </div>
            </div>
        </div>

        <div id="mainPreview" data-csp-style="display:none; flex:1; flex-direction:column;">
            <div class="cockpit__preview-header">
                <div data-csp-style="display:flex; align-items:center; gap:1rem;">
                    <span class="cockpit__preview-po" id="pvPoNum"></span>
                    <span class="cockpit__preview-status" id="pvStatus"></span>
                </div>
                <a id="pvReceiveBtn" href="#" class="btn-p btn-p--primary">
                    <i class="fas fa-box-open"></i> Receive This PO
                </a>
            </div>

            <div class="cockpit__preview-info">
                <div class="cockpit__preview-field">
                    <span class="cockpit__preview-label">Vendor</span>
                    <span class="cockpit__preview-value" id="pvVendor"></span>
                </div>
                <div class="cockpit__preview-field">
                    <span class="cockpit__preview-label">Order Date</span>
                    <span class="cockpit__preview-value" id="pvOrderDate"></span>
                </div>
                <div class="cockpit__preview-field">
                    <span class="cockpit__preview-label">Required Date</span>
                    <span class="cockpit__preview-value" id="pvReqDate"></span>
                </div>
                <div class="cockpit__preview-field">
                    <span class="cockpit__preview-label">Ship To</span>
                    <span class="cockpit__preview-value" id="pvShipTo"></span>
                </div>
                <div class="cockpit__preview-field">
                    <span class="cockpit__preview-label">Total Value</span>
                    <span class="cockpit__preview-value cockpit__preview-value--mono" id="pvTotal"></span>
                </div>
            </div>

            <div class="cockpit__preview-lines">
                <div class="cockpit__preview-lines-header">
                    <span><i class="fas fa-list"></i> Line Items</span>
                    <span id="pvLineCount" class="cockpit__queue-count"></span>
                </div>
                <div class="cockpit__preview-table-wrap">
                    <table class="line-table">
                        <thead>
                            <tr>
                                <th class="line-table__th" data-csp-style="width:100px">PART #</th>
                                <th class="line-table__th">DESCRIPTION</th>
                                <th class="line-table__th" data-csp-style="width:45px">UOM</th>
                                <th class="line-table__th line-table__th--right" data-csp-style="width:65px">ORDERED</th>
                                <th class="line-table__th line-table__th--right" data-csp-style="width:65px">RCVD</th>
                                <th class="line-table__th line-table__th--right" data-csp-style="width:75px">REMAINING</th>
                                <th class="line-table__th line-table__th--right" data-csp-style="width:85px">VALUE</th>
                                <th class="line-table__th" data-csp-style="width:120px">PUT-AWAY</th>
                            </tr>
                        </thead>
                        <tbody id="pvLinesBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@*
    Sprint 12A PR #2 — Cockpit primitives extract (ADR-018 §D3).
    Inline <style> moved to ~/css/cockpit.css (loaded via _ModernLayout.cshtml).
    Inline <script> moved to ~/js/cockpit.js (exposes window.filterQueue + window.selectPO).
    Markup remains here for this PR; PR #4-#5 lift it into Pages/Shared/Primitives/Cockpit/* partials.
*@

@section Scripts {
    <script src="~/js/cockpit.js" asp-append-version="true"></script>
}
