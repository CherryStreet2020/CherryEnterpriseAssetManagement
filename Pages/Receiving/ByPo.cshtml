@page "/Receiving/By-Po"
@model Abs.FixedAssets.Pages.Receiving.ByPoModel
@{
    ViewData["Title"] = "Receive against PO";
    ViewData["TabTitle"] = "Receive by PO";
    Layout = "_ModernLayout";

    // Sprint 13.6 PR #6 — backport _CockpitPageHeader so the PO-driven receive
    // workflow gains the anchored title bar (LIVE pill + Voice trigger) that
    // Receiving/ControlCenter already uses. The bare ds-receive__head eyebrow
    // is dropped to avoid stacking two title rows. Form body unchanged.
    var poScope = !string.IsNullOrWhiteSpace(Model.Input?.PoNumber)
        ? $"PO #{Model.Input.PoNumber}"
        : (!string.IsNullOrWhiteSpace(Model.PoNumber) ? $"PO #{Model.PoNumber}" : null);
    var pageHeader = new Abs.FixedAssets.Pages.Shared.Primitives.Cockpit.CockpitPageHeaderViewModel
    {
        Title = "Receive against PO",
        Scope = poScope,
        Subtitle = "Scan or type the PO. Idempotency-mediated, state-machine guarded, audit-logged.",
        ShowLive = false,
        ShowVoiceButton = true,
        VoiceButtonLabel = "Voice",
    };
}

@section Scripts {
    <script src="~/js/receiving-scan.js" asp-append-version="true"></script>
}

@await Html.PartialAsync("Primitives/Cockpit/_CockpitPageHeader", pageHeader)

<section class="ds-receive">

    @if (!string.IsNullOrEmpty(Model.FlashOk))
    {
        <div class="ds-flash ds-flash--success" role="status">
            <strong>@Model.FlashOk</strong>
            <span style="margin-left: 12px;">
                <a href="/Receiving/ControlCenter">Back to Control Center</a>
                &nbsp;·&nbsp;
                Continue receiving more lines from this PO below.
            </span>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.FlashError))
    {
        <div class="ds-flash ds-flash--danger" role="alert">
            <strong>Could not record receipt.</strong>
            <span>@Model.FlashError</span>
        </div>
    }

    <form method="post" class="ds-receive__form" data-scan-form="true">
        @Html.AntiForgeryToken()

        <div class="ds-receive__field ds-receive__field--scan">
            <label for="scan-input">Scan barcode</label>
            <input id="scan-input" type="text" placeholder="Scan GS1-128 or DataMatrix — focus me"
                   data-scan-target="auto" autocomplete="off" autofocus />
            <div class="ds-receive__hint">
                Auto-focus on page load. DataWedge keystroke mode supported.
                GS1-128 / DataMatrix application identifiers (01 GTIN, 10 lot, 17 expiry, 21 serial)
                route to the matching field below.
            </div>
        </div>

        <div class="ds-receive__grid">
            <div class="ds-receive__field">
                <label asp-for="Input.PoNumber">PO number</label>
                <input asp-for="Input.PoNumber" required autocomplete="off" data-scan-target="po" />
                <span asp-validation-for="Input.PoNumber"></span>
            </div>
            <div class="ds-receive__field">
                <label asp-for="Input.PoLineId">PO line</label>
                <input asp-for="Input.PoLineId" required autocomplete="off" />
                <span asp-validation-for="Input.PoLineId"></span>
            </div>
            <div class="ds-receive__field">
                <label asp-for="Input.ItemId">Item ID</label>
                <input asp-for="Input.ItemId" type="number" required min="1" />
                <span asp-validation-for="Input.ItemId"></span>
            </div>
            <div class="ds-receive__field">
                <label asp-for="Input.ProfileId">Profile ID</label>
                <input asp-for="Input.ProfileId" type="number" min="1" />
                <span asp-validation-for="Input.ProfileId"></span>
            </div>
            <div class="ds-receive__field">
                <label asp-for="Input.LotNumber">Lot / heat</label>
                <input asp-for="Input.LotNumber" autocomplete="off" data-scan-target="lot" />
                <span asp-validation-for="Input.LotNumber"></span>
            </div>
            <div class="ds-receive__field">
                <label asp-for="Input.SerialNumber">Serial</label>
                <input asp-for="Input.SerialNumber" autocomplete="off" data-scan-target="serial" />
                <span asp-validation-for="Input.SerialNumber"></span>
            </div>
            <div class="ds-receive__field">
                <label asp-for="Input.QuantityReceived">Quantity received</label>
                <input asp-for="Input.QuantityReceived" type="number" step="0.0001" min="0.0001" required />
                <span asp-validation-for="Input.QuantityReceived"></span>
            </div>
            <div class="ds-receive__field">
                <label asp-for="Input.Uom">UoM</label>
                <input asp-for="Input.Uom" placeholder="ea / kg / L" maxlength="16" />
                <span asp-validation-for="Input.Uom"></span>
            </div>
            <div class="ds-receive__field">
                <label asp-for="Input.LocationId">Location ID</label>
                <input asp-for="Input.LocationId" type="number" min="1" />
                <span asp-validation-for="Input.LocationId"></span>
            </div>
        </div>

        <div class="ds-receive__field">
            <label asp-for="Input.Attributes">Profile-specific attributes (JSON)</label>
            <textarea asp-for="Input.Attributes" rows="4"
                placeholder='{ "heatNumber": "H-12345", "mill": "ACME Steel" }'></textarea>
            <div class="ds-receive__hint">
                Validated against the active <code>ReceiptProfile</code>'s JSON Schema
                at the service layer (ADR-015 D3). Leave blank if your profile has no required attributes.
            </div>
        </div>

        <div class="ds-receive__field">
            <label asp-for="Input.Notes">Notes</label>
            <textarea asp-for="Input.Notes" rows="2"></textarea>
        </div>

        <div class="ds-receive__actions">
            <a href="/Receiving/ControlCenter" class="ds-btn ds-btn--ghost ds-btn--md">Cancel</a>
            <button type="submit" class="ds-btn ds-btn--primary ds-btn--md">Receive</button>
        </div>
    </form>
</section>

