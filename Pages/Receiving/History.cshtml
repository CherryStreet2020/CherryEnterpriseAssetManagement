@page
@model Abs.FixedAssets.Pages.Receiving.HistoryModel
@{
    ViewData["Title"] = "Receipt History";
    ViewData["TabTitle"] = "Receipt History";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";

    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = "Receipt History",
        ["Subtitle"] = "Browse and search goods receipts",
        ["TypeLabel"] = "Purchasing",
        ["StatusText"] = $"{Model.TotalCount} Receipts",
        ["StatusTone"] = "info",
        ["Breadcrumbs"] = new (string, string)[] { ("Materials", "/Purchasing"), ("Receiving", "/Receiving"), ("History", "") },
        ["ShowBackLink"] = true,
        ["BackLinkFallback"] = "/Receiving",
        ["BackLinkLabel"] = "Back to Receiving"
    };
}

@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

<!-- FILTERS -->
<div class="pe-card" style="margin-bottom:1rem;">
    <div class="pe-card__header">
        <span class="pe-card__title"><span class="accent-dot accent-dot--blue"></span> Filters</span>
    </div>
    <div class="pe-card__body">
        <form method="get" id="filterForm">
            <div class="form-grid form-grid--4" style="margin-bottom:0.75rem;">
                <div class="form-group-p">
                    <label class="form-label-p">Date From</label>
                    <input type="date" name="dateFrom" class="form-input-p" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="form-group-p">
                    <label class="form-label-p">Date To</label>
                    <input type="date" name="dateTo" class="form-input-p" value="@Model.DateTo?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="form-group-p">
                    <label class="form-label-p">Vendor</label>
                    <input type="text" name="vendorSearch" class="form-input-p" placeholder="Search vendor..." value="@Model.VendorSearch" />
                </div>
                <div class="form-group-p">
                    <label class="form-label-p">Status</label>
                    <select name="statusFilter" class="form-input-p">
                        <option value="">All Statuses</option>
                        <option value="1" selected="@(Model.StatusFilter == 1)">Received</option>
                        <option value="2" selected="@(Model.StatusFilter == 2)">Partially Received</option>
                        <option value="3" selected="@(Model.StatusFilter == 3)">Inspecting</option>
                        <option value="4" selected="@(Model.StatusFilter == 4)">Accepted</option>
                        <option value="5" selected="@(Model.StatusFilter == 5)">Rejected</option>
                    </select>
                </div>
            </div>
            <div class="form-grid form-grid--4">
                <div class="form-group-p">
                    <label class="form-label-p">PO Number</label>
                    <input type="text" name="poSearch" class="form-input-p" placeholder="PO-..." value="@Model.POSearch" />
                </div>
                <div class="form-group-p">
                    <label class="form-label-p">Receipt Number</label>
                    <input type="text" name="receiptSearch" class="form-input-p" placeholder="GR-..." value="@Model.ReceiptSearch" />
                </div>
                <div class="form-group-p" style="display:flex; align-items:flex-end; gap:0.5rem;">
                    <button type="submit" class="btn-p btn-p--primary btn-p--sm">
                        <i class="fas fa-search"></i> Search
                    </button>
                    <a href="/Receiving/History" class="btn-p btn-p--ghost btn-p--sm">Clear</a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- RESULTS -->
<div class="line-section">
    <div class="line-section__header">
        <h3 class="line-section__title">
            <i class="fas fa-clipboard-check"></i> Receipts
        </h3>
        <div class="line-section__summary">
            <span class="line-section__count">@Model.TotalCount found</span>
        </div>
    </div>

    <div class="line-section__body">
        @if (Model.Receipts.Any())
        {
            <table class="line-table">
                <thead>
                    <tr>
                        <th class="line-table__th" style="width:130px">RECEIPT #</th>
                        <th class="line-table__th" style="width:120px">PO #</th>
                        <th class="line-table__th">VENDOR</th>
                        <th class="line-table__th" style="width:100px">DATE</th>
                        <th class="line-table__th" style="width:100px">RECEIVED BY</th>
                        <th class="line-table__th line-table__th--right" style="width:50px">LINES</th>
                        <th class="line-table__th line-table__th--right" style="width:110px">VALUE</th>
                        <th class="line-table__th" style="width:120px">STATUS</th>
                        <th class="line-table__th" style="width:80px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var gr in Model.Receipts)
                    {
                        var grValue = gr.Lines.Sum(l => l.QuantityAccepted * (l.PurchaseOrderLine?.UnitPrice ?? 0));
                        var statusClass = gr.Status switch {
                            Models.ReceiptStatus.Received => "status-badge-p--info",
                            Models.ReceiptStatus.Accepted => "status-badge-p--approved",
                            Models.ReceiptStatus.Rejected => "status-badge-p--danger",
                            Models.ReceiptStatus.Inspecting => "status-badge-p--pending",
                            _ => "status-badge-p--draft"
                        };
                        <tr class="line-table__row">
                            <td class="line-table__td line-table__td--primary" style="font-weight:600;">@gr.ReceiptNumber</td>
                            <td class="line-table__td line-table__td--mono">
                                <a href="/Purchasing/Details/@gr.PurchaseOrderId" style="color:var(--cherry-red, #cf3339); text-decoration:none;">@(gr.PurchaseOrder?.PONumber ?? "—")</a>
                            </td>
                            <td class="line-table__td">@(gr.PurchaseOrder?.Vendor?.Name ?? "—")</td>
                            <td class="line-table__td line-table__td--muted">@gr.ReceiptDate.ToString("MM/dd/yyyy")</td>
                            <td class="line-table__td line-table__td--muted">@(gr.ReceivedBy ?? "—")</td>
                            <td class="line-table__td line-table__td--right line-table__td--mono">@gr.Lines.Count</td>
                            <td class="line-table__td line-table__td--right line-table__td--mono line-table__td--bold">@grValue.ToString("N2")</td>
                            <td class="line-table__td"><span class="status-badge-p @statusClass" style="font-size:0.65rem;">@gr.Status</span></td>
                            <td class="line-table__td line-table__td--actions">
                                <a href="/Receiving/Details/@gr.Id" class="btn-p btn-p--ghost btn-p--sm">
                                    <i class="fas fa-eye"></i> View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="line-section__empty">
                No receipts found matching your criteria.
            </div>
        }
    </div>
</div>
