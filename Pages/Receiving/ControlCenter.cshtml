@page "/Receiving"
@model Abs.FixedAssets.Pages.Receiving.ControlCenterModel
@{
    ViewData["Title"] = "Receiving Control Center";
    ViewData["TabTitle"] = "Receiving";
    Layout = "_ModernLayout";
}

@*
    Sprint 12A PR #4 — /Receiving is now the four-tab Cockpit shell per ADR-018 §D2.

    Tabs (in order, default = PO Queue):
      - po-queue   : Cockpit canvas (real wiring lands PR #5 — placeholder for now)
      - asn-queue  : Cockpit canvas (real wiring lands PR #6 — placeholder)
      - orphans    : Cockpit canvas (real wiring lands PR #7 — placeholder)
      - exceptions : Sprint 11 four-quadrant scaffold via _ControlCenterShell

    Tab state is in the URL via ?tab=<key>. Tab keyboard nav lives in cockpit.js.
    Voice context (BuildContextPayload) emits the active tab so commands like
    "show me overdue receipts" target the right canvas.
*@

@await Html.PartialAsync("Primitives/Cockpit/_CockpitTabShell", Model.TabShell)

@switch (Model.ActiveTab)
{
    case Abs.FixedAssets.Pages.Receiving.ControlCenterModel.TabExceptions:
        @await Html.PartialAsync("_ControlCenterShell", Model.Shell)
        break;

    case Abs.FixedAssets.Pages.Receiving.ControlCenterModel.TabAsnQueue:
        <div class="cockpit-tab-placeholder" role="tabpanel" aria-labelledby="tab-asn-queue">
            <i class="fas fa-truck-fast cockpit-tab-placeholder__icon" aria-hidden="true"></i>
            <h2 class="cockpit-tab-placeholder__title">ASN Queue &mdash; coming Sprint 12A PR #6</h2>
            <p class="cockpit-tab-placeholder__sub">
                ASNs grouped by ETA window with a click-to-preview pane on the right.
                Same Cockpit primitives the PO Queue tab uses, keyed on ASN ETAs and
                expected items. Receive by ASN scan from the preview pane.
            </p>
            <span class="cockpit-tab-placeholder__chip">SOON &middot; SPRINT 12A</span>
        </div>
        break;

    case Abs.FixedAssets.Pages.Receiving.ControlCenterModel.TabOrphans:
        <div class="cockpit-tab-placeholder" role="tabpanel" aria-labelledby="tab-orphans">
            <i class="fas fa-question-circle cockpit-tab-placeholder__icon" aria-hidden="true"></i>
            <h2 class="cockpit-tab-placeholder__title">Orphans &mdash; coming Sprint 12A PR #7</h2>
            <p class="cockpit-tab-placeholder__sub">
                Unmatched receipts with AI-suggested PO matches in a dedicated column.
                One-click resolve via the preview pane &mdash; MatchOrphanReceipt is
                already wired up server-side (Sprint 11 PR #4).
            </p>
            <span class="cockpit-tab-placeholder__chip">SOON &middot; SPRINT 12A</span>
        </div>
        break;

    default:
        @* TabPoQueue is the default. Real wiring lands PR #5
           (IReceivingControlCenterService.GetPoQueueAsync +
           PoQueueRow : ICockpitQueueRow). Legacy /Receiving/Cockpit-Legacy
           remains the operator's daily driver until then. *@
        <div class="cockpit-tab-placeholder" role="tabpanel" aria-labelledby="tab-po-queue">
            <i class="fas fa-file-invoice cockpit-tab-placeholder__icon" aria-hidden="true"></i>
            <h2 class="cockpit-tab-placeholder__title">PO Queue &mdash; coming Sprint 12A PR #5</h2>
            <p class="cockpit-tab-placeholder__sub">
                Time-bucketed PO queue (Overdue / Today / This Week / Later) with a
                click-to-preview pane on the right &mdash; the daily-driver canvas.
                Will render pixel-identical to <a href="/Receiving/Cockpit-Legacy">/Receiving/Cockpit-Legacy</a>.
            </p>
            <a class="cockpit-tab-placeholder__chip" href="/Receiving/Cockpit-Legacy" style="text-decoration: none;">USE COCKPIT (LEGACY)</a>
        </div>
        break;
}
