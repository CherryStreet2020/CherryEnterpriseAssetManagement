@page "/Receiving/Blind"
@model Abs.FixedAssets.Pages.Receiving.BlindModel
@{
    ViewData["Title"] = "Blind receive";
    ViewData["TabTitle"] = "Blind receive";
    Layout = "_ModernLayout";
}

@section Scripts {
    <script src="~/js/receiving-scan.js" asp-append-version="true"></script>
}

<section class="ds-receive">
    <header class="ds-receive__head">
        <div class="ds-receive__eyebrow">RECEIVING · BLIND (5% workflow)</div>
        <h1 class="ds-receive__title">Blind receive — no PO, no ASN</h1>
        <p class="ds-receive__subtitle">
            Freight arrived without paperwork. Record what's on the dock now;
            the AI <code>MatchOrphanReceiptAsync</code> tool will attach a candidate PO
            when one is identified.
        </p>
    </header>

    @if (!string.IsNullOrEmpty(Model.FlashOk))
    {
        <div class="ds-flash ds-flash--success" role="status">
            <strong>@Model.FlashOk</strong>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.FlashError))
    {
        <div class="ds-flash ds-flash--danger" role="alert">
            <strong>Could not record receipt.</strong>
            <span>@Model.FlashError</span>
        </div>
    }

    <form method="post" class="ds-receive__form" data-scan-form="true">
        @Html.AntiForgeryToken()

        <div class="ds-receive__field ds-receive__field--scan">
            <label for="scan-input">Scan barcode</label>
            <input id="scan-input" type="text" placeholder="Scan GTIN / DataMatrix"
                   data-scan-target="auto" autocomplete="off" autofocus />
            <div class="ds-receive__hint">
                Scanned GTIN (AI 01) and lot (AI 10) populate the Item ID / Lot fields below.
            </div>
        </div>

        <div class="ds-receive__grid">
            <div class="ds-receive__field">
                <label asp-for="Input.VendorId">Vendor ID (best guess)</label>
                <input asp-for="Input.VendorId" type="number" min="1" />
                <span asp-validation-for="Input.VendorId"></span>
            </div>
            <div class="ds-receive__field">
                <label asp-for="Input.ItemId">Item ID</label>
                <input asp-for="Input.ItemId" type="number" min="1" required />
                <span asp-validation-for="Input.ItemId"></span>
            </div>
            <div class="ds-receive__field">
                <label asp-for="Input.ProfileId">Profile ID</label>
                <input asp-for="Input.ProfileId" type="number" min="1" />
                <span asp-validation-for="Input.ProfileId"></span>
            </div>
            <div class="ds-receive__field">
                <label asp-for="Input.QuantityReceived">Quantity</label>
                <input asp-for="Input.QuantityReceived" type="number" step="0.0001" min="0.0001" required />
                <span asp-validation-for="Input.QuantityReceived"></span>
            </div>
            <div class="ds-receive__field">
                <label asp-for="Input.Uom">UoM</label>
                <input asp-for="Input.Uom" placeholder="ea / kg / L" maxlength="16" />
                <span asp-validation-for="Input.Uom"></span>
            </div>
            <div class="ds-receive__field">
                <label asp-for="Input.LocationId">Location ID</label>
                <input asp-for="Input.LocationId" type="number" min="1" />
                <span asp-validation-for="Input.LocationId"></span>
            </div>
        </div>

        <div class="ds-receive__field">
            <label asp-for="Input.Attributes">Profile-specific attributes (JSON)</label>
            <textarea asp-for="Input.Attributes" rows="3" placeholder='{ "heatNumber": "?", "mill": "?" }'></textarea>
        </div>

        <div class="ds-receive__field">
            <label asp-for="Input.Notes">Notes</label>
            <textarea asp-for="Input.Notes" rows="2" placeholder="What was on the BOL? Carrier name? Where did it land?"></textarea>
        </div>

        <div class="ds-receive__actions">
            <a href="/Receiving/ControlCenter" class="ds-btn ds-btn--ghost ds-btn--md">Cancel</a>
            <button type="submit" class="ds-btn ds-btn--primary ds-btn--md">Create orphan receipt</button>
        </div>
    </form>
</section>
