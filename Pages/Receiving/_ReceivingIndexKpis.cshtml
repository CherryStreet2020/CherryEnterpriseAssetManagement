@model Abs.FixedAssets.Pages.Receiving.IndexModel
<div class="kpi-card">
    <div class="kpi-label">Pending</div>
    <div class="kpi-value warning">@Model.PendingReceiptCount</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Today</div>
    <div class="kpi-value success">@Model.ReceivedTodayCount</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">This Week</div>
    <div class="kpi-value">@Model.ReceivedThisWeekCount</div>
</div>
<div class="kpi-card">
    <div class="kpi-label">Overdue</div>
    <div class="kpi-value @(Model.OverdueCount > 0 ? "danger" : "")">@Model.OverdueCount</div>
</div>
