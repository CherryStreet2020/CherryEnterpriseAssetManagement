@page "/Receiving/By-Asn/{AsnId?}"
@model Abs.FixedAssets.Pages.Receiving.ByAsnModel
@{
    ViewData["Title"] = "Receive by ASN";
    ViewData["TabTitle"] = "Receive by ASN";
    Layout = "_ModernLayout";
}

@section Scripts {
    <script src="~/js/receiving-scan.js" asp-append-version="true"></script>
}

<section class="ds-receive">
    <header class="ds-receive__head">
        <div class="ds-receive__eyebrow">RECEIVING · ASN-DRIVEN (10% workflow)</div>
        <h1 class="ds-receive__title">Receive against an ASN</h1>
        <p class="ds-receive__subtitle">
            EDI 856 declares lines in advance. Scan the ASN barcode, confirm
            the line, accept or override the declared quantity.
            Real EDI 856 parser ships in a future sprint — PR #6 wires the
            service path and persists each receipt with an <code>ASN:</code> prefix.
        </p>
    </header>

    @if (!string.IsNullOrEmpty(Model.FlashOk))
    {
        <div class="ds-flash ds-flash--success" role="status">
            <strong>@Model.FlashOk</strong>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.FlashError))
    {
        <div class="ds-flash ds-flash--danger" role="alert">
            <strong>Could not record receipt.</strong>
            <span>@Model.FlashError</span>
        </div>
    }

    <form method="post" class="ds-receive__form" data-scan-form="true">
        @Html.AntiForgeryToken()

        <div class="ds-receive__field ds-receive__field--scan">
            <label for="scan-input">Scan ASN barcode</label>
            <input id="scan-input" type="text" placeholder="Scan the ASN label"
                   data-scan-target="asn" autocomplete="off" autofocus />
            <div class="ds-receive__hint">
                Scanned ASN ID lands in the field below.
            </div>
        </div>

        <div class="ds-receive__grid">
            <div class="ds-receive__field">
                <label asp-for="Input.AsnId">ASN ID</label>
                <input asp-for="Input.AsnId" required autocomplete="off" />
                <span asp-validation-for="Input.AsnId"></span>
            </div>
            <div class="ds-receive__field">
                <label asp-for="Input.LineId">Line ID</label>
                <input asp-for="Input.LineId" autocomplete="off" />
                <span asp-validation-for="Input.LineId"></span>
            </div>
            <div class="ds-receive__field">
                <label asp-for="Input.OverrideQuantity">Override quantity (optional)</label>
                <input asp-for="Input.OverrideQuantity" type="number" step="0.0001" min="0" />
                <span asp-validation-for="Input.OverrideQuantity"></span>
            </div>
        </div>

        <div class="ds-receive__field">
            <label asp-for="Input.Notes">Notes</label>
            <textarea asp-for="Input.Notes" rows="2" placeholder="Discrepancies vs ASN, damage, etc."></textarea>
        </div>

        <div class="ds-receive__actions">
            <a href="/Receiving/ControlCenter" class="ds-btn ds-btn--ghost ds-btn--md">Cancel</a>
            <button type="submit" class="ds-btn ds-btn--primary ds-btn--md">Receive line</button>
        </div>
    </form>
</section>
