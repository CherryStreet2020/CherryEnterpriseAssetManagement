                    </div>
                </div>

                <div class="menu-group @(IsAny("/AI", "/API") || IsPage("/Admin/Webhooks") || IsPage("/Admin/Integrations") ? "expanded" : "")" data-section="ai-integrations">
                    <div class="menu-group-header" data-tooltip="AI & Integrations" role="button" tabindex="0" aria-expanded="false">
                        <span class="menu-group-icon"><i class="fas fa-robot"></i></span>
                        <span class="menu-group-title">AI & Integrations</span>
                        <span class="menu-group-arrow"><i class="fas fa-chevron-down"></i></span>
                    </div>
                    <div class="menu-items">
                        <a href="/AI" class="menu-item @(IsPage("/AI") ? "active" : "")" data-nav-route="/AI">
                            <i class="fas fa-brain menu-item-icon"></i>
                            <span>AI Assistant</span>
                        </a>
                        <a href="/API" class="menu-item @(IsPage("/API") ? "active" : "")" data-nav-route="/API">
                            <i class="fas fa-code menu-item-icon"></i>
                            <span>API Hub</span>
                        </a>
                        <a href="/Admin/Webhooks" class="menu-item @(IsPage("/Admin/Webhooks") ? "active" : "")" data-nav-route="/Admin/Webhooks">
                            <i class="fas fa-satellite-dish menu-item-icon"></i>
                            <span>Webhooks</span>
                        </a>
                        <a href="/Admin/Webhooks/Deliveries" class="menu-item @(IsPage("/Admin/Webhooks/Deliveries") ? "active" : "")" data-nav-route="/Admin/Webhooks/Deliveries">
                            <i class="fas fa-paper-plane menu-item-icon"></i>
                            <span>Webhook Deliveries</span>
                        </a>
                        <a href="/Admin/Webhooks/Catalog" class="menu-item @(IsPage("/Admin/Webhooks/Catalog") ? "active" : "")" data-nav-route="/Admin/Webhooks/Catalog">
                            <i class="fas fa-book-open menu-item-icon"></i>
                            <span>Event Catalog</span>
                        </a>
                        <a href="/Admin/Outbox" class="menu-item @(IsPage("/Admin/Outbox/Index") ? "active" : "")" data-nav-route="/Admin/Outbox">
                            <i class="fas fa-inbox menu-item-icon"></i>
                            <span>Outbox</span>
                        </a>
                        <a href="/Admin/Integrations" class="menu-item @(IsPage("/Admin/Integrations") ? "active" : "")" data-nav-route="/Admin/Integrations">
                            <i class="fas fa-plug menu-item-icon"></i>
                            <span>Integration Hub</span>
                        </a>
                    </div>
                </div>
                
                <div class="nav-section-label">SYSTEM</div>
                
                @if (isAdmin)
                {
                <div class="menu-group @(IsPage("/Admin") && !IsPage("/Admin/Locations") && !IsPage("/Admin/Vendors") && !IsPage("/Admin/PMTemplate") && !IsPage("/Admin/Technicians") && !IsPage("/Admin/Requisitions") && !IsPage("/Admin/Kits") && !IsPage("/Admin/StockLevels") && !IsPage("/Admin/ItemCategories") && !IsPage("/Admin/AssetCategories") && !IsPage("/Admin/Barcodes") && !IsPage("/Admin/Webhooks") && !IsPage("/Admin/Integrations") ? "expanded" : "")" data-section="admin">
                    <div class="menu-group-header" data-tooltip="Administration" role="button" tabindex="0" aria-expanded="false">
                        <span class="menu-group-icon"><i class="fas fa-gear"></i></span>
                        <span class="menu-group-title">Administration</span>
                        <span class="menu-group-arrow"><i class="fas fa-chevron-down"></i></span>
                    </div>
                    <div class="menu-items">
                        <a href="/Admin/Sites" class="menu-item @(IsAny("/Admin/Sites") ? "active" : "")" data-nav-route="/Admin/Sites">
                            <i class="fas fa-sitemap menu-item-icon"></i>
                            <span>Organization & Sites</span>
                        </a>
                        <a href="/Admin/Companies" class="menu-item @(IsPage("/Admin/Companies") || IsPage("/Admin/Company") ? "active" : "")" data-nav-route="/Admin/Companies">
                            <i class="fas fa-building menu-item-icon"></i>
                            <span>Companies</span>
                        </a>
                        <a href="/Admin/Departments" class="menu-item @(IsPage("/Admin/Departments") ? "active" : "")" data-nav-route="/Admin/Departments">
                            <i class="fas fa-people-group menu-item-icon"></i>
                            <span>Departments</span>
                        </a>
                        <a href="/Admin/CostCenters" class="menu-item @(IsPage("/Admin/CostCenters") ? "active" : "")" data-nav-route="/Admin/CostCenters">
                            <i class="fas fa-bullseye menu-item-icon"></i>
                            <span>Cost Centers</span>
                        </a>
                        <a href="/Admin/Users" class="menu-item @(IsPage("/Admin/Users") ? "active" : "")" data-nav-route="/Admin/Users">
                            <i class="fas fa-users menu-item-icon"></i>
                            <span>Users & Roles</span>
                        </a>
                        <a href="/Admin/Lookups" class="menu-item @(IsPage("/Admin/Lookups") ? "active" : "")" data-nav-route="/Admin/Lookups">
                            <i class="fas fa-table-list menu-item-icon"></i>
                            <span>Lookups</span>
                        </a>
                        <a href="/Admin/SystemSettings" class="menu-item @(IsPage("/Admin/SystemSettings") ? "active" : "")" data-nav-route="/Admin/SystemSettings">
                            <i class="fas fa-cogs menu-item-icon"></i>
                            <span>System Settings</span>
                        </a>
                        <a href="/Admin/FiscalCalendar" class="menu-item @(IsPage("/Admin/FiscalCalendar") ? "active" : "")" data-nav-route="/Admin/FiscalCalendar">
                            <i class="fas fa-calendar-days menu-item-icon"></i>
                            <span>Fiscal Calendar</span>
                        </a>
                        <a href="/Admin/DataManagement" class="menu-item @(IsPage("/Admin/DataManagement") ? "active" : "")" data-nav-route="/Admin/DataManagement">
                            <i class="fas fa-database menu-item-icon"></i>
                            <span>Data Management</span>
                        </a>
                        <a href="/Admin/AuditLog" class="menu-item @(IsPage("/Admin/AuditLog") ? "active" : "")" data-nav-route="/Admin/AuditLog">
                            <i class="fas fa-clipboard-check menu-item-icon"></i>
                            <span>Audit Log</span>
                        </a>
                        <a href="/Admin/Manufacturers" class="menu-item @(IsPage("/Admin/Manufacturers") ? "active" : "")" data-nav-route="/Admin/Manufacturers">
                            <i class="fas fa-industry menu-item-icon"></i>
                            <span>Manufacturers</span>
                        </a>
                        <a href="/Admin/ProjectManagers" class="menu-item @(IsPage("/Admin/ProjectManagers") ? "active" : "")" data-nav-route="/Admin/ProjectManagers">
                            <i class="fas fa-user-tie menu-item-icon"></i>
                            <span>Project Managers</span>
                        </a>
                    </div>
                </div>
                }
                
                <div id="recentNavSection" class="recent-nav-section" data-csp-style="display:none;">
                    <div class="nav-section-label">RECENT</div>
                    <div id="recentNavList" class="recent-nav-list"></div>
                </div>
            </nav>
            
            <div class="sidebar-footer">
                <a href="/Help" class="nav-item @(IsPage("/Help") ? "active" : "")" data-nav-route="/Help">
                    <span class="nav-item-icon"><i class="fas fa-circle-question"></i></span>
                    <span class="nav-item-label">Help Center</span>
                </a>
                @if (!isAuthenticated)
                {
                <a href="/Account/Login" class="nav-item nav-item-signin @(IsPage("/Account/Login") ? "active" : "")" data-nav-route="/Account/Login">
                    <span class="nav-item-icon"><i class="fas fa-right-to-bracket"></i></span>
                    <span class="nav-item-label">Sign In</span>
                </a>
                }
                @if (isAuthenticated)
                {
                <div class="sidebar-user-info">
                    <div class="sidebar-user-avatar">@User.Identity?.Name?.Substring(0, 1).ToUpper()</div>
                    <div class="sidebar-user-details">
                        <span class="sidebar-user-name">@(User.FindFirst("FullName")?.Value ?? User.Identity?.Name)</span>
                        <span class="sidebar-user-role">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
                    </div>
                </div>
                }
            </div>
        </aside>
        
        <main class="main-content" id="mainContent">
            <header class="main-header" id="mainHeader">
                <button class="mobile-menu-btn" id="mobileMenuBtn" type="button" aria-label="Open menu">
                    <i class="fas fa-bars"></i>
                </button>
                @{
                    var hasScreenHeader = ViewData["HasScreenHeader"] as bool? ?? false;
                    var hideDefaultPageHeader = ViewData["HideDefaultPageHeader"] as bool? ?? false;
                }
                @if (!hasScreenHeader && !hideDefaultPageHeader)
                {
                    <h1 class="header-title">@ViewData["Title"]</h1>
                }
                @if (ViewData["Breadcrumb"] != null)
                {
                    <span class="header-breadcrumb">@ViewData["Breadcrumb"]</span>
                }
                
                <div class="header-actions">
                    <div class="global-search-wrapper">
                        <i class="fas fa-search global-search-icon"></i>
                        <input type="text" id="globalSearchInput" class="global-search-input" placeholder="Search..." autocomplete="off" />
                        <kbd class="global-search-kbd">/</kbd>
                    </div>
                    <button class="cmd-palette-trigger" id="cmdPaletteTrigger" type="button" title="Command palette (Ctrl+K)">
                        <i class="fas fa-terminal"></i>
                        <kbd>Ctrl+K</kbd>
                    </button>
                    <button class="theme-toggle-btn" id="themeToggleBtn" type="button" title="Toggle dark/light mode" aria-label="Toggle dark/light mode" aria-pressed="false">
                        <i class="fas fa-moon"></i>
                    </button>
                    @{
                        var helpTopic = currentPage switch
                        {
                            var p when p.StartsWith("/Index") || p == "/" => "dashboard",
                            var p when p.StartsWith("/Assets") => "assets",
                            var p when p.StartsWith("/Books") => "books",
                            var p when p.StartsWith("/Journals") => "journals",
                            var p when p.StartsWith("/CCA") => "cca",
                            var p when p.StartsWith("/Reports") => "reports",
                            var p when p.StartsWith("/Maintenance") => "maintenance",
                            var p when p.StartsWith("/CIP") => "cip",
                            var p when p.StartsWith("/Inventory") => "inventory",
                            var p when p.StartsWith("/AI") => "ai-assistant",
                            var p when p.StartsWith("/Depreciation") => "depreciation",
                            var p when p.StartsWith("/Admin/Company") => "company-settings",
                            var p when p.StartsWith("/Admin/Users") => "admin",
                            var p when p.StartsWith("/Admin") => "admin",
                            _ => ""
                        };
                    }
                    @if (!string.IsNullOrEmpty(helpTopic))
                    {
                        <a href="/Help/Topic?id=@helpTopic" class="btn-p btn-p--secondary btn-p--sm header-help-btn" title="Get help for this page">
                            <i class="fas fa-circle-question"></i>
                        </a>
                    }
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="user-dropdown">
                            <button class="user-btn" onclick="toggleUserMenu()" type="button">
                                <div class="user-avatar">@User.Identity.Name?.Substring(0, 1).ToUpper()</div>
                            </button>
                            <div class="user-menu" id="userMenu" data-csp-style="display: none;">
                                <div class="user-menu-header">
                                    <strong>@(User.FindFirst("FullName")?.Value ?? User.Identity.Name)</strong>
                                    <span>@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
                                </div>
                                <a asp-page="/Account/Logout" class="user-menu-item">
                                    <i class="fas fa-right-from-bracket"></i>
                                    Sign Out
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </header>
            
            <div class="page-content">
                @RenderBody()
            </div>
            
            <footer class="app-footer">
                <div data-csp-style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px;">
                    <p data-csp-style="margin: 0;">&copy; 2026 ABS Machining EAM, powered by <a href="https://cherrystreetconsulting.com" data-csp-style="color: var(--text-muted); text-decoration: none;">CherryAI</a> &mdash; a division of Cherry Street Consulting, New York, NY. All Rights Reserved.</p>
                </div>
            </footer>
        </main>
    </div>
    
    <div id="commandPaletteOverlay" class="command-palette-overlay" data-csp-style="display:none;">
        <div class="command-palette" aria-label="Command palette">
            <div class="command-palette-header">
                <i class="fas fa-search command-palette-search-icon"></i>
                <input type="text" id="commandPaletteInput" class="command-palette-input" placeholder="Type a command or page name..." autocomplete="off" autofocus />
                <kbd class="command-palette-esc">Esc</kbd>
            </div>
            <div class="command-palette-results" id="commandPaletteResults"></div>
            <div class="command-palette-footer">
                <span><kbd>&uarr;</kbd><kbd>&darr;</kbd> Navigate</span>
                <span><kbd>Enter</kbd> Open</span>
                <span><kbd>Esc</kbd> Close</span>
            </div>
        </div>
    </div>
    
    <div id="helpPanel" class="help-panel" data-csp-style="display: none;">
        <div class="help-panel-content">
            <div class="help-panel-header">
                <h2>Help & Support</h2>
                <button onclick="toggleHelp()" class="btn-close">&times;</button>
            </div>
            <div class="help-panel-body">
                <div class="help-section">
                    <h3>Getting Started</h3>
                    <p>Welcome to ABS Machining EAM. Use the sidebar to navigate between different sections.</p>
                </div>
                <div class="help-section">
                    <h3>Keyboard Shortcuts</h3>
                    <ul>
                        <li><kbd>/</kbd> — Focus global search</li>
                        <li><kbd>Ctrl+K</kbd> — Open command palette</li>
                        <li><kbd>Esc</kbd> — Close panel / clear search</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
    
    <script>
        function toggleHelp() {
            const panel = document.getElementById('helpPanel');
            panel.style.display = panel.style.display === 'none' ? 'flex' : 'none';
        }
        function toggleUserMenu() {
            const menu = document.getElementById('userMenu');
            menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
        }
        document.addEventListener('click', function(e) {
            const dropdown = document.querySelector('.user-dropdown');
            const menu = document.getElementById('userMenu');
            if (dropdown && menu && !dropdown.contains(e.target)) {
                menu.style.display = 'none';
            }
        });
    </script>
    
    <script src="~/js/csp-bootstrap.js" asp-append-version="true"></script>
    <script src="~/js/enhanced-grid.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/modal.js" asp-append-version="true"></script>
    <script src="~/js/tour.js" asp-append-version="true"></script>
    <script src="~/js/sidebar-nav.js" asp-append-version="true"></script>
    <script src="~/js/scroll-restore.js" asp-append-version="true"></script>
    <script src="~/js/org-selector.js" asp-append-version="true"></script>
    <script src="~/js/site-selector.js" asp-append-version="true"></script>
    <script src="~/js/tabs.js" asp-append-version="true"></script>
    <script src="~/js/command-palette.js" asp-append-version="true"></script>
    <script src="~/js/recent-nav.js" asp-append-version="true"></script>
    <script src="~/js/return-path.js" asp-append-version="true"></script>
    <script src="~/js/theme-toggle.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js" integrity="sha384-cnROoUgVILyibe3J0zhzWoJ9p2WmdnK7j/BOTSWqVDbC1pVw2d+i6Q/1ESKJKCYf" crossorigin="anonymous"></script>
    <script src="~/js/cherry-typeahead.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
