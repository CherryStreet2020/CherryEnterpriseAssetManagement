@* _ModernLayout.cshtml — Modern Navigation Overhaul: grouped sidebar IA, command palette, search stub *@
@inject Abs.FixedAssets.Data.AppDbContext DbContext
@inject Abs.FixedAssets.Services.ISeedGuardService SeedGuard
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@using System.Security.Claims
@{
    var appEnv = Environment.GetEnvironmentVariable("APP_ENVIRONMENT");
    var envProfile = !string.IsNullOrEmpty(appEnv) ? appEnv.ToUpper() : SeedGuard.GetEnvironmentProfile();
    var isDefaultedEnv = string.IsNullOrEmpty(appEnv);
    var envBannerClass = envProfile.Contains("LAB") ? "env-banner-lab" : 
                         envProfile.Contains("DEMO") ? "env-banner-demo" : 
                         envProfile.Contains("PROD") ? "env-banner-prod" : "env-banner-unknown";
    
    var dbConnString = Configuration.GetConnectionString("DefaultConnection") 
                       ?? Environment.GetEnvironmentVariable("DATABASE_URL") ?? "";
    var dbHost = "";
    var dbName = "";
    
    if (!string.IsNullOrEmpty(dbConnString))
    {
        if (dbConnString.StartsWith("postgres://") || dbConnString.StartsWith("postgresql://"))
        {
            try
            {
                var uri = new Uri(dbConnString);
                dbHost = uri.Host;
                dbName = uri.AbsolutePath.TrimStart('/').Split('?')[0];
            }
            catch { }
        }
        else
        {
            var parts = dbConnString.Split(';')
                .Select(p => p.Split(new[] {'='}, 2))
                .Where(p => p.Length == 2)
                .ToDictionary(p => p[0].Trim().ToLower(), p => p[1].Trim(), StringComparer.OrdinalIgnoreCase);
            parts.TryGetValue("host", out dbHost);
            if (string.IsNullOrEmpty(dbHost)) parts.TryGetValue("server", out dbHost);
            parts.TryGetValue("database", out dbName);
            
            if (!string.IsNullOrEmpty(dbHost))
            {
                if (dbHost.StartsWith("tcp:", StringComparison.OrdinalIgnoreCase)) 
                    dbHost = dbHost.Substring(4);
                var commaIdx = dbHost.IndexOf(',');
                if (commaIdx > 0) dbHost = dbHost.Substring(0, commaIdx);
                var colonIdx = dbHost.LastIndexOf(':');
                if (colonIdx > 0 && colonIdx < dbHost.Length - 1)
                {
                    var afterColon = dbHost.Substring(colonIdx + 1);
                    if (int.TryParse(afterColon, out _)) dbHost = dbHost.Substring(0, colonIdx);
                }
            }
        }
    }
    
    if (string.IsNullOrEmpty(dbHost)) dbHost = Environment.GetEnvironmentVariable("PGHOST") ?? "";
    if (string.IsNullOrEmpty(dbName)) dbName = Environment.GetEnvironmentVariable("PGDATABASE") ?? "";
    
    var maskedHost = string.IsNullOrEmpty(dbHost) ? "unknown" :
        dbHost.Length >= 6 ? dbHost.Substring(0, 3) + "***" + dbHost.Substring(dbHost.Length - 2) :
        dbHost.Length >= 4 ? dbHost.Substring(0, 2) + "**" + dbHost.Substring(dbHost.Length - 1) :
        "***";
    
    if (string.IsNullOrEmpty(dbName)) dbName = "unknown";
    var company = DbContext.Companies.OrderBy(c => c.Id).FirstOrDefault();
    var enablePurchasing = company?.EnablePurchasing ?? true;
    var enableAP = company?.EnableAccountsPayable ?? true;
    var enableVendors = company?.EnableVendors ?? true;
    var enableWorkOrders = company?.EnableWorkOrders ?? true;
    var enableInventory = company?.EnableInventory ?? true;
    
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
    
    bool IsPage(string prefix) => currentPage.StartsWith(prefix, StringComparison.OrdinalIgnoreCase);
    bool IsExactPage(string path) => currentPage.Equals(path, StringComparison.OrdinalIgnoreCase);
    bool IsAny(params string[] prefixes) => prefixes.Any(p => IsPage(p));
    
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var roleFromIsInRole = User.IsInRole("Admin");
    var roleClaims = User.Claims.Where(c => c.Type == ClaimTypes.Role || c.Type == "role").Select(c => c.Value).ToList();
    var roleFromClaims = roleClaims.Any(r => r.Equals("Admin", StringComparison.OrdinalIgnoreCase));
    var isAdmin = isAuthenticated && (roleFromIsInRole || roleFromClaims);
}
