@* _ModernLayout.cshtml — Modern Navigation Overhaul: grouped sidebar IA, command palette, search stub *@
@inject Abs.FixedAssets.Data.AppDbContext DbContext
@inject Abs.FixedAssets.Services.ISeedGuardService SeedGuard
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@using System.Security.Claims
@{
    var appEnv = Environment.GetEnvironmentVariable("APP_ENVIRONMENT");
    var envProfile = !string.IsNullOrEmpty(appEnv) ? appEnv.ToUpper() : SeedGuard.GetEnvironmentProfile();
    var isDefaultedEnv = string.IsNullOrEmpty(appEnv);
    var envBannerClass = envProfile.Contains("LAB") ? "env-banner-lab" : 
                         envProfile.Contains("DEMO") ? "env-banner-demo" : 
                         envProfile.Contains("PROD") ? "env-banner-prod" : "env-banner-unknown";
    
    var dbConnString = Configuration.GetConnectionString("DefaultConnection") 
                       ?? Environment.GetEnvironmentVariable("DATABASE_URL") ?? "";
    var dbHost = "";
    var dbName = "";
    
    if (!string.IsNullOrEmpty(dbConnString))
    {
        if (dbConnString.StartsWith("postgres://") || dbConnString.StartsWith("postgresql://"))
        {
            try
            {
                var uri = new Uri(dbConnString);
                dbHost = uri.Host;
                dbName = uri.AbsolutePath.TrimStart('/').Split('?')[0];
            }
            catch { }
        }
        else
        {
            var parts = dbConnString.Split(';')
                .Select(p => p.Split(new[] {'='}, 2))
                .Where(p => p.Length == 2)
                .ToDictionary(p => p[0].Trim().ToLower(), p => p[1].Trim(), StringComparer.OrdinalIgnoreCase);
            parts.TryGetValue("host", out dbHost);
            if (string.IsNullOrEmpty(dbHost)) parts.TryGetValue("server", out dbHost);
            parts.TryGetValue("database", out dbName);
            
            if (!string.IsNullOrEmpty(dbHost))
            {
                if (dbHost.StartsWith("tcp:", StringComparison.OrdinalIgnoreCase)) 
                    dbHost = dbHost.Substring(4);
                var commaIdx = dbHost.IndexOf(',');
                if (commaIdx > 0) dbHost = dbHost.Substring(0, commaIdx);
                var colonIdx = dbHost.LastIndexOf(':');
                if (colonIdx > 0 && colonIdx < dbHost.Length - 1)
                {
                    var afterColon = dbHost.Substring(colonIdx + 1);
                    if (int.TryParse(afterColon, out _)) dbHost = dbHost.Substring(0, colonIdx);
                }
            }
        }
    }
    
    if (string.IsNullOrEmpty(dbHost)) dbHost = Environment.GetEnvironmentVariable("PGHOST") ?? "";
    if (string.IsNullOrEmpty(dbName)) dbName = Environment.GetEnvironmentVariable("PGDATABASE") ?? "";
    
    var maskedHost = string.IsNullOrEmpty(dbHost) ? "unknown" :
        dbHost.Length >= 6 ? dbHost.Substring(0, 3) + "***" + dbHost.Substring(dbHost.Length - 2) :
        dbHost.Length >= 4 ? dbHost.Substring(0, 2) + "**" + dbHost.Substring(dbHost.Length - 1) :
        "***";
    
    if (string.IsNullOrEmpty(dbName)) dbName = "unknown";
    var company = DbContext.Companies.OrderBy(c => c.Id).FirstOrDefault();
    var enablePurchasing = company?.EnablePurchasing ?? true;
    var enableAP = company?.EnableAccountsPayable ?? true;
    var enableVendors = company?.EnableVendors ?? true;
    var enableWorkOrders = company?.EnableWorkOrders ?? true;
    var enableInventory = company?.EnableInventory ?? true;
    
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
    
    bool IsPage(string prefix) => currentPage.StartsWith(prefix, StringComparison.OrdinalIgnoreCase);
    bool IsExactPage(string path) => currentPage.Equals(path, StringComparison.OrdinalIgnoreCase);
    bool IsAny(params string[] prefixes) => prefixes.Any(p => IsPage(p));
    
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var roleFromIsInRole = User.IsInRole("Admin");
    var roleClaims = User.Claims.Where(c => c.Type == ClaimTypes.Role || c.Type == "role").Select(c => c.Value).ToList();
    var roleFromClaims = roleClaims.Any(r => r.Equals("Admin", StringComparison.OrdinalIgnoreCase));
    var isAdmin = isAuthenticated && (roleFromIsInRole || roleFromClaims);
}
<!DOCTYPE html>
<html lang="en" class="@(Context.Request.Query.ContainsKey("theme") ? Context.Request.Query["theme"] == "dark" ? "dark" : "" : "")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["TabTitle"] ?? ViewData["Title"] ?? "Dashboard") - ABS Machining EAM</title>
    <script>
        (function(){var u=new URLSearchParams(window.location.search);var t=u.get('theme')||localStorage.getItem('cherryai_theme');if(t==='dark'||(!t&&!window.matchMedia)){document.documentElement.classList.add('dark')}else if(t!=='light'&&window.matchMedia&&window.matchMedia('(prefers-color-scheme:dark)').matches){document.documentElement.classList.add('dark')}})();
    </script>
    <script>
        /* Density mode init — read localStorage before paint to avoid flash. */
        (function(){try{var d=localStorage.getItem('cherryai.density');if(d==='compact'||d==='spacious'){document.documentElement.classList.add('density-'+d);}}catch(e){}})();
    </script>
    
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/primitives.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/cockpit.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/control-center.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/receiving.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/nav-rebuild.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/base.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modern.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/premium-components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sidebar-nav.css" asp-append-version="true" />
    @* Sprint 13.5 PR #4 — Best In Class cockpit UI tokens (luxury baseline
       from docs/research/luxury-cockpit-ux.md applied as concrete CSS).
       Loaded after sidebar-nav so it can override where needed. *@
    <link rel="stylesheet" href="~/css/cockpit-v2.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tour.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/forms.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/assets.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/finance.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/reports.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/help.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/tax.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/inventory.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/maintenance.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/technicians.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/cip.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/api.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/ai.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/bulk-operations.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/purchasing.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/workorders.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/tabs.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/layout-components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/headers.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/org-selector.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/site-selector.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/command-palette.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/asset-premium.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/utility-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/premium-enterprise.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.css" integrity="sha384-dC18+guBm9Lk5IBQfkKIOw2YSxXWMsiuPfIOZNPilutZQn6MgBvcx+vejNQYlrbc" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/modules/tom-select-premium.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/cherryai-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/cherryai-dark-compliance.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" integrity="sha384-/o6I2CkkWC//PSjvWC/eYN7l3xM3tJm8ZzVkCOfp//W05QcE3mlGskpoHB6XqI+B" crossorigin="anonymous" />
    <link rel="icon" type="image/png" href="/images/cherry-favicon.png" />
    
    <link rel="stylesheet" href="~/css/modules/premium-polish.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)

    @* Sprint 11 Voice MVP — per-page VoiceContextPayload as meta tags. *@
    @await Html.PartialAsync("_VoiceContextMeta")
</head>
<body class="@(ViewData["BodyClass"] as string ?? "")">
    
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    
    <div class="app-container">
        <aside class="sidebar cherryai-sidebar" id="mainSidebar">
            <div class="sidebar-brand">
                <div class="sidebar-brand-logo-wrap" data-csp-style="display:flex; align-items:center; gap:0.6rem; min-width:0; flex:1;">
                    <img src="/images/abs-logo-icon.png" alt="ABS" data-csp-style="height:32px; flex-shrink:0;" />
                    <div data-csp-style="min-width:0;">
                        <div class="sidebar-brand-text" data-csp-style="font-size:1.25rem; font-weight:700; letter-spacing:0.08em;">EAM</div>
                        <div class="sidebar-brand-module" data-csp-style="font-size:0.55rem; opacity:0.5; letter-spacing:0.05em;">&copy; Powered by CherryAI</div>
                    </div>
                </div>
                <button class="sidebar-collapse-btn" id="sidebarCollapseBtn" type="button" title="Collapse sidebar" aria-label="Toggle sidebar">
                    <svg class="collapse-arrow" width="18" height="18" viewBox="0 0 18 18" fill="none">
                        <path d="M11 4L6 9L11 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>
            </div>
            
            <div class="org-selector-wrapper" id="orgSelectorWrapper">
                <button class="org-selector-btn" id="orgSelectorBtn" type="button">
                    <i class="fas fa-sitemap org-selector-icon"></i>
                    <span class="org-selector-label" id="orgSelectorLabel">Loading...</span>
                    <i class="fas fa-chevron-down org-selector-arrow"></i>
                </button>
                <div class="org-selector-dropdown" id="orgSelectorDropdown" data-csp-style="display:none;">
                    <div class="org-selector-search">
                        <input type="text" id="orgSearchInput" placeholder="Search companies..." autocomplete="off" />
                    </div>
                    <div class="org-selector-list" id="orgSelectorList"></div>
                </div>
            </div>

            <div class="site-selector-wrapper" id="siteSelectorWrapper" data-csp-style="display:none;">
                <button class="site-selector-btn" id="siteSelectorBtn" type="button">
                    <i class="fas fa-map-marker-alt site-selector-icon"></i>
                    <span class="site-selector-label" id="siteSelectorLabel">All Sites</span>
                    <i class="fas fa-chevron-down site-selector-arrow"></i>
                </button>
                <div class="site-selector-dropdown" id="siteSelectorDropdown" data-csp-style="display:none;">
                    <div class="site-selector-list" id="siteSelectorList"></div>
                </div>
            </div>

            <nav class="sidebar-nav" id="sidebarNav">
                <a href="/" class="nav-item nav-item-overview @(IsExactPage("/Index") ? "active" : "")" data-nav-route="/" data-tooltip="Dashboard" title="Dashboard">
                    <span class="nav-item-icon"><i class="fas fa-gauge-high"></i></span>
                    <span class="nav-item-label">Dashboard</span>
                </a>

                @* Sprint 11.5 PR #2 / Nav-1 — ADR-017 §D1 + §D5.
                   Control Centers (the spine of the new IA) + Quick Actions
                   verb tray, inserted above the legacy Operations groups.
                   Driven by Services.Navigation.ControlCenterRegistry — each
                   future sprint that ships a Control Center edits one line
                   in the registry (IsLive: false → true). *@
                @await Html.PartialAsync("_NavControlCenters")
                @await Html.PartialAsync("_NavQuickActions")

                @* Sprint 13.5 PR #4 — Best In Class nav rebuild.
                   Single partial driven by Services.Navigation.NavRegistry.
                   Replaces ~300 lines of hard-coded menu-group HTML that
                   used to live inline here. Adding a sidebar item is now a
                   one-line edit to NavRegistry.cs — no Razor changes. *@
                @await Html.PartialAsync("_NavSidebar")
                
                <div id="recentNavSection" class="recent-nav-section" data-csp-style="display:none;">
                    <div class="nav-section-label">RECENT</div>
                    <div id="recentNavList" class="recent-nav-list"></div>
                </div>
            </nav>
            
            <div class="sidebar-footer">
                @* PR #116b: global controls (search/Cmd-K/theme) moved here from the killed topbar.
                   Render as compact icon-row when sidebar is expanded; collapse to a single column
                   stack when sidebar is in icon-rail mode. *@
                <div class="sidebar-utility-row">
                    <button class="sidebar-utility-btn" id="cmdPaletteTrigger" type="button" title="Search and navigate (Cmd+K / Ctrl+K)" data-tooltip="Search">
                        <i class="fas fa-magnifying-glass"></i>
                        <span class="sidebar-utility-label">Search</span>
                        <kbd class="sidebar-utility-kbd">⌘K</kbd>
                    </button>
                    <button class="sidebar-utility-btn icon-only" id="themeToggleBtn" type="button" title="Toggle dark/light mode" aria-label="Toggle dark/light mode" aria-pressed="false" data-tooltip="Toggle theme">
                        <i class="fas fa-moon"></i>
                    </button>
                    @{
                        // PR #116b: help button moved from killed topbar to sidebar footer.
                        var helpTopic = currentPage switch
                        {
                            var p when p.StartsWith("/Index") || p == "/" => "dashboard",
                            var p when p.StartsWith("/Assets") => "assets",
                            var p when p.StartsWith("/Books") => "books",
                            var p when p.StartsWith("/Journals") => "journals",
                            var p when p.StartsWith("/CCA") => "cca",
                            var p when p.StartsWith("/Reports") => "reports",
                            var p when p.StartsWith("/Maintenance") => "maintenance",
                            var p when p.StartsWith("/CIP") => "cip",
                            var p when p.StartsWith("/Inventory") => "inventory",
                            var p when p.StartsWith("/AI") => "ai-assistant",
                            var p when p.StartsWith("/Depreciation") => "depreciation",
                            var p when p.StartsWith("/Admin/Company") => "company-settings",
                            var p when p.StartsWith("/Admin") => "admin",
                            _ => ""
                        };
                        var helpHref = string.IsNullOrEmpty(helpTopic) ? "/Help" : $"/Help/Topic?id={helpTopic}";
                    }
                    @* Sprint 11.5 PR #2 / Nav-1 — ADR-017 §D8 + §D9.
                       Approvals bell + Settings link in the footer utility row.
                       Approvals is an inbox flow — the bell pattern (Linear/Stripe/GitHub)
                       beats a sidebar entry. Settings opens the drawer landing that holds
                       the 30 admin items previously cluttering the operational sidebar. *@
                    <a href="/Approvals/Pending" class="sidebar-utility-btn icon-only sidebar-utility-btn--approvals @(IsPage("/Approvals") ? "active" : "")" title="Pending approvals inbox" data-tooltip="Approvals">
                        <i class="fas fa-bell"></i>
                    </a>
                    <a href="@helpHref" class="sidebar-utility-btn icon-only" title="Help for this page" data-tooltip="Help">
                        <i class="fas fa-circle-question"></i>
                    </a>
                    <a href="/Settings" class="sidebar-utility-btn icon-only @(IsPage("/Settings") ? "active" : "")" title="Settings & administration" data-tooltip="Settings">
                        <i class="fas fa-gear"></i>
                    </a>
                </div>

                @if (!isAuthenticated)
                {
                <a href="/Account/Login" class="nav-item nav-item-signin @(IsPage("/Account/Login") ? "active" : "")" data-nav-route="/Account/Login" data-tooltip="Sign In">
                    <span class="nav-item-icon"><i class="fas fa-right-to-bracket"></i></span>
                    <span class="nav-item-label">Sign In</span>
                </a>
                }
                @if (isAuthenticated)
                {
                @* PR #116b: user-info now a clickable dropdown holding Sign Out (moved from killed topbar user-btn). *@
                <div class="sidebar-user-info sidebar-user-dropdown" id="sidebarUserMenu">
                    <button class="sidebar-user-trigger" type="button" id="sidebarUserTrigger" aria-haspopup="menu" aria-expanded="false" data-tooltip="@(User.FindFirst("FullName")?.Value ?? User.Identity?.Name)">
                        <div class="sidebar-user-avatar">@User.Identity?.Name?.Substring(0, 1).ToUpper()</div>
                        <div class="sidebar-user-details">
                            <span class="sidebar-user-name">@(User.FindFirst("FullName")?.Value ?? User.Identity?.Name)</span>
                            <span class="sidebar-user-role">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
                        </div>
                        <i class="fas fa-chevron-up sidebar-user-caret"></i>
                    </button>
                    <div class="sidebar-user-popover" id="sidebarUserPopover" role="menu" data-csp-style="display: none;">
                        <div class="sidebar-user-popover-header">
                            <strong>@(User.FindFirst("FullName")?.Value ?? User.Identity?.Name)</strong>
                            <span>@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
                        </div>
                        <a href="/Help" class="sidebar-user-popover-item" role="menuitem">
                            <i class="fas fa-circle-question"></i>
                            Help Center
                        </a>
                        <a asp-page="/Account/Logout" class="sidebar-user-popover-item" role="menuitem">
                            <i class="fas fa-right-from-bracket"></i>
                            Sign Out
                        </a>
                    </div>
                </div>
                }
            </div>
        </aside>
        
        <main class="main-content" id="mainContent">
            @* PR #116b: persistent .main-header removed entirely.
               Reclaims ~64px of vertical real estate on every page.
               Search/Cmd-K/Theme/Help/User controls moved to sidebar footer.
               Mobile menu trigger is a floating button (see below).
               Page-specific breadcrumbs render via _ScreenHeader inside the page content. *@
            <button class="mobile-menu-btn-floating" id="mobileMenuBtn" type="button" aria-label="Open menu">
                <i class="fas fa-bars"></i>
            </button>

            <div class="page-content">
                @RenderBody()
            </div>
            
            <footer class="app-footer">
                <div data-csp-style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px;">
                    <p data-csp-style="margin: 0;">&copy; 2026 ABS Machining EAM, powered by <a href="https://cherrystreetconsulting.com" data-csp-style="color: var(--text-muted); text-decoration: none;">CherryAI</a> &mdash; a division of Cherry Street Consulting, New York, NY. All Rights Reserved.</p>
                </div>
            </footer>
        </main>
    </div>
    
    <div id="commandPaletteOverlay" class="command-palette-overlay" data-csp-style="display:none;">
        <div class="command-palette" aria-label="Command palette">
            <div class="command-palette-header">
                <i class="fas fa-search command-palette-search-icon"></i>
                <input type="text" id="commandPaletteInput" class="command-palette-input" placeholder="Type a command or page name..." autocomplete="off" autofocus />
                <kbd class="command-palette-esc">Esc</kbd>
            </div>
            <div class="command-palette-results" id="commandPaletteResults"></div>
            <div class="command-palette-footer">
                <span><kbd>&uarr;</kbd><kbd>&darr;</kbd> or <kbd>⌃</kbd><kbd>N</kbd>/<kbd>P</kbd> nav</span>
                <span><kbd>Enter</kbd> open</span>
                <span><kbd>⌘</kbd><kbd>Enter</kbd> new tab</span>
                <span><kbd>Esc</kbd> close</span>
            </div>
        </div>
    </div>
    
    <div id="helpPanel" class="help-panel" data-csp-style="display: none;">
        <div class="help-panel-content">
            <div class="help-panel-header">
                <h2>Help & Support</h2>
                <button onclick="toggleHelp()" class="btn-close">&times;</button>
            </div>
            <div class="help-panel-body">
                <div class="help-section">
                    <h3>Getting Started</h3>
                    <p>Welcome to ABS Machining EAM. Use the sidebar to navigate between different sections.</p>
                </div>
                <div class="help-section">
                    <h3>Keyboard Shortcuts</h3>
                    <ul>
                        <li><kbd>/</kbd> — Focus global search</li>
                        <li><kbd>Ctrl+K</kbd> — Open command palette</li>
                        <li><kbd>Esc</kbd> — Close panel / clear search</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
    
    <script>
        function toggleHelp() {
            const panel = document.getElementById('helpPanel');
            panel.style.display = panel.style.display === 'none' ? 'flex' : 'none';
        }
        /* PR #116b: toggleUserMenu() removed — the topbar user dropdown
           it controlled is gone. The new sidebar user dropdown is wired
           up via sidebar-nav.js::initSidebarUserDropdown(). */
    </script>
    
    <script src="~/js/csp-bootstrap.js" asp-append-version="true"></script>
    <script src="~/js/enhanced-grid.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/modal.js" asp-append-version="true"></script>
    <script src="~/js/tour.js" asp-append-version="true"></script>
    <script src="~/js/sidebar-nav.js" asp-append-version="true"></script>
    <script src="~/js/scroll-restore.js" asp-append-version="true"></script>
    <script src="~/js/org-selector.js" asp-append-version="true"></script>
    <script src="~/js/site-selector.js" asp-append-version="true"></script>
    <script src="~/js/tabs.js" asp-append-version="true"></script>
    <script src="~/js/command-palette.js" asp-append-version="true"></script>
    <script src="~/js/recent-nav.js" asp-append-version="true"></script>
    <script src="~/js/return-path.js" asp-append-version="true"></script>
    <script src="~/js/theme-toggle.js" asp-append-version="true"></script>
    <script src="~/js/primitives.js" asp-append-version="true"></script>
    <script src="~/js/control-center.js" asp-append-version="true"></script>
    @* Sprint 11 Voice MVP — voice client (webkitSpeechRecognition + /_voice/invoke). *@
    <script src="~/js/voice-client.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js" integrity="sha384-cnROoUgVILyibe3J0zhzWoJ9p2WmdnK7j/BOTSWqVDbC1pVw2d+i6Q/1ESKJKCYf" crossorigin="anonymous"></script>
    <script src="~/js/cherry-typeahead.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
