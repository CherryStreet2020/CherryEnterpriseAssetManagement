@*
    Shared Pagination Partial
    Usage: <partial name="_Pagination" model="new PaginationModel { CurrentPage = Model.CurrentPage, PageSize = Model.PageSize, TotalCount = Model.TotalCount, BaseUrl = "/Assets" }" />
    Or pass extra query params: model.ExtraQueryParams = "search=foo&status=Active"
*@
@model Abs.FixedAssets.Pages.Shared.PaginationModel

@if (Model.TotalCount > 0)
{
    var totalPages = Model.TotalPages;
    var startRecord = ((Model.CurrentPage - 1) * Model.PageSize) + 1;
    var endRecord = Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount);
    var extraParams = string.IsNullOrEmpty(Model.ExtraQueryParams) ? "" : "&" + Model.ExtraQueryParams;

    <div class="pe-pagination">
        <div class="pe-pagination__info">
            Showing <strong>@startRecord–@endRecord</strong> of <strong>@Model.TotalCount.ToString("N0")</strong> records
        </div>
        <div class="pe-pagination__controls">
            <div class="pe-pagination__size">
                <label>Rows:</label>
                <select onchange="window.location.href='@(Model.BaseUrl)?page=1&pageSize=' + this.value + '@(Html.Raw(extraParams))'" class="pe-pagination__select">
                    @foreach (var size in new[] { 25, 50, 100, 250, 500 })
                    {
                        <option value="@size" selected="@(Model.PageSize == size)">@size</option>
                    }
                    <option value="@Model.TotalCount" selected="@(Model.PageSize >= Model.TotalCount && Model.TotalCount > 500)">All</option>
                </select>
            </div>
            @if (totalPages > 1)
            {
                <nav class="pe-pagination__nav">
                    @if (Model.CurrentPage > 1)
                    {
                        <a href="@(Model.BaseUrl)?page=@(Model.CurrentPage - 1)&pageSize=@Model.PageSize@(Html.Raw(extraParams))" class="pe-pagination__btn">‹ Prev</a>
                    }
                    else
                    {
                        <span class="pe-pagination__btn pe-pagination__btn--disabled">‹ Prev</span>
                    }

                    @{
                        var pages = new List<int>();
                        if (totalPages <= 7)
                        {
                            for (int i = 1; i <= totalPages; i++) pages.Add(i);
                        }
                        else
                        {
                            pages.Add(1);
                            if (Model.CurrentPage > 3) pages.Add(-1);
                            for (int i = Math.Max(2, Model.CurrentPage - 1); i <= Math.Min(totalPages - 1, Model.CurrentPage + 1); i++)
                                pages.Add(i);
                            if (Model.CurrentPage < totalPages - 2) pages.Add(-1);
                            pages.Add(totalPages);
                        }
                    }

                    @foreach (var p in pages)
                    {
                        if (p == -1)
                        {
                            <span class="pe-pagination__ellipsis">…</span>
                        }
                        else if (p == Model.CurrentPage)
                        {
                            <span class="pe-pagination__btn pe-pagination__btn--active">@p</span>
                        }
                        else
                        {
                            <a href="@(Model.BaseUrl)?page=@p&pageSize=@Model.PageSize@(Html.Raw(extraParams))" class="pe-pagination__btn">@p</a>
                        }
                    }

                    @if (Model.CurrentPage < totalPages)
                    {
                        <a href="@(Model.BaseUrl)?page=@(Model.CurrentPage + 1)&pageSize=@Model.PageSize@(Html.Raw(extraParams))" class="pe-pagination__btn">Next ›</a>
                    }
                    else
                    {
                        <span class="pe-pagination__btn pe-pagination__btn--disabled">Next ›</span>
                    }
                </nav>
            }
        </div>
    </div>
}
