@page
@model Abs.FixedAssets.Pages.Periods.IndexModel
@using Abs.FixedAssets.Pages.Shared.Primitives
@{
    ViewData["Title"] = "Period Close";
    ViewData["TabTitle"] = "Period Close";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";

    var subtitle = Model.CompanyName != null
        ? $"{Model.CompanyName} · {Model.Years.Count} fiscal year(s)"
        : "Select a company to view periods.";

    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = "Period Close",
        ["HeaderSubtitle"] = subtitle
    };

    // PR #116d.14 — fleet-wide period rollup for the top KPI strip.
    var allPeriods = Model.Years.SelectMany(fy => Model.PeriodsByYear.GetValueOrDefault(fy.Id) ?? new List<Abs.FixedAssets.Models.FiscalPeriod>()).ToList();
    var totalOpen = allPeriods.Count(p => p.Status == Abs.FixedAssets.Models.PeriodStatus.Open);
    var totalClosed = allPeriods.Count(p => p.Status == Abs.FixedAssets.Models.PeriodStatus.Closed);
    var totalLocked = allPeriods.Count(p => p.Status == Abs.FixedAssets.Models.PeriodStatus.Locked);
    var overdueOpen = allPeriods.Count(p => p.Status == Abs.FixedAssets.Models.PeriodStatus.Open && p.EndDate <= DateTime.UtcNow.Date);

    // PR #116d.14 — Map PeriodStatus → design system tone.
    string PeriodTone(Abs.FixedAssets.Models.PeriodStatus s) => s switch
    {
        Abs.FixedAssets.Models.PeriodStatus.Open => "success",
        Abs.FixedAssets.Models.PeriodStatus.Closed => "info",
        Abs.FixedAssets.Models.PeriodStatus.Locked => "brand",
        _ => "neutral"
    };
}

@await Html.PartialAsync("_ScreenHeader", headerVd)

@* PR #116d.14 — Top KPI strip surfacing fleet-wide period status. The
   "Overdue Open" tile is the operationally critical one — periods that have
   ended but haven't been closed yet. Tone flips to danger when ≥1. *@
@if (Model.Years.Any())
{
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-top: 20px;">
        @await Html.PartialAsync("Primitives/_KPITile", new KpiTileModel
        {
            Label = "Fiscal Years",
            Value = Model.Years.Count.ToString("N0"),
            DeltaText = $"{allPeriods.Count} total period(s)",
            DeltaDirection = "flat",
            SparkTone = "info"
        })
        @await Html.PartialAsync("Primitives/_KPITile", new KpiTileModel
        {
            Label = "Open Periods",
            Value = totalOpen.ToString("N0"),
            DeltaText = overdueOpen > 0 ? $"▼ {overdueOpen} overdue (end-date passed)" : "▲ all open periods are current",
            DeltaDirection = overdueOpen > 0 ? "down" : "up",
            SparkTone = overdueOpen > 0 ? "danger" : "success"
        })
        @await Html.PartialAsync("Primitives/_KPITile", new KpiTileModel
        {
            Label = "Closed Periods",
            Value = totalClosed.ToString("N0"),
            DeltaText = totalClosed == 0 ? "no closes yet this company" : "books locked through last close",
            DeltaDirection = "flat",
            SparkTone = "info"
        })
        @await Html.PartialAsync("Primitives/_KPITile", new KpiTileModel
        {
            Label = "Locked Periods",
            Value = totalLocked.ToString("N0"),
            DeltaText = totalLocked > 0 ? "audited & immutable" : "no audit lock yet",
            DeltaDirection = "flat",
            SparkTone = "brand"
        })
    </div>
}

@* PR #116d.14 — Filter as a DataCard with neutral tone, ds-btn primary. *@
<form method="get" class="ds-card" data-tone="neutral" style="margin-top: 20px; display: flex; gap: 16px; align-items: end; flex-wrap: wrap;">
    <div style="flex: 1; min-width: 240px;">
        <label style="display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500; margin-bottom: 6px;">Company</label>
        <select name="CompanyId" style="width: 100%; padding: 8px 10px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface-2, rgba(0,0,0,0.18)); color: var(--text-primary); font-size: 13px;">
            @foreach (var c in Model.CompanyOptions)
            {
                if (Model.CompanyId?.ToString() == c.Value)
                {
                    <option value="@c.Value" selected>@c.Text</option>
                }
                else
                {
                    <option value="@c.Value">@c.Text</option>
                }
            }
        </select>
    </div>
    <button type="submit" class="ds-btn ds-btn--primary ds-btn--md">Apply</button>
</form>

@if (Model.NextCloseable != null)
{
    @* PR #116d.14 — "Next eligible to close" hero as a DataCard with brand tone.
       The CTA is the conversion-driving action on this page — make it luxurious. *@
    <div class="ds-card" data-tone="brand" style="margin-top: 20px; padding: 22px 26px; display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap;">
        <div>
            <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500;">Next period eligible to close</div>
            <h2 style="margin: 6px 0 4px; font-size: 24px; font-weight: 700; color: var(--text-primary);">@Model.NextCloseable.Name</h2>
            <div style="color: var(--text-muted); font-size: 13px;">
                @Model.NextCloseable.StartDate.ToString("MMM d, yyyy") – @Model.NextCloseable.EndDate.ToString("MMM d, yyyy") · @Model.NextCloseable.DaysInPeriod days
            </div>
        </div>
        <a class="ds-btn ds-btn--primary ds-btn--lg" href="/Periods/Close?fiscalPeriodId=@Model.NextCloseable.Id&companyId=@Model.CompanyId">
            Run sequenced close →
        </a>
    </div>
}

@if (!Model.Years.Any())
{
    @* PR #116d.14 — EmptyState v2 with calendar icon. *@
    <div style="margin-top: 24px;">
        @await Html.PartialAsync("Primitives/_EmptyStateV2", new EmptyStateModel
        {
            Icon = "calendar",
            Tone = "info",
            Title = "No fiscal years materialized for this company",
            Body = "Visit Admin → Fiscal Calendar to generate the calendar for the next fiscal year. Period close, depreciation runs, and journal entries all depend on a materialized calendar.",
            CtaLabel = "Open Fiscal Calendar Admin",
            CtaHref = "/Admin/FiscalCalendar",
            SecondaryLabel = "Back to Reports",
            SecondaryHref = "/Reports"
        })
    </div>
}

@foreach (var fy in Model.Years)
{
    var periods = Model.PeriodsByYear.GetValueOrDefault(fy.Id) ?? new List<Abs.FixedAssets.Models.FiscalPeriod>();
    var openCount = periods.Count(p => p.Status == Abs.FixedAssets.Models.PeriodStatus.Open);
    var closedCount = periods.Count(p => p.Status == Abs.FixedAssets.Models.PeriodStatus.Closed);
    var lockedCount = periods.Count(p => p.Status == Abs.FixedAssets.Models.PeriodStatus.Locked);

    @* PR #116d.14 — Fiscal year section as DataCard with brand tone. Header
       carries StatusPills for open/closed/locked counts. *@
    <div class="ds-card" data-tone="brand" style="margin-top: 24px; padding: 0;">
        <div style="padding: 18px 22px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap;">
            <div>
                <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500;">Fiscal Year</div>
                <div style="font-size: 18px; font-weight: 700; color: var(--text-primary); margin-top: 4px;">@fy.Name</div>
            </div>
            <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel { Label = "Open", MonoNum = openCount.ToString(), Tone = "success", ShowDot = true })
                @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel { Label = "Closed", MonoNum = closedCount.ToString(), Tone = "info", ShowDot = true })
                @if (lockedCount > 0)
                {
                    @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel { Label = "Locked", MonoNum = lockedCount.ToString(), Tone = "brand", ShowDot = true })
                }
            </div>
        </div>
        <div style="padding: 0;">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: var(--surface-2, rgba(120,120,200,0.04));">
                        <th style="text-align: left; padding: 12px 16px; border-bottom: 1px solid var(--border); font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 600;">Period</th>
                        <th style="text-align: left; padding: 12px 16px; border-bottom: 1px solid var(--border); font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 600;">Window</th>
                        <th style="text-align: center; padding: 12px 16px; border-bottom: 1px solid var(--border); font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 600;">Status</th>
                        <th style="text-align: left; padding: 12px 16px; border-bottom: 1px solid var(--border); font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 600;">Closed</th>
                        <th style="text-align: right; padding: 12px 16px; border-bottom: 1px solid var(--border); font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 600;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in periods)
                    {
                        <tr style="border-top: 1px solid var(--border);">
                            <td style="padding: 12px 16px;"><strong style="color: var(--text-primary);">@p.Name</strong></td>
                            <td style="padding: 12px 16px; color: var(--text-muted); font-size: 13px;">@p.StartDate.ToString("MMM d") – @p.EndDate.ToString("MMM d")</td>
                            <td style="padding: 12px 16px; text-align: center;">
                                @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel
                                {
                                    Label = p.Status.ToString(),
                                    Tone = PeriodTone(p.Status),
                                    ShowDot = true
                                })
                            </td>
                            <td style="padding: 12px 16px; color: var(--text-muted); font-size: 13px;">
                                @if (p.ClosedAt.HasValue)
                                {
                                    <span style="color: var(--text-primary);">@p.ClosedAt.Value.ToString("yyyy-MM-dd")</span>
                                    <span style="display: block; font-size: 11px;">by @p.ClosedBy</span>
                                }
                                else
                                {
                                    <span style="color: var(--text-muted);">—</span>
                                }
                            </td>
                            <td style="padding: 12px 16px; text-align: right;">
                                @if (p.Status == Abs.FixedAssets.Models.PeriodStatus.Open && p.EndDate <= DateTime.UtcNow.Date)
                                {
                                    <a class="ds-btn ds-btn--primary ds-btn--sm" href="/Periods/Close?fiscalPeriodId=@p.Id&companyId=@Model.CompanyId">Close →</a>
                                }
                                else if (p.Status == Abs.FixedAssets.Models.PeriodStatus.Closed)
                                {
                                    <a class="ds-btn ds-btn--secondary ds-btn--sm" href="/Periods/Close?fiscalPeriodId=@p.Id&companyId=@Model.CompanyId">View packet</a>
                                }
                                else if (p.Status == Abs.FixedAssets.Models.PeriodStatus.Open && p.EndDate > DateTime.UtcNow.Date)
                                {
                                    <span style="font-size: 11px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em;">future</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
