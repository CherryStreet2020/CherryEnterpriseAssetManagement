@page
@model Abs.FixedAssets.Pages.Periods.IndexModel
@{
    ViewData["Title"] = "Period Close";
    ViewData["TabTitle"] = "Period Close";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";

    var subtitle = Model.CompanyName != null
        ? $"{Model.CompanyName} · {Model.Years.Count} fiscal year(s)"
        : "Select a company to view periods.";

    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = "Period Close",
        ["HeaderSubtitle"] = subtitle
    };

    string StatusBadgeStyle(Abs.FixedAssets.Models.PeriodStatus s) => s switch
    {
        Abs.FixedAssets.Models.PeriodStatus.Open => "background: rgba(34,197,94,0.12); border: 1px solid rgba(34,197,94,0.35); color: #86efac;",
        Abs.FixedAssets.Models.PeriodStatus.Closed => "background: rgba(59,130,246,0.10); border: 1px solid rgba(59,130,246,0.35); color: #93c5fd;",
        Abs.FixedAssets.Models.PeriodStatus.Locked => "background: rgba(168,85,247,0.10); border: 1px solid rgba(168,85,247,0.35); color: #d8b4fe;",
        _ => "background: rgba(120,120,120,0.10); border: 1px solid rgba(120,120,120,0.35); color: #cbd5e1;"
    };
}

@await Html.PartialAsync("_ScreenHeader", headerVd)

<form method="get" class="filter-bar" data-csp-style="margin-top: 1rem; padding: 1rem 1.25rem; border-radius: 8px; background: var(--hero-bg, rgba(120,120,200,0.04)); display: flex; gap: 1rem; align-items: end; flex-wrap: wrap;">
    <div class="form-group" data-csp-style="flex: 1; min-width: 240px;">
        <label class="form-label" data-csp-style="display: block; font-size: 0.75rem; text-transform: uppercase; color: var(--text-muted); margin-bottom: 0.25rem;">Company</label>
        <select name="CompanyId" class="form-control" data-csp-style="width: 100%; padding: 0.5rem; border-radius: 6px; border: 1px solid var(--border); background: rgba(0,0,0,0.2); color: inherit;">
            @foreach (var c in Model.CompanyOptions)
            {
                if (Model.CompanyId?.ToString() == c.Value)
                {
                    <option value="@c.Value" selected>@c.Text</option>
                }
                else
                {
                    <option value="@c.Value">@c.Text</option>
                }
            }
        </select>
    </div>
    <button type="submit" class="btn-p btn-p--primary" data-csp-style="padding: 0.5rem 1.25rem; font-weight: 600;">Apply</button>
</form>

@if (Model.NextCloseable != null)
{
    <div class="section-card" data-csp-style="margin-top: 1.5rem; border: 1px solid rgba(168,85,247,0.4); background: linear-gradient(135deg, rgba(168,85,247,0.08), rgba(99,102,241,0.04));">
        <div class="section-card-body" data-csp-style="padding: 1.5rem; display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap;">
            <div>
                <div data-csp-style="font-size: 0.75rem; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.05em;">Next period eligible to close</div>
                <h2 data-csp-style="margin: 0.25rem 0; font-size: 1.5rem;">@Model.NextCloseable.Name</h2>
                <div data-csp-style="color: var(--text-muted); font-size: 0.875rem;">
                    @Model.NextCloseable.StartDate.ToString("MMM d, yyyy") – @Model.NextCloseable.EndDate.ToString("MMM d, yyyy") · @Model.NextCloseable.DaysInPeriod days
                </div>
            </div>
            <a class="btn-p btn-p--primary" data-csp-style="padding: 0.75rem 1.5rem; font-weight: 600; font-size: 1rem;" href="/Periods/Close?fiscalPeriodId=@Model.NextCloseable.Id&companyId=@Model.CompanyId">
                Run sequenced close →
            </a>
        </div>
    </div>
}

@if (!Model.Years.Any())
{
    <div class="section-card" data-csp-style="margin-top: 1.5rem;">
        <div class="section-card-body" data-csp-style="padding: 2rem; text-align: center;">
            <h3 data-csp-style="margin-top: 0;">No fiscal years materialized for this company yet.</h3>
            <p data-csp-style="color: var(--text-muted);">
                Visit <a href="/Admin/FiscalCalendar">Admin → Fiscal Calendar</a> to generate the calendar for the next fiscal year.
            </p>
        </div>
    </div>
}

@foreach (var fy in Model.Years)
{
    var periods = Model.PeriodsByYear.GetValueOrDefault(fy.Id) ?? new List<Abs.FixedAssets.Models.FiscalPeriod>();
    var openCount = periods.Count(p => p.Status == Abs.FixedAssets.Models.PeriodStatus.Open);
    var closedCount = periods.Count(p => p.Status == Abs.FixedAssets.Models.PeriodStatus.Closed);
    var lockedCount = periods.Count(p => p.Status == Abs.FixedAssets.Models.PeriodStatus.Locked);

    <div class="section-card" data-csp-style="margin-top: 1.5rem;">
        <div class="section-card-header" data-csp-style="display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.25rem; border-bottom: 1px solid var(--border);">
            <h3 data-csp-style="margin: 0;">@fy.Name</h3>
            <div data-csp-style="display: flex; gap: 0.5rem; font-size: 0.75rem;">
                <span data-csp-style="padding: 0.25rem 0.5rem; border-radius: 4px; background: rgba(34,197,94,0.12); color: #86efac;">@openCount open</span>
                <span data-csp-style="padding: 0.25rem 0.5rem; border-radius: 4px; background: rgba(59,130,246,0.10); color: #93c5fd;">@closedCount closed</span>
                @if (lockedCount > 0)
                {
                    <span data-csp-style="padding: 0.25rem 0.5rem; border-radius: 4px; background: rgba(168,85,247,0.10); color: #d8b4fe;">@lockedCount locked</span>
                }
            </div>
        </div>
        <div class="section-card-body" data-csp-style="padding: 0;">
            <table class="ledger-table" data-csp-style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr data-csp-style="background: var(--hero-bg, rgba(120,120,200,0.04));">
                        <th data-csp-style="text-align: left; padding: 0.625rem 1rem; border-bottom: 1px solid var(--border);">Period</th>
                        <th data-csp-style="text-align: left; padding: 0.625rem 1rem; border-bottom: 1px solid var(--border);">Window</th>
                        <th data-csp-style="text-align: center; padding: 0.625rem 1rem; border-bottom: 1px solid var(--border);">Status</th>
                        <th data-csp-style="text-align: left; padding: 0.625rem 1rem; border-bottom: 1px solid var(--border);">Closed</th>
                        <th data-csp-style="text-align: right; padding: 0.625rem 1rem; border-bottom: 1px solid var(--border);">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var p in periods)
                {
                    var badgeStyle = $"padding: 0.25rem 0.625rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600; {StatusBadgeStyle(p.Status)}";
                    <tr>
                        <td data-csp-style="padding: 0.625rem 1rem; border-bottom: 1px solid var(--border);"><strong>@p.Name</strong></td>
                        <td data-csp-style="padding: 0.625rem 1rem; border-bottom: 1px solid var(--border); color: var(--text-muted);">@p.StartDate.ToString("MMM d") – @p.EndDate.ToString("MMM d")</td>
                        <td data-csp-style="padding: 0.625rem 1rem; border-bottom: 1px solid var(--border); text-align: center;">
                            <span data-csp-style="@badgeStyle">@p.Status</span>
                        </td>
                        <td data-csp-style="padding: 0.625rem 1rem; border-bottom: 1px solid var(--border); color: var(--text-muted); font-size: 0.875rem;">
                            @if (p.ClosedAt.HasValue)
                            {
                                <span>@p.ClosedAt.Value.ToString("yyyy-MM-dd")</span>
                                <span data-csp-style="display: block; font-size: 0.75rem;">by @p.ClosedBy</span>
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </td>
                        <td data-csp-style="padding: 0.625rem 1rem; border-bottom: 1px solid var(--border); text-align: right;">
                            @if (p.Status == Abs.FixedAssets.Models.PeriodStatus.Open && p.EndDate <= DateTime.UtcNow.Date)
                            {
                                <a class="btn-p btn-p--primary" data-csp-style="padding: 0.375rem 0.875rem; font-size: 0.8125rem;" href="/Periods/Close?fiscalPeriodId=@p.Id&companyId=@Model.CompanyId">Close →</a>
                            }
                            else if (p.Status == Abs.FixedAssets.Models.PeriodStatus.Closed)
                            {
                                <a class="btn-p btn-p--secondary" data-csp-style="padding: 0.375rem 0.875rem; font-size: 0.8125rem;" href="/Periods/Close?fiscalPeriodId=@p.Id&companyId=@Model.CompanyId">View packet</a>
                            }
                            else if (p.Status == Abs.FixedAssets.Models.PeriodStatus.Open && p.EndDate > DateTime.UtcNow.Date)
                            {
                                <span data-csp-style="font-size: 0.75rem; color: var(--text-muted);">future</span>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}
