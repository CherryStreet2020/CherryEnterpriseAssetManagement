@page "{id:int}"
@model Abs.FixedAssets.Pages.Assets.TransferModel
@{
    ViewData["Title"] = "Transfers";
    Layout = "_ModernLayout";
    ViewData["HasScreenHeader"] = true;
}

@if (Model.Asset is null)
{
    var notFoundVd = new ViewDataDictionary(ViewData)
    {
        ["HeaderTitle"] = "Asset Not Found",
        ["Subtitle"] = "The asset you're looking for doesn't exist or has been removed.",
        ["TypeLabel"] = "Asset Workflow",
        ["ShowBackLink"] = true,
        ["BackLinkFallback"] = "/Assets",
        ["BackLinkLabel"] = "Assets"
    };
    @await Html.PartialAsync("Shared/_ScreenHeader", notFoundVd)
    <div class="section-card">
        <div class="section-card-body">
            <div class="pe-empty" style="padding:2rem;">
                <i class="fas fa-box-open pe-empty__icon" style="font-size:1.5rem;"></i>
                <div class="pe-empty__title">Asset Not Found</div>
                <div class="pe-empty__text">The requested asset could not be located.</div>
                <a asp-page="./Index" class="btn-p btn-p--primary">Back to Assets</a>
            </div>
        </div>
    </div>
    return;
}

@{
    var headerVd = new ViewDataDictionary(ViewData)
    {
        ["HeaderTitle"] = "Asset Transfer",
        ["Subtitle"] = "Move asset to a new location or department",
        ["TypeLabel"] = "Asset Workflow",
        ["StatusText"] = "Transfer",
        ["StatusTone"] = "info",
        ["ContextText"] = $"{Model.Asset.AssetNumber} / {Model.Asset.LocationRef?.Name ?? "Unassigned"}",
        ["ShowBackLink"] = true,
        ["BackLinkFallback"] = $"/Assets/Asset/{Model.AssetId}",
        ["BackLinkLabel"] = "Back to Asset"
    };
}
@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

<div class="wizard-steps">
    <div class="wizard-step active">
        <div class="step-number">1</div>
        <div class="step-label">Select Asset</div>
    </div>
    <div class="wizard-step active">
        <div class="step-number">2</div>
        <div class="step-label">Transfer Details</div>
    </div>
    <div class="wizard-step">
        <div class="step-number">3</div>
        <div class="step-label">Confirm</div>
    </div>
</div>

<form method="post">
    <input type="hidden" asp-for="AssetId" />
    
    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                </svg>
                Transfer Details
            </h3>
        </div>
        <div class="section-card-body">
            <div class="form-row" style="display: grid; grid-template-columns: 1fr auto 1fr; gap: 20px; align-items: start;">
                <div class="location-card from">
                    <div class="location-label">Current Location</div>
                    <div class="form-group" style="margin-bottom: 12px;">
                        <label class="form-label">Location</label>
                        <input type="text" class="form-control" value="@(Model.Asset.LocationRef?.Name ?? "Unassigned")" readonly />
                    </div>
                    <div class="form-group" style="margin-bottom: 12px;">
                        <label class="form-label">Bay/Station</label>
                        <input type="text" class="form-control" value="@(Model.Asset.Bay ?? "N/A")" readonly />
                    </div>
                    <div class="form-group" style="margin-bottom: 0;">
                        <label class="form-label">Department</label>
                        <input type="text" class="form-control" value="@(Model.Asset.DepartmentRef?.Name ?? "Unassigned")" readonly />
                    </div>
                </div>

                <div class="transfer-arrow">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                    </svg>
                </div>

                <div class="location-card to">
                    <div class="location-label">New Location</div>
                    <div class="form-group" style="margin-bottom: 12px;">
                        <label class="form-label">Location <span class="text-danger">*</span></label>
                        <select asp-for="NewLocationId" class="form-control" data-cherry-select data-placeholder="Search locations..." required>
                            <option value="">Select location...</option>
                            @foreach (var loc in Model.LocationsList)
                            {
                                var indent = loc.ParentLocationId.HasValue ? (loc.Type == LocationType.Bay || loc.Type == LocationType.Station ? "\u00A0\u00A0\u00A0\u00A0" : "\u00A0\u00A0") : "";
                                <option value="@loc.Id">@indent@loc.Code - @loc.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group" style="margin-bottom: 12px;">
                        <label class="form-label">Bay/Station</label>
                        <input asp-for="NewBay" class="form-control" placeholder="e.g., Bay 3, Station A" />
                    </div>
                    <div class="form-group" style="margin-bottom: 0;">
                        <label class="form-label">Department</label>
                        <select asp-for="NewDepartmentId" class="form-control" data-cherry-select data-placeholder="Search departments...">
                            <option value="">Select department...</option>
                            @foreach (var dept in Model.DepartmentsList)
                            {
                                <option value="@dept.Id">@dept.Name</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Transfer Information
            </h3>
        </div>
        <div class="section-card-body">
            <div class="form-row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div class="form-group">
                    <label asp-for="TransferDate" class="form-label">Transfer Date <span class="text-danger">*</span></label>
                    <input asp-for="TransferDate" type="date" class="form-control" required />
                </div>
                <div class="form-group">
                    <label asp-for="TransferReason" class="form-label">Reason</label>
                    <select asp-for="TransferReasonLookupValueId" asp-items="Model.TransferReasonOptions" class="form-control">
                    </select>
                </div>
            </div>
            <div class="form-group">
                <label asp-for="Notes" class="form-label">Notes</label>
                <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Additional notes about this transfer..."></textarea>
            </div>
        </div>
    </div>

    <div class="section-card">
        <div class="section-card-body" style="display: flex; justify-content: space-between; align-items: center;">
            <a asp-page="./Asset" asp-route-id="@Model.AssetId" class="btn-p btn-p--secondary">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Cancel
            </a>
            <button type="submit" class="btn-p btn-p--primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                </svg>
                Complete Transfer
            </button>
        </div>
    </div>
</form>


<script>
    document.getElementById('NewLocation')?.addEventListener('change', function() {
        var customInput = document.getElementById('customLocationInput');
        if (customInput) {
            if (this.value === '__new__') {
                customInput.style.display = 'block';
                customInput.required = true;
            } else {
                customInput.style.display = 'none';
                customInput.required = false;
                customInput.value = '';
            }
        }
    });
</script>
