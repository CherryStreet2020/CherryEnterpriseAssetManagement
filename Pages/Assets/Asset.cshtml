                    @* PR #107 / B-22: Connection Status panel only renders in read
                       mode when IoT was enabled, the asset has communicated, or has a
                       known connection status. Pre-PR it always showed "Status: Unknown,
                       Last Communication: -" regardless of whether any IoT was wired. *@
                    @if (!Model.IsCreateMode && !isEditable && hasIotConnection)
                    {
                        <div class="spec-card collapsed">
                            <div class="spec-header">
                                <span class="accent-dot accent-dot--cyan"></span>
                                <span class="spec-title">Connection Status</span>
                                <span class="spec-chevron">▾</span>
                            </div>
                            <div class="spec-body">
                        <div class="form-section">
                            <h4 class="form-section-title">Connection Status</h4>
                            <div class="form-row">
                                <div class="form-group" data-csp-style="flex: 1;">
                                    <label class="form-label">Status</label>
                                    <div class="form-value">
                                        @{
                                            var iotStatus = Model.Asset!.IoTConnectionStatus ?? "Unknown";
                                            var iotStatusClass = iotStatus == "Online" ? "badge-success" : iotStatus == "Offline" ? "badge-danger" : "badge-secondary";
                                        }
                                        <span class="badge @iotStatusClass">@iotStatus</span>
                                    </div>
                                </div>
                                <div class="form-group" data-csp-style="flex: 1;">
                                    <label class="form-label">Last Communication</label>
                                    <div class="form-value">@(Model.Asset.LastIoTCommunication?.ToString("g") ?? "-")</div>
                                </div>
                            </div>
                        </div>
                            </div>
                        </div>
                    }

                    @* PR #107 / B-22: Current Sensor Readings panel only renders when
                       at least one temperature/vibration/pressure/timestamp value exists.
                       The empty-state banner below covers both this and the Connection
                       Status section when neither has data, avoiding stacked banners. *@
