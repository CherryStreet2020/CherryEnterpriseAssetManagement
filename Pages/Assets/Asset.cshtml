                </div>
                <form method="post" asp-page-handler="AddMeterReading" asp-route-id="@Model.Asset.Id" class="form-section" data-csp-style="margin-bottom: 1rem;">
                    <div class="form-row">
                        <div class="form-group" data-csp-style="flex: 1;">
                            <label class="form-label">New Reading *</label>
                            <input asp-for="NewMeterReading" type="number" step="0.01" min="0" class="form-control" required placeholder="e.g., 12500" />
                        </div>
                        <div class="form-group" data-csp-style="flex: 1;">
                            <label class="form-label">Reading Date</label>
                            <input asp-for="NewMeterReadingDate" type="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="form-group" data-csp-style="flex: 1;">
                            <label class="form-label">Source</label>
                            <select asp-for="NewMeterSource" class="form-control">
                                <option value="Manual">Manual</option>
                                <option value="IoT">IoT</option>
                                <option value="Import">Import</option>
                            </select>
                        </div>
                        <div class="form-group" data-csp-style="flex: 2;">
                            <label class="form-label">Notes</label>
                            <input asp-for="NewMeterNotes" class="form-control" placeholder="Optional notes" />
                        </div>
                        <div class="form-group" data-csp-style="flex: 0 0 auto; display: flex; align-items: flex-end;">
                            <button type="submit" class="btn-p btn-p--primary btn-p--sm">Add Reading</button>
                        </div>
                    </div>
                </form>

                @if (Model.MeterReadings.Any())
                {
                    <div class="table-responsive" data-csp-style="margin-top: 0.5rem;">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Reading</th>
                                    <th>Previous</th>
                                    <th>Delta</th>
                                    <th>Recorded By</th>
                                    <th>Source</th>
                                    <th>Notes</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var mr in Model.MeterReadings)
                                {
                                    <tr>
                                        <td>@mr.ReadingDate.ToString("MMM d, yyyy HH:mm")</td>
                                        <td><strong>@mr.Reading.ToString("N2")</strong></td>
                                        <td>@(mr.PreviousReading?.ToString("N2") ?? "—")</td>
                                        <td>
                                            @if (mr.IsRollover)
                                            {
                                                <span class="badge badge-warning" title="Meter rollover detected">Rollover</span>
                                            }
                                            else if (mr.Delta.HasValue)
                                            {
                                                <span>@mr.Delta.Value.ToString("N2")</span>
                                            }
                                            else
                                            {
                                                <span>—</span>
                                            }
                                        </td>
                                        <td>@(mr.RecordedBy ?? "—")</td>
                                        <td>@(mr.Source ?? "—")</td>
                                        <td>@(mr.Notes ?? "—")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-muted" data-csp-style="padding: 1rem; text-align: center;">No meter readings recorded yet.</div>
                }
            </div>
        }

