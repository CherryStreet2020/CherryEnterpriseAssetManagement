@page "{id:int?}"
@model Abs.FixedAssets.Pages.Assets.AssetModel
@using Abs.FixedAssets.Models
@using Abs.FixedAssets.Helpers
@{
    var assetNumber = Model.Asset?.AssetNumber ?? "";
    var assetDesc = Model.Asset?.Description ?? "";
    ViewData["Title"] = UiTerms.AssetManagement;
    ViewData["TabTitle"] = Model.IsCreateMode 
        ? $"New {UiTerms.AssetSingular}" 
        : UiTerms.GetAssetTabTitle(assetNumber);
    var isEditable = Model.IsEditMode || Model.IsCreateMode;
    var hasHealthScore = Model.Asset?.PredictiveHealthScore.HasValue == true;
    var healthScore = Model.Asset?.PredictiveHealthScore ?? 0;
    var healthColor = healthScore >= 80 ? "#10b981" : healthScore >= 60 ? "#f59e0b" : "#ef4444";

    // PR #107 / B-22: read-mode gating helpers so the asset detail page hides
    // the Current OEE block, Connection Status, and Current Sensor Readings
    // when no data has been captured. Edit/Create modes still see the full
    // form so admins can populate manually.
    var assetForGating = Model.Asset;
    var hasCurrentOee = assetForGating != null && (
           assetForGating.CurrentOEE.HasValue
        || assetForGating.CurrentAvailability.HasValue
        || assetForGating.CurrentPerformance.HasValue
        || assetForGating.CurrentQuality.HasValue);
    var hasIotConnection = assetForGating != null && (
           assetForGating.IoTEnabled
        || assetForGating.LastIoTCommunication.HasValue
        || !string.IsNullOrEmpty(assetForGating.IoTConnectionStatus));
    var hasSensorReadings = assetForGating != null && (
           assetForGating.CurrentTemperature.HasValue
        || assetForGating.CurrentVibration.HasValue
        || assetForGating.CurrentPressure.HasValue
        || assetForGating.SensorReadingsLastUpdated.HasValue);
    // PR #107 / B-23: shared empty-state banner — appears in place of the
    // would-be-dashes panel and links to the new iot-setup help topic.
    Func<string, object> reliabilityEmptyState = (string sectionLabel) => {
        return Html.Raw($@"
            <div data-csp-style=""border: 1px dashed var(--border, #44424a); padding: 1rem 1.25rem; border-radius: 8px; background: rgba(120,120,200,0.04); margin-top: 12px;"">
                <p data-csp-style=""margin: 0; color: var(--text-muted, #b0aebd); font-size: 0.875rem; line-height: 1.5;"">
                    <span data-csp-style=""font-weight: 600; color: var(--text-primary, #e2e8f0);"">{sectionLabel} not yet captured for this asset.</span>
                    Configure an IoT gateway or MES feed to populate this panel automatically.
                    <a href=""/Help/Topic?id=iot-setup"" data-csp-style=""color: #60a5fa; text-decoration: none;"">How to connect data sources →</a>
                </p>
            </div>");
    };
    ViewData["ReturnUrl"] = Model.ReturnUrl;
    ViewData["FallbackPage"] = "/Assets";
    ViewData["FallbackLabel"] = "Assets";
    
    // View/Edit mode: use ScreenHeader inside asset-hero
    // Create mode: show breadcrumb for context
    if (!Model.IsCreateMode)
    {
        ViewData["HasScreenHeader"] = true;
        // Do NOT set Breadcrumb - suppresses the header-breadcrumb row
    }
    else
    {
        ViewData["Breadcrumb"] = UiTerms.AssetManagement;
        ViewData["HasScreenHeader"] = true;
    }
}

@if (!Model.IsCreateMode)
{
    <div data-csp-style="padding: 1rem 2rem 0;">
        @await Html.PartialAsync("_BackLink")
    </div>
}


@if (TempData["Success"] != null)
{
    <div class="alert alert-success" data-csp-style="margin-bottom: 20px;">@TempData["Success"]</div>
}

@if (Model.HasConcurrencyConflict)
{
    <div class="alert alert-warning"
         role="alert"
         data-testid="asset-concurrency-banner" data-csp-style="margin: 0 2rem 1rem; padding: 1rem 1.25rem; background: #fef3c7; border: 1px solid #f59e0b; border-left: 4px solid #d97706; border-radius: 8px; color: #78350f; display: flex; gap: 0.75rem; align-items: flex-start;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-csp-style="flex-shrink: 0; margin-top: 2px;">
            <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
            <line x1="12" y1="9" x2="12" y2="13"></line>
            <line x1="12" y1="17" x2="12.01" y2="17"></line>
        </svg>
        <div>
            <strong>Conflict detected.</strong>
            <div asp-validation-summary="ModelOnly" class="text-danger" data-csp-style="margin-top: 0.25rem; color: #78350f;"></div>
            @if (Model.ConflictServerCopy != null)
            {
                <div data-csp-style="margin-top: 0.5rem; font-size: 0.875rem;">
                    Latest server value: <strong>@Model.ConflictServerCopy.Description</strong>
                    (modified by @(string.IsNullOrWhiteSpace(Model.ConflictServerCopy.ModifiedBy) ? "another user" : Model.ConflictServerCopy.ModifiedBy)).
                </div>
            }
        </div>
    </div>
}

<div class="asset-page">
    @if (!Model.IsCreateMode)
    {
        <!-- Rebuilt Asset Hero Card -->
        <div class="asset-hero">
            <div class="asset-hero-main">
                <div class="asset-hero-image">
                    @if (!string.IsNullOrEmpty(Model.Asset!.ImageUrl))
                    {
                        <img src="@Model.Asset.ImageUrl" alt="@Model.Asset.Description" id="assetImage" />
                    }
                    else
                    {
                        <div class="asset-photo-placeholder" id="assetImage">
                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" viewBox="0 0 24 24" stroke="currentColor" data-csp-style="opacity:0.3;">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                            <span data-csp-style="font-size:0.75rem;color:var(--lux-text-muted);margin-top:0.25rem;">No Photo</span>
                        </div>
                    }
                    <div class="image-upload-overlay" onclick="document.getElementById('imageUploadInput').click()">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                        <span>Change Image</span>
                    </div>
                    <form id="imageUploadForm" method="post" asp-page-handler="UploadImage" asp-route-id="@Model.Asset.Id" enctype="multipart/form-data" data-csp-style="display:none;">
                        <input type="file" id="imageUploadInput" name="imageFile" accept="image/*" onchange="document.getElementById('imageUploadForm').submit();" />
                    </form>
                    <div class="qr-code-badge" onclick="var p=document.getElementById('qrPanel');p.style.display=p.style.display==='none'?'':'none';" title="View QR Code">
                        <img src="https://api.qrserver.com/v1/create-qr-code/?size=64x64&data=@Uri.EscapeDataString($"ASSET:{Model.Asset.AssetNumber}")" alt="QR" />
                    </div>
                    @if (hasHealthScore)
                    {
                        <div class="health-ring">
                            <span class="health-ring-value">@healthScore</span>
                            <span class="health-ring-label">Health</span>
                        </div>
                    }
                </div>
                <div class="asset-hero-info">
                    @{
                        var statusTone = Model.Asset.Status switch {
                            AssetStatus.Active => "success",
                            AssetStatus.FullyDepreciated => "info",
                            AssetStatus.Disposed => "danger",
                            AssetStatus.Transferred => "warning",
                            AssetStatus.WrittenOff => "danger",
                            AssetStatus.Impaired => "warning",
                            AssetStatus.Held => "muted",
                            _ => "info"
                        };
                        var heroHeaderVd = new ViewDataDictionary(ViewData)
                        {
                            ["HeaderTitle"] = Model.Asset.AssetNumber,
                            ["Subtitle"] = Model.Asset.Description,
                            ["TypeLabel"] = $"{Model.Asset.AssetType} Asset",
                            ["StatusText"] = Model.Asset.Status.ToString(),
                            ["StatusTone"] = statusTone,
                            ["ContextPartial"] = "Assets/_AssetHeroContext",
                            ["KpisPartial"] = "Assets/_AssetHeroKpis",
                            ["ActionsPartial"] = "Assets/_AssetHeroActions"
                        };
                    }
                    @await Html.PartialAsync("Shared/_ScreenHeader", heroHeaderVd)
                </div>
            </div>
        </div>

        <!-- Quick Stats Row - Best of Breed Feature -->
        <div class="quick-stats-row">
            <div class="quick-stat-card">
                <div class="quick-stat-icon work-orders">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
                </div>
                <div class="quick-stat-content">
                    <div class="quick-stat-value @(Model.OpenWorkOrderCount > 0 ? "has-count" : "")">@Model.OpenWorkOrderCount</div>
                    <div class="quick-stat-label">Open Work Orders</div>
                </div>
            </div>
            <div class="quick-stat-card">
                <div class="quick-stat-icon next-pm @(Model.DaysUntilNextPM >= 0 && Model.DaysUntilNextPM <= 7 ? "urgent" : "")">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
                <div class="quick-stat-content">
                    @if (Model.DaysUntilNextPM >= 0)
                    {
                        <div class="quick-stat-value @(Model.DaysUntilNextPM <= 7 ? "warn" : "")">@Model.DaysUntilNextPM days</div>
                        <div class="quick-stat-label">Next PM Due</div>
                    }
                    else
                    {
                        <div class="quick-stat-value muted">—</div>
                        <div class="quick-stat-label">No PM Scheduled</div>
                    }
                </div>
            </div>
            <div class="quick-stat-card">
                <div class="quick-stat-icon last-maint">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <div class="quick-stat-content">
                    @if (Model.LastMaintenanceDate.HasValue)
                    {
                        <div class="quick-stat-value">@Model.LastMaintenanceDate.Value.ToString("MMM d, yyyy")</div>
                    }
                    else
                    {
                        <div class="quick-stat-value muted">—</div>
                    }
                    <div class="quick-stat-label">Last Maintenance</div>
                </div>
            </div>
            <div class="quick-stat-card">
                <div class="quick-stat-icon cost-ytd">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div class="quick-stat-content">
                    <div class="quick-stat-value">@Model.FormatMoney(Model.TotalMaintenanceCostYTD, Model.Asset.Currency)</div>
                    <div class="quick-stat-label">Maintenance Cost YTD</div>
                </div>
            </div>
            <div class="quick-stat-card clickable" onclick="document.querySelector('[data-tab=attachments]')?.click()">
                <div class="quick-stat-icon attachments">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg>
                </div>
                <div class="quick-stat-content">
                    <div class="quick-stat-value">@Model.Attachments.Count</div>
                    <div class="quick-stat-label">Attachments</div>
                </div>
            </div>
        </div>

        <!-- Activity Timeline - Best of Breed Feature -->
        @if (Model.RecentActivity.Any())
        {
            <div class="activity-timeline-card">
                <div class="activity-header">
                    <h3 class="activity-title">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        Recent Activity
                    </h3>
                    <a href="/operations/maintenance?assetId=@Model.Asset.Id" class="activity-view-all">View All</a>
                </div>
                <div class="activity-list">
                    @foreach (var activity in Model.RecentActivity)
                    {
                        <div class="activity-item">
                            <div class="activity-dot @activity.Status.ToString().ToLower()"></div>
                            <div class="activity-content">
                                <div class="activity-desc">@activity.Description</div>
                                <div class="activity-meta">
                                    <span class="activity-type">@activity.Type</span>
                                    <span class="activity-date">@activity.CreatedAt.ToString("MMM d, yyyy")</span>
                                </div>
                            </div>
                            <div class="activity-status @activity.Status.ToString().ToLower()">@Abs.FixedAssets.Helpers.StatusLabelExtensions.Humanize(activity.Status.ToString())</div>
                        </div>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <!-- Create Mode Header -->
        var createHeaderVd = new ViewDataDictionary(ViewData)
        {
            ["HeaderTitle"] = "Register Capital Asset",
            ["Subtitle"] = "Add a new machine, equipment, or capital asset to your inventory",
            ["TypeLabel"] = "New Asset",
            ["ShowBackLink"] = true,
            ["BackLinkFallback"] = ViewData["FallbackPage"] ?? "/Assets",
            ["BackLinkLabel"] = ViewData["FallbackLabel"] ?? "Assets"
        };
        @await Html.PartialAsync("Shared/_ScreenHeader", createHeaderVd)
    }

    @{
        var activeTab = Request.Query["tab"].FirstOrDefault() ?? "general";
    }
    <!-- Premium Tabs Card -->
    <div class="premium-tabs">
        <form method="post">
            <input type="hidden" asp-for="Asset.Id" />
            <input type="hidden" asp-for="Mode" />
            <input type="hidden" asp-for="Asset.CreatedAt" />
            <input type="hidden" asp-for="Asset.CreatedBy" />
            <input type="hidden" asp-for="Asset.RowVersion" />

            @{
                var assetTabs = new List<(string keyOrHref, string label, bool active, int? count, string? icon)> {
                    ("general", "General", activeTab == "general", null, null),
                    ("location", "Location", activeTab == "location", null, null),
                    ("financial", "Financial", activeTab == "financial", null, null),
                    ("technical", "Technical", activeTab == "technical", null, null),
                    ("mes", "MES/OEE", activeTab == "mes", null, null),
                    ("iot", "IoT", activeTab == "iot", null, null),
                    ("safety", "Safety", activeTab == "safety", null, null),
                    ("warranty", "Warranty", activeTab == "warranty", null, null)
                };
                if (!Model.IsCreateMode)
                {
                    assetTabs.Add(("hierarchy", "Hierarchy", activeTab == "hierarchy", null, null));
                    assetTabs.Add(("attachments", "Attachments", activeTab == "attachments", null, null));
                    assetTabs.Add(("transactions", "Transactions", activeTab == "transactions", null, null));
                }
            }
            @await Html.PartialAsync("_TabNav", new ViewDataDictionary(ViewData) {
                { "TabId", "asset-tabs" },
                { "Mode", "button" },
                { "UrlParam", "tab" },
                { "AriaLabel", "Asset detail sections" },
                { "Tabs", assetTabs }
            })

                <!-- General Tab -->
                <div class="tab-panel @(activeTab == "general" ? "active" : "")" id="panel-general" role="tabpanel" aria-labelledby="asset-tabs-general" @(activeTab != "general" ? Html.Raw("hidden") : null)>
                    <div class="spec-controls">
                        <button type="button" class="spec-control-btn" onclick="expandAllSections(this)">Expand All</button>
                        <button type="button" class="spec-control-btn" onclick="collapseAllSections(this)">Collapse All</button>
                    </div>
                    <div class="spec-card">
                        <div class="spec-header">
                            <span class="accent-dot accent-dot--blue"></span>
                            <span class="spec-title">Basic Information</span>
                            <span class="spec-chevron">▾</span>
                        </div>
                        <div class="spec-body">
                    <div class="form-section">
                        <h4 class="form-section-title">Basic Information</h4>
                        <div class="form-row">
                            <div class="form-group" data-csp-style="flex: 1;">
                                <label class="form-label">Asset Number *</label>
                                @if (isEditable)
                                {
                                    <input asp-for="Asset.AssetNumber" class="form-control" placeholder="e.g., AST-00001" />
                                    <span asp-validation-for="Asset.AssetNumber" class="form-error"></span>
                                }
                                else
                                {
                                    <div class="form-value">@Model.Asset!.AssetNumber</div>
                                }
                            </div>
                            <div class="form-group" data-csp-style="flex: 1;">
                                <label class="form-label">Tag Number</label>
                                @if (isEditable)
                                {
                                    <input asp-for="Asset.TagNumber" class="form-control" placeholder="Physical barcode tag" />
                                }
                                else
                                {
                                    <div class="form-value">@(Model.Asset!.TagNumber ?? "-")</div>
                                }
                            </div>
                            <div class="form-group" data-csp-style="flex: 1;">
                                <label class="form-label">Status</label>
                                @if (isEditable)
                                {
                                    <select asp-for="Asset.StatusLookupValueId" asp-items="Model.StatusOptions" class="form-select"></select>
                                }
                                else
                                {
                                    <div class="form-value"><span class="badge @(Model.Asset!.Status == AssetStatus.Active ? "badge-success" : "badge-secondary")">@Model.Asset!.Status</span></div>
                                }
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group" data-csp-style="flex: 2;">
                                <label class="form-label">Description *</label>
                                @if (isEditable)
                                {
                                    <input asp-for="Asset.Description" class="form-control" placeholder="Short description" />
                                    <span asp-validation-for="Asset.Description" class="form-error"></span>
                                }
                                else
                                {
                                    <div class="form-value">@Model.Asset!.Description</div>
                                }
                            </div>
                            <div class="form-group" data-csp-style="flex: 1;">
                                <label class="form-label">Asset Type</label>
                                @if (isEditable)
                                {
                                    <select asp-for="Asset.AssetTypeLookupValueId" asp-items="Model.AssetTypeOptions" class="form-control" data-cherry-select data-placeholder="Search asset types...">
                                    </select>
                                }
                                else
                                {
                                    <div class="form-value">@(Model.Asset!.AssetType ?? "-")</div>
                                }
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group" data-csp-style="flex: 1;">
                                <label class="form-label">Long Description</label>
                                @if (isEditable)
                                {
                                    <textarea asp-for="Asset.LongDescription" class="form-control" rows="2" placeholder="Detailed description"></textarea>
                                }
                                else
                                {
                                    <div class="form-value">@(Model.Asset!.LongDescription ?? "-")</div>
                                }
                            </div>
                        </div>
                    </div>
                        </div>
                    </div>

                    <div class="spec-card collapsed">
                        <div class="spec-header">
                            <span class="accent-dot accent-dot--emerald"></span>
                            <span class="spec-title">Identification</span>
                            <span class="spec-chevron">▾</span>
                        </div>
                        <div class="spec-body">
                    <div class="form-section">
                        <h4 class="form-section-title">Identification</h4>
                        <div class="form-row">
                            <div class="form-group" data-csp-style="flex: 1;">
                                <label class="form-label">Model</label>
                                @if (isEditable)
                                {
                                    <input asp-for="Asset.Model" class="form-control" placeholder="Model number" />
                                }
                                else
                                {
                                    <div class="form-value">@(Model.Asset!.Model ?? "-")</div>
                                }
                            </div>
                            <div class="form-group" data-csp-style="flex: 1;">
                                <label class="form-label">Serial Number</label>
                                @if (isEditable)
                                {
                                    <input asp-for="Asset.SerialNumber" class="form-control" placeholder="Serial number" />
                                }
                                else
                                {
                                    <div class="form-value">@(Model.Asset!.SerialNumber ?? "-")</div>
                                }
                            </div>
                            <div class="form-group" data-csp-style="flex: 1;">
                                <label class="form-label">Classification Code</label>
                                @if (isEditable)
                                {
                                    <input asp-for="Asset.ClassificationCode" class="form-control" placeholder="e.g., MACH-CNC" />
                                }
                                else
                                {
                                    <div class="form-value">@(Model.Asset!.ClassificationCode ?? "-")</div>
                                }
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group" data-csp-style="flex: 1;">
                                <label class="form-label">Manufacturer</label>
                                @if (isEditable)
                                {
                                    <select asp-for="Asset.ManufacturerId" class="form-control" data-cherry-select data-placeholder="Search manufacturers...">
                                        <option value="">-- Select --</option>
                                        @foreach (var m in Model.Manufacturers)
                                        {
                                            <option value="@m.Id" selected="@(Model.Asset!.ManufacturerId == m.Id)">@m.Name</option>
                                        }
                                    </select>
                                }
                                else
                                {
                                    <div class="form-value">@(Model.Asset!.Manufacturer?.Name ?? "-")</div>
                                }
                            </div>
                            <div class="form-group" data-csp-style="flex: 1;">
                                <label class="form-label">Vendor</label>
                                @if (isEditable)
                                {
                                    <select asp-for="Asset.VendorId" class="form-control" data-cherry-select data-placeholder="Search vendors...">
                                        <option value="">-- Select --</option>
                                        @foreach (var v in Model.Vendors)
                                        {
