@model Abs.FixedAssets.Pages.Assets.AssetModel

<div class="asset-tags">
    @if (Model.Asset.IsCritical) { <span class="asset-tag critical">Critical</span> }
    @if (Model.Asset.Priority <= 2) { <span class="asset-tag priority">Priority @Model.Asset.Priority</span> }
    @if (Model.Asset.WarrantyEndDate.HasValue)
    {
        var warrantyEnd = Model.Asset.WarrantyEndDate.Value;
        var warrantyDays = (warrantyEnd - DateTime.UtcNow.Date).Days;
        <span class="warranty-status-pill @(warrantyDays > 0 ? "" : "warranty-expired")">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            @(warrantyDays > 0 ? $"Warranty {warrantyDays} days" : $"Warranty Expired {warrantyEnd:MMM yyyy}")
        </span>
    }
</div>
<div class="hero-btns">
    @if (Model.IsViewMode)
    {
        <a href="?id=@Model.Asset.Id&mode=edit" class="hero-btn hero-btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            Edit Asset
        </a>
        <a asp-page="./Schedule" asp-route-id="@Model.Asset.Id" class="hero-btn hero-btn-ghost">Depreciation</a>
        @if (Model.Asset.Active)
        {
            <a asp-page="./Improve" asp-route-id="@Model.Asset.Id" class="hero-btn hero-btn-ghost">Improve</a>
            <a asp-page="./Transfer" asp-route-id="@Model.Asset.Id" class="hero-btn hero-btn-ghost">Transfer</a>
            <a asp-page="./Dispose" asp-route-id="@Model.Asset.Id" class="hero-btn hero-btn-danger">Dispose</a>
        }
    }
    else if (Model.IsEditMode)
    {
        <a href="?id=@Model.Asset.Id&mode=view" class="hero-btn hero-btn-ghost">Cancel</a>
    }
</div>
