@model Abs.FixedAssets.Pages.Assets.AssetModel
@{
    var isEditable = Model.IsEditMode || Model.IsCreateMode;
    var activeSubtab = Context.Request.Query["subtab"].FirstOrDefault() ?? "mes";
}

@await Html.PartialAsync("_TabNav", new ViewDataDictionary(ViewData) {
    { "TabId", "asset-mes-tabs" },
    { "Mode", "button" },
    { "Variant", "compact" },
    { "UrlParam", "subtab" },
    { "AriaLabel", "MES/IoT/Safety sections" },
    { "Tabs", new (string keyOrHref, string label, bool active, int? count, string? icon)[] {
        ("mes", "MES/OEE", activeSubtab == "mes", null, null),
        ("iot", "IoT", activeSubtab == "iot", null, null),
        ("safety", "Safety", activeSubtab == "safety", null, null)
    }}
})

<!-- MES/OEE Tab -->
<div class="tab-panel @(activeSubtab == "mes" ? "active" : "")" id="panel-mes" role="tabpanel" aria-labelledby="asset-mes-tabs-mes" @(activeSubtab != "mes" ? Html.Raw("hidden") : null)>
    <div class="form-section">
        <h4 class="form-section-title">Work Center Assignment</h4>
        <div class="form-row">
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Work Center ID</label>
                @if (isEditable) { <input asp-for="Asset.WorkCenterId" class="form-control" placeholder="e.g., WC-001" /> }
                else { <div class="form-value">@(Model.Asset.WorkCenterId ?? "-")</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Work Center Name</label>
                @if (isEditable) { <input asp-for="Asset.WorkCenterName" class="form-control" placeholder="e.g., CNC Machining" /> }
                else { <div class="form-value">@(Model.Asset.WorkCenterName ?? "-")</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Production Line</label>
                @if (isEditable) { <input asp-for="Asset.ProductionLineId" class="form-control" placeholder="e.g., LINE-A" /> }
                else { <div class="form-value">@(Model.Asset.ProductionLineName ?? Model.Asset.ProductionLineId ?? "-")</div> }
            </div>
        </div>
        <div class="form-row">
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Cell ID</label>
                @if (isEditable) { <input asp-for="Asset.CellId" class="form-control" placeholder="e.g., CELL-01" /> }
                else { <div class="form-value">@(Model.Asset.CellId ?? "-")</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Process ID</label>
                @if (isEditable) { <input asp-for="Asset.ProcessId" class="form-control" placeholder="e.g., PROC-100" /> }
                else { <div class="form-value">@(Model.Asset.ProcessId ?? "-")</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Operation ID</label>
                @if (isEditable) { <input asp-for="Asset.OperationId" class="form-control" placeholder="e.g., OP-010" /> }
                else { <div class="form-value">@(Model.Asset.OperationId ?? "-")</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Routing Sequence</label>
                @if (isEditable) { <input asp-for="Asset.RoutingSequence" type="number" class="form-control" placeholder="e.g., 10" /> }
                else { <div class="form-value">@(Model.Asset.RoutingSequence?.ToString() ?? "-")</div> }
            </div>
        </div>
        <div class="form-row">
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Shift Calendar</label>
                @if (isEditable) { <input asp-for="Asset.ShiftCalendarId" class="form-control" placeholder="e.g., 3-SHIFT" /> }
                else { <div class="form-value">@(Model.Asset.ShiftCalendarId ?? "-")</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Planned Hours/Day</label>
                @if (isEditable) { <input asp-for="Asset.PlannedProductionHoursPerDay" type="number" class="form-control" placeholder="e.g., 16" /> }
                else { <div class="form-value">@(Model.Asset.PlannedProductionHoursPerDay?.ToString() ?? "-")</div> }
            </div>
        </div>
    </div>

    <div class="form-section">
        <h4 class="form-section-title">OEE Configuration</h4>
        <div class="form-row">
            @if (isEditable)
            {
                <div class="form-group" style="flex: 1;">
                    <label class="checkbox-label">
                        <input asp-for="Asset.OEETracked" type="checkbox" />
                        <span class="checkbox-text">OEE Tracked</span>
                    </label>
                </div>
            }
            else
            {
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">OEE Tracked</label>
                    <div class="form-value"><span class="badge @(Model.Asset.OEETracked ? "badge-success" : "badge-secondary")">@(Model.Asset.OEETracked ? "Yes" : "No")</span></div>
                </div>
            }
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Standard Run Rate</label>
                @if (isEditable) { <input asp-for="Asset.StandardRunRate" type="number" step="0.0001" class="form-control" placeholder="Units per hour" /> }
                else { <div class="form-value">@(Model.Asset.StandardRunRate?.ToString("N2") ?? "-") @(Model.Asset.StandardRunRateUOM ?? "units/hr")</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Ideal Cycle Time (sec)</label>
                @if (isEditable) { <input asp-for="Asset.IdealCycleTimeSeconds" type="number" step="0.0001" class="form-control" placeholder="Seconds per unit" /> }
                else { <div class="form-value">@(Model.Asset.IdealCycleTimeSeconds?.ToString("N2") ?? "-") sec</div> }
            </div>
        </div>
        <div class="form-row">
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Target Availability %</label>
                @if (isEditable) { <input asp-for="Asset.TargetAvailability" type="number" step="0.01" class="form-control" placeholder="e.g., 90.00" /> }
                else { <div class="form-value">@(Model.Asset.TargetAvailability?.ToString("N1") ?? "-")%</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Target Performance %</label>
                @if (isEditable) { <input asp-for="Asset.TargetPerformance" type="number" step="0.01" class="form-control" placeholder="e.g., 95.00" /> }
                else { <div class="form-value">@(Model.Asset.TargetPerformance?.ToString("N1") ?? "-")%</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Target Quality %</label>
                @if (isEditable) { <input asp-for="Asset.TargetQuality" type="number" step="0.01" class="form-control" placeholder="e.g., 99.50" /> }
                else { <div class="form-value">@(Model.Asset.TargetQuality?.ToString("N1") ?? "-")%</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Target OEE %</label>
                @if (isEditable) { <input asp-for="Asset.TargetOEE" type="number" step="0.01" class="form-control" placeholder="e.g., 85.00" /> }
                else { <div class="form-value"><strong>@(Model.Asset.TargetOEE?.ToString("N1") ?? "-")%</strong></div> }
            </div>
        </div>
        @if (!Model.IsCreateMode && !isEditable)
        {
            <div class="form-row" style="margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border);">
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Current Availability</label>
                    <div class="form-value">@(Model.Asset.CurrentAvailability?.ToString("N1") ?? "-")%</div>
                </div>
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Current Performance</label>
                    <div class="form-value">@(Model.Asset.CurrentPerformance?.ToString("N1") ?? "-")%</div>
                </div>
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Current Quality</label>
                    <div class="form-value">@(Model.Asset.CurrentQuality?.ToString("N1") ?? "-")%</div>
                </div>
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Current OEE</label>
                    <div class="form-value"><strong>@(Model.Asset.CurrentOEE?.ToString("N1") ?? "-")%</strong></div>
                </div>
            </div>
        }
    </div>

    <div class="form-section">
        <h4 class="form-section-title">Predictive Maintenance Thresholds</h4>
        <div class="form-row">
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Vibration Warning (mm/s)</label>
                @if (isEditable) { <input asp-for="Asset.VibrationWarningThreshold" type="number" step="0.001" class="form-control" /> }
                else { <div class="form-value">@(Model.Asset.VibrationWarningThreshold?.ToString("N2") ?? "-")</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Vibration Alarm (mm/s)</label>
                @if (isEditable) { <input asp-for="Asset.VibrationAlarmThreshold" type="number" step="0.001" class="form-control" /> }
                else { <div class="form-value">@(Model.Asset.VibrationAlarmThreshold?.ToString("N2") ?? "-")</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Temp Warning (°C)</label>
                @if (isEditable) { <input asp-for="Asset.TemperatureWarningThreshold" type="number" step="0.01" class="form-control" /> }
                else { <div class="form-value">@(Model.Asset.TemperatureWarningThreshold?.ToString("N1") ?? "-")</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Temp Alarm (°C)</label>
                @if (isEditable) { <input asp-for="Asset.TemperatureAlarmThreshold" type="number" step="0.01" class="form-control" /> }
                else { <div class="form-value">@(Model.Asset.TemperatureAlarmThreshold?.ToString("N1") ?? "-")</div> }
            </div>
        </div>
        <div class="form-row">
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Pressure Warning</label>
                @if (isEditable) { <input asp-for="Asset.PressureWarningThreshold" type="number" step="0.01" class="form-control" /> }
                else { <div class="form-value">@(Model.Asset.PressureWarningThreshold?.ToString("N1") ?? "-") @(Model.Asset.PressureUOM ?? "PSI")</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Pressure Alarm</label>
                @if (isEditable) { <input asp-for="Asset.PressureAlarmThreshold" type="number" step="0.01" class="form-control" /> }
                else { <div class="form-value">@(Model.Asset.PressureAlarmThreshold?.ToString("N1") ?? "-") @(Model.Asset.PressureUOM ?? "PSI")</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Pressure UOM</label>
                @if (isEditable)
                {
                    <select asp-for="Asset.PressureUOM" asp-items="Model.PressureUnitOptions" class="form-control">
                    </select>
                }
                else { <div class="form-value">@(Model.Asset.PressureUOM ?? "-")</div> }
            </div>
        </div>
    </div>
</div>

<!-- IoT Tab -->
<div class="tab-panel @(activeSubtab == "iot" ? "active" : "")" id="panel-iot" role="tabpanel" aria-labelledby="asset-mes-tabs-iot" @(activeSubtab != "iot" ? Html.Raw("hidden") : null)>
    <div class="form-section">
        <h4 class="form-section-title">IoT Device Configuration</h4>
        <div class="form-row">
            @if (isEditable)
            {
                <div class="form-group" style="flex: 1;">
                    <label class="checkbox-label">
                        <input asp-for="Asset.IoTEnabled" type="checkbox" />
                        <span class="checkbox-text">IoT Enabled</span>
                    </label>
                </div>
            }
            else
            {
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">IoT Enabled</label>
                    <div class="form-value"><span class="badge @(Model.Asset.IoTEnabled ? "badge-success" : "badge-secondary")">@(Model.Asset.IoTEnabled ? "Yes" : "No")</span></div>
                </div>
            }
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Device ID</label>
                @if (isEditable) { <input asp-for="Asset.IoTDeviceId" class="form-control" placeholder="e.g., DEV-001-CNC" /> }
                else { <div class="form-value">@(Model.Asset.IoTDeviceId ?? "-")</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Gateway ID</label>
                @if (isEditable) { <input asp-for="Asset.IoTGatewayId" class="form-control" placeholder="e.g., GW-PLANT1" /> }
                else { <div class="form-value">@(Model.Asset.IoTGatewayId ?? "-")</div> }
            </div>
        </div>
        <div class="form-row">
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Protocol</label>
                @if (isEditable)
                {
                    <select asp-for="Asset.IoTProtocol" asp-items="Model.IoTProtocolOptions" class="form-control">
                    </select>
                }
                else { <div class="form-value">@(Model.Asset.IoTProtocol ?? "-")</div> }
            </div>
            <div class="form-group" style="flex: 2;">
                <label class="form-label">Endpoint URL</label>
                @if (isEditable) { <input asp-for="Asset.IoTEndpointUrl" class="form-control" placeholder="e.g., opc.tcp://192.168.1.100:4840" /> }
                else { <div class="form-value">@(Model.Asset.IoTEndpointUrl ?? "-")</div> }
            </div>
        </div>
        <div class="form-row">
            <div class="form-group" style="flex: 1;">
                <label class="form-label">IP Address</label>
                @if (isEditable) { <input asp-for="Asset.IPAddress" class="form-control" placeholder="e.g., 192.168.1.100" /> }
                else { <div class="form-value">@(Model.Asset.IPAddress ?? "-")</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">MAC Address</label>
                @if (isEditable) { <input asp-for="Asset.MACAddress" class="form-control" placeholder="e.g., 00:1A:2B:3C:4D:5E" /> }
                else { <div class="form-value">@(Model.Asset.MACAddress ?? "-")</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Polling Interval (sec)</label>
                @if (isEditable) { <input asp-for="Asset.IoTPollingIntervalSeconds" type="number" class="form-control" placeholder="e.g., 60" /> }
                else { <div class="form-value">@(Model.Asset.IoTPollingIntervalSeconds?.ToString() ?? "-") sec</div> }
            </div>
        </div>
    </div>

    <div class="form-section">
        <h4 class="form-section-title">Data Integration</h4>
        <div class="form-row">
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Data Historian Tag</label>
                @if (isEditable) { <input asp-for="Asset.DataHistorianTag" class="form-control" placeholder="e.g., PLANT1.CNC01.TEMP" /> }
                else { <div class="form-value">@(Model.Asset.DataHistorianTag ?? "-")</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">SCADA Tag</label>
                @if (isEditable) { <input asp-for="Asset.SCADATag" class="form-control" placeholder="e.g., CNC01_STATUS" /> }
                else { <div class="form-value">@(Model.Asset.SCADATag ?? "-")</div> }
            </div>
        </div>
    </div>

    @if (!Model.IsCreateMode && !isEditable)
    {
        <div class="form-section">
            <h4 class="form-section-title">Connection Status</h4>
            <div class="form-row">
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Status</label>
                    <div class="form-value">
                        @{
                            var status = Model.Asset.IoTConnectionStatus ?? "Unknown";
                            var statusClass = status == "Online" ? "badge-success" : status == "Offline" ? "badge-danger" : "badge-secondary";
                        }
                        <span class="badge @statusClass">@status</span>
                    </div>
                </div>
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Last Communication</label>
                    <div class="form-value">@(Model.Asset.LastIoTCommunication?.ToString("g") ?? "-")</div>
                </div>
            </div>
        </div>

        <div class="form-section">
            <h4 class="form-section-title">Current Sensor Readings</h4>
            <div class="form-row">
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Temperature</label>
                    <div class="form-value">@(Model.Asset.CurrentTemperature?.ToString("N1") ?? "-") °C</div>
                </div>
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Vibration</label>
                    <div class="form-value">@(Model.Asset.CurrentVibration?.ToString("N2") ?? "-") mm/s</div>
                </div>
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Pressure</label>
                    <div class="form-value">@(Model.Asset.CurrentPressure?.ToString("N1") ?? "-") @(Model.Asset.PressureUOM ?? "PSI")</div>
                </div>
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Last Updated</label>
                    <div class="form-value">@(Model.Asset.SensorReadingsLastUpdated?.ToString("g") ?? "-")</div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Safety Tab -->
<div class="tab-panel @(activeSubtab == "safety" ? "active" : "")" id="panel-safety" role="tabpanel" aria-labelledby="asset-mes-tabs-safety" @(activeSubtab != "safety" ? Html.Raw("hidden") : null)>
    <div class="form-section">
        <h4 class="form-section-title">Safety Classification</h4>
        <div class="form-row">
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Safety Class</label>
                @if (isEditable)
                {
                    <select asp-for="Asset.SafetyClassification" asp-items="Model.SafetyClassOptions" class="form-control">
                    </select>
                }
                else
                {
                    <div class="form-value">
                        @{
                            var safetyClass = Model.Asset.SafetyClassification ?? "Not Classified";
                            var safetyBadge = safetyClass == "Critical" ? "badge-danger" : safetyClass == "High" ? "badge-warning" : "badge-secondary";
                        }
                        <span class="badge @safetyBadge">@safetyClass</span>
                    </div>
                }
            </div>
            @if (isEditable)
            {
                <div class="form-group" style="flex: 1;">
                    <label class="checkbox-label">
                        <input asp-for="Asset.LockoutTagoutRequired" type="checkbox" />
                        <span class="checkbox-text">LOTO Required</span>
                    </label>
                </div>
            }
            else
            {
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">LOTO Required</label>
                    <div class="form-value"><span class="badge @(Model.Asset.LockoutTagoutRequired ? "badge-danger" : "badge-secondary")">@(Model.Asset.LockoutTagoutRequired ? "Yes" : "No")</span></div>
                </div>
            }
            <div class="form-group" style="flex: 1;">
                <label class="form-label">LOTO Procedure ID</label>
                @if (isEditable) { <input asp-for="Asset.LOTOProcedureId" class="form-control" placeholder="e.g., LOTO-CNC-001" /> }
                else { <div class="form-value">@(Model.Asset.LOTOProcedureId ?? "-")</div> }
            </div>
        </div>
        <div class="form-row">
            @if (isEditable)
            {
                <div class="form-group" style="flex: 1;">
                    <label class="checkbox-label"><input asp-for="Asset.ConfinedSpaceEntry" type="checkbox" /><span class="checkbox-text">Confined Space Entry</span></label>
                </div>
                <div class="form-group" style="flex: 1;">
                    <label class="checkbox-label"><input asp-for="Asset.HotWorkPermitRequired" type="checkbox" /><span class="checkbox-text">Hot Work Permit</span></label>
                </div>
                <div class="form-group" style="flex: 1;">
                    <label class="checkbox-label"><input asp-for="Asset.HighVoltage" type="checkbox" /><span class="checkbox-text">High Voltage</span></label>
                </div>
            }
            else
            {
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Confined Space</label>
                    <div class="form-value"><span class="badge @(Model.Asset.ConfinedSpaceEntry ? "badge-warning" : "badge-secondary")">@(Model.Asset.ConfinedSpaceEntry ? "Yes" : "No")</span></div>
                </div>
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Hot Work Permit</label>
                    <div class="form-value"><span class="badge @(Model.Asset.HotWorkPermitRequired ? "badge-warning" : "badge-secondary")">@(Model.Asset.HotWorkPermitRequired ? "Yes" : "No")</span></div>
                </div>
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">High Voltage</label>
                    <div class="form-value"><span class="badge @(Model.Asset.HighVoltage ? "badge-danger" : "badge-secondary")">@(Model.Asset.HighVoltage ? "Yes" : "No")</span></div>
                </div>
            }
        </div>
        <div class="form-row">
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Safety Notes</label>
                @if (isEditable) { <textarea asp-for="Asset.SafetyNotes" class="form-control" rows="2" placeholder="Special safety requirements..."></textarea> }
                else { <div class="form-value">@(Model.Asset.SafetyNotes ?? "-")</div> }
            </div>
        </div>
    </div>

    <div class="form-section">
        <h4 class="form-section-title">Environmental & Regulatory</h4>
        <div class="form-row">
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Environmental Class</label>
                @if (isEditable) { <input asp-for="Asset.EnvironmentalClass" class="form-control" placeholder="e.g., Class I" /> }
                else { <div class="form-value">@(Model.Asset.EnvironmentalClass ?? "-")</div> }
            </div>
            @if (isEditable)
            {
                <div class="form-group" style="flex: 1;">
                    <label class="checkbox-label"><input asp-for="Asset.EmissionsMonitored" type="checkbox" /><span class="checkbox-text">Emissions Monitored</span></label>
                </div>
            }
            else
            {
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Emissions Monitored</label>
                    <div class="form-value"><span class="badge @(Model.Asset.EmissionsMonitored ? "badge-warning" : "badge-secondary")">@(Model.Asset.EmissionsMonitored ? "Yes" : "No")</span></div>
                </div>
            }
            <div class="form-group" style="flex: 1;">
                <label class="form-label">EPA Permit #</label>
                @if (isEditable) { <input asp-for="Asset.EPAPermitNumber" class="form-control" /> }
                else { <div class="form-value">@(Model.Asset.EPAPermitNumber ?? "-")</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">OSHA Classification</label>
                @if (isEditable) { <input asp-for="Asset.OSHAClassification" class="form-control" /> }
                else { <div class="form-value">@(Model.Asset.OSHAClassification ?? "-")</div> }
            </div>
        </div>
    </div>

    <div class="form-section">
        <h4 class="form-section-title">Calibration</h4>
        <div class="form-row">
            @if (isEditable)
            {
                <div class="form-group" style="flex: 1;">
                    <label class="checkbox-label"><input asp-for="Asset.CalibrationRequired" type="checkbox" /><span class="checkbox-text">Calibration Required</span></label>
                </div>
            }
            else
            {
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Calibration Required</label>
                    <div class="form-value"><span class="badge @(Model.Asset.CalibrationRequired ? "badge-primary" : "badge-secondary")">@(Model.Asset.CalibrationRequired ? "Yes" : "No")</span></div>
                </div>
            }
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Calibration Type</label>
                @if (isEditable) { <input asp-for="Asset.CalibrationType" class="form-control" placeholder="e.g., Annual" /> }
                else { <div class="form-value">@(Model.Asset.CalibrationType ?? "-")</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Frequency (Days)</label>
                @if (isEditable) { <input asp-for="Asset.CalibrationFrequencyDays" type="number" class="form-control" /> }
                else { <div class="form-value">@(Model.Asset.CalibrationFrequencyDays?.ToString() ?? "-") days</div> }
            </div>
        </div>
        <div class="form-row">
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Last Calibration</label>
                @if (isEditable) { <input asp-for="Asset.LastCalibrationDate" type="date" class="form-control" /> }
                else { <div class="form-value">@(Model.Asset.LastCalibrationDate?.ToString("yyyy-MM-dd") ?? "-")</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Next Due</label>
                @if (isEditable) { <input asp-for="Asset.NextCalibrationDue" type="date" class="form-control" /> }
                else
                {
                    <div class="form-value">
                        @if (Model.Asset.NextCalibrationDue.HasValue)
                        {
                            var isOverdue = Model.Asset.NextCalibrationDue.Value < DateTime.Today;
                            <span class="badge @(isOverdue ? "badge-danger" : "badge-success")">@Model.Asset.NextCalibrationDue.Value.ToString("yyyy-MM-dd") @(isOverdue ? "(Overdue)" : "")</span>
                        }
                        else { <text>-</text> }
                    </div>
                }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Certificate #</label>
                @if (isEditable) { <input asp-for="Asset.CalibrationCertificateNumber" class="form-control" /> }
                else { <div class="form-value">@(Model.Asset.CalibrationCertificateNumber ?? "-")</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Calibration Vendor</label>
                @if (isEditable) { <input asp-for="Asset.CalibrationVendor" class="form-control" /> }
                else { <div class="form-value">@(Model.Asset.CalibrationVendor ?? "-")</div> }
            </div>
        </div>
    </div>

    <div class="form-section">
        <h4 class="form-section-title">Energy Management</h4>
        <div class="form-row">
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Energy Class</label>
                @if (isEditable)
                {
                    <select asp-for="Asset.EnergyClass" asp-items="Model.EnergyEfficiencyOptions" class="form-control">
                    </select>
                }
                else { <div class="form-value">@(Model.Asset.EnergyClass ?? "-")</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Rated Power (kW)</label>
                @if (isEditable) { <input asp-for="Asset.RatedPowerConsumptionKW" type="number" step="0.01" class="form-control" /> }
                else { <div class="form-value">@(Model.Asset.RatedPowerConsumptionKW?.ToString("N2") ?? "-") kW</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Idle Power (kW)</label>
                @if (isEditable) { <input asp-for="Asset.IdlePowerConsumptionKW" type="number" step="0.01" class="form-control" /> }
                else { <div class="form-value">@(Model.Asset.IdlePowerConsumptionKW?.ToString("N2") ?? "-") kW</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Standby Power (kW)</label>
                @if (isEditable) { <input asp-for="Asset.StandbyPowerConsumptionKW" type="number" step="0.01" class="form-control" /> }
                else { <div class="form-value">@(Model.Asset.StandbyPowerConsumptionKW?.ToString("N2") ?? "-") kW</div> }
            </div>
        </div>
        <div class="form-row">
            @if (isEditable)
            {
                <div class="form-group" style="flex: 1;">
                    <label class="checkbox-label"><input asp-for="Asset.HasStandbyMode" type="checkbox" /><span class="checkbox-text">Has Standby Mode</span></label>
                </div>
            }
            else
            {
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Has Standby Mode</label>
                    <div class="form-value">@(Model.Asset.HasStandbyMode ? "Yes" : "No")</div>
                </div>
            }
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Annual Energy (kWh)</label>
                @if (isEditable) { <input asp-for="Asset.AnnualEnergyConsumptionKWH" type="number" step="0.01" class="form-control" /> }
                else { <div class="form-value">@(Model.Asset.AnnualEnergyConsumptionKWH?.ToString("N0") ?? "-") kWh</div> }
            </div>
            <div class="form-group" style="flex: 1;">
                <label class="form-label">Energy Meter ID</label>
                @if (isEditable) { <input asp-for="Asset.EnergyMeterId" class="form-control" /> }
                else { <div class="form-value">@(Model.Asset.EnergyMeterId ?? "-")</div> }
            </div>
        </div>
    </div>
</div>
