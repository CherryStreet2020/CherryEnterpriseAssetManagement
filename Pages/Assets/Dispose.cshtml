@page "{id:int}"
@model Abs.FixedAssets.Pages.Assets.DisposeModel
@{
    ViewData["Title"] = "Disposals";
    Layout = "_ModernLayout";
    ViewData["HasScreenHeader"] = true;
    
    var headerVd = new ViewDataDictionary(ViewData)
    {
        ["HeaderTitle"] = "Disposals",
        ["Subtitle"] = "Record disposal, sale, or retirement of a fixed asset",
        ["TypeLabel"] = "Asset Workflow",
        ["StatusText"] = "Disposal",
        ["StatusTone"] = "warning",
        ["ContextText"] = $"{Model.Asset?.AssetNumber} / {Model.CurrentBookValue:C0} NBV",
        ["ShowBackLink"] = true,
        ["BackLinkFallback"] = $"/Assets/Asset/{Model.AssetId}",
        ["BackLinkLabel"] = "Back to Asset"
    };
}
@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}
@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}

<form method="post">
    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Asset Information
            </h3>
        </div>
        <div class="section-card-body">
            <div class="asset-info-grid">
                <div class="info-item">
                    <label>Asset Number</label>
                    <div class="info-value">@Model.Asset?.AssetNumber</div>
                </div>
                <div class="info-item">
                    <label>Description</label>
                    <div class="info-value">@Model.Asset?.Description</div>
                </div>
                <div class="info-item">
                    <label>Original Cost</label>
                    <div class="info-value">@Model.Asset?.AcquisitionCost.ToString("C2")</div>
                </div>
                <div class="info-item">
                    <label>In Service Date</label>
                    <div class="info-value">@Model.Asset?.InServiceDate.ToString("MMM dd, yyyy")</div>
                </div>
                <div class="info-item">
                    <label>Accumulated Depreciation</label>
                    <div class="info-value">@Model.Asset?.AccumulatedDepreciation.ToString("C2")</div>
                </div>
                <div class="info-item">
                    <label>Current Book Value</label>
                    <div class="info-value highlight">@Model.CurrentBookValue.ToString("C2")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                Disposal Details
            </h3>
        </div>
        <div class="section-card-body">
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="DisposalDate" class="form-label">Disposal Date *</label>
                    <input asp-for="DisposalDate" type="date" class="form-control" required />
                    <span asp-validation-for="DisposalDate" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="DisposalType" class="form-label">Disposal Type *</label>
                    <select asp-for="DisposalReasonLookupValueId" asp-items="Model.DisposalReasonOptions" class="form-control" required data-cherry-select data-placeholder="Search disposal reasons...">
                    </select>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Proceeds" class="form-label">Sale Proceeds</label>
                    <div class="input-group-currency">
                        <span class="currency-prefix">$</span>
                        <input asp-for="Proceeds" type="number" step="0.01" class="form-control" placeholder="0.00" />
                    </div>
                    <span class="form-help">Enter 0 for retirement/scrap with no proceeds</span>
                </div>
                <div class="form-group">
                    <label asp-for="DisposalExpense" class="form-label">Disposal Expense</label>
                    <div class="input-group-currency">
                        <span class="currency-prefix">$</span>
                        <input asp-for="DisposalExpense" type="number" step="0.01" class="form-control" placeholder="0.00" />
                    </div>
                    <span class="form-help">Removal costs, commissions, fees</span>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group full-width">
                    <label asp-for="Notes" class="form-label">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Additional disposal notes..."></textarea>
                </div>
            </div>
        </div>
    </div>

    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                </svg>
                Gain/Loss Preview
            </h3>
        </div>
        <div class="section-card-body">
            <div class="preview-grid" id="previewGrid">
                <div class="preview-item">
                    <label>Original Cost</label>
                    <span class="value" id="prevCost">@Model.Asset?.AcquisitionCost.ToString("C2")</span>
                </div>
                <div class="preview-item">
                    <label>Less: Accumulated Depreciation</label>
                    <span class="value" id="prevAccum">(@Model.Asset?.AccumulatedDepreciation.ToString("C2"))</span>
                </div>
                <div class="preview-item">
                    <label>Book Value</label>
                    <span class="value" id="prevBookValue">@Model.CurrentBookValue.ToString("C2")</span>
                </div>
                <div class="preview-item">
                    <label>Less: Disposal Expense</label>
                    <span class="value" id="prevExpense">($0.00)</span>
                </div>
                <div class="preview-item">
                    <label>Net Proceeds</label>
                    <span class="value" id="prevProceeds">$0.00</span>
                </div>
                <div class="preview-item highlight-result">
                    <label>Gain / (Loss)</label>
                    <span class="value result-value" id="prevGainLoss">$0.00</span>
                </div>
            </div>
        </div>
    </div>

    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                Journal Entry Options
            </h3>
        </div>
        <div class="section-card-body">
            <div class="form-check">
                <input asp-for="CreateJournalEntry" type="checkbox" class="form-check-input" id="createJournal" checked />
                <label class="form-check-label" for="createJournal">
                    Create disposal journal entry automatically
                </label>
            </div>
            <div class="form-group" id="bookSelectGroup">
                <label asp-for="BookId" class="form-label">Book</label>
                <select asp-for="BookId" asp-items="Model.BookOptions" class="form-control"></select>
            </div>
        </div>
    </div>

    <div class="section-card">
        <div class="section-card-body" style="display: flex; justify-content: flex-end; gap: 1rem;">
            <a asp-page="/Assets/Asset" asp-route-id="@Model.AssetId" class="btn-p btn-p--secondary">Cancel</a>
            <button type="submit" class="btn-p btn-p--danger">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
                Record Disposal
            </button>
        </div>
    </div>
</form>


<script>
    document.addEventListener('DOMContentLoaded', function() {
        const proceedsInput = document.querySelector('[name="Proceeds"]');
        const expenseInput = document.querySelector('[name="DisposalExpense"]');
        const bookValue = @Model.CurrentBookValue;
        const cost = @(Model.Asset?.AcquisitionCost ?? 0m);
        const accum = @(Model.Asset?.AccumulatedDepreciation ?? 0m);

        function updatePreview() {
            const proceeds = parseFloat(proceedsInput.value) || 0;
            const expense = parseFloat(expenseInput.value) || 0;
            const netProceeds = proceeds - expense;
            const gainLoss = netProceeds - bookValue;

            document.getElementById('prevProceeds').textContent = formatMoney(proceeds);
            document.getElementById('prevExpense').textContent = '(' + formatMoney(expense) + ')';
            document.getElementById('prevGainLoss').textContent = formatMoney(gainLoss);

            const resultEl = document.getElementById('prevGainLoss');
            resultEl.classList.remove('gain', 'loss');
            if (gainLoss > 0) resultEl.classList.add('gain');
            else if (gainLoss < 0) resultEl.classList.add('loss');
        }

        function formatMoney(value) {
            return '$' + value.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        proceedsInput.addEventListener('input', updatePreview);
        expenseInput.addEventListener('input', updatePreview);

        const createJournalCheck = document.getElementById('createJournal');
        const bookSelectGroup = document.getElementById('bookSelectGroup');
        createJournalCheck.addEventListener('change', function() {
            bookSelectGroup.style.display = this.checked ? 'block' : 'none';
        });
    });
</script>
