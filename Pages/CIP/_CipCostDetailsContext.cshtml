@{
    var project = ViewData["Project"] as Abs.FixedAssets.Models.CipProject;
    var cost = ViewData["Cost"] as Abs.FixedAssets.Models.CipCost;
}
@if (project != null && cost != null)
{
    <div class="screen-header__context">
        <span class="loc-pill">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
            @project.ProjectNumber
        </span>
        <span class="loc-divider">/</span>
        <span class="loc-pill">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            @cost.TransactionDate.ToString("MMM dd, yyyy")
        </span>
    </div>
}
