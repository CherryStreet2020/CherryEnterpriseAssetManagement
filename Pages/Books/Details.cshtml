@page "{id:int}"
@model Abs.FixedAssets.Pages.Books.DetailsModel
@{
    ViewData["Title"] = "Book Details";
    Layout = "_ModernLayout";
    ViewData["HasScreenHeader"] = true;
    
    var statusText = Model.Book.IsActive ? "Active" : "Inactive";
    var statusTone = Model.Book.IsActive ? "success" : "muted";
    var headerVd = new ViewDataDictionary(ViewData)
    {
        ["HeaderTitle"] = Model.Book.Code,
        ["Subtitle"] = Model.Book.Name,
        ["TypeLabel"] = "Depreciation",
        ["StatusText"] = statusText,
        ["StatusTone"] = statusTone,
        ["ContextText"] = $"{Model.Book.BookType} Book",
        ["ShowBackLink"] = true,
        ["BackLinkFallback"] = "/Books",
        ["BackLinkLabel"] = "Back to results",
        ["Breadcrumbs"] = ViewData["Breadcrumbs"]
    };
}
@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

<div class="screen-header__actions">
    <div class="hero-btns">
        <a asp-page="./Edit" asp-route-id="@Model.Book.Id" class="hero-btn hero-btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
            Edit Book
        </a>
    </div>
</div>

<div class="section-card">
    <div class="section-card-header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
            Book Information
        </h3>
        <span class="status-badge @(Model.Book.IsActive ? "success" : "secondary")">@(Model.Book.IsActive ? "ACTIVE" : "INACTIVE")</span>
    </div>
    <div class="section-card-body">
        <div class="row g-4">
            <div class="col-md-6">
                <dl class="detail-list">
                    <div class="detail-item">
                        <dt>Code</dt>
                        <dd><strong>@Model.Book.Code</strong></dd>
                    </div>
                    <div class="detail-item">
                        <dt>Name</dt>
                        <dd>@Model.Book.Name</dd>
                    </div>
                    <div class="detail-item">
                        <dt>Book Type</dt>
                        <dd><span class="badge badge-outline">@Model.Book.BookType</span></dd>
                    </div>
                    <div class="detail-item">
                        <dt>Description</dt>
                        <dd>@(Model.Book.Description ?? "-")</dd>
                    </div>
                </dl>
            </div>
            <div class="col-md-6">
                <dl class="detail-list">
                    <div class="detail-item">
                        <dt>Depreciation Method</dt>
                        <dd>@Model.Book.Method</dd>
                    </div>
                    <div class="detail-item">
                        <dt>Convention</dt>
                        <dd>@Model.Book.Convention</dd>
                    </div>
                    <div class="detail-item">
                        <dt>Useful Life Override</dt>
                        <dd>@(Model.Book.UsefulLifeOverrideMonths?.ToString() ?? "Uses asset default") months</dd>
                    </div>
                    <div class="detail-item">
                        <dt>Calculation Frequency</dt>
                        <dd>@Model.Book.CalculationFrequency</dd>
                    </div>
                </dl>
            </div>
        </div>
    </div>
</div>

<div class="section-card">
    <div class="section-card-header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Processing Options
        </h3>
    </div>
    <div class="section-card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="option-item">
                    <span class="option-indicator @(Model.Book.IsPrimaryBook ? "active" : "")"></span>
                    <span>Primary Book</span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="option-item">
                    <span class="option-indicator @(Model.Book.CalculateOnlyNoPosting ? "active" : "")"></span>
                    <span>Calculate Only (No GL Posting)</span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="option-item">
                    <span class="option-indicator @(Model.Book.AllowManualDepreciation ? "active" : "")"></span>
                    <span>Allow Manual Depreciation</span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="option-item">
                    <span class="option-indicator @(Model.Book.RequireApprovalToPost ? "active" : "")"></span>
                    <span>Require Approval to Post</span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="option-item">
                    <span class="option-indicator @(Model.Book.AutoPostOnPeriodClose ? "active" : "")"></span>
                    <span>Auto-Post on Period Close</span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="option-item">
                    <span class="option-indicator @(Model.Book.TrackBudgetVsActual ? "active" : "")"></span>
                    <span>Track Budget vs Actual</span>
                </div>
            </div>
        </div>
    </div>
</div>
