@page
@model Abs.FixedAssets.Pages.Books.CreateModel
@{
    ViewData["Title"] = "Create Book";
    Layout = "_ModernLayout";
    ViewData["HasScreenHeader"] = true;
    
    var headerVd = new ViewDataDictionary(ViewData)
    {
        ["HeaderTitle"] = "New Book",
        ["Subtitle"] = "Create a new depreciation book for asset depreciation calculations",
        ["TypeLabel"] = "Depreciation",
        ["StatusText"] = "New",
        ["StatusTone"] = "info",
        ["ContextText"] = "Creating New Book",
        ["ShowBackLink"] = true,
        ["BackLinkFallback"] = "/Books",
        ["BackLinkLabel"] = "Books"
    };
}
@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

<form method="post">
    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
                Book Information
            </h3>
        </div>
        <div class="section-card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Code <span class="text-danger">*</span></label>
                    <input asp-for="Book.Code" class="form-control" placeholder="e.g., GAAP, TAX, CCA" />
                    <span asp-validation-for="Book.Code" class="text-danger"></span>
                </div>
                <div class="col-md-8">
                    <label class="form-label">Name <span class="text-danger">*</span></label>
                    <input asp-for="Book.Name" class="form-control" placeholder="e.g., US GAAP Financial Book" />
                    <span asp-validation-for="Book.Name" class="text-danger"></span>
                </div>
            </div>
        </div>
    </div>

    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6" />
                </svg>
                Depreciation Settings
            </h3>
        </div>
        <div class="section-card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Method <span class="text-danger">*</span></label>
                    <select asp-for="Book.Method" class="form-select"
                            asp-items="Html.GetEnumSelectList<Abs.FixedAssets.Models.DepreciationMethod>()" data-cherry-select data-placeholder="Search methods..."></select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Convention <span class="text-danger">*</span></label>
                    <select asp-for="Book.Convention" class="form-select"
                            asp-items="Html.GetEnumSelectList<Abs.FixedAssets.Models.DepreciationConvention>()" data-cherry-select data-placeholder="Search conventions..."></select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Useful Life Override (months)</label>
                    <input asp-for="Book.UsefulLifeOverrideMonths" class="form-control" type="number" min="0" placeholder="Leave blank for asset default" />
                    <small class="text-muted">Optional override for all assets in this book</small>
                </div>
            </div>
        </div>
    </div>

    <div class="section-card">
        <div class="section-card-body" data-csp-style="display: flex; align-items: center; gap: 12px;">
            <button type="submit" class="btn-p btn-p--primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Create Book
            </button>
            <a class="btn-p btn-p--secondary" href="/Books">Cancel</a>
        </div>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
