@page "{bookId:int}"
@model Abs.FixedAssets.Pages.Books.GlAccountsModel
@{
    ViewData["Title"] = "GL Accounts";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
    
    var headerVd = new ViewDataDictionary(ViewData)
    {
        ["HeaderTitle"] = Model.Book?.Code,
        ["Subtitle"] = $"{Model.Book?.Name} — GL Account Configuration",
        ["TypeLabel"] = "Depreciation",
        ["StatusText"] = "GL Mapping",
        ["StatusTone"] = "info",
        ["ContextPartial"] = "Books/_BooksGlAccountsContext",
        ["KpisPartial"] = "Books/_BooksGlAccountsKpis",
        ["KpisViewData"] = new ViewDataDictionary(ViewData) { ["Book"] = Model.Book },
        ["ActionsPartial"] = "Books/_BooksGlAccountsActions",
        ["ActionsViewData"] = new ViewDataDictionary(ViewData) { ["BookId"] = Model.BookId }
    };
    ViewData["Book"] = Model.Book;
}
@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

<form method="post">
    <input type="hidden" asp-for="BookId" />
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                About GL Account Mapping
            </h3>
            <span class="status-badge info">INFO</span>
        </div>
        <div class="section-card-body">
            <p style="margin: 0; color: var(--text-secondary); font-size: 13px;">
                These accounts determine where depreciation entries are posted. Select from your Chart of Accounts below.
                Accounts marked with <span class="badge badge-secondary" style="font-size: 10px;">System</span> are pre-configured for fixed asset transactions.
            </p>
        </div>
    </div>

    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                </svg>
                Asset Accounts
            </h3>
            <span class="status-badge success">BALANCE SHEET</span>
        </div>
        <div class="section-card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Fixed Asset Account <span class="text-danger">*</span></label>
                    <select asp-for="Input.AssetAccountId" class="form-select" data-cherry-select data-placeholder="Search asset accounts...">
                        <option value="">-- Select Asset Account --</option>
                        @foreach (var acct in Model.AssetAccounts)
                        {
                            <option value="@acct.Id">@acct.AccountNumber — @acct.Name</option>
                        }
                    </select>
                    <small class="text-muted">Balance sheet account for asset cost</small>
                    <span asp-validation-for="Input.AssetAccountId" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Accumulated Depreciation <span class="text-danger">*</span></label>
                    <select asp-for="Input.AccumDepAccountId" class="form-select" data-cherry-select data-placeholder="Search depreciation accounts...">
                        <option value="">-- Select Accumulated Depreciation Account --</option>
                        @foreach (var acct in Model.AccumDepAccounts)
                        {
                            <option value="@acct.Id">@acct.AccountNumber — @acct.Name</option>
                        }
                    </select>
                    <small class="text-muted">Contra-asset account for accumulated depreciation</small>
                    <span asp-validation-for="Input.AccumDepAccountId" class="text-danger"></span>
                </div>
            </div>
        </div>
    </div>

    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6" />
                </svg>
                Expense & Income Accounts
            </h3>
            <span class="status-badge warning">INCOME STATEMENT</span>
        </div>
        <div class="section-card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Depreciation Expense <span class="text-danger">*</span></label>
                    <select asp-for="Input.DepExpAccountId" class="form-select" data-cherry-select data-placeholder="Search expense accounts...">
                        <option value="">-- Select Depreciation Expense Account --</option>
                        @foreach (var acct in Model.ExpenseAccounts)
                        {
                            <option value="@acct.Id">@acct.AccountNumber — @acct.Name</option>
                        }
                    </select>
                    <small class="text-muted">Income statement expense for depreciation</small>
                    <span asp-validation-for="Input.DepExpAccountId" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">CIP Account (Construction in Progress)</label>
                    <select asp-for="Input.CipAccountId" class="form-select" data-cherry-select data-placeholder="Search CIP accounts...">
                        <option value="">-- No CIP Account --</option>
                        @foreach (var acct in Model.CipAccounts)
                        {
                            <option value="@acct.Id">@acct.AccountNumber — @acct.Name</option>
                        }
                    </select>
                    <small class="text-muted">For capital projects before asset is placed in service</small>
                    <span asp-validation-for="Input.CipAccountId" class="text-danger"></span>
                </div>
            </div>
        </div>
    </div>

    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
                Disposal Accounts
            </h3>
            <span class="status-badge danger">DISPOSALS</span>
        </div>
        <div class="section-card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Gain on Disposal</label>
                    <select asp-for="Input.GainAccountId" class="form-select" data-cherry-select data-placeholder="Search gain accounts...">
                        <option value="">-- Select Gain Account --</option>
                        @foreach (var acct in Model.GainAccounts)
                        {
                            <option value="@acct.Id">@acct.AccountNumber — @acct.Name</option>
                        }
                    </select>
                    <small class="text-muted">Income account for disposal gains</small>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Loss on Disposal</label>
                    <select asp-for="Input.LossAccountId" class="form-select" data-cherry-select data-placeholder="Search loss accounts...">
                        <option value="">-- Select Loss Account --</option>
                        @foreach (var acct in Model.LossAccounts)
                        {
                            <option value="@acct.Id">@acct.AccountNumber — @acct.Name</option>
                        }
                    </select>
                    <small class="text-muted">Expense account for disposal losses</small>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Asset Clearing / WIP</label>
                    <select asp-for="Input.ClearingAccountId" class="form-select" data-cherry-select data-placeholder="Search clearing accounts...">
                        <option value="">-- No Clearing Account --</option>
                        @foreach (var acct in Model.ClearingAccounts)
                        {
                            <option value="@acct.Id">@acct.AccountNumber — @acct.Name</option>
                        }
                    </select>
                    <small class="text-muted">Temporary clearing account for asset transactions</small>
                </div>
            </div>
        </div>
    </div>

    <div class="section-card">
        <div class="section-card-body" style="display: flex; align-items: center; gap: 12px;">
            <button type="submit" class="btn-p btn-p--primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Save GL Accounts
            </button>
            <a class="btn-p btn-p--secondary" asp-page="./Edit" asp-route-id="@Model.BookId">Cancel</a>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
