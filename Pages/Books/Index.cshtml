@page
@model Abs.FixedAssets.Pages.Books.IndexModel
@{
    ViewData["Title"] = "Depreciation Books";
    ViewData["Breadcrumb"] = "Depreciation";
    Layout = "_ModernLayout";

    var totalBooks = Model.Items?.Count ?? 0;
    var activeBooks = Model.Items?.Count(b => b.IsActive) ?? 0;
    var primaryBook = Model.Items?.FirstOrDefault(b => b.IsPrimaryBook);
    var booksWithGl = Model.Items?.Count(b => b.HasGl) ?? 0;

    string GetMethodName(Abs.FixedAssets.Models.DepreciationMethod method) => method switch
    {
        Abs.FixedAssets.Models.DepreciationMethod.StraightLine => "Straight-Line",
        Abs.FixedAssets.Models.DepreciationMethod.DoubleDecliningBalance => "200% DB",
        Abs.FixedAssets.Models.DepreciationMethod.SumOfYearsDigits => "Sum-of-Years",
        Abs.FixedAssets.Models.DepreciationMethod.UnitsOfProduction => "Units of Production",
        Abs.FixedAssets.Models.DepreciationMethod.DecliningBalance150 => "150% DB",
        Abs.FixedAssets.Models.DepreciationMethod.MACRS => "MACRS",
        Abs.FixedAssets.Models.DepreciationMethod.CustomSchedule => "Custom Schedule",
        Abs.FixedAssets.Models.DepreciationMethod.CCA => "Canadian CCA",
        Abs.FixedAssets.Models.DepreciationMethod.MACRS3Year => "MACRS 3-Year",
        Abs.FixedAssets.Models.DepreciationMethod.MACRS5Year => "MACRS 5-Year",
        Abs.FixedAssets.Models.DepreciationMethod.MACRS7Year => "MACRS 7-Year",
        Abs.FixedAssets.Models.DepreciationMethod.MACRS10Year => "MACRS 10-Year",
        Abs.FixedAssets.Models.DepreciationMethod.MACRS15Year => "MACRS 15-Year",
        Abs.FixedAssets.Models.DepreciationMethod.MACRS20Year => "MACRS 20-Year",
        Abs.FixedAssets.Models.DepreciationMethod.MACRS27_5Year => "MACRS 27.5-Year",
        Abs.FixedAssets.Models.DepreciationMethod.MACRS39Year => "MACRS 39-Year",
        Abs.FixedAssets.Models.DepreciationMethod.ADS => "ADS",
        Abs.FixedAssets.Models.DepreciationMethod.GroupComposite => "Group/Composite",
        Abs.FixedAssets.Models.DepreciationMethod.Component => "Component",
        Abs.FixedAssets.Models.DepreciationMethod.Amortization => "Amortization",
        Abs.FixedAssets.Models.DepreciationMethod.NoDepreciation => "No Depreciation",
        Abs.FixedAssets.Models.DepreciationMethod.IFRSRevaluation => "IFRS Revaluation",
        _ => method.ToString()
    };

    string GetConventionName(Abs.FixedAssets.Models.DepreciationConvention conv) => conv switch
    {
        Abs.FixedAssets.Models.DepreciationConvention.FullMonth => "Full Month",
        Abs.FixedAssets.Models.DepreciationConvention.HalfYear => "Half-Year",
        Abs.FixedAssets.Models.DepreciationConvention.MidMonth => "Mid-Month",
        Abs.FixedAssets.Models.DepreciationConvention.HalfMonth => "Half-Month",
        Abs.FixedAssets.Models.DepreciationConvention.ActualDays => "Actual Days",
        Abs.FixedAssets.Models.DepreciationConvention.ModifiedHalfYear => "Mod. Half-Year",
        Abs.FixedAssets.Models.DepreciationConvention.FullYear => "Full Year",
        Abs.FixedAssets.Models.DepreciationConvention.MidQuarter => "Mid-Quarter",
        Abs.FixedAssets.Models.DepreciationConvention.NextMonth => "Next Month",
        Abs.FixedAssets.Models.DepreciationConvention.NoProrate => "No Prorate",
        Abs.FixedAssets.Models.DepreciationConvention.FirstDayOfMonth => "First Day",
        Abs.FixedAssets.Models.DepreciationConvention.LastDayOfMonth => "Last Day",
        _ => conv.ToString()
    };

    string GetBookTypeBadge(Abs.FixedAssets.Models.BookType type) => type switch
    {
        Abs.FixedAssets.Models.BookType.Financial => "badge-primary",
        Abs.FixedAssets.Models.BookType.Tax => "badge-warning",
        Abs.FixedAssets.Models.BookType.Management => "badge-secondary",
        _ => "badge-secondary"
    };

    string GetBookTypeName(Abs.FixedAssets.Models.BookType type) => type switch
    {
        Abs.FixedAssets.Models.BookType.Financial => "GAAP",
        Abs.FixedAssets.Models.BookType.Tax => "Tax",
        Abs.FixedAssets.Models.BookType.Management => "Management",
        _ => type.ToString()
    };
}

@{
    ViewData["HasScreenHeader"] = true;
    var headerVd = new ViewDataDictionary(ViewData)
    {
        { "HeaderTitle", "Depreciation Books" },
        { "Subtitle", "Configure depreciation methods, conventions, and GL account mappings" },
        { "TypeLabel", "Depreciation" },
        { "StatusText", $"{activeBooks} Active" },
        { "StatusTone", "active" },
        { "KpisPartial", "Books/_BooksIndexKpis" },
        { "ActionsPartial", "Books/_BooksIndexActions" }
    };
}
@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

<div class="section-card">
    <div class="section-card-header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
            All Books
        </h3>
        <span class="status-badge info">@totalBooks BOOKS</span>
    </div>
    <div class="section-card-body" data-csp-style="padding: 0;">
        @if (Model.Items != null && Model.Items.Count > 0)
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Name</th>
                        <th data-csp-style="text-align: center;">Type</th>
                        <th>Method</th>
                        <th>Convention</th>
                        <th data-csp-style="text-align: center;">Life Override</th>
                        <th data-csp-style="text-align: center;">GL Accounts</th>
                        <th data-csp-style="text-align: center;">Status</th>
                        <th data-csp-style="text-align: center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr class="@(!item.IsActive ? "inactive-row" : "")">
                            <td>
                                <div data-csp-style="display: flex; align-items: center; gap: 8px;">
                                    <strong>@item.Code</strong>
                                    @if (item.IsPrimaryBook)
                                    {
                                        <span class="badge badge-success" data-csp-style="font-size: 9px; padding: 2px 6px;" title="Primary Book">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                                            </svg>
                                        </span>
                                    }
                                </div>
                            </td>
                            <td>@item.Name</td>
                            <td data-csp-style="text-align: center;">
                                <span class="badge @GetBookTypeBadge(item.BookType)">@GetBookTypeName(item.BookType)</span>
                            </td>
                            <td>
                                <span class="method-badge">@GetMethodName(item.Method)</span>
                            </td>
                            <td data-csp-style="color: var(--text-secondary);">@GetConventionName(item.Convention)</td>
                            <td data-csp-style="text-align: center;">
                                @if (item.UsefulLifeOverrideMonths.HasValue)
                                {
                                    <span>@item.UsefulLifeOverrideMonths mo</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td data-csp-style="text-align: center;">
                                @if (item.HasGl)
                                {
                                    <span class="badge badge-success">Configured</span>
                                }
                                else
                                {
                                    <a asp-page="./GlAccounts" asp-route-bookId="@item.Id" class="badge badge-warning" data-csp-style="text-decoration: none;">
                                        Set Up
                                    </a>
                                }
                            </td>
                            <td data-csp-style="text-align: center;">
                                @if (item.IsActive)
                                {
                                    <span class="badge badge-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-secondary">Inactive</span>
                                }
                            </td>
                            <td>
                                <div class="action-group" data-csp-style="justify-content: center;">
                                    <a asp-page="./Details" asp-route-id="@item.Id" asp-route-returnUrl="/Books" class="btn-p btn-p--secondary btn-p--sm btn-p--icon" title="View Details">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                        </svg>
                                    </a>
                                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn-p btn-p--secondary btn-p--sm btn-p--icon" title="Edit">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                        </svg>
                                    </a>
                                    <a asp-page="./GlAccounts" asp-route-bookId="@item.Id" class="btn-p btn-p--secondary btn-p--sm" title="Edit GL Accounts">
                                        GL
                                    </a>
                                    <a asp-page="./Delete" asp-route-id="@item.Id" class="btn-p btn-p--danger btn-p--sm btn-p--icon" title="Delete">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                        </svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="pe-empty" data-csp-style="padding:2rem;">
                <i class="fas fa-book pe-empty__icon" data-csp-style="font-size:1.5rem;"></i>
                <div class="pe-empty__title">No depreciation books</div>
                <div class="pe-empty__text">Create your first book to configure depreciation methods</div>
                <a asp-page="./Create" class="btn-p btn-p--primary">Create Book</a>
            </div>
        }
    </div>
</div>

<div class="section-card" data-csp-style="background: var(--primary-light); border-color: var(--primary);">
    <div class="section-card-body" data-csp-style="padding: 16px 24px;">
        <div data-csp-style="display: flex; align-items: flex-start; gap: 12px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="var(--primary)" data-csp-style="flex-shrink: 0; margin-top: 2px;">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
                <strong data-csp-style="color: var(--primary);">About Depreciation Books</strong>
                <p data-csp-style="color: var(--text-secondary); font-size: 13px; margin: 8px 0 0 0;">
                    Each book represents a different depreciation calculation method. Common configurations include:
                </p>
                <ul data-csp-style="color: var(--text-secondary); font-size: 13px; margin: 8px 0 0 0; padding-left: 20px;">
                    <li><strong>GAAP Book:</strong> For financial reporting — typically Straight-Line method with Mid-Month convention</li>
                    <li><strong>Tax Book:</strong> For tax purposes — MACRS for US (with Mid-Quarter convention), CCA for Canada</li>
                    <li><strong>Management Book:</strong> For internal reporting and custom depreciation schedules</li>
                </ul>
            </div>
        </div>
    </div>
</div>

