@page "{id:int}"
@model Abs.FixedAssets.Pages.Books.EditModel
@{
    ViewData["Title"] = "Edit Book";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
    
    var statusText = Model.Book.IsPrimaryBook ? "Primary" : (Model.Book.IsActive ? "Active" : "Inactive");
    var statusTone = Model.Book.IsPrimaryBook ? "success" : (Model.Book.IsActive ? "success" : "muted");
    
    var headerVd = new ViewDataDictionary(ViewData)
    {
        ["HeaderTitle"] = Model.Book.Code,
        ["Subtitle"] = Model.Book.Name,
        ["TypeLabel"] = "Depreciation",
        ["StatusText"] = statusText,
        ["StatusTone"] = statusTone,
        ["ContextPartial"] = "Books/_BooksEditContext",
        ["KpisPartial"] = "Books/_BooksEditKpis",
        ["KpisViewData"] = new ViewDataDictionary(ViewData) { ["Book"] = Model.Book },
        ["ActionsPartial"] = "Books/_BooksEditActions",
        ["ActionsViewData"] = new ViewDataDictionary(ViewData) { ["Book"] = Model.Book }
    };
    ViewData["Book"] = Model.Book;
}
@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

<form method="post">
    <input type="hidden" asp-for="Book.Id" />
    <input type="hidden" asp-for="Book.CreatedAt" />
    <input type="hidden" asp-for="Book.CreatedBy" />

    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
                Basic Information
            </h3>
        </div>
        <div class="section-card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <div class="form-field">
                        <label class="form-field__label">Code <span class="text-danger">*</span></label>
                        <input asp-for="Book.Code" class="form-field__input" maxlength="20" />
                        <span asp-validation-for="Book.Code" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-5">
                    <div class="form-field">
                        <label class="form-field__label">Name <span class="text-danger">*</span></label>
                        <input asp-for="Book.Name" class="form-field__input" />
                        <span asp-validation-for="Book.Name" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-field">
                        <label class="form-field__label">Book Type</label>
                        <select asp-for="Book.BookTypeLookupValueId" class="form-field__input" asp-items="Model.BookTypeOptions"></select>
                    </div>
                </div>
                <div class="col-md-12">
                    <div class="form-field">
                        <label class="form-field__label">Description</label>
                        <textarea asp-for="Book.Description" class="form-field__input" rows="2" placeholder="Optional description for this depreciation book"></textarea>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6" />
                </svg>
                Depreciation Settings
            </h3>
        </div>
        <div class="section-card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="form-field">
                        <label class="form-field__label">Depreciation Method</label>
                        <select asp-for="Book.MethodLookupValueId" class="form-field__input" asp-items="Model.DepreciationMethodOptions" data-cherry-select data-placeholder="Search methods...">
                        </select>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-field">
                        <label class="form-field__label">Averaging Convention</label>
                        <select asp-for="Book.ConventionLookupValueId" class="form-field__input" asp-items="Model.DepreciationConventionOptions" data-cherry-select data-placeholder="Search conventions...">
                        </select>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-field">
                        <label class="form-field__label">Tax Jurisdiction</label>
                        <select asp-for="Book.TaxJurisdictionLookupValueId" class="form-field__input" asp-items="Model.TaxJurisdictionOptions">
                        </select>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-field">
                        <label class="form-field__label">Useful Life Override (months)</label>
                        <input asp-for="Book.UsefulLifeOverrideMonths" class="form-field__input" type="number" min="0" placeholder="Leave blank to use asset default" />
                        <span class="form-field__help">Overrides individual asset useful life settings</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-field">
                        <label class="form-field__label">Calculation Frequency</label>
                        <select asp-for="Book.FrequencyLookupValueId" class="form-field__input" asp-items="Model.CalculationFrequencyOptions">
                        </select>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-field">
                        <label class="form-field__label">Default Depreciation Policy</label>
                        <select asp-for="Book.DefaultPolicyId" class="form-field__input">
                            <option value="">-- No default policy --</option>
                            @foreach (var policy in Model.Policies)
                            {
                                <option value="@policy.Id">@policy.Name</option>
                            }
                        </select>
                        <span class="form-field__help">Applied to new assets by default</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                Processing Options
            </h3>
        </div>
        <div class="section-card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="form-check form-switch">
                        <input asp-for="Book.IsPrimaryBook" class="form-check-input" type="checkbox" />
                        <label class="form-check-label" asp-for="Book.IsPrimaryBook">
                            <strong>Primary Book</strong>
                        </label>
                    </div>
                    <small class="text-muted d-block mt-1">This book will be used as the default for reporting</small>
                </div>
                <div class="col-md-4">
                    <div class="form-check form-switch">
                        <input asp-for="Book.IsActive" class="form-check-input" type="checkbox" />
                        <label class="form-check-label" asp-for="Book.IsActive">
                            <strong>Active</strong>
                        </label>
                    </div>
                    <small class="text-muted d-block mt-1">Inactive books are excluded from depreciation runs</small>
                </div>
                <div class="col-md-4">
                    <div class="form-check form-switch">
                        <input asp-for="Book.CalculateOnlyNoPosting" class="form-check-input" type="checkbox" />
                        <label class="form-check-label" asp-for="Book.CalculateOnlyNoPosting">
                            <strong>Calculate Only (No GL Posting)</strong>
                        </label>
                    </div>
                    <small class="text-muted d-block mt-1">Calculate depreciation without creating journal entries</small>
                </div>
                <div class="col-md-4">
                    <div class="form-check form-switch">
                        <input asp-for="Book.AllowManualDepreciation" class="form-check-input" type="checkbox" />
                        <label class="form-check-label" asp-for="Book.AllowManualDepreciation">
                            <strong>Allow Manual Depreciation</strong>
                        </label>
                    </div>
                    <small class="text-muted d-block mt-1">Permit manual depreciation adjustments</small>
                </div>
                <div class="col-md-4">
                    <div class="form-check form-switch">
                        <input asp-for="Book.RequireApprovalToPost" class="form-check-input" type="checkbox" />
                        <label class="form-check-label" asp-for="Book.RequireApprovalToPost">
                            <strong>Require Approval to Post</strong>
                        </label>
                    </div>
                    <small class="text-muted d-block mt-1">Depreciation must be approved before posting</small>
                </div>
                <div class="col-md-4">
                    <div class="form-check form-switch">
                        <input asp-for="Book.AutoPostOnPeriodClose" class="form-check-input" type="checkbox" />
                        <label class="form-check-label" asp-for="Book.AutoPostOnPeriodClose">
                            <strong>Auto-Post on Period Close</strong>
                        </label>
                    </div>
                    <small class="text-muted d-block mt-1">Automatically post when fiscal period closes</small>
                </div>
                <div class="col-md-4">
                    <div class="form-check form-switch">
                        <input asp-for="Book.TrackBudgetVsActual" class="form-check-input" type="checkbox" />
                        <label class="form-check-label" asp-for="Book.TrackBudgetVsActual">
                            <strong>Track Budget vs Actual</strong>
                        </label>
                    </div>
                    <small class="text-muted d-block mt-1">Enable variance tracking for budget books</small>
                </div>
            </div>
        </div>
    </div>

    <div class="section-card">
        <div class="section-card-header">
            <h3 class="section-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
                Company Assignment
            </h3>
        </div>
        <div class="section-card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Company</label>
                    <div class="form-value">@(Model.Book.Company?.Name ?? "Shared across all companies")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="section-card">
        <div class="section-card-body" data-csp-style="display: flex; align-items: center; gap: 12px;">
            <button type="submit" class="btn-p btn-p--primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Save Changes
            </button>
            <a class="btn-p btn-p--secondary" asp-page="./Index">Cancel</a>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
