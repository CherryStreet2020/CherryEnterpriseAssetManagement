@page "/Controller/Walkthrough"
@model Abs.FixedAssets.Pages.Controller.WalkthroughModel
@{
    ViewData["Title"] = "Controller — CFO Motion Walkthrough";
    ViewData["TabTitle"] = "CFO Walkthrough";
    Layout = "_ModernLayout";
}

@*
    Sprint 12.7 PR #5 — CFO motion walkthrough.

    Scripted teleprompter for the demo segment. Split-screen: scripted
    steps on the left, anchor links + open-in-Controller buttons on the
    right so the presenter can drive the live surface one click at a time.

    Content is tenant-generic — no real customer references anywhere.
    Cherry's voice intent ExplainChainTrace (PR #347) does the live
    narration; this page is the human teleprompter backup.
*@

<header class="ds-page-header">
    <div class="ds-page-header__inner">
        <h1 class="ds-page-header__title">Controller — CFO Motion Walkthrough</h1>
        <p class="ds-page-header__subtitle">
            CFO motion script. Each step pairs a presenter action,
            what the Cockpit surface should show, and Cherry's voice prompt.
        </p>
    </div>
</header>

<main class="ds-page">
    <div class="ds-grid ds-grid--2-col">

        <!-- LEFT PANE — scripted steps -->
        <section class="ds-card">
            <div class="ds-card__body">
                <h2 class="ds-h2">The CFO Motion (8 steps · ~12 min)</h2>

                <ol class="ds-walkthrough-list">
                    @foreach (var step in Model.Steps)
                    {
                        <li class="ds-walkthrough-step" id="step-@step.Number">
                            <header class="ds-walkthrough-step__header">
                                <span class="ds-walkthrough-step__number">@step.Number</span>
                                <h3 class="ds-h3 ds-mb-0">@step.Title</h3>
                            </header>
                            <div class="ds-walkthrough-step__body">
                                <p><strong>What you see:</strong> @step.WhatYouSee</p>
                                <p><strong>What you click:</strong> @step.WhatYouClick</p>
                                <p class="ds-walkthrough-step__voice"><strong>Cherry says:</strong> <em>"@step.CherryLine"</em></p>
                                @if (!string.IsNullOrEmpty(step.OpenUrl))
                                {
                                    <p>
                                        <a href="@step.OpenUrl" class="ds-btn ds-btn--secondary ds-btn--sm" target="_blank" rel="noopener">Open @step.OpenLabel</a>
                                    </p>
                                }
                            </div>
                        </li>
                    }
                </ol>

                <footer class="ds-walkthrough-footer ds-mt-4">
                    <p class="ds-text-muted">
                        Demo budget: ~12 minutes for this CFO segment. The
                        audience typically jumps in at Step 4 (drilldown)
                        if they're already convinced on the KPI band.
                    </p>
                </footer>
            </div>
        </section>

        <!-- RIGHT PANE — quick jump nav -->
        <aside class="ds-card">
            <div class="ds-card__body">
                <h2 class="ds-h2">Jump to a step</h2>
                <nav class="ds-walkthrough-toc">
                    <ol>
                        @foreach (var step in Model.Steps)
                        {
                            <li><a href="#step-@step.Number">@step.Number — @step.Title</a></li>
                        }
                    </ol>
                </nav>

                <h2 class="ds-h2 ds-mt-4">Quick links</h2>
                <ul class="ds-list">
                    <li><a asp-page="/Controller/Index">Controller Control Center →</a></li>
                    <li><a asp-page="/Controller/Index" asp-route-tab="drilldown">… Drilldown tab →</a></li>
                    <li><a asp-page="/Controller/Index" asp-route-tab="audit-trail">… Audit Trail tab →</a></li>
                    <li><a asp-page="/Admin/SeedCfoMotionDemo">Seed demo data (admin) →</a></li>
                </ul>

                <h2 class="ds-h2 ds-mt-4">Before you start</h2>
                <p>Make sure the demo data is seeded on the demo tenant
                (<code>CompanyCode = "PWH-CAN"</code>) — open the seed
                page and click the button. KPI band should read at
                least <strong>$5M cash</strong>, <strong>danger-tone AP</strong>,
                <strong>120+ POs</strong>, <strong>$2M+ WIP</strong>. Sanity check
                the numbers BEFORE walking on stage.</p>
            </div>
        </aside>

    </div>
</main>
