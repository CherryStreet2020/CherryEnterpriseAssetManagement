@using Abs.FixedAssets.Models
@{
    var inv = ViewData["Invoice"] as VendorInvoice;
    var backUrl = ViewData["BackUrl"]?.ToString() ?? "/AccountsPayable";
    var canEdit = inv != null && (inv.Status == InvoiceStatus.Draft || inv.Status == InvoiceStatus.PendingApproval);
    // PR #105 / B-19: override-approve is an Admin-only escape hatch surfaced only
    // when the 3-way match would block a clean Approve. Accountants see the normal
    // Approve button (which the server will refuse if match fails); Admins also see
    // the Override panel below that captures a required reason.
    var isAdmin = User.IsInRole("Admin");
    var showOverridePanel = inv != null
        && inv.Status == InvoiceStatus.PendingApproval
        && inv.MatchStatus != InvoiceMatchStatus.FullyMatched
        && isAdmin;
    if (inv == null) return;
}
<div class="hero-tags">
    <span class="hero-tag @(inv.MatchStatus == InvoiceMatchStatus.FullyMatched ? "success" : inv.MatchStatus == InvoiceMatchStatus.PartialMatch ? "warning" : "info")">
        @inv.MatchStatus.ToString().ToUpper()
    </span>
</div>
<div class="hero-btns">
    <a href="@backUrl" class="hero-btn hero-btn-ghost">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back
    </a>
    @if (inv.Status == InvoiceStatus.PendingApproval)
    {
        <form method="post" asp-page-handler="Approve">
            <input type="hidden" name="id" value="@inv.Id" />
            <input type="hidden" name="returnUrl" value="@backUrl" />
            <button type="submit" class="hero-btn hero-btn-success">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Approve
            </button>
        </form>
    }
    @if (inv.Status == InvoiceStatus.Approved && inv.BalanceDue > 0)
    {
        <button type="button" class="hero-btn hero-btn-primary" onclick="togglePaymentForm(); document.getElementById('inlinePaymentForm').scrollIntoView({behavior:'smooth'});">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            Record Payment
        </button>
    }
    @if (canEdit)
    {
        <form method="post" asp-page-handler="Void" onsubmit="return confirm('Void this invoice? This cannot be undone.')">
            <input type="hidden" name="id" value="@inv.Id" />
            <input type="hidden" name="returnUrl" value="@backUrl" />
            <button type="submit" class="hero-btn hero-btn-danger">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
                </svg>
                Void
            </button>
        </form>
    }
</div>
@if (showOverridePanel)
{
    <details class="ap-override-panel" style="margin-top:0.75rem; border:1px solid var(--hero-border, #44424a); border-radius:8px; padding:0.75rem 1rem; background:rgba(255, 220, 100, 0.05);">
        <summary style="cursor:pointer; font-weight:600; color:#f0b429;">⚠ Approve with match override (Admin only)</summary>
        <p style="margin:0.5rem 0; font-size:0.875rem; color:var(--text-muted, #b0aebd);">
            This invoice did not pass the 3-way match. Override only when you have verified the variance offline. Every override is written to the AuditLog with your user, timestamp, and the reason below.
        </p>
        <form method="post" asp-page-handler="Approve" onsubmit="return confirm('Approve this invoice with match override? This will be recorded in the audit trail.');">
            <input type="hidden" name="id" value="@inv.Id" />
            <input type="hidden" name="returnUrl" value="@backUrl" />
            <input type="hidden" name="overrideMatch" value="true" />
            <label for="overrideReason_@inv.Id" style="display:block; font-size:0.875rem; font-weight:600; margin-bottom:0.25rem;">Reason (required)</label>
            <input type="text" id="overrideReason_@inv.Id" name="overrideReason" required minlength="5" maxlength="500"
                placeholder="e.g. Vendor agreed to rebate the variance; credit memo CM-2025-117 to follow"
                style="width:100%; padding:0.5rem; border-radius:6px; border:1px solid var(--hero-border, #44424a); background:rgba(0,0,0,0.2); color:inherit;" />
            <button type="submit" class="hero-btn hero-btn-warning" style="margin-top:0.5rem;">
                Approve with Override
            </button>
        </form>
    </details>
}
