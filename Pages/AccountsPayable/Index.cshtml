@page
@model Abs.FixedAssets.Pages.AccountsPayable.IndexModel
@using Abs.FixedAssets.Models
@using Abs.FixedAssets.Pages.Shared.Primitives
@{
    ViewData["Title"] = "Accounts Payable";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
    var statusText = Model.PastDueCount > 0 ? $"{Model.PastDueCount} Past Due" : "Current";
    var statusTone = Model.PastDueCount > 0 ? "danger" : "active";

    var headerVd = new ViewDataDictionary(ViewData)
    {
        { "HeaderTitle", "Accounts Payable" },
        { "Subtitle", "Manage vendor invoices, payments, and aging" },
        { "TypeLabel", "Financial" },
        { "StatusText", statusText },
        { "StatusTone", statusTone },
        // PR #116d.17 — Header KPIs removed; render horizontal strip in body.
        // KpisPartial intentionally not set so header stays compact.
        { "ActionsPartial", "AccountsPayable/_AccountsPayableIndexActions" }
    };

    // PR #116d.17 — Pre-compute KPI delta logic per .cowork-gotchas pattern.
    var pastDueTone = Model.PastDueCount > 0 ? "danger" : "success";
    var pastDueDirection = Model.PastDueCount > 0 ? "down" : "up";
    var pastDueDelta = Model.PastDueCount > 0 ? $"▼ {Model.PastDueCount} need attention" : "▲ all current";

    var payableTone = Model.TotalPayable >= 100000m ? "warning" : "brand";
    var avgInvoice = Model.OpenInvoiceCount > 0 ? Model.TotalPayable / Model.OpenInvoiceCount : 0m;
}
@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

@* PR #116d.17 — Flash messages restyled on the design system. *@
@if (TempData["ErrorMessage"] != null)
{
    <div class="ds-card" data-tone="danger" style="margin-top: 14px; padding: 12px 16px; color: var(--text-primary); display: flex; align-items: center; gap: 12px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: var(--ds-danger, #f87171); flex-shrink: 0;">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <span>@TempData["ErrorMessage"]</span>
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="ds-card" data-tone="success" style="margin-top: 14px; padding: 12px 16px; color: var(--text-primary); display: flex; align-items: center; gap: 12px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: var(--ds-success, #34d399); flex-shrink: 0;">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span>@TempData["SuccessMessage"]</span>
    </div>
}

@* PR #116d.17 — 4 KPITiles horizontal at top. Past Due tile flips to DANGER tone
   with downward delta whenever there's even one overdue invoice — operationally
   critical alert visible at-a-glance. *@
<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-top: 20px;">
    @await Html.PartialAsync("Primitives/_KPITile", new KpiTileModel
    {
        Label = "Open Invoices",
        Value = Model.OpenInvoiceCount.ToString("N0"),
        DeltaText = Model.OpenInvoiceCount > 0 ? "awaiting payment" : "all invoices closed",
        DeltaDirection = "flat",
        SparkTone = "info"
    })
    @await Html.PartialAsync("Primitives/_KPITile", new KpiTileModel
    {
        Label = "Past Due",
        Value = Model.PastDueCount.ToString("N0"),
        DeltaText = pastDueDelta,
        DeltaDirection = pastDueDirection,
        SparkTone = pastDueTone
    })
    @await Html.PartialAsync("Primitives/_KPITile", new KpiTileModel
    {
        Label = "Total Payable",
        Value = Model.TotalPayable.ToString("C0"),
        DeltaText = Model.OpenInvoiceCount > 0 ? $"~ {avgInvoice.ToString("C0")} per invoice" : "no open invoices",
        DeltaDirection = "flat",
        SparkTone = payableTone
    })
    @await Html.PartialAsync("Primitives/_KPITile", new KpiTileModel
    {
        Label = "Paid (MTD)",
        Value = Model.PaidThisMonth.ToString("C0"),
        DeltaText = Model.PaidThisMonth > 0 ? "▲ cash out this month" : "no payments yet this month",
        DeltaDirection = Model.PaidThisMonth > 0 ? "up" : "flat",
        SparkTone = "success"
    })
</div>

@* PR #116d.17 — Recent Invoices table wrapped in a DataCard with brand tone.
   Tone flips to DANGER on the card itself if any invoices are past due, so the
   operator sees the urgency before reading any rows. *@
<div class="ds-card" data-tone="@(Model.PastDueCount > 0 ? "danger" : "brand")" style="margin-top: 24px; padding: 0;">
    <div style="padding: 18px 22px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap;">
        <div>
            <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 500;">Accounts Payable</div>
            <div style="font-size: 17px; font-weight: 700; color: var(--text-primary); margin-top: 4px;">Recent Invoices</div>
        </div>
        @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel
        {
            Label = Model.Invoices.Count == 1 ? "Invoice" : "Invoices",
            MonoNum = Model.Invoices.Count.ToString(),
            Tone = "info",
            ShowDot = true
        })
    </div>
    @if (Model.Invoices.Any())
    {
        <div style="padding: 0;">
            @{ var returnUrl = $"{HttpContext.Request.Path}{HttpContext.Request.QueryString}"; }
            <table class="data-table premium-table" id="invoiceGrid" data-enhanced-grid="true" data-row-click="true">
                <thead>
                    <tr>
                        <th data-csp-style="width: 120px;" data-col="Invoice #" data-filter="text">Invoice #</th>
                        <th data-csp-style="min-width: 160px;" data-col="Vendor" data-filter="text">Vendor</th>
                        <th data-csp-style="width: 110px;" data-col="Invoice Date" data-filter="text">Invoice Date</th>
                        <th data-csp-style="width: 100px;" data-col="Due Date" data-filter="text">Due Date</th>
                        <th data-csp-style="width: 100px;" class="no-sort" data-col="Status" data-filter="select" data-filter-options="Draft|Pending|Approved|Paid">Status</th>
                        <th data-csp-style="width: 100px;" class="no-sort" data-col="Match" data-filter="select" data-filter-options="NotMatched|PartialMatch|FullyMatched|Exception">Match</th>
                        <th data-csp-style="width: 100px; text-align: right;" data-col="Total" data-filter="number">Total</th>
                        <th data-csp-style="width: 100px; text-align: right;" data-col="Balance" data-filter="number">Balance</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var inv in Model.Invoices)
                    {
                        var isOverdue = inv.DueDate < DateTime.Today && inv.BalanceDue > 0;
                        @* PR #116d.17 — Tone mapping for status and match badges. *@
                        var statusBadgeTone = inv.Status == InvoiceStatus.Paid ? "success"
                            : inv.Status == InvoiceStatus.Approved ? "brand"
                            : isOverdue ? "danger"
                            : "neutral";
                        var statusBadgeLabel = isOverdue && inv.Status != InvoiceStatus.Paid ? "Past Due" : inv.Status.ToString();
                        var matchBadgeTone = inv.MatchStatus == InvoiceMatchStatus.FullyMatched ? "success"
                            : inv.MatchStatus == InvoiceMatchStatus.PartialMatch ? "warning"
                            : inv.MatchStatus == InvoiceMatchStatus.Exception ? "danger"
                            : "neutral";
                        <tr data-row-id="@inv.Id" data-row-href="@Url.Page("/AccountsPayable/Details", new { id = inv.Id, returnUrl = returnUrl })">
                            <td><strong style="color: var(--text-primary);">@inv.InvoiceNumber</strong></td>
                            <td style="font-weight: 500; color: var(--text-primary);">@inv.Vendor?.Name</td>
                            <td style="white-space: nowrap; color: var(--text-secondary);">@inv.InvoiceDate.ToString("MM/dd/yyyy")</td>
                            <td style="white-space: nowrap; color: @(isOverdue ? "var(--ds-danger, #f87171)" : "var(--text-secondary)"); font-weight: @(isOverdue ? "600" : "400");">@inv.DueDate.ToString("MM/dd/yyyy")</td>
                            <td>
                                @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel { Label = statusBadgeLabel, Tone = statusBadgeTone, ShowDot = true })
                            </td>
                            <td>
                                @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel { Label = inv.MatchStatus.ToString(), Tone = matchBadgeTone, ShowDot = true })
                            </td>
                            <td style="text-align: right; font-family: var(--font-mono, ui-monospace, monospace); font-weight: 600; color: var(--text-primary);">@inv.Total.ToString("C2")</td>
                            <td style="text-align: right; font-family: var(--font-mono, ui-monospace, monospace); font-weight: @(inv.BalanceDue > 0 ? "700" : "400"); color: @(inv.BalanceDue > 0 ? (isOverdue ? "var(--ds-danger, #f87171)" : "var(--text-primary)") : "var(--text-muted)");">
                                @(inv.BalanceDue > 0 ? inv.BalanceDue.ToString("C2") : "—")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        @* PR #116d.17 — EmptyState v2 for the no-invoices path. *@
        <div style="padding: 24px;">
            @await Html.PartialAsync("Primitives/_EmptyStateV2", new EmptyStateModel
            {
                Icon = "document",
                Tone = "info",
                Title = "No invoices yet",
                Body = "Enter your first vendor invoice to start tracking accounts payable. Invoices link to POs for three-way matching against receipts.",
                CtaLabel = "Create First Invoice",
                CtaHref = "/AccountsPayable/Create",
                SecondaryLabel = "Back to Dashboard",
                SecondaryHref = "/"
            })
        </div>
    }
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function() {
    if (typeof initEnhancedGrid === 'function') {
        initEnhancedGrid('invoiceGrid', {
            searchable: true,
            sortable: true,
            exportable: true,
            clickableRows: true,
            rowClickUrl: '/AccountsPayable/Details/{id}'
        });
    }
});
</script>
}
