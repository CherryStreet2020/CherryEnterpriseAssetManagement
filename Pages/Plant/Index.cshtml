@page
@model Abs.FixedAssets.Pages.Plant.IndexModel
@using Abs.FixedAssets.Pages.Shared.Primitives
@{
    ViewData["Title"] = "Plant Floor";
    ViewData["TabTitle"] = "Plant Floor";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";

    var subtitle = Model.Plants.Count == 1
        ? $"{Model.TotalAssetsAcrossPlants} assets monitored across 1 plant · {Model.TotalRedAssets} need attention"
        : $"{Model.TotalAssetsAcrossPlants} assets monitored across {Model.Plants.Count} plants · {Model.TotalRedAssets} need attention";

    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = "Plant Floor",
        ["Subtitle"] = subtitle,
        ["TypeLabel"] = "Operations",
        ["StatusText"] = Model.TotalRedAssets > 0 ? $"{Model.TotalRedAssets} red" : "All green",
        ["StatusTone"] = Model.TotalRedAssets > 0 ? "danger" : "success"
    };
}

@await Html.PartialAsync("_ScreenHeader", headerVd)

@if (Model.Plants.Count == 0)
{
    @* PR #116d.3 — rebuilt with <EmptyState> v2 primitive. *@
    <div style="margin-top: 1.5rem;">
        @await Html.PartialAsync("Primitives/_EmptyStateV2", new EmptyStateModel
        {
            Icon = "folder",
            Tone = "info",
            Title = "No plants configured",
            Body = "Create a Site under Admin → Organization & Sites to start monitoring assets on the plant floor.",
            CtaLabel = "Open Admin → Sites",
            CtaHref = "/Admin/Sites"
        })
    </div>
}
else
{
    @* PR #116d.3 — Plant index rebuilt on the new design system.
       Each plant is a tone-driven <DataCard> with eyebrow (Type), title (Name),
       subtitle (SiteCode + City), body (big avg-health number + 3 status pills),
       footer (asset count + drill-through link). Hover-lift comes from
       data-interactive="true". Brand-glow rings tone-tinted on hover. *@
    <div class="ds-showcase__grid" style="grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); margin-top: 1.5rem;">
        @foreach (var p in Model.Plants)
        {
            var dominantTone = p.RedCount > 0 ? "critical" : (p.AmberCount > 0 ? "warning" : "success");
            var avgPct = p.TotalAssets > 0 ? (int)Math.Round((double)p.AvgHealthScore) : 0;
            var avgColor = dominantTone switch
            {
                "critical" => "var(--danger)",
                "warning" => "var(--warning)",
                _ => "var(--success)"
            };
            <a class="ds-card is-interactive" data-tone="@dominantTone" data-interactive="true" href="/Plant/Floor/@p.SiteId" style="text-decoration: none; color: inherit;">
                <div class="ds-card__eyebrow">
                    <span class="ds-card__eyebrow-label">@p.Type</span>
                    <span style="font-size: 32px; font-weight: 700; color: @avgColor; line-height: 1; font-family: var(--font-sans); letter-spacing: -0.025em;">
                        @avgPct<span style="font-size: 14px; font-weight: 500; color: var(--text-muted); margin-left: 2px;">%</span>
                    </span>
                </div>
                <div class="ds-card__title">@p.Name</div>
                <div class="ds-card__subtitle">
                    @p.SiteCode@(string.IsNullOrEmpty(p.City) ? "" : $" · {p.City}")
                </div>

                <div style="display: flex; gap: 8px; margin-top: 16px;">
                    @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel { Label = "Green", Tone = "success", MonoNum = p.GreenCount.ToString() })
                    @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel { Label = "Amber", Tone = "warning", MonoNum = p.AmberCount.ToString() })
                    @await Html.PartialAsync("Primitives/_StatusPill", new StatusPillModel { Label = "Red", Tone = "critical", MonoNum = p.RedCount.ToString() })
                </div>

                <div class="ds-card__footer">
                    <span>@p.TotalAssets total assets</span>
                    <span style="margin-left: auto; color: var(--color-accent); font-weight: 500;">View floor →</span>
                </div>
            </a>
        }
    </div>

    @* PR #117.8 — the "Refresh demo health data" link was removed because
       the page no longer re-seeds on load (that work moved to Program.cs
       startup). A proper admin re-seed surface will land alongside the
       new sensor architecture in PR #118 (/Admin/Snapshots / /Admin/Seed). *@
}
