@page
@model Abs.FixedAssets.Pages.Plant.IndexModel
@{
    ViewData["Title"] = "Plant Floor";
    ViewData["TabTitle"] = "Plant Floor";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";

    var subtitle = Model.Plants.Count == 1
        ? $"{Model.TotalAssetsAcrossPlants} assets monitored across 1 plant · {Model.TotalRedAssets} need attention"
        : $"{Model.TotalAssetsAcrossPlants} assets monitored across {Model.Plants.Count} plants · {Model.TotalRedAssets} need attention";

    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = "Plant Floor",
        ["Subtitle"] = subtitle,
        ["TypeLabel"] = "Operations",
        ["StatusText"] = Model.TotalRedAssets > 0 ? $"{Model.TotalRedAssets} red" : "All green",
        ["StatusTone"] = Model.TotalRedAssets > 0 ? "danger" : "success"
    };
}

@await Html.PartialAsync("_ScreenHeader", headerVd)

@if (Model.Plants.Count == 0)
{
    <div class="section-card" data-csp-style="margin-top: 1.5rem;">
        <div class="section-card-body" data-csp-style="padding: 2.5rem; text-align: center;">
            <h3 data-csp-style="margin-top: 0;">No plants configured</h3>
            <p data-csp-style="color: var(--text-muted);">
                Create a Site under <a href="/Admin/Sites">Admin → Organization &amp; Sites</a> to start monitoring assets on the plant floor.
            </p>
        </div>
    </div>
}
else
{
    <div data-csp-style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1rem; margin-top: 1.5rem;">
        @foreach (var p in Model.Plants)
        {
            var dominantTone = p.RedCount > 0 ? "danger" : (p.AmberCount > 0 ? "warning" : "success");
            var accentColor = dominantTone switch
            {
                "danger" => "#ef4444",
                "warning" => "#f59e0b",
                _ => "#22c55e"
            };
            var avgPct = p.TotalAssets > 0 ? (int)Math.Round((double)p.AvgHealthScore) : 0;
            <a href="/Plant/Floor/@p.SiteId" class="section-card plant-tile" data-csp-style="text-decoration: none; color: inherit; transition: transform 0.15s ease, border-color 0.15s ease; border-left: 3px solid @accentColor;">
                <div class="section-card-body" data-csp-style="padding: 1.25rem;">
                    <div data-csp-style="display: flex; align-items: baseline; justify-content: space-between; gap: 0.5rem;">
                        <div data-csp-style="min-width: 0;">
                            <div data-csp-style="font-size: 0.7rem; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.06em;">@p.Type</div>
                            <h3 data-csp-style="margin: 0.25rem 0 0; font-size: 1.125rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@p.Name</h3>
                            <div data-csp-style="color: var(--text-muted); font-size: 0.8125rem; margin-top: 0.125rem;">
                                @p.SiteCode@(string.IsNullOrEmpty(p.City) ? "" : $" · {p.City}")
                            </div>
                        </div>
                        <div data-csp-style="text-align: right; flex-shrink: 0;">
                            <div data-csp-style="font-size: 1.5rem; font-weight: 700; color: @accentColor; line-height: 1;">@avgPct<span data-csp-style="font-size: 0.875rem; font-weight: 500; opacity: 0.7;">%</span></div>
                            <div data-csp-style="font-size: 0.7rem; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.06em; margin-top: 0.125rem;">Avg health</div>
                        </div>
                    </div>

                    <div data-csp-style="display: flex; gap: 0.5rem; margin-top: 1rem;">
                        <span data-csp-style="flex: 1; padding: 0.5rem 0.625rem; border-radius: 6px; background: rgba(34,197,94,0.10); border: 1px solid rgba(34,197,94,0.25); text-align: center;">
                            <strong data-csp-style="color: #86efac; font-size: 1rem; display: block;">@p.GreenCount</strong>
                            <span data-csp-style="font-size: 0.7rem; text-transform: uppercase; color: rgba(134, 239, 172, 0.7); letter-spacing: 0.04em;">Green</span>
                        </span>
                        <span data-csp-style="flex: 1; padding: 0.5rem 0.625rem; border-radius: 6px; background: rgba(245,158,11,0.10); border: 1px solid rgba(245,158,11,0.25); text-align: center;">
                            <strong data-csp-style="color: #fcd34d; font-size: 1rem; display: block;">@p.AmberCount</strong>
                            <span data-csp-style="font-size: 0.7rem; text-transform: uppercase; color: rgba(252, 211, 77, 0.7); letter-spacing: 0.04em;">Amber</span>
                        </span>
                        <span data-csp-style="flex: 1; padding: 0.5rem 0.625rem; border-radius: 6px; background: rgba(239,68,68,0.10); border: 1px solid rgba(239,68,68,0.25); text-align: center;">
                            <strong data-csp-style="color: #fca5a5; font-size: 1rem; display: block;">@p.RedCount</strong>
                            <span data-csp-style="font-size: 0.7rem; text-transform: uppercase; color: rgba(252, 165, 165, 0.7); letter-spacing: 0.04em;">Red</span>
                        </span>
                    </div>

                    <div data-csp-style="margin-top: 1rem; display: flex; justify-content: space-between; align-items: center;">
                        <span data-csp-style="font-size: 0.8125rem; color: var(--text-muted);">@p.TotalAssets total assets</span>
                        <span data-csp-style="font-size: 0.8125rem; color: @accentColor;">View floor →</span>
                    </div>
                </div>
            </a>
        }
    </div>

    @* PR #117.8 — the "Refresh demo health data" link was removed because
       the page no longer re-seeds on load (that work moved to Program.cs
       startup). A proper admin re-seed surface will land alongside the
       new sensor architecture in PR #118 (/Admin/Snapshots / /Admin/Seed). *@
}
