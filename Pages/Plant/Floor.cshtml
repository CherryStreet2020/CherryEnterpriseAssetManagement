@page "{siteId:int}"
@model Abs.FixedAssets.Pages.Plant.FloorModel
@{
    ViewData["Title"] = $"Plant Floor — {Model.Site?.Name}";
    ViewData["TabTitle"] = Model.Site?.Name ?? "Plant Floor";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";

    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = Model.Site?.Name ?? "Plant Floor",
        ["Subtitle"] = $"{Model.CountTotal} assets · live health monitoring",
        ["TypeLabel"] = $"Plant · {Model.Site?.SiteCode}",
        ["StatusText"] = Model.CountRed > 0 ? $"{Model.CountRed} need attention" : "All operational",
        ["StatusTone"] = Model.CountRed > 0 ? "danger" : "success"
    };

    string CardAccent(decimal? h) =>
        !h.HasValue ? "#64748b" :
        h >= 80m ? "#22c55e" :
        h >= 60m ? "#f59e0b" : "#ef4444";

    string CardBgTint(decimal? h) =>
        !h.HasValue ? "rgba(100,116,139,0.04)" :
        h >= 80m ? "rgba(34,197,94,0.04)" :
        h >= 60m ? "rgba(245,158,11,0.06)" : "rgba(239,68,68,0.08)";

    string CardTextColor(decimal? h) =>
        !h.HasValue ? "#cbd5e1" :
        h >= 80m ? "#86efac" :
        h >= 60m ? "#fcd34d" : "#fca5a5";

    // PR #117.2: class-appropriate sensor tile rendering. Each tile carries
    // its own label, unit, and tone (ok / warn / crit / muted) from the
    // SensorProfile thresholds. No more hardcoded Temp/Vib/PSI on every card.
    string FormatTileValue(decimal? v, string unit)
    {
        if (!v.HasValue) return "—";
        // Big absolute counters (cycle counts, hour meters) display as integers
        // with thousands separators; small physical readings get 1-2 decimals.
        bool isCounter = unit == "cycles" || unit == "strokes" || unit == "hr";
        if (isCounter) return $"{v.Value:N0}";
        if (Math.Abs(v.Value) >= 100) return $"{v.Value:0}";
        return $"{v.Value:0.00}";
    }

    string TileToneColor(string tone) => tone switch
    {
        "crit" => "#fca5a5",
        "warn" => "#fcd34d",
        "ok"   => "#86efac",
        _       => "var(--text-muted)"
    };

    string TileToneBg(string tone) => tone switch
    {
        "crit" => "rgba(239,68,68,0.10)",
        "warn" => "rgba(245,158,11,0.10)",
        "ok"   => "rgba(34,197,94,0.06)",
        _       => "rgba(255,255,255,0.025)"
    };
}

@await Html.PartialAsync("_ScreenHeader", headerVd)

<div data-csp-style="margin-top: 0.75rem;">
    <a href="/Plant" data-csp-style="font-size: 0.875rem; color: var(--text-muted); text-decoration: none;">← All plants</a>
</div>

@* Band filter chips *@
<div data-csp-style="margin-top: 1rem; display: flex; gap: 0.5rem; flex-wrap: wrap;">
    @{
        var bands = new[] {
            ("all", "All", Model.CountTotal, "#cbd5e1"),
            ("green", "Healthy", Model.CountGreen, "#22c55e"),
            ("amber", "Watch", Model.CountAmber, "#f59e0b"),
            ("red", "Critical", Model.CountRed, "#ef4444")
        };
    }
    @foreach (var (key, label, count, color) in bands)
    {
        var isActive = string.Equals(Model.Band, key, StringComparison.OrdinalIgnoreCase);
        var chipStyle = isActive
            ? $"padding: 0.5rem 1rem; border-radius: 999px; background: {color}; color: white; font-weight: 600; font-size: 0.8125rem; text-decoration: none; border: 1px solid {color};"
            : $"padding: 0.5rem 1rem; border-radius: 999px; background: transparent; color: var(--text-muted); font-size: 0.8125rem; text-decoration: none; border: 1px solid var(--border);";
        <a href="?band=@key" data-csp-style="@chipStyle">
            @label <span data-csp-style="opacity: 0.85; margin-left: 0.25rem;">@count</span>
        </a>
    }
</div>

@if (Model.Cards.Count == 0)
{
    <div class="section-card" data-csp-style="margin-top: 1.5rem;">
        <div class="section-card-body" data-csp-style="padding: 2.5rem; text-align: center;">
            <h3 data-csp-style="margin-top: 0;">No assets in this band</h3>
            <p data-csp-style="color: var(--text-muted);">
                Try clearing the filter to see all assets on this floor.
            </p>
        </div>
    </div>
}
else
{
    <div data-csp-style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 0.875rem; margin-top: 1.25rem;">
        @foreach (var c in Model.Cards)
        {
            var accent = CardAccent(c.HealthScore);
            var tint = CardBgTint(c.HealthScore);
            var textColor = CardTextColor(c.HealthScore);
            var healthDisplay = c.HealthScore.HasValue ? $"{c.HealthScore.Value:0}" : "—";
            var cardStyle = $"display: block; text-decoration: none; color: inherit; background: {tint}; border: 1px solid var(--border); border-left: 4px solid {accent}; border-radius: 10px; padding: 1rem 1.125rem; transition: transform 0.12s ease, box-shadow 0.12s ease;";

            <a href="/Assets/Asset/@c.Id" class="plant-floor-asset-card" data-csp-style="@cardStyle">
                <div data-csp-style="display: flex; justify-content: space-between; align-items: flex-start; gap: 0.5rem;">
                    <div data-csp-style="min-width: 0; flex: 1;">
                        <div data-csp-style="font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: 0.75rem; color: var(--text-muted); letter-spacing: 0.04em;">@c.AssetNumber</div>
                        <div data-csp-style="font-weight: 600; margin-top: 0.125rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@c.Description</div>
                        @if (!string.IsNullOrEmpty(c.LocationName))
                        {
                            <div data-csp-style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.125rem;">@c.LocationName</div>
                        }
                    </div>
                    <div data-csp-style="text-align: right; flex-shrink: 0;">
                        <div data-csp-style="font-size: 1.5rem; font-weight: 700; color: @textColor; line-height: 1;">@healthDisplay</div>
                        <div data-csp-style="font-size: 0.6875rem; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.06em; margin-top: 0.125rem;">Health</div>
                    </div>
                </div>

                <div data-csp-style="display: grid; grid-template-columns: repeat(@(c.SensorTiles.Count > 0 ? c.SensorTiles.Count : 3), 1fr); gap: 0.5rem; margin-top: 0.875rem;">
                    @foreach (var tile in c.SensorTiles)
                    {
                        var toneColor = TileToneColor(tile.Tone);
                        var toneBg = TileToneBg(tile.Tone);
                        var tileStyle = $"text-align: center; padding: 0.375rem 0.25rem; background: {toneBg}; border-radius: 6px;";
                        var valueStyle = $"font-family: ui-monospace, Menlo, monospace; font-size: 0.875rem; font-weight: 600; margin-top: 0.125rem; color: {toneColor};";
                        <div data-csp-style="@tileStyle" title="@tile.Label">
                            <div data-csp-style="font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@tile.Label</div>
                            <div data-csp-style="@valueStyle">@FormatTileValue(tile.Value, tile.Unit) <span data-csp-style="font-size: 0.7rem; color: var(--text-muted); font-weight: 400;">@tile.Unit</span></div>
                        </div>
                    }
                </div>

                <div data-csp-style="display: flex; justify-content: space-between; align-items: center; margin-top: 0.875rem; padding-top: 0.625rem; border-top: 1px solid rgba(255,255,255,0.06);">
                    @if (c.OpenWorkOrders > 0)
                    {
                        <span data-csp-style="font-size: 0.75rem; color: var(--text-muted);"><strong data-csp-style="color: #fcd34d;">@c.OpenWorkOrders</strong> open WO@(c.OpenWorkOrders == 1 ? "" : "s")</span>
                    }
                    else
                    {
                        <span data-csp-style="font-size: 0.75rem; color: var(--text-muted);">No open work</span>
                    }
                    <span data-csp-style="font-size: 0.75rem; color: @textColor;">Inspect →</span>
                </div>
            </a>
        }
    </div>
}
