@page "{siteId:int}"
@model Abs.FixedAssets.Pages.Plant.FloorModel
@using Abs.FixedAssets.Pages.Shared.Primitives
@{
    ViewData["Title"] = $"Plant Floor — {Model.Site?.Name}";
    ViewData["TabTitle"] = Model.Site?.Name ?? "Plant Floor";
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";

    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = Model.Site?.Name ?? "Plant Floor",
        ["Subtitle"] = $"{Model.CountTotal} assets · live health monitoring",
        ["TypeLabel"] = $"Plant · {Model.Site?.SiteCode}",
        ["StatusText"] = Model.CountRed > 0 ? $"{Model.CountRed} need attention" : "All operational",
        ["StatusTone"] = Model.CountRed > 0 ? "danger" : "success"
    };

    // PR #116d.4 — Tone-driven helpers. Critical < 60, warning 60-79, success >= 80.
    string ToneFor(decimal? h) =>
        !h.HasValue ? "neutral" :
        h >= 80m ? "success" :
        h >= 60m ? "warning" : "critical";

    string SensorPillTone(string tone) => tone switch
    {
        "crit" => "critical",
        "warn" => "warning",
        "ok"   => "success",
        _       => "muted"
    };

    string FormatTileValue(decimal? v, string unit)
    {
        if (!v.HasValue) return "—";
        bool isCounter = unit == "cycles" || unit == "strokes" || unit == "hr";
        if (isCounter) return $"{v.Value:N0}";
        if (Math.Abs(v.Value) >= 100) return $"{v.Value:0}";
        return $"{v.Value:0.00}";
    }

    // PR #116d.4 — Extract manufacturer name from Description for BrandChip.
    // Asset descriptions follow the pattern "MANUFACTURER MODEL #00001" so we
    // pick the first word + capitalize. Unknown manufacturers fall through to
    // BrandChip's "neutral" tint.
    string ManufacturerFromDesc(string? desc)
    {
        if (string.IsNullOrEmpty(desc)) return "";
        var firstWord = desc.Split(' ').FirstOrDefault() ?? "";
        return firstWord.Length > 1
            ? char.ToUpper(firstWord[0]) + firstWord.Substring(1).ToLower()
            : firstWord;
    }
}

@await Html.PartialAsync("_ScreenHeader", headerVd)

<div style="margin-top: 12px;">
    <a href="/Plant" style="font-size: 13px; color: var(--text-muted); text-decoration: none;">← All plants</a>
</div>

@* Band filter chips — rebuilt as <StatusPill> partials *@
<div style="margin-top: 16px; display: flex; gap: 8px; flex-wrap: wrap;">
    @{
        var bandTuples = new (string Key, string Label, int Count, string Tone)[]
        {
            ("all",   "All",      Model.CountTotal, "neutral"),
            ("green", "Healthy",  Model.CountGreen, "success"),
            ("amber", "Watch",    Model.CountAmber, "warning"),
            ("red",   "Critical", Model.CountRed,   "critical")
        };
    }
    @foreach (var (key, label, count, tone) in bandTuples)
    {
        var isActive = string.Equals(Model.Band, key, StringComparison.OrdinalIgnoreCase);
        var pillStyle = isActive
            ? "background: var(--color-accent); color: white; border-color: var(--color-accent); box-shadow: var(--glow-brand);"
            : "";
        <a href="?band=@key" class="ds-pill" data-tone="@tone" style="text-decoration: none; padding: 6px 12px; font-weight: 500; @pillStyle">
            @if (tone != "neutral")
            {
                <span class="ds-pill__dot" aria-hidden="true"></span>
            }
            <span>@label</span>
            <span class="ds-pill__num">@count</span>
        </a>
    }
</div>

@if (Model.Cards.Count == 0)
{
    <div style="margin-top: 24px;">
        @await Html.PartialAsync("Primitives/_EmptyStateV2", new EmptyStateModel
        {
            Icon = "search",
            Tone = "info",
            Title = "No assets in this band",
            Body = "Try clearing the filter to see all assets on this floor.",
            CtaLabel = "Show all assets",
            CtaHref = $"/Plant/Floor/{Model.SiteId}?band=all"
        })
    </div>
}
else
{
    @* PR #116d.4 — Asset cards rebuilt on the design system.
       Each card is a tone-driven <DataCard>:
       - Health number prominent in eyebrow row
       - Description as title, AssetNumber as mono eyebrow
       - Location as subtitle
       - BrandChip surfacing the manufacturer
       - Sensor tiles as a custom grid using design-system tokens
       - Footer with Open WOs + Inspect link
       Brand-glow rings tone-tinted on hover. Hover-lift 5px. *@
    <div class="ds-showcase__grid" style="grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); margin-top: 20px;">
        @foreach (var c in Model.Cards)
        {
            var tone = ToneFor(c.HealthScore);
            var healthDisplay = c.HealthScore.HasValue ? $"{c.HealthScore.Value:0}" : "—";
            var healthColor = tone switch
            {
                "critical" => "var(--danger)",
                "warning"  => "var(--warning)",
                "success"  => "var(--success)",
                _          => "var(--text-muted)"
            };
            var mfr = ManufacturerFromDesc(c.Description);
            <a class="ds-card is-interactive" data-tone="@tone" data-interactive="true" href="/Assets/Asset/@c.Id" style="text-decoration: none; color: inherit;">
                <div class="ds-card__eyebrow">
                    <span class="ds-card__eyebrow-label" style="font-family: var(--font-mono); font-feature-settings: 'tnum' 1; text-transform: none; letter-spacing: 0.02em;">@c.AssetNumber</span>
                    <span style="font-size: 28px; font-weight: 700; color: @healthColor; line-height: 1; letter-spacing: -0.025em;">
                        @healthDisplay<span style="font-size: 11px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; margin-left: 6px; font-weight: 500;">health</span>
                    </span>
                </div>
                <div class="ds-card__title" style="margin-top: 6px;">@c.Description</div>
                @if (!string.IsNullOrEmpty(c.LocationName))
                {
                    <div class="ds-card__subtitle">@c.LocationName</div>
                }
                @if (!string.IsNullOrEmpty(mfr))
                {
                    <div style="margin-top: 10px;">
                        @await Html.PartialAsync("Primitives/_BrandChip", new BrandChipModel { Manufacturer = mfr, Size = "sm" })
                    </div>
                }

                @if (c.SensorTiles.Count > 0)
                {
                    <div style="display: grid; grid-template-columns: repeat(@Math.Min(c.SensorTiles.Count, 3), 1fr); gap: 6px; margin-top: 12px;">
                        @foreach (var tile in c.SensorTiles)
                        {
                            var tilePillTone = SensorPillTone(tile.Tone);
                            var tileBg = tile.Tone switch
                            {
                                "crit" => "rgba(239,68,68,0.10)",
                                "warn" => "rgba(245,158,11,0.10)",
                                "ok"   => "rgba(16,185,129,0.08)",
                                _       => "rgba(255,255,255,0.025)"
                            };
                            var tileBorder = tile.Tone switch
                            {
                                "crit" => "rgba(239,68,68,0.28)",
                                "warn" => "rgba(245,158,11,0.25)",
                                "ok"   => "rgba(16,185,129,0.22)",
                                _       => "var(--border-secondary)"
                            };
                            var valColor = tile.Tone switch
                            {
                                "crit" => "#ffcdcd",
                                "warn" => "#ffe0ad",
                                "ok"   => "#b3f8d8",
                                _       => "var(--text-primary)"
                            };
                            <div title="@tile.Label" style="text-align: center; padding: 6px 6px; background: @tileBg; border: 1px solid @tileBorder; border-radius: var(--radius-md, 8px);">
                                <div style="font-size: 9.5px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.07em; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@tile.Label</div>
                                <div style="font-family: var(--font-mono); font-feature-settings: 'tnum' 1; font-size: 14px; font-weight: 600; margin-top: 2px; color: @valColor;">
                                    @FormatTileValue(tile.Value, tile.Unit)<span style="font-size: 10px; color: var(--text-muted); font-weight: 500; margin-left: 2px;">@tile.Unit</span>
                                </div>
                            </div>
                        }
                    </div>
                }

                <div class="ds-card__footer">
                    @if (c.OpenWorkOrders > 0)
                    {
                        <span><strong style="color: var(--warning);">@c.OpenWorkOrders</strong> open WO@(c.OpenWorkOrders == 1 ? "" : "s")</span>
                    }
                    else
                    {
                        <span>No open work</span>
                    }
                    <span style="margin-left: auto; color: var(--color-accent); font-weight: 500;">Inspect →</span>
                </div>
            </a>
        }
    </div>
}
