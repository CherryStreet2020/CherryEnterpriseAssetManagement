@model Abs.FixedAssets.Pages.IndexModel
<div class="hero-tags">
    @if (Model.OpenMaintenance > 0)
    {
        <span class="hero-tag info">@Model.OpenMaintenance OPEN WORK ORDERS</span>
    }
    @if (Model.ActiveCipProjects > 0)
    {
        <span class="hero-tag success">@Model.ActiveCipProjects ACTIVE PROJECTS</span>
    }
</div>
<div class="hero-btns">
    <a href="/Assets/Asset?mode=create" class="hero-btn hero-btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        New Asset
    </a>
    <a href="/Reports/ReportHub" class="hero-btn hero-btn-ghost">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
        </svg>
        Reports
    </a>
</div>
