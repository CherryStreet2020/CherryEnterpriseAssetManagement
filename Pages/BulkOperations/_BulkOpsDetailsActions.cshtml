@{
    var op = ViewData["Operation"] as Abs.FixedAssets.Models.BulkOperation;
}
@if (op != null)
{
    <div class="screen-header__actions">
        <div class="hero-tags">
            <span class="hero-tag info">@op.CreatedAt.ToString("MMM dd, yyyy h:mm tt")</span>
        </div>
        <div class="hero-btns">
            <a href="/BulkOperations" class="hero-btn hero-btn-ghost">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Back to Bulk Operations
            </a>
            <a href="/Assets" class="hero-btn hero-btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                </svg>
                View All Assets
            </a>
        </div>
    </div>
}
