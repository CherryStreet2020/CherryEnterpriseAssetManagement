@page
@model Abs.FixedAssets.Pages.ModuleDisabledModel
@{
    ViewData["Title"] = "Module Not Available";
    Layout = "_ModernLayout";
    ViewData["HideDefaultPageHeader"] = true;
}

<div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 60vh; text-align: center; padding: 40px;">
    <div class="gradient-btn-amber" style="width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 24px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
    </div>
    
    <h1 style="font-size: 28px; font-weight: 600; color: var(--text-primary); margin-bottom: 12px;">Module Not Enabled</h1>
    
    <p style="font-size: 16px; color: var(--text-muted); max-width: 500px; margin-bottom: 32px;">
        The <strong>@Model.ModuleName</strong> module is currently disabled for your organization.
        Contact your system administrator to enable this feature.
    </p>
    
    <div style="display: flex; gap: 12px;">
        <a href="/" class="btn-p btn-p--primary">Go to Dashboard</a>
        <a href="/Admin/Company" class="btn-p btn-p--secondary">Company Settings</a>
    </div>
    
    <div style="margin-top: 48px; padding: 20px; background: var(--bg-secondary); border-radius: 12px; max-width: 400px;">
        <h3 style="font-size: 14px; font-weight: 600; margin-bottom: 8px; color: var(--text-primary);">Need this module?</h3>
        <p style="font-size: 13px; color: var(--text-muted); margin: 0;">
            Go to <strong>Administration &rarr; Company Settings</strong> and enable the module under "Optional Modules".
        </p>
    </div>
</div>
