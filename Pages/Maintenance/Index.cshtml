@page
@model Abs.FixedAssets.Pages.Maintenance.IndexModel
@using Abs.FixedAssets.Helpers
@using Abs.FixedAssets.Services.Maintenance
@{
    ViewData["Title"] = UiTerms.ModuleName;
    ViewData["TabTitle"] = UiTerms.WorkOrderPlural;
    ViewData["HasScreenHeader"] = true;
    Layout = "_ModernLayout";
    
    var statusText = Model.Stats.OverdueCount > 0 ? $"{Model.Stats.OverdueCount} Overdue" : "All Current";
    var statusTone = Model.Stats.OverdueCount > 0 ? "warning" : "success";
    
    var headerVd = new ViewDataDictionary(ViewData) {
        ["HeaderTitle"] = UiTerms.ModuleName,
        ["Subtitle"] = "Manage work orders, track maintenance progress, and monitor costs",
        ["TypeLabel"] = "Work Execution",
        ["StatusText"] = statusText,
        ["StatusTone"] = statusTone,
        ["ContextPartial"] = "/Pages/Maintenance/_MaintenanceIndexContext.cshtml",
        ["KpisPartial"] = "/Pages/Maintenance/_MaintenanceIndexKpis.cshtml",
        ["ActionsPartial"] = "/Pages/Maintenance/_MaintenanceIndexActions.cshtml"
    };
}

@await Html.PartialAsync("_ScreenHeader", headerVd)

<div class="module-header">
    <nav class="module-pills" role="navigation" aria-label="@UiTerms.ModuleName navigation">
        <a href="/Maintenance" class="module-pill active" aria-current="page">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
            </svg>
            @UiTerms.WorkOrderPlural
        </a>
        <a href="/Maintenance/PMTemplates" class="module-pill" aria-current="false">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            @UiTerms.PMTemplates
        </a>
        <a href="/Maintenance/Assignments" class="module-pill" aria-current="false">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
            PM Assignments
        </a>
        <a href="/Maintenance/Schedules" class="module-pill" aria-current="false">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            @UiTerms.Schedules
        </a>
    </nav>
</div>

@if (Model.RecurringFailures30.Any() || Model.RecurringFailures90.Any())
{
<div class="recurring-failures-grid">
    <div class="recurring-failures-card">
        <h3 class="recurring-failures-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#ef4444">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            Recurring Failures (30 Days)
        </h3>
        @if (Model.RecurringFailures30.Any())
        {
            <table class="recurring-failures-table">
                <thead>
                    <tr>
                        <th>Failure Code</th>
                        <th>Asset</th>
                        <th class="text-center">Count</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var failure in Model.RecurringFailures30)
                    {
                        <tr>
                            <td><span class="failure-code-badge danger">@failure.FailureCode</span></td>
                            <td>@(failure.AssetNumber ?? "N/A")</td>
                            <td class="text-center failure-count danger">@failure.Count</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="recurring-failures-empty">No recurring failures in the last 30 days</p>
        }
    </div>
    <div class="recurring-failures-card">
        <h3 class="recurring-failures-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#f59e0b">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            Recurring Failures (90 Days)
        </h3>
        @if (Model.RecurringFailures90.Any())
        {
            <table class="recurring-failures-table">
                <thead>
                    <tr>
                        <th>Failure Code</th>
                        <th>Asset</th>
                        <th class="text-center">Count</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var failure in Model.RecurringFailures90)
                    {
                        <tr>
                            <td><span class="failure-code-badge warning">@failure.FailureCode</span></td>
                            <td>@(failure.AssetNumber ?? "N/A")</td>
                            <td class="text-center failure-count warning">@failure.Count</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="recurring-failures-empty">No recurring failures in the last 90 days</p>
        }
    </div>
</div>
}

<div class="quick-stats-row-4">
    <a href="/Maintenance" class="quick-stat-card clickable @(Model.Filter == null ? "stat-active" : "")">
        <div class="quick-stat-icon primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
        </div>
        <div class="quick-stat-content">
            <div class="quick-stat-value primary">@Model.Stats.TotalEvents</div>
            <div class="quick-stat-label">Total Work Orders</div>
        </div>
    </a>
    <a href="/Maintenance?filter=overdue" class="quick-stat-card clickable @(Model.Filter == "overdue" ? "stat-active" : "")">
        <div class="quick-stat-icon danger">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
        </div>
        <div class="quick-stat-content">
            <div class="quick-stat-value danger">@Model.Stats.OverdueCount</div>
            <div class="quick-stat-label">Overdue</div>
        </div>
    </a>
    <a href="/Maintenance?filter=scheduled" class="quick-stat-card clickable @(Model.Filter == "scheduled" ? "stat-active" : "")">
        <div class="quick-stat-icon warning">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
        </div>
        <div class="quick-stat-content">
            <div class="quick-stat-value warning">@Model.Stats.ScheduledCount</div>
            <div class="quick-stat-label">Scheduled</div>
        </div>
    </a>
    <a href="/Maintenance?filter=completed" class="quick-stat-card clickable @(Model.Filter == "completed" ? "stat-active" : "")">
        <div class="quick-stat-icon success">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </div>
        <div class="quick-stat-content">
            <div class="quick-stat-value success">@Model.Stats.CompletedThisMonth</div>
            <div class="quick-stat-label">Completed (Month)</div>
        </div>
    </a>
</div>

<div class="section-card pe-card">
    <div class="section-card-header pe-card__header">
        <h3 class="section-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
            </svg>
            @Model.FilterLabel
        </h3>
        @if (Model.Filter != null)
        {
            <a href="/Maintenance" class="btn-premium btn-premium-secondary btn-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
                Clear Filter
            </a>
        }
    </div>
    @if (Model.Events.Any())
    {
        <div class="section-card-body section-card-body-flush pe-card__body">
            @{ var returnUrl = $"{HttpContext.Request.Path}{HttpContext.Request.QueryString}"; }
            <table class="data-table premium-table" id="maintenanceGrid" data-enhanced-grid="true" data-row-click="true">
                <thead>
                    <tr>
                        <th style="width: 110px;" data-col="WO #" data-filter="text">WO #</th>
                        <th style="width: 90px;" class="no-sort" data-col="Status" data-filter="select" data-filter-options="Scheduled|InProgress|Completed|Cancelled|Overdue">Status</th>
                        <th style="width: 80px;" class="no-sort" data-col="Priority" data-filter="select" data-filter-options="Low|Medium|High|Critical">Priority</th>
                        <th style="width: 95px;" class="no-sort" data-col="Source" data-filter="text">Source</th>
                        <th style="width: 100px;" data-col="Asset" data-filter="text">Asset</th>
                        <th style="min-width: 180px;" data-col="Description" data-filter="text">Description</th>
                        <th style="width: 100px;" data-col="Scheduled" data-filter="text">Scheduled</th>
                        <th style="width: 90px; text-align: right;" data-col="Est. Cost" data-filter="number">Est. Cost</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var evt in Model.Events)
                    {
                        var origin = Model.EventOrigins.GetValueOrDefault(evt.Id, new WorkOrderOriginInfo());
                        var isOverdue = evt.ScheduledDate < DateTime.UtcNow && evt.Status != MaintenanceStatus.Completed && evt.Status != MaintenanceStatus.Cancelled;
                        <tr data-row-id="@evt.Id" data-row-href="@Url.Page("/Maintenance/Details", new { id = evt.Id, returnUrl = returnUrl })">
                            <td><strong class="text-primary">@(evt.WorkOrderNumber ?? $"#{evt.Id}")</strong></td>
                            <td>
                                <span class="badge @(evt.Status == MaintenanceStatus.Completed ? "badge-success" : evt.Status == MaintenanceStatus.InProgress ? "badge-warning" : isOverdue ? "badge-danger" : evt.Status == MaintenanceStatus.Cancelled ? "badge-secondary" : "badge-neutral")">
                                    @(isOverdue ? "Overdue" : evt.Status.ToString())
                                </span>
                            </td>
                            <td>
                                <span class="badge @(evt.Priority == MaintenancePriority.Critical ? "badge-danger" : evt.Priority == MaintenancePriority.High ? "badge-warning" : "badge-neutral")">
                                    @evt.Priority
                                </span>
                            </td>
                            <td>
                                <span class="badge @origin.BadgeClass" title="@(origin.TemplateReference ?? origin.ScheduleReference ?? "")">
                                    @origin.Label
                                </span>
                            </td>
                            <td class="cell-medium">
                                @if (evt.Asset != null)
                                {
                                    @evt.Asset.AssetNumber
                                }
                                else
                                {
                                    <span class="cell-muted">Unassigned</span>
                                }
                            </td>
                            <td class="cell-truncate" title="@evt.Description">@evt.Description</td>
                            <td class="cell-nowrap">@evt.ScheduledDate.ToString("MM/dd/yyyy")</td>
                            <td class="cell-right cell-bold">@evt.EstimatedCost.ToString("C0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state empty-state-padded">
            <svg xmlns="http://www.w3.org/2000/svg" class="empty-state-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            @if (Model.Filter != null)
            {
                <h3 class="empty-state-title">No Work Orders Match These Filters</h3>
                <p class="empty-state-text">Try adjusting your filters or view all work orders.</p>
                <a href="/Maintenance" class="btn btn-primary empty-state-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="empty-state-icon">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                    Clear Filters
                </a>
            }
            else
            {
                <h3 class="empty-state-title">No Work Orders</h3>
                <p class="empty-state-text">No work orders have been created yet. Add your first work order to start tracking maintenance.</p>
                <a href="/Maintenance/Create" class="btn btn-primary empty-state-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="empty-state-icon">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                    New Work Order
                </a>
            }
        </div>
    }
</div>

