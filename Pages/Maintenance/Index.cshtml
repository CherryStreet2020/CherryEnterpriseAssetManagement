@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function() {
    initEnhancedGrid('maintenanceGrid', {
        searchable: true,
        sortable: true,
        exportable: true,
        columnVisibility: true,
        clickableRows: true
    });
    
    @if (Model.CreateFor.HasValue)
    {
        <text>
        window.location.href = '/Maintenance/Create?createFor=@Model.CreateFor.Value';
        </text>
    }
});
</script>
}
