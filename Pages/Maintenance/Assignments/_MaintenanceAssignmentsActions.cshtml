@model Abs.FixedAssets.Pages.Maintenance.Assignments.IndexModel

<div class="hero-tags">
    @if (Model.ActiveAssignments > 0)
    {
        <span class="hero-tag success">@Model.ActiveAssignments ACTIVE</span>
    }
</div>
<div class="hero-btns">
    <a href="/Maintenance/Schedules" class="hero-btn hero-btn-ghost">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        View Schedules
    </a>
    <button type="button" class="hero-btn hero-btn-primary" onclick="toggleInlineForm('createForm')">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Create Assignment
    </button>
</div>
