@page
@model Abs.FixedAssets.Pages.Maintenance.WorkRequests.CreateModel
@{
    ViewData["Title"] = "Create Work Request";
    ViewData["TabTitle"] = "New Work Request";
    ViewData["HasScreenHeader"] = true;
}

@{
    var headerVd = new ViewDataDictionary(ViewData)
    {
        { "HeaderTitle", "Create Work Request" },
        { "Subtitle", "Describe your maintenance issue or request. Smart Assist will help generate a work order." },
        { "TypeLabel", "Maintenance" },
        { "StatusText", "New" },
        { "StatusTone", "info" },
        { "ActionsPartial", "Maintenance/WorkRequests/_WorkRequestsCreateActions" }
    };
}
@await Html.PartialAsync("Shared/_ScreenHeader", headerVd)

<div class="content-grid">
    <div class="content-main">
        <form method="get" id="filterForm" class="card mb-3">
            <div class="card-header">
                <h3 class="card-title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="me-2">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    Select Location & Asset
                </h3>
            </div>
            <div class="card-body">
                @if (!Model.HasSites)
                {
                    <div class="alert alert-warning d-flex align-items-center gap-2 mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                        <span>No sites configured. Contact your administrator to configure Sites.</span>
                    </div>
                }
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Site <span class="text-danger">*</span></label>
                        <select name="SelectedSiteId" class="form-select" data-wr-site>
                            <option value="">-- Select Site --</option>
                            @foreach (var site in Model.Sites)
                            {
                                <option value="@site.Value" selected="@(site.Value == Model.SelectedSiteId?.ToString())">@site.Text</option>
                            }
                        </select>
                        <small class="text-muted">Required to filter locations and assets</small>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Location</label>
                        @if (!Model.IsSiteSelected)
                        {
                            <select class="form-select" data-wr-location disabled>
                                <option value="">-- Select a site first --</option>
                            </select>
                        }
                        else if (!Model.HasLocationsForSite)
                        {
                            <select class="form-select" data-wr-location disabled>
                                <option value="">-- No locations for this site --</option>
                            </select>
                            <small class="text-muted">No locations defined. <a href="/Assets/Locations">Configure Locations</a></small>
                        }
                        else
                        {
                            <select name="SelectedLocationId" class="form-select" data-wr-location>
                                <option value="">-- All Locations --</option>
                                @foreach (var loc in Model.Locations)
                                {
                                    <option value="@loc.Value" selected="@(loc.Value == Model.SelectedLocationId?.ToString())">@loc.Text</option>
                                }
                            </select>
                            <small class="text-muted">Optional - filter assets by location</small>
                        }
                    </div>
                </div>
            </div>
        </form>

        <form method="post">
            <input type="hidden" asp-for="SelectedSiteId" />
            <input type="hidden" asp-for="SelectedLocationId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="form-section">
                <div class="form-section__title">
                    <h3>
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="me-2">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                        Request Details
                    </h3>
                </div>
                <div class="form-section__body">
                    <div class="form-grid">
                        <div class="form-field form-field--full">
                            <label asp-for="IssueSummary" class="form-field__label">Brief Summary <span class="form-field__required">*</span></label>
                            <input asp-for="IssueSummary" class="form-field__input" placeholder="e.g., Hydraulic press grinding noise" maxlength="200" />
                            <span asp-validation-for="IssueSummary" class="form-field__error"></span>
                        </div>
                        <div class="form-field form-field--full">
                            <label asp-for="WorkRequest.RequestText" class="form-field__label">Full Description</label>
                            <textarea asp-for="WorkRequest.RequestText" class="form-field__input" rows="4" placeholder="Provide additional details about the issue..."></textarea>
                            <span asp-validation-for="WorkRequest.RequestText" class="form-field__error"></span>
                        </div>
                        <div class="form-field">
                            <label asp-for="Symptoms" class="form-field__label">Symptoms Observed</label>
                            <input asp-for="Symptoms" class="form-field__input" placeholder="e.g., Loud noise, vibration, leak" />
                        </div>
                        <div class="form-field">
                            <label asp-for="ErrorCode" class="form-field__label">Error Code (if any)</label>
                            <input asp-for="ErrorCode" class="form-field__input" placeholder="e.g., E-401, OVR-TEMP" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="me-2">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                        </svg>
                        Asset Selection
                    </h3>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="WorkRequest.AssetId" class="form-label">Asset</label>
                            @if (!Model.IsSiteSelected)
                            {
                                <select class="form-select" data-wr-asset disabled>
                                    <option value="">-- Select a site first (above) --</option>
                                </select>
                                <small class="text-muted">Choose a site to see available assets</small>
                            }
                            else if (!Model.HasAssetsForSite)
                            {
                                <select class="form-select" data-wr-asset disabled>
                                    <option value="">-- No assets in this site/location --</option>
                                </select>
                                <small class="text-muted">No matching assets found. <a href="/Assets">View Assets</a> to set site/location on assets.</small>
                            }
                            else
                            {
                                <select asp-for="WorkRequest.AssetId" asp-items="Model.Assets" class="form-select" data-cherry-select data-placeholder="Search assets..." data-wr-asset>
                                    <option value="">-- Select or leave blank for Smart Assist --</option>
                                </select>
                            }
                        </div>
                        <div class="col-md-6">
                            <label asp-for="AssetHint" class="form-label">Asset Hint (if not listed)</label>
                            <input asp-for="AssetHint" class="form-control" placeholder="e.g., Press #3 near dock, blue conveyor" />
                            <small class="text-muted">Describe the asset if you can't find it in the list</small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="me-2">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        Impact & Urgency
                    </h3>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="WorkRequest.Priority" class="form-label">Priority</label>
                            <select asp-for="WorkRequest.Priority" asp-items="Html.GetEnumSelectList<Abs.FixedAssets.Models.WorkRequestPriority>()" class="form-select"></select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="StartedAt" class="form-label">When did it start?</label>
                            <input asp-for="StartedAt" type="datetime-local" class="form-control" />
                        </div>
                        <div class="col-md-4 d-flex flex-column justify-content-end gap-2">
                            <div class="form-check">
                                <input asp-for="IsDowntime" class="form-check-input" type="checkbox" />
                                <label asp-for="IsDowntime" class="form-check-label">Equipment is DOWN</label>
                            </div>
                            <div class="form-check">
                                <input asp-for="IsSafetyRisk" class="form-check-input" type="checkbox" />
                                <label asp-for="IsSafetyRisk" class="form-check-label">Safety concern</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <div class="form-section__title">
                    <h3>
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="me-2">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                        Contact Information
                    </h3>
                </div>
                <div class="form-section__body">
                    <div class="form-grid">
                        <div class="form-field">
                            <label asp-for="WorkRequest.RequestedBy" class="form-field__label">Requested By</label>
                            <input asp-for="WorkRequest.RequestedBy" class="form-field__input" value="@User.Identity?.Name" />
                        </div>
                        <div class="form-field">
                            <label asp-for="WorkRequest.ContactPhone" class="form-field__label">Phone</label>
                            <input asp-for="WorkRequest.ContactPhone" class="form-field__input" placeholder="(555) 123-4567" />
                        </div>
                        <div class="form-field">
                            <label asp-for="WorkRequest.ContactEmail" class="form-field__label">Email</label>
                            <input asp-for="WorkRequest.ContactEmail" class="form-field__input" type="email" placeholder="user@company.com" />
                        </div>
                        <div class="form-field form-field--full">
                            <label asp-for="AttachmentNotes" class="form-field__label">Attachment Notes / URLs</label>
                            <input asp-for="AttachmentNotes" class="form-field__input" placeholder="e.g., Photo in shared drive: //files/maintenance/issue-photo.jpg" />
                            <span class="form-field__help">Reference any photos, documents, or file locations</span>
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.ShowAssistPanel && Model.AssistResult != null)
            {
                <div class="card border-success">
                    <div class="card-header bg-success text-white">
                        <h3 class="card-title mb-0">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="me-2">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                            Smart Assist Analysis
                            <span class="badge bg-light text-dark ms-2">@Model.AssistResult.Confidence Confidence</span>
                        </h3>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            @if (Model.AssistResult.SuggestedAssetName != null)
                            {
                                <div class="col-md-3">
                                    <label class="form-label text-muted">Suggested Asset</label>
                                    <div class="fw-semibold">@Model.AssistResult.SuggestedAssetName</div>
                                </div>
                            }
                            <div class="col-md-3">
                                <label class="form-label text-muted">Priority</label>
                                <div class="fw-semibold">@Model.AssistResult.SuggestedPriority</div>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label text-muted">Est. Labor</label>
                                <div class="fw-semibold">@Model.AssistResult.EstimatedLaborHours hours</div>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label text-muted">Craft</label>
                                <div class="fw-semibold">@Model.AssistResult.SuggestedCraft</div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="form-actions form-actions--between">
                <div>
                    <a class="btn-p btn-p--secondary" href="/Maintenance/WorkRequests">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="me-1">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                        Cancel
                    </a>
                </div>
                <div>
                    <button type="submit" asp-page-handler="SaveOnly" class="btn-p btn-p--secondary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="me-1">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" />
                        </svg>
                        Save Request Only
                    </button>
                    <button type="submit" class="btn-p btn-p--primary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="me-1">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                        </svg>
                        Smart Assist - Generate Work Order
                    </button>
                </div>
            </div>
        </form>
    </div>

    <div class="content-sidebar">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="me-2">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Smart Assist Readiness
                </h3>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">Readiness Score</span>
                        <span class="fw-semibold">@Model.ReadinessScore%</span>
                    </div>
                    <div class="progress">
                        <div class="progress-bar @(Model.ReadinessScore >= 70 ? "bg-success" : Model.ReadinessScore >= 40 ? "bg-warning" : "bg-secondary")" 
                             role="progressbar" 
                             aria-valuenow="@Model.ReadinessScore" 
                             aria-valuemin="0" 
                             aria-valuemax="100"
                             style="width: @(Model.ReadinessScore)%"></div>
                    </div>
                </div>
                <p class="text-muted small mb-2">For best AI analysis, include:</p>
                <ul class="list-unstyled mb-0 small">
                    <li class="mb-1 d-flex align-items-start gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="text-success flex-shrink-0 mt-1">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        Brief summary of the issue
                    </li>
                    <li class="mb-1 d-flex align-items-start gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="text-success flex-shrink-0 mt-1">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        Select or describe the asset
                    </li>
                    <li class="mb-1 d-flex align-items-start gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="text-muted flex-shrink-0 mt-1">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                        </svg>
                        Symptoms or error codes
                    </li>
                    <li class="mb-1 d-flex align-items-start gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="text-muted flex-shrink-0 mt-1">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                        </svg>
                        Downtime or safety impact
                    </li>
                </ul>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="me-2">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
                    </svg>
                    What Happens Next
                </h3>
            </div>
            <div class="card-body">
                <ol class="mb-0 ps-3 small">
                    <li class="mb-2"><strong>Submit</strong> your request</li>
                    <li class="mb-2"><strong>Triage</strong> — queued for review</li>
                    <li class="mb-2"><strong>Smart Assist</strong> analyzes priority, craft, labor</li>
                    <li class="mb-2"><strong>Convert</strong> to Work Order</li>
                    <li class="mb-0"><strong>Dispatch</strong> to technician</li>
                </ol>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="me-2">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                    </svg>
                    Tips for Faster Triage
                </h3>
            </div>
            <div class="card-body">
                <ul class="mb-0 ps-3 small">
                    <li class="mb-1">Use specific equipment names</li>
                    <li class="mb-1">Include error codes if displayed</li>
                    <li class="mb-1">Note when the issue started</li>
                    <li class="mb-1">Mark if equipment is down</li>
                    <li class="mb-0">Mention safety concerns</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/work-requests-create.js"></script>
}
