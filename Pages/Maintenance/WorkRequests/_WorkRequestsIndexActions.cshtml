@model Abs.FixedAssets.Pages.Maintenance.WorkRequests.IndexModel
@{
}
<div class="hero-tags">
    @if (!string.IsNullOrEmpty(Model.StatusFilter))
    {
        <span class="hero-tag info">FILTERED: @Model.StatusFilter.ToUpper()</span>
    }
</div>
<div class="hero-btns">
    @if (!string.IsNullOrEmpty(Model.StatusFilter) || !string.IsNullOrEmpty(Model.SearchTerm))
    {
        <a asp-page="./Index" asp-route-view="@Model.View" class="hero-btn hero-btn-ghost">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
            Clear Filter
        </a>
    }
    <a asp-page="./Create" class="hero-btn hero-btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        New Request
    </a>
</div>
