@model Abs.FixedAssets.Pages.Maintenance.SchedulesModel

<div class="hero-tags">
    @if (Model.Overdue > 0)
    {
        <span class="hero-tag danger">@Model.Overdue OVERDUE</span>
    }
</div>
<div class="hero-btns">
    <a href="/Maintenance/Schedules" class="hero-btn hero-btn-ghost">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Create Schedule
    </a>
    <a href="/Maintenance/PMTemplates" class="hero-btn hero-btn-ghost">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        PM Templates
    </a>
</div>
