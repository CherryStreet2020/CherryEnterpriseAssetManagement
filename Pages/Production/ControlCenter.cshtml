@page
@model Abs.FixedAssets.Pages.Production.ControlCenterModel
@using Abs.FixedAssets.Models.Production
@using Abs.FixedAssets.Services.Production
@{
    ViewData["Title"] = "Production Control Center";
    ViewData["TabTitle"] = "Production";
    ViewData["BodyClass"] = "is-control-center";
    Layout = "_ModernLayout";
}

@*
    Sprint 13.5 PR #5b.1 — Production Control Center.
    Composes the shared Cockpit primitives (same ones Receiving uses).
    Dark theme + two-pane queue+preview + LIVE + Voice + KPI hero band.
    Per Dean 2026-05-23 lock: user-facing label is "Control Center".
*@

@* 1) Anchored page header — title + scope + LIVE + Voice push-to-talk pill. *@
@if (Model.PageHeader is not null)
{
    @await Html.PartialAsync("Primitives/Cockpit/_CockpitPageHeader", Model.PageHeader)
}

@* 2) KPI hero band — 4 big tiles. Past-Due / Due-Today / In-Progress / On-Hold.
       OEE / Throughput / Down-Machines tiles get wired when PR #5c (operations)
       + PR #5e (event tables) ship. *@
@if (Model.KpiBand is not null)
{
    @await Html.PartialAsync("Primitives/Cockpit/_CockpitKpiBand", Model.KpiBand)
}

@* 3) Tab shell — Dispatch / Exceptions / Activity. (Machines / Downtime /
       Quality tabs land in PR #5e once event tables exist.) *@
@await Html.PartialAsync("Primitives/Cockpit/_CockpitTabShell", Model.TabShell)

@* 4) Per-tab content. *@
@switch (Model.ActiveTab)
{
    case Abs.FixedAssets.Pages.Production.ControlCenterModel.TabExceptions:
        <div role="tabpanel" aria-labelledby="tab-exceptions" class="cockpit-tab-pane">
            @if (Model.ExceptionLane is null || Model.ExceptionLane.Items.Count == 0)
            {
                <div class="cockpit__empty">
                    <i class="fas fa-circle-check cockpit__empty-icon cockpit__empty-icon--success"></i>
                    <div class="cockpit__empty-message">No exceptions — nothing past due, nothing stale on hold.</div>
                </div>
            }
            else
            {
                <div class="cockpit__exception-lane">
                    <div class="cockpit__exception-lane-header">
                        <strong>@Model.ExceptionLane.TotalCount</strong> candidates · ranked by composite score
                        <span class="muted">as of @Model.ExceptionLane.AsOfUtc.ToString("HH:mm") UTC</span>
                    </div>
                    @foreach (var item in Model.ExceptionLane.Items)
                    {
                        <a href="@item.Href" class="cockpit__exception cockpit__exception--@item.Severity">
                            <span class="cockpit__exception-dot"></span>
                            <div class="cockpit__exception-body">
                                <div class="cockpit__exception-line1">
                                    <span class="cockpit__exception-eyebrow">@item.OrderNumber</span>
                                    <span class="cockpit__exception-headline">@item.Headline</span>
                                </div>
                                <div class="cockpit__exception-subtext">@item.Subtext</div>
                            </div>
                            <span class="cockpit__exception-score" title="Composite rank">@item.Score</span>
                        </a>
                    }
                </div>
            }
        </div>
        break;

    case Abs.FixedAssets.Pages.Production.ControlCenterModel.TabActivity:
        <div role="tabpanel" aria-labelledby="tab-activity" class="cockpit-tab-pane">
            @if (Model.ActivityFeed is null || Model.ActivityFeed.Entries.Count == 0)
            {
                <div class="cockpit__empty">
                    <i class="fas fa-clock cockpit__empty-icon"></i>
                    <div class="cockpit__empty-message">No recent activity — mutations show here as they happen.</div>
                </div>
            }
            else
            {
                <ul class="cockpit__activity-feed">
                    @foreach (var e in Model.ActivityFeed.Entries)
                    {
                        var iconCls = e.ActorKind == "ai" ? "fa-sparkles"
                                    : e.ActorKind == "system" ? "fa-gear" : "fa-user";
                        <li class="cockpit__activity-entry">
                            <div class="cockpit__activity-icon cockpit__activity-icon--@e.ActorKind">
                                <i class="fas @iconCls"></i>
                            </div>
                            <div class="cockpit__activity-body">
                                <div class="cockpit__activity-line1">
                                    <strong>@e.ActorName</strong>
                                    <span class="muted">@e.Verb</span>
                                    @if (!string.IsNullOrEmpty(e.Href))
                                    { <a href="@e.Href">@e.TargetRef</a> }
                                    else
                                    { <span>@e.TargetRef</span> }
                                </div>
                                @if (!string.IsNullOrEmpty(e.Snippet))
                                {
                                    <div class="cockpit__activity-snippet">@e.Snippet</div>
                                }
                                <div class="cockpit__activity-time">@e.OccurredAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</div>
                            </div>
                        </li>
                    }
                </ul>
            }
        </div>
        break;

    default:
        @* Dispatch tab — the real Cockpit canvas (queue + preview). *@
        <div role="tabpanel" aria-labelledby="tab-dispatch">
            @if (Model.QueueShell is not null)
            {
                @await Html.PartialAsync("Primitives/Cockpit/_CockpitShell", Model.QueueShell)
            }
        </div>
        break;
}

@* 5) AI suggestions strip — always present below the workspace. *@
@if (Model.AiSuggestions is not null && Model.AiSuggestions.Suggestions.Count > 0)
{
    <div class="cockpit__ai-strip">
        <div class="cockpit__ai-summary">
            <i class="fas fa-wand-magic-sparkles cockpit__ai-icon"></i>
            <span class="cockpit__ai-label">AI SNAPSHOT</span>
            <span class="cockpit__ai-text">@Model.AiSuggestions.SummaryText</span>
        </div>
        <div class="cockpit__ai-suggestions">
            @foreach (var s in Model.AiSuggestions.Suggestions)
            {
                <div class="cockpit__ai-card cockpit__ai-card--@s.Tone">
                    <div class="cockpit__ai-card-headline">@s.Headline</div>
                    @if (!string.IsNullOrEmpty(s.Subtext))
                    {
                        <div class="cockpit__ai-card-subtext">@s.Subtext</div>
                    }
                    @if (!string.IsNullOrEmpty(s.ActionHref))
                    {
                        <a href="@s.ActionHref" class="cockpit__ai-card-action">@(s.ActionLabel ?? "View") →</a>
                    }
                </div>
            }
        </div>
    </div>
}

@section Scripts {
    <script src="~/js/cockpit.js" asp-append-version="true"></script>
    <script>
        // selectProductionOrder — Production-specific preview hydrator (mirrors selectPO).
        // Reads from __productionDetails blob (a dict: rowId -> preview record) emitted by
        // IProductionControlCenterService.GetProductionQueueAsync.
        (function () {
            var PRO_DATA = {};
            try {
                var blob = document.getElementById('__productionDetails');
                if (blob) { PRO_DATA = JSON.parse(blob.textContent); }
            } catch (e) { /* fall back to welcome state */ }

            window.selectProductionOrder = function (id) {
                document.querySelectorAll('.cockpit__card').forEach(function (c) { c.classList.remove('cockpit__card--active'); });
                var card = document.querySelector('.cockpit__card[data-id="' + id + '"]');
                if (card) card.classList.add('cockpit__card--active');

                var pro = PRO_DATA[id];
                if (!pro) return;

                var welcome = document.getElementById('mainWelcome');
                var pv = document.getElementById('mainPreview');
                if (welcome) welcome.style.display = 'none';
                if (pv) pv.style.display = 'flex';

                function set(id, val) { var el = document.getElementById(id); if (el) el.textContent = val == null ? '—' : val; }
                set('pvProOrderNum', pro.orderNumber);
                set('pvProTitle', pro.title);
                set('pvProCustomer', pro.customer);
                set('pvProProject', pro.project);
                set('pvProScheduledEnd', pro.scheduledEnd);
                set('pvProQtyOrdered', pro.qtyOrdered);
                set('pvProQtyOrdered_dup', pro.qtyOrdered);
                set('pvProQtyCompleted', pro.qtyCompleted);

                var pct = (pro.qtyOrdered > 0) ? Math.round(100 * (pro.qtyCompleted || 0) / pro.qtyOrdered) : 0;
                set('pvProProgressPct', pct + '%');
                var bar = document.getElementById('pvProProgressBar');
                if (bar) bar.style.width = pct + '%';

                var statusEl = document.getElementById('pvProStatus');
                if (statusEl) {
                    statusEl.textContent = pro.status;
                    statusEl.className = 'cockpit__preview-status status-badge-p status-badge-p--' + (pro.status || '').toLowerCase();
                }

                // Routing stepper — Siemens style: highlights pips through Planned -> Released -> InProgress -> Completed.
                var steps = ['Planned', 'Released', 'InProgress', 'Completed'];
                var activeIdx = steps.indexOf(pro.status);
                steps.forEach(function (s, i) {
                    var pip = document.getElementById('pvProStep_' + s);
                    if (!pip) return;
                    pip.classList.remove('cockpit__step--active', 'cockpit__step--done', 'cockpit__step--pending');
                    if (i < activeIdx) pip.classList.add('cockpit__step--done');
                    else if (i === activeIdx) pip.classList.add('cockpit__step--active');
                    else pip.classList.add('cockpit__step--pending');
                });

                // Wire the Details / Transition links to the actual order.
                var detailsBtn = document.getElementById('pvProDetailsBtn');
                if (detailsBtn) detailsBtn.href = '/Production/Details/' + id;
                document.querySelectorAll('[data-pv-pro-order-id]').forEach(function (input) {
                    input.value = id;
                });
            };
        })();
    </script>
}
