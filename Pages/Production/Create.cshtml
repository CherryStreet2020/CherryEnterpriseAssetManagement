@page
@model Abs.FixedAssets.Pages.Production.CreateModel
@{
    ViewData["Title"] = "New Production Order";
    Layout = "_ModernLayout";
}

<div class="page-header">
    <div class="page-header-titles">
        <nav aria-label="breadcrumb" class="breadcrumb-trail">
            <a href="/">Home</a>
            <span class="breadcrumb-sep">/</span>
            <a href="/Production">Production</a>
            <span class="breadcrumb-sep">/</span>
            <span class="breadcrumb-current">New Order</span>
        </nav>
        <h1 class="page-title">New Production Order</h1>
        <p class="page-subtitle">Opens in <strong>Planned</strong> status. Status transitions enforced by the legal-transition map.</p>
    </div>
    <div class="page-header-actions">
        <a href="/Production" class="btn-secondary">
            <i class="fas fa-arrow-left"></i> Cancel
        </a>
    </div>
</div>

<form method="post" class="form-grid">
    <div asp-validation-summary="ModelOnly" class="alert alert--error"></div>

    <div class="form-section">
        <h3 class="form-section-title">Identification</h3>

        <div class="form-row">
            <label asp-for="Input.OrderNumber" class="form-label form-label--required">Order Number</label>
            <input asp-for="Input.OrderNumber" class="form-input form-input--mono" placeholder="e.g. PRO-2026-00042" />
            <span asp-validation-for="Input.OrderNumber" class="form-error"></span>
        </div>

        <div class="form-row">
            <label asp-for="Input.Title" class="form-label form-label--required">Title</label>
            <input asp-for="Input.Title" class="form-input" />
            <span asp-validation-for="Input.Title" class="form-error"></span>
        </div>

        <div class="form-row">
            <label asp-for="Input.Description" class="form-label">Description</label>
            <textarea asp-for="Input.Description" class="form-input" rows="3"></textarea>
        </div>

        <div class="form-row">
            <label asp-for="Input.Type" class="form-label">Production Type</label>
            <select asp-for="Input.Type" class="form-input" asp-items="Html.GetEnumSelectList<Abs.FixedAssets.Models.Production.ProductionType>()"></select>
        </div>
    </div>

    <div class="form-section">
        <h3 class="form-section-title">Tenant Scope</h3>
        <p class="hint">Set <strong>Location</strong> OR <strong>Customer</strong> (or both) so the order is tenant-scoped. Orders without either are unlinkable to projects.</p>

        <div class="form-row">
            <label asp-for="Input.LocationId" class="form-label">Location</label>
            <select asp-for="Input.LocationId" class="form-input" asp-items="Model.LocationOptions">
                <option value="">— none —</option>
            </select>
        </div>

        <div class="form-row">
            <label asp-for="Input.CustomerId" class="form-label">Customer</label>
            <select asp-for="Input.CustomerId" class="form-input" asp-items="Model.CustomerOptions">
                <option value="">— none —</option>
            </select>
        </div>

        <div class="form-row">
            <label asp-for="Input.ItemId" class="form-label">Principal Item</label>
            <select asp-for="Input.ItemId" class="form-input" asp-items="Model.ItemOptions">
                <option value="">— none —</option>
            </select>
        </div>
    </div>

    <div class="form-section">
        <h3 class="form-section-title">Quantity &amp; Schedule</h3>

        <div class="form-row form-row--inline">
            <div>
                <label asp-for="Input.QuantityOrdered" class="form-label form-label--required">Quantity Ordered</label>
                <input asp-for="Input.QuantityOrdered" class="form-input form-input--num" type="number" step="0.0001" />
                <span asp-validation-for="Input.QuantityOrdered" class="form-error"></span>
            </div>
            <div>
                <label asp-for="Input.Uom" class="form-label">UoM</label>
                <input asp-for="Input.Uom" class="form-input form-input--narrow" placeholder="e.g. EA / KG" />
            </div>
            <div>
                <label asp-for="Input.Priority" class="form-label">Priority (0–100)</label>
                <input asp-for="Input.Priority" class="form-input form-input--narrow" type="number" min="0" max="100" />
            </div>
        </div>

        <div class="form-row form-row--inline">
            <div>
                <label asp-for="Input.ScheduledStart" class="form-label">Scheduled Start</label>
                <input asp-for="Input.ScheduledStart" class="form-input" type="datetime-local" />
            </div>
            <div>
                <label asp-for="Input.ScheduledEnd" class="form-label">Scheduled End</label>
                <input asp-for="Input.ScheduledEnd" class="form-input" type="datetime-local" />
            </div>
        </div>
    </div>

    <div class="form-actions">
        <a href="/Production" class="btn-secondary">Cancel</a>
        <button type="submit" class="btn-primary">
            <i class="fas fa-plus"></i> Create Order
        </button>
    </div>
</form>
